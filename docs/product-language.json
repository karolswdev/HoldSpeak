  "meeting_projections": [
    "summary",
    "action_items",
    "transcript",
    "topics"
  ],
  "guarded_terms": [
    "Profile",
    "Action",
    "Context",
    "Target",
    "Pending",
    "Local"
  ],
  "copy_contract": {
    "version": 1,
    "classifications": [
      "label",
      "state",
      "supporting_line",
      "detail",
      "error_recovery",
      "marketing_sdk_exception"
    ],
    "generic_consequential_verbs": [
      "Approve",
      "Apply",
      "Open",
      "Run"
    ],
    "prohibited_operational_patterns": [
      {
        "id": "legacy-product-nouns",
        "pattern": "\\b(?:Agent Desk|Personas?|Profiles?|Recipes?|Chains?|Knowledge Base)\\b",
        "reason": "Primary UI uses Coder session, Runs on, Agent, Sequence, and Knowledge."
      },
      {
        "id": "raw-control-mode-labels",
        "pattern": "\\b(?-i:ControlMode|Safe|Neutral)\\b",
        "reason": "Product UI renders Control mode with Secure, Normal, and YOLO labels."
      },
      {
        "id": "unqualified-state",
        "pattern": "^(?:pending|local|complete)$",
        "reason": "State and boundary copy must name its axis."
      },
      {
        "id": "promotional-narration",
        "pattern": "\\b(?:magical|revolutionary|powerful|beautiful|cinematic|quest-like|congratulations?|powerhouse|superpower)\\b|(?:comes alive|ready when you are|say hi to|something went wrong|you're all set|we've got this|living conversation|the desk remembers)",
        "reason": "Operational copy stays factual and task-first."
      },
      {
        "id": "paired-as-local",
        "pattern": "(?:paired|mesh|desktop).{0,32}(?:local|on-device)|(?:local|on-device).{0,32}(?:paired|mesh|desktop)",
        "reason": "Paired work crosses a device boundary and must name it."
      }
    ],
    "failure_requirements": [
      "failed_operation",
      "retained_work",
      "next_action",
      "destination_when_relevant"
    ],
    "primary_surfaces": {
      "web": [
        "web/src/**/*.tsx",
        "web/src/lib/productLanguage.ts"
      ],
      "swift": [
        "apple/App/**/*.swift",
        "apple/Sources/Contracts/{ProductLanguage,EgressScope}.swift"
      ],
      "hub": [
        "holdspeak/web/routes/system/voice.py",
        "holdspeak/web/routes/dictation/pipeline.py",
        "holdspeak/web/routes/meetings/{crud,speakers,action_items}.py",
        "holdspeak/web/routes/meeting_import.py",
        "holdspeak/web/routes/primitives/{chains,recipes,workflows}.py",
        "holdspeak/web/routes/authority.py"
      ],
      "cli_and_guides": [
        "holdspeak/main.py",
        "README.md",
        "docs/{README,AUTHORITY,SECURITY,MODELS,USER_GUIDE,WEB_DESK,DICTATION_COPILOT,DICTATION_PIPELINE_GUIDE,MEETING_MODE_GUIDE}.md",
        "uat/scenarios/phase-92-{web,native}/07-decision-authority.yaml"
      ]
    },
    "exceptions": [
      {
        "id": "swift-artifact-open-v1",
        "path": "apple/App/MeetingCapture/ReviewUI.swift",
        "literals": [
          "Open"
        ],
        "reason": "Open reveals read-only Artifact detail and has no external, destructive, queued, or authority-changing effect."
      },
      {
        "id": "swift-desk-open-v1",
        "path": "apple/App/MeetingCapture/DeskDioramaStage.swift",
        "literals": [
          "Open"
        ],
        "reason": "Open reveals the selected Desk item's local inspector and does not execute or queue an effect."
      },
      {
        "id": "swift-runs-on-readiness-v1",
        "path": "apple/App/MeetingCapture/RunsOnPicker.swift",
        "literals": [
          "Unavailable · no models synced yet",
          "Unavailable · no paired device"
        ],
        "reason": "Runs on picker rows state a disabled destination's readiness before any operation runs; no work exists to retain and each row names the missing prerequisite."
      },
      {
        "id": "swift-review-glog-v1",
        "path": "apple/App/MeetingCapture/ReviewUI.swift",
        "literals": [
          "w{value} FAIL {value}: {value"
        ],
        "reason": "Generation worker glog lines are internal debug-log diagnostics that never render on a product surface; the census only sees the literal because it interpolates the caught error."
      },
      {
        "path": "apple/*.swift",
        "terms": [
          "Persona",
          "Personas"
        ],
        "reason": "HS-100-10 renamed the canon to Agent on the web; the Apple surfaces consume the thesis in the HSM follow-up phase and keep the old noun until then.",
        "id": "apple-agent-rename-pending-v1",
        "literals": []
      }
    ]
  },
  "compatibility_exceptions": [
    {
      "id": "python-persistence-wire-v2",
      "registry_version": 2,
      "kind": "wire",
      "path": "holdspeak/db/{models,core,actuators}.py",
      "terms": [
        "Profile",
        "Agent",
        "Action",
        "Context",
        "Target",
        "Pending",
        "Local"
      ],
      "reason": "Persistence model and legacy wire names remain stable during the additive language migration."
    },
    {
      "id": "python-http-wire-v2",
      "registry_version": 2,
      "kind": "wire",
      "path": "holdspeak/web/routes/{authority,actuator_shared,mesh,primitives/*.py}",
      "terms": [
        "Profile",
        "Agent",
        "Action",
        "Context",
        "Target",
        "Pending",
        "Local"
      ],
      "reason": "Public API compatibility and qualified architectural identifiers retain their existing wire names."
    },
    {
      "id": "web-desk-adapter-v2",
      "registry_version": 2,
      "kind": "migration",
      "path": "web/src/desk/api.ts",
      "terms": [
        "Profile",
        "Agent"
      ],
      "reason": "The API adapter consumes legacy recipe/profile wires but emits canonical product labels."
    },
    {
      "id": "swift-contract-wire-v2",
      "registry_version": 2,
      "kind": "wire",
      "path": "apple/Sources/Contracts/{Models,Primitives,ProductLanguage,InferenceTarget}.swift",
      "terms": [
        "Profile",
        "Agent",
        "Action",
        "Context",
        "Target",
        "Pending",
        "Local"
      ],
      "reason": "Codable compatibility types preserve public wire identifiers."
    },
    {
      "id": "swift-runtime-types-v2",
      "registry_version": 2,
      "kind": "sdk",
      "path": "apple/Sources/RuntimeCore/{Companion/*.swift,Desk/ContextEnvelope.swift}",
      "terms": [
        "Profile",
        "Agent",
        "Action",
        "Context",
        "Target",
        "Pending",
        "Local"
      ],
      "reason": "Qualified implementation types remain internal and are not product labels."
    }
  ]
}
