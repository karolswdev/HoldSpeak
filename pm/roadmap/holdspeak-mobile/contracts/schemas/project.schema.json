{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holdspeak.dev/contracts/v0/project.schema.json",
  "title": "Project",
  "description": "A named endeavor; resource relationships are separate many-to-many edges.",
  "x-sync-kind": "project",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "is_archived", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "is_archived": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "last_modified": { "type": "string", "format": "date-time" },
    "deleted": { "type": "boolean" }
  }
}
