{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holdspeak.dev/contracts/v0/intel-snapshot.schema.json",
  "title": "IntelSnapshot",
  "description": "A point-in-time intel snapshot embedded in a meeting. Source: holdspeak/meeting_session/models.py IntelSnapshot.to_dict().",
  "type": "object",
  "additionalProperties": false,
  "required": ["timestamp", "topics", "action_items", "summary"],
  "properties": {
    "timestamp": { "type": "number", "description": "When the intel was generated (seconds)" },
    "topics": { "type": "array", "items": { "type": "string" } },
    "action_items": {
      "type": "array",
      "items": { "$ref": "https://holdspeak.dev/contracts/v0/action-item.schema.json" }
    },
    "summary": { "type": "string" }
  }
}
