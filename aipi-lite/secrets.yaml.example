# Template for secrets.yaml. Copy to secrets.yaml and fill in.
# secrets.yaml is gitignored.

# Primary network (typically home WiFi).
wifi_ssid_home: "your-home-ssid"
wifi_password_home: "your-home-password"

# Secondary network (typically phone hotspot). Leave placeholder if unused —
# the device will skip it and fall through to AP-mode.
wifi_ssid_phone: "your-phone-hotspot-ssid"
wifi_password_phone: "your-phone-hotspot-password"

# Password for the device's own AP-mode network ("AiPi-Setup"), used when
# none of the known networks are reachable. Must be at least 8 characters.
wifi_ap_password: "aipi-setup-changeme"
