# bridge.py configuration. Copy to `bridge.env` next to bridge.py and
# fill in. `bridge.env` is gitignored. Env vars override file values.

# --- ESPHome (the AIPI-Lite device) -----------------------------------

# Hostname or IP. Defaults to `aipi.local` (mDNS).
ESPHOME_HOST=aipi.local

# Port for the ESPHome native API. ESPHome's default is 6053.
ESPHOME_PORT=6053

# Optional API password. Leave unset for an unprotected API
# (production: set one in aipi.yaml's `api:` block).
# ESPHOME_PASSWORD=

# --- HoldSpeak --------------------------------------------------------

# HoldSpeak host. Defaults to `127.0.0.1` (HoldSpeak binds to loopback
# in phase 14; cross-network reach is HS-15 / AIPI-3).
HOLDSPEAK_HOST=127.0.0.1

# HoldSpeak port. **Required.** Find it in HoldSpeak's runtime log
# (`holdspeak web` prints something like `Uvicorn running on http://127.0.0.1:<port>`).
HOLDSPEAK_PORT=

# HoldSpeak device PSK. **Required.** Print + rotate from the
# HoldSpeak CLI:
#   $ holdspeak device-psk show
#   $ holdspeak device-psk rotate
# The bridge sends this in the WS handshake; HoldSpeak validates with
# `hmac.compare_digest`.
HOLDSPEAK_PSK=

# --- Identity ---------------------------------------------------------

# Stable device id used in handshake / registry / meeting attach.
# Two AIPI-Lites would each have a unique id (e.g. "aipi-living-room",
# "aipi-office").
DEVICE_ID=aipi-1

# Human label shown verbatim in HoldSpeak meeting transcripts as
# `TranscriptSegment.speaker`. Defaults to DEVICE_ID when blank.
DEVICE_LABEL=

# --- Bridge runtime ---------------------------------------------------

# UDP port the bridge listens on for the device's voice_assistant
# audio stream. The bridge advertises this back to the device on
# voice_assistant.start; the device opens a UDP socket here and
# pushes int16-LE PCM. Default 50000. Don't change unless you have
# a port conflict — ESPHome's voice_assistant is UDP-first and the
# bridge MUST run a listener on this port.
UDP_AUDIO_PORT=50000

# Optional debug monitor for AI Pi mic audio. When set, the bridge
# mirrors accepted UDP mic chunks to this command's stdin as raw
# signed-16-bit little-endian PCM, 16 kHz, mono. Useful to pre-hear
# exactly what HoldSpeak receives from the device.
# Example:
# AUDIO_MONITOR_CMD=aplay -q -f S16_LE -r 16000 -c 1 -t raw -

# Log level. One of DEBUG / INFO / WARNING / ERROR / CRITICAL.
LOG_LEVEL=INFO
