---
// HS-10-03 Toolbar.
//
// Horizontal action group. Wraps on narrow viewports; never causes
// horizontal scroll. Acts as a flex container for Buttons and Pills.

interface Props {
  align?: "start" | "end" | "between";
  class?: string;
}

const { align = "start", class: extraClass } = Astro.props;

const classes = ["toolbar", `toolbar--${align}`, extraClass]
  .filter(Boolean)
  .join(" ");
---

<div class={classes} role="group">
  <slot />
</div>

<style>
  .toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .toolbar--start { justify-content: flex-start; }
  .toolbar--end { justify-content: flex-end; }
  .toolbar--between { justify-content: space-between; }
</style>
