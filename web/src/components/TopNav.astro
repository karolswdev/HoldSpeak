---
// HS-70-01 TopNav — the two-mode IA spine (Phase 70, Legible Product).
//
// The flat Live / Review / Configure groups (14 co-equal doors) are
// replaced by the four-destination model that expresses the product's
// own story — "one copilot, two modes":
//   Home       → /            the orienting front door (HS-70-02 reframes it)
//   Dictation  → /dictation   the voice-typing mode (folds /activity in HS-70-04)
//   Meetings   → /history      the meeting mode (route→Meetings in HS-70-05)
//   Studio ▾   → a collapsed advanced tier (Workbench, Desk, Agent Desk,
//                Cadence, Commands, Profiles)
//
// Right cluster: a status slot (default LocalPill/TrustChip) + a Settings
// (⚙) link to /settings.
//
// Studio is a native <details> disclosure: it collapses with zero JS, is
// keyboard-accessible, and opens automatically when the active route lives
// inside it. Active route is DUAL-encoded (accent-tint + weight + underbar +
// aria-current), never colour-only.
//
// Responsive: below the nav breakpoint the whole strip collapses behind the
// menu toggle ([data-nav-toggle]); the Studio panel renders inline (static).
//
// Notes: Activity folded into Dictation (HS-70-04) — /activity is now a
// Dictation sub-view (current="dictation"), reached from the cockpit's
// pre-briefing section, not a top-level door. Presence is a nav-less HUD
// overlay reached from Settings, so it is intentionally not a Studio nav item
// (the HS-70-06 Studio index may still card it).

import AppMark from "./AppMark.astro";
import TrustChip from "./TrustChip.astro";

type Route =
  | "home"
  | "dictation"
  | "meetings"
  | "studio"
  | "workbench"
  | "desk"
  | "companion"
  | "activity"
  | "cadence"
  | "commands"
  | "profiles";

interface Props {
  current?: Route;
}

const { current } = Astro.props;

const primary: { slug: Route; label: string; href: string }[] = [
  { slug: "home", label: "Desk", href: "/" },
  { slug: "dictation", label: "Dictation", href: "/dictation" },
  { slug: "meetings", label: "Meetings", href: "/history" },
];

const studio: { slug: Route; label: string; href: string }[] = [
  { slug: "workbench", label: "Workbench", href: "/workbench" },
  { slug: "companion", label: "Agent Desk", href: "/companion" },
  { slug: "cadence", label: "Cadence", href: "/cadence" },
  { slug: "commands", label: "Commands", href: "/commands" },
  { slug: "profiles", label: "Profiles", href: "/profiles" },
];

const studioActive = current === "studio" || studio.some((s) => s.slug === current);
---

<header class="topnav" role="banner">
  <a href="#main" class="topnav-skip">Skip to content</a>

  <a href="/" class="topnav-brand" aria-label="HoldSpeak — Runtime">
    <AppMark size={22} class="topnav-mark" />
    <span class="topnav-wordmark">HoldSpeak</span>
  </a>

  <button
    type="button"
    class="topnav-toggle"
    data-nav-toggle
    aria-expanded="false"
    aria-controls="topnav-nav"
    aria-label="Toggle navigation"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <path d="M4 7h16M4 12h16M4 17h16" />
    </svg>
  </button>

  <nav class="topnav-nav" id="topnav-nav" aria-label="Primary">
    {primary.map((r) => (
      <a
        href={r.href}
        class:list={["topnav-link", current === r.slug && "is-current"]}
        aria-current={current === r.slug ? "page" : undefined}
      >
        {r.label}
      </a>
    ))}

    <details class="topnav-studio" open={studioActive ? true : undefined}>
      <summary
        class:list={["topnav-link", "topnav-studio-summary", studioActive && "has-active"]}
      >
        <span>Studio</span>
        <svg
          class="topnav-studio-caret"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M6 9l6 6 6-6" />
        </svg>
      </summary>
      <div class="topnav-studio-panel">
        <a
          href="/studio"
          class:list={["topnav-studio-index", current === "studio" && "is-current"]}
          aria-current={current === "studio" ? "page" : undefined}
        >
          <span class="topnav-studio-eyebrow">Advanced</span>
          <span class="topnav-studio-index-arrow" aria-hidden="true">→</span>
        </a>
        {studio.map((r) => (
          <a
            href={r.href}
            class:list={["topnav-studio-item", current === r.slug && "is-current"]}
            aria-current={current === r.slug ? "page" : undefined}
          >
            {r.label}
          </a>
        ))}
      </div>
    </details>
  </nav>

  <div class="topnav-tail">
    <slot name="status">
      <TrustChip />
    </slot>
    <slot name="overflow" />
    <a
      class="topnav-icon"
      href="/settings"
      aria-label="Settings"
      title="Settings"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="3" />
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
      </svg>
    </a>
  </div>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-3) var(--space-5);
    background: linear-gradient(180deg, var(--surface-1), var(--bg));
    border-bottom: 1px solid var(--border-subtle);
  }

  .topnav-skip {
    position: absolute;
    top: var(--space-2);
    left: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--surface-2);
    color: var(--text);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    text-decoration: none;
    transform: translateY(-200%);
    transition: transform var(--duration-short) var(--ease-standard);
    z-index: var(--z-overlay);
  }
  .topnav-skip:focus-visible {
    transform: translateY(0);
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  .topnav-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }
  .topnav-brand:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
    border-radius: var(--radius-xs);
  }
  .topnav-mark {
    color: var(--accent);
    flex-shrink: 0;
    filter: drop-shadow(0 0 6px var(--accent-glow));
  }

  /* Nav: the two modes as inline links + a Studio disclosure. */
  .topnav-nav {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    flex: 1 1 auto;
  }

  /* Studio — a native <details> disclosure (zero-JS, keyboard-native). */
  .topnav-studio {
    position: relative;
  }
  .topnav-studio-summary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .topnav-studio-summary::-webkit-details-marker {
    display: none;
  }
  .topnav-studio-summary::marker {
    content: "";
  }
  /* "You are somewhere in Studio" — subtle tint, no page underbar. */
  .topnav-studio-summary.has-active {
    color: var(--text);
    background: var(--accent-tint);
  }
  .topnav-studio-caret {
    opacity: 0.7;
    transition: transform var(--duration-short) var(--ease-standard);
  }
  .topnav-studio[open] .topnav-studio-caret {
    transform: rotate(180deg);
  }
  .topnav-studio-panel {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 0;
    z-index: var(--z-overlay);
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 190px;
    padding: var(--space-2);
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--elev-2);
  }
  .topnav-studio-index {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-1) var(--space-2) var(--space-2);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }
  .topnav-studio-index:hover .topnav-studio-eyebrow,
  .topnav-studio-index:hover .topnav-studio-index-arrow { color: var(--accent); }
  .topnav-studio-index.is-current .topnav-studio-eyebrow { color: var(--accent); }
  .topnav-studio-index:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .topnav-studio-index-arrow {
    color: var(--text-faint);
    font-size: var(--font-size-sm);
    transition: color var(--duration-short) var(--ease-standard);
  }
  .topnav-studio-eyebrow {
    padding: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--text-faint);
    user-select: none;
    transition: color var(--duration-short) var(--ease-standard);
  }
  .topnav-studio-item {
    padding: var(--space-2) var(--space-3);
    color: var(--text-muted);
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    font-weight: 500;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition:
      color var(--duration-short) var(--ease-standard),
      background var(--duration-short) var(--ease-standard);
  }
  .topnav-studio-item:hover {
    color: var(--text);
    background: var(--surface-hover);
  }
  .topnav-studio-item:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .topnav-studio-item.is-current {
    color: var(--text);
    font-weight: 600;
    background: var(--accent-tint);
  }

  .topnav-link {
    position: relative;
    padding: var(--space-2) var(--space-3);
    color: var(--text-muted);
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition:
      color var(--duration-short) var(--ease-standard),
      background var(--duration-short) var(--ease-standard);
  }
  .topnav-link:hover {
    color: var(--text);
    background: var(--surface-hover);
  }
  .topnav-link:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  /* Active: dual-encoded — accent-tint fill + weight + accent underbar. */
  .topnav-link.is-current {
    color: var(--text);
    font-weight: 600;
    background: var(--accent-tint);
  }
  .topnav-link.is-current::after {
    content: "";
    position: absolute;
    left: var(--space-3);
    right: var(--space-3);
    bottom: 2px;
    height: 2px;
    border-radius: 2px;
    background: var(--accent);
  }

  .topnav-tail {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
    flex-shrink: 0;
  }

  .topnav-icon {
    display: inline-grid;
    place-items: center;
    width: 34px;
    height: 34px;
    color: var(--text-muted);
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      color var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard),
      background var(--duration-short) var(--ease-standard);
  }
  .topnav-icon:hover {
    color: var(--text);
    border-color: var(--border-strong);
    background: var(--surface-2);
  }
  .topnav-icon:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  /* Mobile menu toggle — hidden on desktop. */
  .topnav-toggle {
    display: none;
    place-items: center;
    width: 34px;
    height: 34px;
    color: var(--text-muted);
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .topnav-toggle:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  @media (max-width: 880px) {
    .topnav {
      flex-wrap: wrap;
      gap: var(--space-3);
    }
    .topnav-toggle {
      display: inline-grid;
      order: 2;
      margin-left: auto;
    }
    .topnav-tail {
      order: 3;
    }
    .topnav-nav {
      order: 4;
      flex-basis: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-2);
      display: none;
      padding-top: var(--space-2);
      border-top: 1px solid var(--border-subtle);
    }
    .topnav[data-open] .topnav-nav {
      display: flex;
    }
    .topnav-link {
      width: 100%;
    }
    .topnav-studio {
      width: 100%;
    }
    .topnav-studio-summary {
      width: 100%;
      justify-content: space-between;
    }
    /* On mobile the Studio panel renders inline (static), never floating. */
    .topnav-studio-panel {
      position: static;
      min-width: 0;
      padding: var(--space-1) 0 var(--space-1) var(--space-3);
      background: transparent;
      border: 0;
      box-shadow: none;
    }
    .topnav-studio-item {
      width: 100%;
    }
  }
</style>
