---
// HS-69-09: the generation theater — the "model thinking" set-piece. A plasma
// orb (the SAME PixelLab asset the iPad uses) breathing inside concentric rings,
// with an artifact-type constellation that lights up as intelligence is produced.
// Driven live by the meeting-intelligence WS frames (intel_status / intel_token /
// intel_complete) via theater.js on the shared runtime-bus — no backend change.
//
// Mounted in AppLayout; hidden at rest, reveals centred while intel generates,
// holds briefly when ready, then fades. Non-blocking (pointer-events: none).
---

<div class="hs-theater" data-theater role="status" aria-live="polite" aria-hidden="true">
  <div class="hs-theater-card signal-card">
    <div class="hs-theater-stage" aria-hidden="true">
      <span class="hs-theater-ring"></span>
      <span class="hs-theater-ring"></span>
      <span class="hs-theater-ring"></span>
      <img class="hs-theater-orb" src="/_built/theater/theaterorb.png" alt="" width="92" height="92" />
    </div>
    <p class="hs-theater-label" data-theater-label>Generating intelligence…</p>
    <div class="hs-theater-constellation">
      <span class="ht-node" data-type="summary">Summary</span>
      <span class="ht-node" data-type="decisions">Decisions</span>
      <span class="ht-node" data-type="actions">Actions</span>
      <span class="ht-node" data-type="topics">Topics</span>
    </div>
  </div>
</div>

<script src="../scripts/theater.js"></script>

<style is:global>
  /* Authored is:global: theater.js toggles .is-on / .is-streaming / .is-lit at
     runtime. Centred, non-blocking, below dialogs. */
  .hs-theater {
    position: fixed;
    inset: 0;
    z-index: calc(var(--z-overlay) - 1);
    display: grid;
    place-items: center;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--duration-medium) var(--ease-standard), visibility 0s linear var(--duration-medium);
  }
  .hs-theater.is-on {
    opacity: 1;
    visibility: visible;
    transition: opacity var(--duration-medium) var(--ease-standard);
  }
  .hs-theater-card {
    --signal-card-surface: var(--surface-2);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-6);
    transform: translateY(8px) scale(0.96);
    transition: transform var(--duration-medium) var(--ease-emphasized, var(--ease-standard));
  }
  .hs-theater.is-on .hs-theater-card { transform: translateY(0) scale(1); }

  .hs-theater-stage {
    position: relative;
    width: 140px;
    height: 140px;
    display: grid;
    place-items: center;
  }
  /* a vibrant accent backlight so the orb glows against the dark card even
     though the asset has a dark rim */
  .hs-theater-stage::before {
    content: "";
    position: absolute;
    width: 124px;
    height: 124px;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 38%, transparent) 0%, transparent 62%);
    animation: ht-orb-breathe 3.2s var(--ease-standard) infinite;
  }
  .hs-theater.is-streaming .hs-theater-stage::before {
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 55%, transparent) 0%, transparent 64%);
    animation: ht-orb-breathe 1.4s var(--ease-standard) infinite;
  }
  .hs-theater-orb {
    position: relative;
    width: 96px;
    height: 96px;
    border-radius: 50%;       /* clip the asset's transparent corners while it spins */
    image-rendering: auto;
    filter: drop-shadow(0 0 16px color-mix(in srgb, var(--accent) 45%, transparent));
    animation: ht-orb-spin 16s linear infinite, ht-orb-breathe 3.2s var(--ease-standard) infinite;
  }
  .hs-theater.is-streaming .hs-theater-orb {
    animation: ht-orb-spin 7s linear infinite, ht-orb-breathe 1.4s var(--ease-standard) infinite;
    filter: drop-shadow(0 0 24px color-mix(in srgb, var(--accent) 70%, transparent));
  }
  @keyframes ht-orb-spin { to { transform: rotate(360deg); } }
  @keyframes ht-orb-breathe { 0%, 100% { scale: 1; } 50% { scale: 1.06; } }

  .hs-theater-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    opacity: 0;
    animation: ht-ring 3s var(--ease-standard) infinite;
  }
  .hs-theater-ring:nth-child(2) { animation-delay: 1s; }
  .hs-theater-ring:nth-child(3) { animation-delay: 2s; }
  .hs-theater.is-streaming .hs-theater-ring { animation-duration: 1.6s; }
  @keyframes ht-ring {
    0%   { transform: scale(0.55); opacity: 0.6; }
    100% { transform: scale(1.25); opacity: 0; }
  }

  .hs-theater-label {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text);
  }
  .hs-theater-constellation {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
  }
  .ht-node {
    padding: 0.15rem 0.6rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    font-size: var(--font-size-xs);
    letter-spacing: 0.02em;
    color: var(--text-faint);
    background: var(--surface-1);
    transition: color var(--duration-short) var(--ease-standard),
                border-color var(--duration-short) var(--ease-standard),
                box-shadow var(--duration-short) var(--ease-standard),
                background var(--duration-short) var(--ease-standard);
  }
  .ht-node.is-lit {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    background: color-mix(in srgb, var(--accent) 10%, var(--surface-1));
    box-shadow: 0 0 14px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .hs-theater { transition: opacity var(--duration-short) var(--ease-standard); }
    .hs-theater-card { transform: none; transition: none; }
    .hs-theater-orb,
    .hs-theater.is-streaming .hs-theater-orb { animation: none; }
    .hs-theater-ring { animation: none; opacity: 0; }
  }
</style>
