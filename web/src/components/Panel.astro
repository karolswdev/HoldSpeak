---
// HS-10-03 Panel.
//
// Slot-driven container: header (title), toolbar (right-aligned action
// strip), default body, and footer. `density=dense` tightens padding
// for activity-style data lists.

interface Props {
  density?: "comfortable" | "dense";
  class?: string;
}

const { density = "comfortable", class: extraClass } = Astro.props;

const classes = ["panel", `panel--${density}`, extraClass]
  .filter(Boolean)
  .join(" ");

const hasHeader = Astro.slots.has("header");
const hasToolbar = Astro.slots.has("toolbar");
const hasFooter = Astro.slots.has("footer");
---

<section class={classes}>
  {(hasHeader || hasToolbar) && (
    <header class="panel-header">
      {hasHeader && (
        <div class="panel-title"><slot name="header" /></div>
      )}
      {hasToolbar && (
        <div class="panel-toolbar"><slot name="toolbar" /></div>
      )}
    </header>
  )}
  <div class="panel-body"><slot /></div>
  {hasFooter && (
    <footer class="panel-footer"><slot name="footer" /></footer>
  )}
</section>

<style>
  /* HS-30-05 "Signal": panels are raised dark surfaces with real
   * depth + radius. The header is a quiet strip whose title reads as
   * an uppercase-tracked eyebrow — the technical cue that replaces the
   * old pixel title-strip. */
  .panel {
    background: var(--surface-1);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--elev-1);
    overflow: hidden;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    background: var(--surface-2);
    color: var(--text);
    border-bottom: 1px solid var(--border-subtle);
  }

  .panel--comfortable .panel-header {
    padding: var(--space-3) var(--space-4);
  }
  .panel--dense .panel-header {
    padding: var(--space-2) var(--space-3);
  }

  .panel-title {
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    line-height: 1.3;
  }

  .panel-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .panel--comfortable .panel-body { padding: var(--space-4); }
  .panel--dense .panel-body { padding: var(--space-3); }

  .panel-footer {
    border-top: 1px solid var(--border-subtle);
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    background: var(--surface-2);
  }

  .panel--comfortable .panel-footer { padding: var(--space-2) var(--space-4); }
  .panel--dense .panel-footer { padding: var(--space-2) var(--space-3); }
</style>
