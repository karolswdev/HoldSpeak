---
// HS-10-11 ConfirmDialog.
//
// One <dialog> element rendered once per page (mounted by AppLayout)
// plus a small dispatcher that exposes
//
//   window.holdspeakConfirm({
//     title, body, scopeNote, confirmLabel, cancelLabel, danger
//   }): Promise<boolean>
//
// Call sites await the promise — true means the user confirmed,
// false means they cancelled (button click, Esc, or backdrop click).
//
// Behaviour:
//   - Cancel button takes default focus on open and is the default
//     Enter target — destructive actions never default-confirm.
//   - Native <dialog>.showModal() traps focus inside the dialog.
//   - Esc fires the dialog's `cancel` event and resolves false.
//   - Origin element (the button that triggered the prompt) is
//     captured at open and re-focused on close.
//   - `scopeNote` slot below the body carries the local-only pill +
//     scope wording for connector-output deletions ("This removes
//     local annotations. Source data on GitHub is untouched.").
//
// The component renders no visible markup until showModal() is
// called by the dispatcher. The styles below target the dialog
// only when it is `[open]`.
---

<dialog
  id="holdspeak-confirm-dialog"
  class="confirm-dialog"
  aria-labelledby="holdspeak-confirm-title"
  aria-describedby="holdspeak-confirm-body"
>
  <div class="confirm-dialog__grabber" aria-hidden="true"></div>
  <header class="confirm-dialog__header">
    <span class="confirm-dialog__glyph glyph-chip" aria-hidden="true">
      <svg class="glyph-confirm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
      <svg class="glyph-danger" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
    </span>
    <h2 id="holdspeak-confirm-title" class="confirm-dialog__title"></h2>
  </header>
  <form method="dialog" class="confirm-dialog__form">
    <p id="holdspeak-confirm-body" class="confirm-dialog__body"></p>
    <p
      id="holdspeak-confirm-scope"
      class="confirm-dialog__scope"
      data-empty="true"
    ></p>
    <div class="confirm-dialog__actions">
      <button
        type="button"
        class="btn btn--secondary btn--md"
        data-confirm-cancel
      >Cancel</button>
      <button
        type="button"
        class="btn btn--danger btn--md"
        data-confirm-ok
      >Confirm</button>
    </div>
  </form>
</dialog>

<script is:inline>
  (() => {
    if (window.holdspeakConfirm) return;

    const dialog = document.getElementById("holdspeak-confirm-dialog");
    if (!dialog) return;

    const titleEl = dialog.querySelector("#holdspeak-confirm-title");
    const bodyEl = dialog.querySelector("#holdspeak-confirm-body");
    const scopeEl = dialog.querySelector("#holdspeak-confirm-scope");
    const cancelBtn = dialog.querySelector("[data-confirm-cancel]");
    const okBtn = dialog.querySelector("[data-confirm-ok]");

    let pending = null;
    let returnFocusTo = null;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    function settle(value) {
      if (!pending) return;
      const resolve = pending;
      pending = null;

      const finalize = () => {
        try {
          if (dialog.open) dialog.close();
        } catch (_) { /* no-op */ }
        dialog.classList.remove("is-closing");
        if (returnFocusTo && typeof returnFocusTo.focus === "function") {
          try { returnFocusTo.focus(); } catch (_) { /* no-op */ }
        }
        returnFocusTo = null;
        resolve(value);
      };

      if (reduceMotion.matches || !dialog.open) {
        finalize();
        return;
      }

      // Trigger the close animation, then close the dialog. 120ms
      // matches --duration-short.
      dialog.classList.add("is-closing");
      window.setTimeout(finalize, 120);
    }

    cancelBtn.addEventListener("click", () => settle(false));
    okBtn.addEventListener("click", () => settle(true));

    // Esc → native `cancel` event on <dialog>; treat as decline.
    dialog.addEventListener("cancel", (event) => {
      event.preventDefault();
      settle(false);
    });

    // Backdrop click (outside the form). Resolves false.
    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) settle(false);
    });

    window.holdspeakConfirm = function holdspeakConfirm(opts = {}) {
      // If a prior prompt is somehow still pending, decline it so
      // we never resolve two promises against the same dialog.
      if (pending) settle(false);

      const {
        title = "Confirm",
        body = "",
        scopeNote = "",
        confirmLabel = "Confirm",
        cancelLabel = "Cancel",
        danger = true,
      } = opts;

      titleEl.textContent = title;
      bodyEl.textContent = body;

      if (scopeNote) {
        scopeEl.innerHTML = "";
        const pill = document.createElement("span");
        pill.className = "confirm-dialog__scope-pill";
        pill.textContent = "local-only";
        const note = document.createElement("span");
        note.className = "confirm-dialog__scope-note";
        note.textContent = scopeNote;
        scopeEl.appendChild(pill);
        scopeEl.appendChild(note);
        scopeEl.removeAttribute("data-empty");
      } else {
        scopeEl.textContent = "";
        scopeEl.setAttribute("data-empty", "true");
      }

      okBtn.textContent = confirmLabel;
      cancelBtn.textContent = cancelLabel;
      okBtn.classList.toggle("btn--danger", !!danger);
      okBtn.classList.toggle("btn--primary", !danger);
      // HS-69-05: tint the sheet's glyph chip + glow to the context.
      dialog.classList.toggle("is-danger", !!danger);

      returnFocusTo = document.activeElement instanceof HTMLElement
        ? document.activeElement
        : null;

      return new Promise((resolve) => {
        pending = resolve;
        dialog.showModal();
        // Default focus on cancel: this also makes Enter resolve to
        // false because Enter activates the focused button.
        requestAnimationFrame(() => cancelBtn.focus());
      });
    };
  })();
</script>

<style>
  /* HS-69-05 "Signal" premium sheet. A raised surface with the top-lit
   * gradient hairline (the same craft as `.signal-card`), a grab handle, a
   * glyph-chip header, an accent "Done" pill, and a tinted-glow backdrop —
   * the web port of the iPad sheet (MeetingCaptureApp.swift:2398-2433). */
  .confirm-dialog {
    position: relative;
    border: 1px solid transparent;     /* the visible edge is the ::before hairline */
    border-radius: var(--radius-lg);
    background: var(--surface-2);
    color: var(--text);
    padding: 0;
    box-shadow: var(--elev-3);
    max-width: min(34rem, calc(100vw - 2 * var(--space-5)));
    width: 100%;
    overflow: hidden;
  }

  /* the top-lit gradient hairline (masked 1px gradient border, crisp on radii) */
  .confirm-dialog::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.14) 0%, rgba(255, 255, 255, 0.04) 100%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask-composite: exclude;
    pointer-events: none;
    z-index: 1;
  }

  /* tinted glow behind the sheet: a soft accent wash over the dim overlay */
  .confirm-dialog::backdrop {
    background:
      radial-gradient(circle at 50% 38%, color-mix(in srgb, var(--accent) 11%, transparent), transparent 55%),
      var(--canvas-overlay);
  }
  .confirm-dialog.is-danger::backdrop {
    background:
      radial-gradient(circle at 50% 38%, color-mix(in srgb, var(--danger) 11%, transparent), transparent 55%),
      var(--canvas-overlay);
  }

  /* grab handle — the iPad sheet's pull affordance, echoed as a quiet bar */
  .confirm-dialog__grabber {
    width: 36px;
    height: 4px;
    border-radius: var(--radius-pill);
    background: var(--line-strong);
    margin: var(--space-2) auto 0;
    position: relative;
    z-index: 2;
  }

  .confirm-dialog__header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: var(--surface-3);
    color: var(--text);
    border-bottom: 1px solid var(--border-subtle);
    padding: var(--space-3) var(--space-4);
    position: relative;
    z-index: 2;
  }

  /* the glyph chip — accent by default, danger-tinted in a destructive prompt;
     the icon swaps confirm (check) ↔ danger (alert) with the `is-danger` class */
  .confirm-dialog__glyph {
    --chip-size: 36px;
  }
  .confirm-dialog__glyph .glyph-danger { display: none; }
  .confirm-dialog.is-danger .confirm-dialog__glyph {
    background: var(--danger);
    box-shadow: 0 4px 14px color-mix(in srgb, var(--danger) 40%, transparent);
  }
  .confirm-dialog.is-danger .confirm-dialog__glyph .glyph-confirm { display: none; }
  .confirm-dialog.is-danger .confirm-dialog__glyph .glyph-danger { display: block; }

  .confirm-dialog__header .confirm-dialog__title {
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .confirm-dialog[open] {
      animation: confirm-dialog-in var(--duration-short) var(--ease-standard);
    }
    .confirm-dialog[open]::backdrop {
      animation: confirm-backdrop-in var(--duration-short) var(--ease-standard);
    }
    .confirm-dialog.is-closing {
      animation: confirm-dialog-out var(--duration-short) var(--ease-standard) forwards;
    }
    .confirm-dialog.is-closing::backdrop {
      animation: confirm-backdrop-out var(--duration-short) var(--ease-standard) forwards;
    }
  }

  @keyframes confirm-dialog-in {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes confirm-dialog-out {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(-4px); }
  }

  @keyframes confirm-backdrop-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes confirm-backdrop-out {
    from { opacity: 1; }
    to   { opacity: 0; }
  }

  .confirm-dialog__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    margin: 0;
    position: relative;
    z-index: 2;
  }

  /* The title rule outside the header is now a no-op since the
   * title lives inside __header — but we keep this scoped rule
   * for any consumer that overrides the markup. */
  .confirm-dialog__form .confirm-dialog__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text);
  }

  .confirm-dialog__body {
    margin: 0;
    color: var(--text);
    line-height: var(--line-height-relaxed, 1.5);
    white-space: pre-wrap;
  }

  .confirm-dialog__scope {
    margin: 0;
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed, 1.5);
    background: var(--info-soft);
    border: 1px solid var(--info);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
  }

  .confirm-dialog__scope[data-empty="true"] {
    display: none;
  }

  .confirm-dialog__scope-pill {
    flex: 0 0 auto;
    font-family: var(--font-display);
    font-size: var(--font-size-sm);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--info);
    background: var(--info-soft);
    border: 1px solid var(--info);
    border-radius: var(--radius-sm);
    padding: 0 var(--space-2);
    line-height: 1.5;
  }

  .confirm-dialog__scope-note {
    flex: 1 1 auto;
  }

  .confirm-dialog__actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  /* Mirror Button.astro's variant + size styles for the buttons we
     render inside the form. The component's <button>s are not
     <Button> instances (we render them in a <script>-driven flow),
     so we duplicate the exact ruleset here against the same tokens
     to keep the dialog visually consistent with the rest of the
     system. */

  .confirm-dialog .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-weight: 500;
    line-height: 1;
    letter-spacing: var(--letter-spacing-loose);
    border: 1px solid transparent;
    border-radius: var(--radius-pill);
    cursor: pointer;
    user-select: none;
    padding: var(--space-3) var(--space-5);
    font-size: var(--font-size-md);
  }

  /* the affirmative is an accent/danger "Done" pill with a soft glow */
  .confirm-dialog .btn--primary {
    box-shadow: 0 4px 14px var(--accent-glow);
  }
  .confirm-dialog .btn--danger {
    box-shadow: 0 4px 14px color-mix(in srgb, var(--danger) 35%, transparent);
  }

  .confirm-dialog .btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  .confirm-dialog .btn--secondary {
    background: var(--canvas-raised);
    color: var(--text);
    border-color: var(--line-strong);
  }

  .confirm-dialog .btn--secondary:hover {
    border-color: var(--line-emphasis);
    background: var(--canvas-elevated);
  }

  .confirm-dialog .btn--danger {
    background: var(--danger);
    color: var(--canvas);
    border-color: var(--danger);
  }

  .confirm-dialog .btn--danger:hover {
    background: var(--danger-strong);
    border-color: var(--danger-strong);
  }

  .confirm-dialog .btn--primary {
    background: var(--accent);
    color: var(--accent-on);
    border-color: var(--accent);
  }

  .confirm-dialog .btn--primary:hover {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
  }
</style>
