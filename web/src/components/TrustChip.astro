---
// HS-42-05: the ambient trust/privacy posture chip.
//
// A persistent shell-header button showing the live privacy posture
// (Local only · Configured endpoint · Writes need approval · Needs attention),
// read from GET /api/setup/status. Opens the full Trust & Privacy panel (markup
// + wiring live in AppLayout). Renders an honest default ("Local only") server-
// side; the shell script fills the live posture on load.
---

<button
  type="button"
  class="trust-chip tone-local"
  data-trust-open
  aria-haspopup="dialog"
  aria-controls="trust-panel"
  title="Privacy posture — what can leave this machine"
>
  <svg class="trust-chip-glyph" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
  </svg>
  <span class="trust-chip-dot" aria-hidden="true"></span>
  <span data-trust-label>Local only</span>
</button>

<style>
  .trust-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    cursor: pointer;
    white-space: nowrap;
    transition: border-color var(--duration-short) var(--ease-standard),
      color var(--duration-short) var(--ease-standard);
  }
  .trust-chip:hover { border-color: var(--border-strong); color: var(--text); }
  .trust-chip:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .trust-chip-glyph { flex: none; opacity: 0.85; }
  .trust-chip-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; box-shadow: 0 0 8px currentColor; }

  .trust-chip.tone-local { color: var(--local, var(--ok)); border-color: color-mix(in srgb, var(--local, var(--ok)) 45%, transparent); }
  .trust-chip.tone-ok { color: var(--ok); border-color: color-mix(in srgb, var(--ok) 45%, transparent); }
  .trust-chip.tone-info { color: var(--info, var(--accent)); border-color: color-mix(in srgb, var(--info, var(--accent)) 45%, transparent); }
  .trust-chip.tone-warn { color: var(--warn-strong, var(--warn)); border-color: color-mix(in srgb, var(--warn) 50%, transparent); }
  .trust-chip.tone-danger { color: var(--danger); border-color: color-mix(in srgb, var(--danger) 55%, transparent); }
</style>
