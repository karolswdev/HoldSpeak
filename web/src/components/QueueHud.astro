---
// HS-69-07: the app-wide Queue HUD shell.
//
// A Dynamic-Island-style pill (collapsed) that expands into a per-job ledger,
// mounted in AppLayout so it rides EVERY route (the iPad `QueueHUD` at app
// root). Markup here; the store + render + the WS-derived job model live in
// `web/src/scripts/queue-hud.js` (fed by the shared `runtime-bus.js`).
//
// The pill starts HIDDEN (`hidden` on the root) and the store reveals it only
// when there is a job — unobtrusive at rest, glanceable when the machine works.
//
// CSS is `is:global` on purpose: the ledger ROWS are injected by JS at runtime
// (no Astro scope hash), so component-scoped styles would silently not apply
// (the standing Astro-scoped-CSS-on-JS-DOM gotcha). Status colors are the
// web-wins palette tokens (--ok/--warn/--danger/--accent/--text-faint).
---

<div class="queue-hud" data-queue-hud hidden>
  <button
    type="button"
    class="qh-pill signal-card"
    data-qh-pill
    aria-expanded="false"
    aria-controls="queue-hud-panel"
    aria-label="Run queue"
  >
    <span class="qh-beacon" data-qh-beacon aria-hidden="true"></span>
    <span class="qh-summary" data-qh-summary>Idle</span>
    <span class="qh-blocked-chip" data-qh-blocked hidden></span>
  </button>

  <div
    id="queue-hud-panel"
    class="qh-panel signal-card"
    data-qh-panel
    role="region"
    aria-label="Run queue"
    aria-live="polite"
    hidden
  >
    <div class="qh-ledger" data-qh-ledger></div>
  </div>
</div>

<script>
  import "../scripts/queue-hud.js";
</script>

<style is:global>
  /* ── the floating shell ── */
  .queue-hud {
    position: fixed;
    /* sits just under the sticky TopNav (sticky z=10), above content,
       below dialogs (200) / toasts (300). */
    top: calc(var(--space-3) + 52px);
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--z-overlay);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    pointer-events: none; /* the children re-enable; the wrapper never blocks */
    max-width: min(420px, calc(100vw - 2 * var(--space-4)));
    width: max-content;
  }
  .queue-hud > * {
    pointer-events: auto;
  }

  /* ── the collapsed pill (Dynamic-Island capsule) ── */
  .qh-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    /* translucent material over surface-2 — the .ultraThinMaterial analog */
    background: color-mix(in srgb, var(--surface-2) 78%, transparent);
    -webkit-backdrop-filter: blur(14px) saturate(1.2);
    backdrop-filter: blur(14px) saturate(1.2);
    color: var(--text);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: 0.01em;
    transition: transform var(--duration-short) var(--ease-standard);
  }
  .qh-pill:hover { transform: translateY(-1px); }
  .qh-pill:active { transform: scale(0.98); }
  /* the pill's signal-card hairline radius follows the pill shape */
  .qh-pill.signal-card::before { border-radius: var(--radius-pill); }

  .qh-summary {
    color: var(--text);
    white-space: nowrap;
  }

  /* the pulsing beacon — colored by the most-urgent status */
  .qh-beacon {
    flex: none;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-faint);
  }
  .qh-beacon.is-working { background: var(--accent); box-shadow: 0 0 8px var(--accent-glow); }
  .qh-beacon.is-blocked { background: var(--warn); }
  .qh-beacon.is-failed { background: var(--danger); }
  .qh-beacon.is-queued { background: var(--text-faint); }
  .qh-beacon.is-live {
    animation: hs-pulse 1.6s var(--ease-standard) infinite;
  }

  .qh-blocked-chip {
    flex: none;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    display: inline-grid;
    place-items: center;
    border-radius: var(--radius-pill);
    background: var(--warn-soft);
    color: var(--warn);
    border: 1px solid color-mix(in srgb, var(--warn) 40%, transparent);
    font-size: 11px;
    font-weight: 700;
  }

  /* ── the expanded ledger panel ── */
  .qh-panel {
    width: min(420px, calc(100vw - 2 * var(--space-4)));
    max-height: min(60vh, 460px);
    overflow-y: auto;
    padding: var(--space-3);
    background: color-mix(in srgb, var(--surface-2) 88%, transparent);
    -webkit-backdrop-filter: blur(18px) saturate(1.2);
    backdrop-filter: blur(18px) saturate(1.2);
    box-shadow: var(--elev-3);
    border-radius: var(--radius-5);
  }
  .qh-ledger {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* ── a per-job ledger row (rendered by queue-hud.js) ── */
  .qh-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3);
    align-items: start;
    padding: var(--space-3);
    background: var(--surface-1);
  }

  /* the status orb */
  .qh-orb {
    flex: none;
    width: 30px;
    height: 30px;
    display: inline-grid;
    place-items: center;
    border-radius: var(--radius-md);
    color: var(--text-faint);
    background: var(--surface-3);
  }
  .qh-orb svg { width: 16px; height: 16px; }
  .qh-orb.is-working { color: var(--accent); background: var(--accent-tint); }
  .qh-orb.is-blocked { color: var(--warn); background: var(--warn-soft); }
  .qh-orb.is-queued { color: var(--text-faint); background: var(--surface-3); }
  .qh-orb.is-done { color: var(--ok); background: var(--ok-soft); }
  .qh-orb.is-failed { color: var(--danger); background: var(--danger-soft); }
  .qh-orb.is-live { animation: hs-pulse 1.6s var(--ease-standard) infinite; }

  .qh-body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .qh-row-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .qh-label {
    color: var(--text);
    font-weight: 600;
    font-size: var(--font-size-sm);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* the status chip — no prose, just the status word */
  .qh-status-chip {
    flex: none;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow);
    padding: 2px 7px;
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
  }
  .qh-status-chip.is-working { color: var(--accent); background: var(--accent-tint); border-color: color-mix(in srgb, var(--accent) 35%, transparent); }
  .qh-status-chip.is-blocked { color: var(--warn); background: var(--warn-soft); border-color: color-mix(in srgb, var(--warn) 35%, transparent); }
  .qh-status-chip.is-queued { color: var(--text-faint); background: var(--surface-3); border-color: var(--border); }
  .qh-status-chip.is-done { color: var(--ok); background: var(--ok-soft); border-color: color-mix(in srgb, var(--ok) 35%, transparent); }
  .qh-status-chip.is-failed { color: var(--danger); background: var(--danger-soft); border-color: color-mix(in srgb, var(--danger) 35%, transparent); }

  /* the progress bar (accent-gradient fill) */
  .qh-bar {
    height: 4px;
    border-radius: var(--radius-pill);
    background: var(--surface-3);
    overflow: hidden;
  }
  .qh-bar-fill {
    height: 100%;
    border-radius: inherit;
    background: var(--accent-gradient);
    transition: width var(--duration-medium) var(--ease-standard);
  }
  .qh-bar-fill.is-done { background: var(--ok); }
  .qh-bar-fill.is-failed { background: var(--danger); width: 100%; }
  .qh-bar-fill.is-blocked { background: var(--warn); width: 100%; }
  .qh-bar-fill.is-queued { background: var(--text-faint); }
  /* indeterminate shimmer — no true 0..1 progress is in the frames */
  .qh-bar-fill.is-indeterminate {
    width: 40%;
    animation: qh-indeterminate 1.4s var(--ease-standard) infinite;
  }
  @keyframes qh-indeterminate {
    0%   { transform: translateX(-120%); }
    100% { transform: translateX(320%); }
  }

  .qh-row-foot {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .qh-target {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow);
    color: var(--text-muted);
    padding: 2px 7px;
    border-radius: var(--radius-pill);
    background: var(--surface-3);
    border: 1px solid var(--border-subtle);
  }
  .qh-note {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* narrow widths: dock as a slim bar so it never fights the mobile nav toggle */
  @media (max-width: 640px) {
    .queue-hud {
      left: var(--space-4);
      right: var(--space-4);
      transform: none;
      align-items: stretch;
      max-width: none;
      width: auto;
    }
    .qh-pill { justify-content: center; }
    .qh-panel { width: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .qh-beacon.is-live,
    .qh-orb.is-live { animation: none; }
    .qh-bar-fill.is-indeterminate { animation: none; width: 40%; }
    .qh-pill, .qh-bar-fill { transition: none; }
  }
</style>
