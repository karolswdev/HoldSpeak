---
// The Dry-run tab: run the current DIR-01 pipeline against typed text
// without touching the keyboard, plus the HS-45-03 moment of truth and the
// HS-48-03 one-tap correction ritual (whose markup is also rendered into
// journal entries — the .moment/.fixit styles here are global for both).
---

<section id="view-dry-run" class="view" hidden>
  <h2>Dry-run preview</h2>
  <p class="lede">
    Run the current DIR-01 pipeline against typed text without
    touching the keyboard. The trace uses the current project
    detected from the <code>holdspeak</code> process cwd.
  </p>
  <div class="grid">
    <section class="panel">
      <header class="panel-header"><h3>Input</h3></header>

      {/* HS-18 (web): the browser-mic capture aid. Speak the utterance, play
          it back to confirm what dictation would hear, then write what you
          said and run the same local dry-run. Preview-only: the hub has no
          dictation transcribe-preview route, so the capture stays in the
          browser and nothing is injected. Egress is the canonical badge. */}
      <div id="mic-widget" class="mic-widget">
        <div class="mic-widget-head">
          <span class="mic-widget-title">Speak it (preview)</span>
          <span id="mic-egress" class="egress-badge is-local" hidden></span>
        </div>
        <p class="mic-widget-note">
          Capture stays in your browser. Play it back to hear what dictation
          would hear, then confirm the words below and run the dry-run. Nothing
          is typed into any app.
        </p>
        <div id="mic-record-row" class="mic-record-row">
          <button
            id="mic-record-btn"
            class="btn mic-record-btn"
            type="button"
            aria-pressed="false"
          >
            <span class="mic-record-dot" aria-hidden="true"></span>
            <span class="mic-record-label">Record</span>
          </button>
          <span id="mic-elapsed" class="mic-elapsed" aria-live="off">00:00</span>
        </div>
        <p id="mic-status" class="mic-status" role="status" aria-live="polite"></p>
        <audio id="mic-playback" class="mic-playback" controls preload="metadata" hidden></audio>
        <div id="mic-review" class="mic-review" hidden>
          <p class="mic-review-hint">
            Now write what you said (your words, your call), then run the
            preview to see the resolved text and where it would land.
          </p>
          <div class="actions">
            <button class="btn primary" id="mic-review-run" type="button">Run preview</button>
            <button class="btn" id="mic-discard" type="button">Discard recording</button>
          </div>
        </div>
      </div>

      <label>Utterance
        <textarea id="dry-utterance" placeholder="Type the utterance to preview"></textarea>
      </label>
      <div id="dry-msg"></div>
      <div class="actions">
        <button class="btn primary" id="dry-btn-run" type="button">Run dry-run</button>
        <button class="btn" id="dry-btn-clear" type="button">Clear</button>
      </div>
    </section>
    <section class="panel">
      <header class="panel-header"><h3>Result</h3></header>
      <div id="dry-meta" class="meta-banner">No dry-run yet.</div>
      <div id="dry-final"></div>
      <!-- HS-45-03: the moment of truth — review the just-typed result and
           fix it in flow; the fix teaches the copilot and is recorded
           against the journal entry. Populated by renderMomentOfTruth(). -->
      <div id="dry-moment" class="moment" hidden></div>
      <div id="dry-trace"></div>
    </section>
  </div>
</section>

<style is:global>
  /* === HS-18 (web): the browser-mic capture aid ===================== */
  .mic-widget {
    margin-bottom: var(--space-3);
    padding: var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-3);
    background: linear-gradient(180deg, var(--accent-tint), var(--surface-2) 70%);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .mic-widget-head {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: space-between;
  }
  .mic-widget-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--font-size-sm);
    color: var(--text);
  }
  .mic-widget-note {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
  }
  .mic-record-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .mic-record-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .mic-record-dot {
    flex: none;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .mic-record-btn.is-recording {
    border-color: var(--accent);
    color: var(--accent);
  }
  .mic-record-btn.is-recording .mic-record-dot {
    background: #e5484d;
    animation: mic-pulse 1.2s ease-in-out infinite;
  }
  @keyframes mic-pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, #e5484d 55%, transparent); }
    70% { box-shadow: 0 0 0 0.5rem color-mix(in srgb, #e5484d 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in srgb, #e5484d 0%, transparent); }
  }
  @media (prefers-reduced-motion: reduce) {
    .mic-record-btn.is-recording .mic-record-dot { animation: none; }
  }
  .mic-elapsed {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }
  .mic-status {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    line-height: var(--line-height-relaxed);
  }
  .mic-status.is-recording { color: var(--accent); }
  .mic-status.is-ready { color: var(--success-strong, var(--success)); }
  .mic-status.is-error { color: var(--danger, #e5484d); }
  .mic-playback {
    width: 100%;
    margin-top: var(--space-1);
  }
  .mic-playback[hidden] { display: none; }
  .mic-review[hidden] { display: none; }
  .mic-review-hint {
    margin: 0 0 var(--space-2);
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
  }
  .mic-record-row[hidden] { display: none; }

  /* === Trace (dry-run) — rendered at runtime into #dry-trace ========= */
  .trace-stage {
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-3);
    background: var(--canvas);
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .trace-stage-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .trace-stage-head strong { color: var(--text); }
  .trace-stage-elapsed { color: var(--text-faint); }
  .trace-intent {
    margin: 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .trace-metadata {
    margin: 0;
    background: var(--canvas-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  .trace-empty {
    margin: 0;
    color: var(--text-faint);
    font-size: var(--font-size-sm);
  }

  /* Calm advisory notes for the dry-run (NOT a red error box) — stage skips,
     "llm disabled", target fallbacks read as context, not failure. */
  .dry-notes {
    margin-top: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid var(--warn);
    border-radius: var(--radius-2);
    background: var(--surface-2);
  }
  .dry-notes-title {
    display: block;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin-bottom: 4px;
  }
  .dry-notes ul { margin: 0; padding-left: var(--space-3); }
  .dry-notes li { color: var(--text-muted); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); }

  /* === HS-45-03: the moment of truth (in-flow correct-and-teach) ===== */
  /* The focal, delightful element — an accent-edged card that invites the fix. */
  .moment {
    margin-top: var(--space-3);
    border: 1px solid color-mix(in srgb, var(--accent) 32%, var(--border-subtle));
    border-radius: var(--radius-3);
    background: linear-gradient(180deg, var(--accent-tint), var(--surface-1) 60%);
    box-shadow: var(--elev-1);
    padding: var(--space-3) var(--space-4);
  }
  .moment-head { display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap; }
  .moment-q { font-family: var(--font-display); font-weight: 700; font-size: var(--font-size-md); color: var(--text); }
  .moment-routed { color: var(--text-muted); font-size: var(--font-size-sm); }
  .moment-conf { font-family: var(--font-mono); opacity: 0.85; }
  .moment-spacer { flex: 1; }
  .moment-fix-btn {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--text-on-accent);
    font-weight: 600;
  }
  .moment-fix-btn:hover { background: var(--accent-hover); border-color: var(--accent-hover); }
  .moment-form { margin-top: var(--space-3); display: flex; flex-direction: column; gap: var(--space-2); }
  .moment-hint { margin: 0; color: var(--text-muted); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); }
  .moment-form .row { display: flex; gap: var(--space-2); flex-wrap: wrap; }
  .moment-form label { display: flex; flex-direction: column; gap: 4px; font-size: var(--font-size-sm); color: var(--text-muted); }
  .moment-form select, .moment-form input {
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-1);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    padding: var(--space-1) var(--space-2);
  }
  .moment-form .actions { display: flex; gap: var(--space-1); }
  .moment-done {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
  }
  .moment-check {
    flex: none;
    display: inline-grid;
    place-items: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--success);
    color: #fff;
    font-weight: 700;
    animation: moment-pop 160ms ease;
  }
  @keyframes moment-pop {
    from { transform: scale(0.6); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .moment-check { animation: none; }
  }

  /* === HS-48-03: the one-tap right/wrong ritual ===================== */
  /* Shared by the dry-run moment and every journal entry. On a journal card it
     reads as a quiet footer rule; on the dry-run it sits inside the accent
     `.moment` card. */
  .fixit { font-size: var(--font-size-sm); }
  /* `[hidden]` must win over the `display` rules below (an explicit author
     `display` otherwise overrides the UA hidden rule and the panels leak open). */
  .fixit-ask[hidden], .fixit-scopes[hidden], .fixit-form[hidden], .fixit-done[hidden] { display: none; }
  .journal-card .fixit {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-subtle);
  }
  .fixit-ask { display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap; }
  .fixit-yes {
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
  }
  .fixit-yes:hover { color: var(--success-strong); border-color: var(--success); background: var(--success-soft); }
  .fixit-scopes {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-3);
  }
  .fixit-scope-q { color: var(--text-muted); }
  .fixit-scope {
    padding: 4px var(--space-3);
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border-subtle));
    background: var(--accent-tint);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    cursor: pointer;
    transition: border-color 140ms ease, background 140ms ease;
  }
  .fixit-scope:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 18%, var(--surface-2)); }
  .fixit-form { margin-top: var(--space-3); }
</style>
