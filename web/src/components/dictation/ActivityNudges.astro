---
// HS-53-04: activity pre-briefing nudges. JS-rendered into #activity-nudges;
// each card is role="note", never steals focus, source-cited from the
// ActivityRecord that produced it. Hidden until /api/activity/nudges
// returns at least one nudge AND activity tracking is on.
---

<section
  id="activity-nudges"
  class="an-hero"
  role="region"
  aria-label="Activity pre-briefing"
  hidden
>
  <header class="an-hero-head">
    <div class="an-hero-titles">
      <p class="an-eyebrow">Pre-briefing</p>
      <h2 class="an-title">Pick up where you left off</h2>
      <p class="an-lede">A quiet read of what you touched recently — every line cites the record on <code>/activity</code>.</p>
    </div>
    <span class="an-trust" aria-label="Local and source-cited">
      <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          d="M12 3l8 4v5c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4z"/>
      </svg>
      Local · source-cited
    </span>
  </header>
  <div id="activity-nudges-list" class="an-list" aria-live="polite"></div>
  <div id="activity-nudges-pin" class="an-pin" role="status" aria-live="polite" hidden>
    <span class="an-pin-glyph" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          d="M20 9V5l-4 4M20 5l-9 9-3-3-4 4"/>
      </svg>
    </span>
    <p class="an-pin-text">
      <strong>Your next dictation will include</strong>
      <span id="activity-nudges-pin-entity" class="an-pin-entity"></span>
    </p>
    <button class="btn an-pin-clear" id="activity-nudges-pin-clear" type="button">Clear</button>
  </div>
</section>

<!-- The card list inside #activity-nudges-list is rendered at runtime by
     the activity-nudges behavior module, so every rule below must be global
     (Astro scoped CSS dies on JS-injected DOM). The hero shell is in this
     template; we style it here too to keep the whole feature in one block. -->
<style is:global>
  /* ===== HS-53-04: Activity Pre-Briefing nudges ===================== */
  .an-hero {
    margin: var(--space-3) 0 var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-3);
    background:
      radial-gradient(120% 120% at 0% 0%,
        color-mix(in srgb, var(--accent) 10%, transparent) 0%, transparent 60%),
      var(--surface-1);
    box-shadow: var(--elev-1);
    padding: var(--space-4) var(--space-5);
  }
  .an-hero[hidden] { display: none; }
  .an-hero-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }
  .an-hero-titles { min-width: 0; }
  .an-eyebrow {
    margin: 0 0 2px;
    font-size: var(--font-size-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
  }
  .an-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    color: var(--text);
    line-height: 1.15;
  }
  .an-lede {
    margin: var(--space-1) 0 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    max-width: 60ch;
  }
  .an-trust {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px var(--space-2);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--accent) 12%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--border-subtle));
    color: var(--text);
    font-size: var(--font-size-xs);
    font-weight: 500;
    white-space: nowrap;
  }
  .an-trust svg { color: var(--accent); flex: none; }

  .an-list {
    display: grid;
    gap: var(--space-3);
  }

  /* === The card ============================================== */
  .activity-nudge {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-3);
    align-items: center;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-2);
    background:
      linear-gradient(180deg,
        color-mix(in srgb, var(--accent) 5%, var(--surface-2)) 0%,
        var(--surface-2) 100%);
    transition: border-color 120ms ease, transform 120ms ease, box-shadow 120ms ease;
  }
  .activity-nudge::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    border-radius: var(--radius-2) 0 0 var(--radius-2);
    background: linear-gradient(180deg, var(--accent), color-mix(in srgb, var(--accent) 30%, transparent));
  }
  .activity-nudge:hover {
    border-color: color-mix(in srgb, var(--accent) 35%, var(--border-subtle));
    box-shadow: var(--elev-1);
  }
  .activity-nudge[data-kind="window"] {
    background:
      linear-gradient(180deg,
        color-mix(in srgb, var(--accent) 9%, var(--surface-2)) 0%,
        var(--surface-2) 100%);
  }
  .activity-nudge-glyph {
    flex: 0 0 auto;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 16%, var(--surface-1));
    border: 1px solid color-mix(in srgb, var(--accent) 32%, var(--border-subtle));
    color: var(--accent);
  }
  .activity-nudge-glyph svg { display: block; }

  .activity-nudge-body {
    min-width: 0;
    display: grid;
    gap: 6px;
  }
  .activity-nudge-headline {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .activity-nudge-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    line-height: 1.25;
    color: var(--text);
    font-weight: 600;
  }
  .activity-nudge-summary {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-normal);
  }

  /* Citation chips — pill style, accent for the entity, neutral for the rest. */
  .activity-nudge-cite {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 2px 0 0;
  }
  .an-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
    background: var(--surface-1);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    font-family: var(--font-mono);
    white-space: nowrap;
  }
  .an-chip svg { color: var(--text-faint); flex: none; }
  .an-chip-entity {
    background: color-mix(in srgb, var(--accent) 14%, var(--surface-2));
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border-subtle));
    color: var(--text);
  }
  .an-chip-entity strong { color: var(--accent); font-weight: 600; }
  .an-chip-entity svg { color: var(--accent); }

  /* Window-summary's stat strip (instead of an entity chip). */
  .activity-nudge-stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 2px 0 0;
  }
  .an-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--accent) 10%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--border-subtle));
  }
  .an-stat-num {
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .an-stat-label {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Actions — primary CTA gets a real fill; dismiss is a quiet ghost. */
  .activity-nudge-actions {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 11rem;
  }
  .activity-nudge-actions .an-btn {
    appearance: none;
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px var(--space-3);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    font-weight: 600;
    line-height: 1;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease, border-color 120ms ease, transform 120ms ease;
  }
  .activity-nudge-actions .an-btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .activity-nudge-actions .an-btn-primary {
    background: var(--accent);
    color: var(--text-on-accent);
    border: 1px solid var(--accent);
  }
  .activity-nudge-actions .an-btn-primary:hover {
    background: color-mix(in srgb, var(--accent) 88%, white);
    transform: translateY(-1px);
  }
  .activity-nudge-actions .an-btn-primary svg { color: currentColor; flex: none; }
  .activity-nudge-actions .an-btn-ghost {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border-subtle);
  }
  .activity-nudge-actions .an-btn-ghost:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border-subtle));
  }

  /* === The selection pin ===================================== */
  .an-hero .an-pin {
    margin-top: var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border: 1px solid color-mix(in srgb, var(--accent) 45%, var(--border-subtle));
    border-radius: var(--radius-2);
    background:
      linear-gradient(90deg,
        color-mix(in srgb, var(--accent) 14%, var(--surface-2)) 0%,
        var(--surface-2) 80%);
    box-shadow: var(--elev-1);
  }
  .an-hero .an-pin[hidden] { display: none; }
  .an-hero .an-pin-glyph {
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 22%, var(--surface-1));
    border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--border-subtle));
    color: var(--accent);
  }
  .an-hero .an-pin-text {
    margin: 0;
    flex: 1;
    color: var(--text);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
  }
  .an-hero .an-pin-text strong {
    color: var(--text);
    font-weight: 600;
  }
  .an-hero .an-pin-entity {
    display: inline-flex;
    align-items: center;
    margin-left: 6px;
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--accent) 18%, var(--surface-1));
    border: 1px solid color-mix(in srgb, var(--accent) 38%, var(--border-subtle));
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 600;
  }
  .an-hero .an-pin-clear {
    flex: 0 0 auto;
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border-subtle);
    padding: 6px var(--space-3);
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    cursor: pointer;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .an-hero .an-pin-clear:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border-subtle));
  }

  @media (max-width: 760px) {
    .activity-nudge {
      grid-template-columns: auto 1fr;
    }
    .activity-nudge-actions {
      grid-column: 1 / -1;
      flex-direction: row;
      min-width: 0;
    }
    .activity-nudge-actions .an-btn { flex: 1; }
  }
</style>
