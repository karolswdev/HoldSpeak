---
// The Runtime tab: the DIR-01 pipeline + backend editor and the HS-40-03
// copilot-depth knobs. The depth/seg/switch grammar is shared with Memory
// and lives in SharedStyles; only the runtime-local helpers are here.
---

<section id="view-runtime" class="view" hidden>
  <h2>Dictation runtime</h2>
  <p class="lede">
    Configure the DIR-01 pipeline without editing
    <code>~/.config/holdspeak/config.json</code>. Counters are
    process-scoped (since runtime start). The cold-start cap is
    <code>max_total_latency_ms × 5</code> — first
    <code>classify()</code> after launch slower than the cap
    disables the LLM stage for the session
    (<code>DIR-R-003</code>).
  </p>
  <div id="rt-meta-banner" class="meta-banner">Loading…</div>
  <div class="grid">
    <section class="panel">
      <header class="panel-header"><h3>Pipeline + runtime</h3></header>
      <label class="check-label"><input type="checkbox" id="rt-enabled" /> Enable dictation pipeline</label>
      <label class="check-label"><input type="checkbox" id="rt-stage-rewriter" /> Enable project-aware rewrite stage (<code>.hs/</code>)</label>
      <label>Target profile override
        <select id="rt-target-profile">
          <option value="auto">Auto-detect target</option>
          <option value="codex_cli">Codex CLI</option>
          <option value="claude_code">Claude Code</option>
          <option value="terminal_shell">Terminal shell</option>
          <option value="browser">Browser</option>
          <option value="editor">Editor</option>
          <option value="chat">Chat</option>
        </select>
      </label>
      <button class="btn" id="rt-target-auto" type="button">Reset target to auto</button>
      <label>Backend
        <select id="rt-backend">
          <option value="auto">auto (prefer MLX)</option>
          <option value="mlx">mlx</option>
          <option value="llama_cpp">llama_cpp</option>
          <option value="openai_compatible">OpenAI-compatible endpoint</option>
        </select>
      </label>
      <label>MLX model path <input type="text" id="rt-mlx-model" /></label>
      <label>llama_cpp GGUF path <input type="text" id="rt-llama-path" /></label>
      <label>OpenAI-compatible model <input type="text" id="rt-openai-model" /></label>
      <label>OpenAI-compatible base URL <input type="text" id="rt-openai-base-url" /></label>
      <label>OpenAI-compatible API key env <input type="text" id="rt-openai-api-key-env" /></label>
      <label>OpenAI-compatible timeout seconds <input type="number" id="rt-openai-timeout" min="1" step="0.5" /></label>
      <label class="check-label"><input type="checkbox" id="rt-warm" /> warm_on_start (load model at launch)</label>
      <label>max_total_latency_ms
        <input type="range" id="rt-latency" min="100" max="5000" step="50" />
      </label>
      <div id="rt-latency-vis" class="rt-latency-vis"></div>

      <!-- ===== Copilot depth (HS-40-03): the Phase-39 knobs ===== -->
      <fieldset class="depth-group">
        <legend class="depth-legend">
          <span class="depth-legend-title">Copilot depth</span>
          <span class="depth-legend-sub">Opt-in refinement — off by default. Nothing here changes how the copilot behaves until you turn it on.</span>
        </legend>

        <!-- rewrite_passes -->
        <div class="depth-knob">
          <div class="depth-knob-head">
            <span class="depth-knob-title">Rewrite passes</span>
            <span class="depth-knob-badge" id="rt-rewrite-badge">1×</span>
          </div>
          <p class="depth-knob-hint">Draft&nbsp;→&nbsp;critique&nbsp;→&nbsp;refine. Each extra pass tightens the rewrite; any pass that would breach your latency budget is skipped automatically.</p>
          <div class="seg" id="rt-rewrite-seg" role="group" aria-label="Rewrite passes, 1 to 5">
            <button type="button" class="seg-btn" data-value="1" aria-pressed="true">1</button>
            <button type="button" class="seg-btn" data-value="2" aria-pressed="false">2</button>
            <button type="button" class="seg-btn" data-value="3" aria-pressed="false">3</button>
            <button type="button" class="seg-btn" data-value="4" aria-pressed="false">4</button>
            <button type="button" class="seg-btn" data-value="5" aria-pressed="false">5</button>
          </div>
          <input type="hidden" id="rt-rewrite-passes" value="1" />
          <p class="depth-knob-desc" id="rt-rewrite-desc">Single pass — fastest; byte-identical to a plain rewrite.</p>
        </div>

        <!-- corrections_enabled -->
        <label class="depth-switch">
          <span class="depth-switch-text">
            <span class="depth-knob-title">Learn from my corrections</span>
            <span class="depth-knob-hint">Correct a route once and similar utterances get nudged the same way — the memory now <strong>survives a restart</strong> (curate it in Memory).</span>
          </span>
          <span class="switch">
            <input type="checkbox" id="rt-corrections-enabled" />
            <span class="switch-track"><span class="switch-knob"></span></span>
          </span>
        </label>

        <!-- target_detect_llm_enabled + _below -->
        <div class="depth-knob depth-knob--group">
          <label class="depth-switch">
            <span class="depth-switch-text">
              <span class="depth-knob-title">Infer the target when unsure</span>
              <span class="depth-knob-hint">When heuristic target detection is low-confidence, ask the model to classify it. A manual override always wins.</span>
            </span>
            <span class="switch">
              <input type="checkbox" id="rt-target-detect-llm-enabled" />
              <span class="switch-track"><span class="switch-knob"></span></span>
            </span>
          </label>
          <div class="depth-subknob" id="rt-target-below-wrap" hidden>
            <div class="depth-knob-head">
              <span class="depth-knob-title">Ask the model below confidence</span>
              <span class="depth-knob-badge" id="rt-target-below-val">0.80</span>
            </div>
            <input type="range" id="rt-target-detect-llm-below" min="0" max="1" step="0.05" />
            <p class="depth-knob-hint">Lower = trust the heuristic (rarely ask the model). Higher = ask more often.</p>
          </div>
        </div>
      </fieldset>

      <div id="rt-msg"></div>
      <div class="actions">
        <button class="btn primary" id="rt-btn-save" type="button">Save</button>
        <button class="btn" id="rt-btn-test" type="button">Save &amp; test in dry-run</button>
        <button class="btn" id="rt-btn-reset" type="button">Reset</button>
      </div>
    </section>
    <section class="panel">
      <header class="panel-header">
        <h3>Runtime status</h3>
        <button id="rt-btn-refresh" class="btn" type="button">Refresh</button>
      </header>
      <div id="rt-session-banner"></div>
      <div id="rt-guidance"></div>
      <div id="rt-counters" class="rt-counters"></div>
      <p class="rt-counter-note">
        Counters reset on every <code>holdspeak</code> restart.
        <code>classify_failures</code> includes both LLM errors
        and constraint-rejected outputs;
        <code>constrained_retries</code> is the count of
        GBNF-grammar re-prompts.
      </p>
    </section>
  </div>
</section>

<style>
  /* Containers are in this template (their innerHTML is JS-set, but the
   * rules target only the static container classes). */
  .rt-latency-vis {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }
  .rt-counters {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
  }
</style>
