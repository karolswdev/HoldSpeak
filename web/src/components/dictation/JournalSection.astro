---
// The Journal tab (HS-45-02): every dictation remembered, searchable, and
// curatable, plus replay (HS-45-04). The entry cards, latency strips, and
// replay panels are rendered at runtime by the journal behavior module, so
// their CSS is global.
---

<section id="view-journal" class="view" hidden>
  <h2>Dictation journal</h2>
  <p class="lede">
    Every dictation, remembered — <strong>what you said</strong> →
    <strong>what it became</strong> → <strong>where it was headed</strong> →
    <strong>how long it took</strong>. Review it, search it, curate it.
    Your meetings have an afterlife; now your voice does too.
  </p>

  <div id="journal-trust" class="journal-trust" role="note">
    <svg class="journal-trust-glyph" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
      <path fill="currentColor" d="M12 1 3 5v6c0 5 3.8 9.4 9 11 5.2-1.6 9-6 9-11V5l-9-4Zm0 10.9h7c-.5 3.8-3.1 7.2-7 8.5V12H5V6.3l7-3.1V11.9Z"/>
    </svg>
    <span id="journal-trust-text">
      This journal lives <strong>only on this machine</strong>. Transcripts
      are secret-filtered before they're stored, and the journal is capped
      to the most recent entries. Clear it anytime.
    </span>
  </div>

  <div class="journal-controls">
    <div class="journal-search">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
        <path fill="currentColor" d="m21 20-5.2-5.2a7 7 0 1 0-1.4 1.4L20 21l1-1ZM5 10a5 5 0 1 1 10 0A5 5 0 0 1 5 10Z"/>
      </svg>
      <input
        type="search"
        id="journal-search"
        placeholder="Search transcripts and typed text…"
        aria-label="Search the dictation journal"
      />
    </div>
    <div class="journal-filters" role="group" aria-label="Filter journal">
      <select id="journal-filter-source" aria-label="Filter by source">
        <option value="">All sources</option>
        <option value="dictation">Spoken</option>
        <option value="dry_run">Dry-run</option>
      </select>
      <label class="journal-filter-check">
        <input type="checkbox" id="journal-filter-warnings" />
        <span>Only with warnings</span>
      </label>
      <label class="journal-filter-check">
        <input type="checkbox" id="journal-filter-corrected" />
        <span>Only corrected</span>
      </label>
    </div>
    <div class="journal-actions">
      <button class="btn" id="journal-btn-refresh" type="button">Refresh</button>
      <button class="btn danger" id="journal-btn-clear" type="button">Clear journal</button>
    </div>
  </div>

  <div id="journal-meta" class="meta-banner">Loading…</div>
  <div id="journal-list" class="journal-list"></div>
</section>

<style is:global>
  /* === HS-45-02: the dictation journal ============================== */
  /* The local-only trust statement — the privacy posture is first-class,
     not a footnote (the TrustChip idiom, expanded to a note). */
  .journal-trust {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    margin-bottom: var(--space-3);
    background: color-mix(in srgb, var(--accent) 7%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--border-subtle));
    border-radius: var(--radius-2);
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
  }
  .journal-trust.is-off {
    background: color-mix(in srgb, var(--warn) 9%, var(--surface-2));
    border-color: color-mix(in srgb, var(--warn) 30%, var(--border-subtle));
  }
  .journal-trust-glyph { flex: none; margin-top: 1px; color: var(--accent); }
  .journal-trust strong { color: var(--text); }

  .journal-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .journal-search {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex: 1 1 16rem;
    padding: 0 var(--space-2);
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    color: var(--text-muted);
  }
  .journal-search input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    padding: var(--space-2) 0;
  }
  .journal-search:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 22%, transparent);
  }
  .journal-filters { display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap; }
  .journal-filters select {
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    padding: var(--space-1) var(--space-2);
  }
  .journal-filter-check {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    cursor: pointer;
  }
  .journal-actions { display: flex; gap: var(--space-1); margin-left: auto; }

  .journal-list { display: flex; flex-direction: column; gap: var(--space-3); }

  .journal-empty {
    text-align: center;
    padding: var(--space-6) var(--space-3);
    border: 1px dashed var(--border-subtle);
    border-radius: var(--radius-3);
    background: color-mix(in srgb, var(--surface-2) 50%, transparent);
  }
  .journal-empty-glyph { color: var(--accent); opacity: 0.6; margin-bottom: var(--space-2); }
  .journal-empty-head {
    margin: 0 0 var(--space-1);
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    color: var(--text);
  }
  .journal-empty-sub { margin: 0 auto; max-width: 44ch; color: var(--text-muted); }

  /* An elevated, contained card on the canvas. A hairline accent rail on the
     left turns success-green once an entry has been corrected. */
  .journal-card {
    position: relative;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-3);
    background: var(--surface-1);
    box-shadow: var(--elev-1);
    padding: var(--space-4);
    overflow: hidden;
    transition: box-shadow 140ms ease, transform 140ms ease, border-color 140ms ease;
  }
  .journal-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--accent);
    opacity: 0.55;
  }
  .journal-card:hover { box-shadow: var(--elev-2); transform: translateY(-2px); border-color: var(--border); }
  .journal-card.is-corrected::before { background: var(--success); opacity: 1; }

  .jr-head {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }
  .jr-spacer { flex: 1; }
  .jr-source {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px var(--space-2);
    border-radius: var(--radius-sm);
  }
  .src-spoken { background: var(--accent-tint); color: var(--accent); }
  .src-dry { background: var(--surface-3); color: var(--text-muted); }
  .jr-badge {
    display: inline-flex;
    align-items: center;
    font-size: var(--font-size-xs);
    padding: 3px var(--space-2);
    border-radius: var(--radius-sm);
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    color: var(--text);
    font-family: var(--font-mono);
  }
  .jr-target { background: transparent; border-color: transparent; color: var(--text-muted); padding-left: 0; }
  .jr-muted { color: var(--text-faint); }
  .jr-when { color: var(--text-faint); font-size: var(--font-size-xs); font-variant-numeric: tabular-nums; }
  .jr-corrected {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--success-strong);
    background: var(--success-soft);
    padding: 3px var(--space-2);
    border-radius: var(--radius-sm);
  }
  /* Header action buttons: real targets, icon + label, calm until hover. */
  .jr-replay-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: var(--font-size-xs);
    padding: 5px var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-subtle);
    background: var(--surface-2);
    color: var(--text-muted);
    cursor: pointer;
    transition: color 140ms ease, border-color 140ms ease, background 140ms ease;
  }
  .jr-replay-btn:hover { color: var(--accent); border-color: var(--accent); background: var(--accent-tint); }
  .jr-del {
    appearance: none;
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    background: transparent;
    border: 1px solid transparent;
    color: var(--text-faint);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: color 140ms ease, background 140ms ease;
  }
  .jr-del:hover { color: var(--danger); background: var(--danger-soft); }

  .jr-flow {
    display: grid;
    grid-template-columns: 1fr 1.5rem 1fr;
    align-items: stretch;
    gap: var(--space-2);
  }
  .jr-text { margin: 0; min-width: 0; }
  .jr-text figcaption {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin-bottom: 6px;
  }
  .jr-typed figcaption { color: var(--accent); }
  .jr-text-frame {
    position: relative;
    background: var(--canvas);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-2);
    padding: var(--space-3);
    padding-right: 2.6rem;
    height: 100%;
  }
  .jr-typed .jr-text-frame {
    background: var(--accent-tint);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border-subtle));
  }
  .jr-text-frame p {
    margin: 0;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    color: var(--text);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
  }
  .jr-said .jr-text-frame p { color: var(--text-muted); }
  .jr-copy {
    position: absolute;
    top: 8px;
    right: 8px;
    opacity: 0;
    transition: opacity 140ms ease;
  }
  .journal-card:hover .jr-copy, .jr-copy:focus-visible { opacity: 1; }
  .jr-arrow {
    align-self: center;
    justify-self: center;
    color: var(--text-faint);
    font-size: var(--font-size-md);
  }

  /* per-utterance latency strip — the black box, opened. A real segmented
     bar (proportional to each stage's time) + a labelled legend below it. */
  .lat-strip {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-subtle);
  }
  .lat-strip-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 6px;
  }
  .lat-strip-title {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow);
    color: var(--text-faint);
  }
  .lat-total {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--text);
  }
  .lat-bar {
    display: flex;
    width: 100%;
    height: 8px;
    border-radius: var(--radius-pill);
    overflow: hidden;
    background: var(--canvas);
    box-shadow: inset 0 0 0 1px var(--border-subtle);
  }
  /* base first, stage tints after — so the per-stage colour wins (the prior
     duplicate base rule was silently greying every segment). */
  .lat-seg { min-width: 3px; background: var(--accent-soft); }
  .lat-seg.lat-intent-router, .lat-dot.lat-intent-router { background: color-mix(in srgb, var(--accent) 45%, var(--surface-3)); }
  .lat-seg.lat-kb-enricher, .lat-dot.lat-kb-enricher { background: color-mix(in srgb, var(--accent) 22%, var(--surface-3)); }
  .lat-seg.lat-project-rewriter, .lat-dot.lat-project-rewriter { background: var(--accent); }
  .lat-dot { background: var(--accent-soft); }
  .lat-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-3);
    margin-top: 8px;
  }
  .lat-key {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }
  .lat-dot { width: 8px; height: 8px; border-radius: 2px; flex: none; }
  .lat-key b { color: var(--text); font-weight: 600; font-family: var(--font-mono); }
  .lat-strip--empty { color: var(--text-faint); font-size: var(--font-size-xs); padding-top: var(--space-2); }

  .jr-warnings { margin-top: var(--space-2); font-size: var(--font-size-sm); }
  .jr-warnings summary { cursor: pointer; color: var(--warn); }
  .jr-warnings ul { margin: var(--space-1) 0 0; padding-left: var(--space-3); color: var(--text-muted); }

  @media (max-width: 640px) {
    .jr-flow { grid-template-columns: 1fr; }
    .jr-arrow { transform: rotate(90deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .journal-card { transition: none; }
    .journal-card:hover { transform: none; }
  }

  /* === HS-45-04: replay (before → after, "prove it learned") ========= */
  .jr-replay-btn {
    font-size: var(--font-size-xs);
    padding: 2px var(--space-2);
  }
  .jr-replay {
    margin-top: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--border-subtle));
    border-radius: var(--radius-1);
    background: color-mix(in srgb, var(--accent) 5%, var(--surface-2));
  }
  .replay-pending { margin: 0; color: var(--text-muted); font-size: var(--font-size-sm); }
  .replay-head { margin-bottom: var(--space-2); font-size: var(--font-size-sm); }
  .replay-changed { color: var(--accent); font-weight: 600; }
  .replay-same { color: var(--text-muted); }
  .replay-row {
    display: grid;
    grid-template-columns: 5rem 1fr auto 1fr;
    align-items: center;
    gap: var(--space-2);
    padding: 2px 0;
    font-size: var(--font-size-sm);
  }
  .replay-label {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow);
    color: var(--text-muted);
  }
  .replay-before { color: var(--text-muted); font-family: var(--font-mono); }
  .replay-after { color: var(--text); font-family: var(--font-mono); }
  .replay-arrow { color: var(--text-muted); }
  .replay-row.is-changed .replay-after { color: var(--accent); font-weight: 600; }
  .replay-row.is-changed .replay-before { text-decoration: line-through; opacity: 0.7; }
  .replay-final { margin-top: var(--space-2); }
  .replay-final-frame {
    position: relative;
    background: var(--canvas);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid var(--accent);
    border-radius: var(--radius-1);
    padding: var(--space-2);
    margin-top: 4px;
  }
  .replay-final-frame p {
    margin: 0;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    color: var(--text);
    font-size: var(--font-size-sm);
    padding-right: 3.2rem;
  }
  .replay-final-frame .cmd-copy { position: absolute; top: 6px; right: 6px; }
  .replay-note { margin: var(--space-2) 0 0; color: var(--text-muted); font-size: var(--font-size-xs); }
  @media (max-width: 640px) {
    .replay-row { grid-template-columns: 1fr; }
    .replay-arrow { display: none; }
  }
</style>
