---
// The project-knowledge explainer / worked-example / teaching-empty-state
// grammar (HS-47-02) + the inline link-button, shared by the Project Facts
// and Project Context sections (the link-button is also rendered at runtime
// into their success messages). Renders no markup; imported by the page
// before the section partials.
---

<style is:global>  /* ===== Project-knowledge explainer + empty states (HS-47-02) =====
   * Shared by the Project Facts and Project Context sections. The markup is
   * static (or static-toggled); the empty states are toggled by the behavior
   * modules setting the `hidden` attribute, never re-rendered via innerHTML. */
  .kn-explainer {
    display: grid;
    grid-template-columns: 1fr minmax(0, 23rem);
    gap: var(--space-4);
    align-items: start;
    padding: var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-1));
    box-shadow: var(--elev-1);
  }
  @media (max-width: 760px) {
    .kn-explainer { grid-template-columns: 1fr; }
  }
  .kn-explainer-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .kn-explainer-eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
  }
  .kn-explainer-what {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
  }
  .kn-explainer-why {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    max-width: 52ch;
  }
  /* Worked example: a small monospace transform panel. */
  .kn-example {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--canvas);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
  }
  .kn-example figcaption {
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .kn-example-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .kn-example-tag {
    flex: 0 0 5.5rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .kn-example code {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text);
    overflow-wrap: anywhere;
  }
  .kn-example-arrow {
    color: var(--accent);
    font-size: var(--font-size-sm);
    line-height: 1;
    padding-left: 5.5rem;
  }
  .kn-example-out code { color: var(--accent); font-weight: 600; }

  /* Teaching empty states (KB rows / .hs files). */
  .kn-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2);
    padding: var(--space-5) var(--space-4);
    border: 1px dashed var(--line);
    border-radius: var(--radius-md);
    background: var(--canvas);
  }
  .kn-empty[hidden] { display: none; }
  .kn-empty-glyph { color: var(--accent); opacity: 0.85; }
  .kn-empty-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text);
  }
  .kn-empty-text {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    max-width: 46ch;
  }
  .kn-empty-eg {
    margin: var(--space-1) 0 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }
  .kn-empty-eg code { color: var(--accent); }
  .kn-empty-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  /* The inline link-button — also rendered at runtime into the Facts /
   * Context success messages ("Try a dry-run"), so it lives with the
   * shared primitives. */
  .kn-linkbtn {
    appearance: none;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    font: inherit;
    color: var(--accent);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .kn-linkbtn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
    border-radius: var(--radius-1);
  }

</style>
