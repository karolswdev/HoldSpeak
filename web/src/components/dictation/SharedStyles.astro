---
// The dictation cockpit's shared design primitives — the rules used by more
// than one section partial (panels, forms, buttons, banners, boxes, the
// block-card list grammar). Renders no markup; imported FIRST by the page so
// these emit before any per-section feature styles, preserving the pre-carve
// base-then-feature cascade order. `is:global` is page-contained: Astro only
// ships these styles on pages that import this component. Selectors are
// verbatim from the pre-carve page (Astro scoping used :where(), so the move
// changes neither reach within the page nor specificity).
---

<style is:global>
  .lede {
    margin: 0 0 var(--space-3);
    color: var(--text-muted);
    line-height: var(--line-height-relaxed);
    max-width: 48rem;
  }

  h2 {
    margin: 0 0 var(--space-2);
    font-family: var(--font-display);
    color: var(--text);
  }

  .view {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .view[hidden] { display: none; }

  /* === Tab + scope row =================================== */
  .scope-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-1);
  }
  .scope-row button {
    appearance: none;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    padding: var(--space-2) var(--space-3);
    color: var(--text-muted);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    cursor: pointer;
    transition: border-color var(--duration-short) var(--ease-standard),
                color var(--duration-short) var(--ease-standard),
                background var(--duration-short) var(--ease-standard);
  }
  .scope-row button:hover { color: var(--text); border-color: var(--line-strong); }
  .scope-row button.active {
    background: var(--accent-soft);
    border-color: var(--accent);
    color: var(--text);
  }
  .scope-row button:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  /* HS-12-02: meta-banner reads as a Workbench tool tray —
   * white surface, hard black border, no rounding. The .warn
   * / .error variants swap the border colour to the matching
   * status ramp. */
  .meta-banner {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--text);
    font-family: var(--font-mono);
    line-height: var(--line-height-relaxed);
  }
  .meta-banner strong {
    color: var(--text);
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: 400;
    letter-spacing: 0.04em;
  }
  .meta-banner.warn  { border-color: var(--warn);  background: var(--warn-soft);  color: var(--warn-strong); }
  .meta-banner.error { border-color: var(--danger); background: var(--danger-soft); color: var(--danger-strong); }

  /* === Grid ============================================== */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }
  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr; }
  }

  /* === Panel (HS-12-02 Workbench window grammar) ===========
   * Markup keeps padding on `.panel` rather than a body div, so
   * we use a negative margin on `.panel-header` to push the
   * blue title strip out to the panel edges. */
  .panel {
    background: var(--surface-1);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--elev-1);
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    overflow: hidden;
  }
  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    background: var(--surface-2);
    color: var(--text);
    border-bottom: 1px solid var(--border-subtle);
    padding: var(--space-3);
    margin: calc(var(--space-3) * -1) calc(var(--space-3) * -1) 0;
  }
  .panel-header h3 {
    margin: 0;
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    line-height: 1.3;
  }
  /* Sub-headings inside panel bodies (e.g. "Starter templates")
   * read as black-on-white labels, not as title strips. */
  .panel h3:not(.panel-header h3):not(.subhead) {
    margin: 0;
    color: var(--text);
    font-family: var(--font-display);
    font-size: var(--font-size-md);
  }
  .panel-toolbar {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .panel-toolbar .btn--ghost { color: var(--text-muted); }
  .panel-divider {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-subtle);
  }
  .subhead {
    font-size: var(--font-size-sm);
    font-family: var(--font-ui);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
  }

  /* === Block list ========================================
   * Shared by the Blocks list and the Project Context file list; the
   * cards themselves are rendered at runtime by the behavior modules. */
  .block-list { display: flex; flex-direction: column; gap: var(--space-1); }
  .block-card {
    border: 1px solid var(--border-subtle);
    border-left: 3px solid transparent;
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    background: var(--surface-2);
    cursor: pointer;
    transition: background var(--duration-short) var(--ease-standard),
                color var(--duration-short) var(--ease-standard),
                border-color var(--duration-short) var(--ease-standard);
  }
  /* HS-44-02: a hover accent edge gives the list tactile feedback. */
  .block-card:hover:not(.selected) {
    background: var(--surface-hover);
    border-left-color: var(--accent);
  }
  .block-card.selected {
    background: var(--selected-bg);
    color: var(--selected-fg);
  }
  .block-card.selected .block-id,
  .block-card.selected .block-desc { color: var(--selected-fg); }
  .block-id { font-family: var(--font-mono); font-weight: 600; color: var(--text); }
  .block-desc {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    margin-top: var(--space-1);
  }
  .block-card .pill {
    display: inline-block;
    padding: 0 var(--space-2);
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    color: var(--accent);
    font-size: var(--font-size-xs);
    margin-left: var(--space-2);
  }

  /* === Form controls ===================================== */
  label {
    display: block;
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }
  .check-label { display: flex; align-items: center; gap: var(--space-2); color: var(--text); }
  input[type="text"],
  input[type="number"],
  input[type="range"],
  textarea,
  select {
    width: 100%;
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    margin-top: var(--space-1);
  }
  input[type="checkbox"] { width: auto; margin: 0; }
  input:focus-visible, textarea:focus-visible, select:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
    border-color: var(--accent);
  }
  textarea { min-height: 5.5rem; resize: vertical; }
  .row { display: flex; gap: var(--space-3); }
  .row > * { flex: 1; }

  /* === Buttons =========================================== */
  .btn {
    appearance: none;
    background: var(--canvas-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    transition: border-color var(--duration-short) var(--ease-standard),
                background var(--duration-short) var(--ease-standard);
  }
  .btn:hover:not(:disabled) { border-color: var(--line-strong); }
  .btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .btn.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-on);
  }
  .btn.danger { color: var(--danger); border-color: var(--danger); }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  /* === Preview / boxes (used by JS-rendered editor previews) === */
  .preview {
    background: var(--canvas);
    border: 1px dashed var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-3);
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    white-space: pre-wrap;
    min-height: 5rem;
  }
  .preview .missing { color: var(--warn); }

  .error-box {
    background: var(--danger-soft);
    border: 1px solid var(--danger);
    color: var(--danger);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    font-family: var(--font-mono);
  }
  .ok-box {
    background: var(--success-soft);
    border: 1px solid var(--success);
    color: var(--success);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
  }

  /* Runtime guidance — rendered by JS into both the Readiness next-actions
   * list and the Runtime status panel. */
  .guidance-block {
    border-top: 1px solid var(--line);
    margin-top: var(--space-2);
    padding-top: var(--space-2);
  }
  .guidance-block p { margin: var(--space-1) 0; color: var(--text-muted); }
  .command-snippet {
    display: flex;
    align-items: stretch;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  .command-snippet code {
    flex: 1;
    min-width: 0;
    overflow-wrap: anywhere;
    white-space: pre-wrap;
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }

  /* Shared by Runtime, Memory, and Project Context footnotes. */
  .rt-counter-note {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    margin-top: var(--space-3);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    color: var(--text);
    background: var(--canvas);
    padding: 0 var(--space-1);
    border-radius: var(--radius-1);
  }
</style>
