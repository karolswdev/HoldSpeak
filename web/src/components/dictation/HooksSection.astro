---
// The Agent Hooks tab: Claude/Codex hook status, the copiable hook
// templates, and the external-agent summary controls. The hook cards are
// rendered at runtime by the agent behavior module, so their CSS is global.
---

<section id="view-hooks" class="view" hidden>
  <h2>Agent hooks</h2>
  <p class="lede">
    Inspect Claude/Codex hook status and copy the HoldSpeak hook templates.
    The browser does not write agent settings files directly; paste the
    template into the target tool's hook settings after review.
  </p>
  <div id="hooks-meta-banner" class="meta-banner">Loading…</div>
  <section class="panel">
    <header class="panel-header">
      <h3>External agent summary</h3>
    </header>
    <p class="lede">
      Compress the latest captured Claude/Codex question into compact
      context for intelligent typing. HoldSpeak uses safe read-only /
      no-tools defaults and only runs this when you click the button.
    </p>
    <div class="row">
      <label>
        Provider
        <select id="agent-summary-provider">
          <option value="codex">Codex CLI</option>
          <option value="claude">Claude Code</option>
        </select>
      </label>
      <label>
        Timeout seconds
        <input id="agent-summary-timeout" type="number" min="1" max="60" value="20" />
      </label>
    </div>
    <div class="actions">
      <button class="btn primary" id="agent-summary-run" type="button">Summarize latest agent context</button>
      <button class="btn" id="agent-summary-refresh" type="button">Refresh captured context</button>
    </div>
    <div id="agent-summary-provider-status" class="hook-status">Provider status loads with hook status.</div>
    <div id="agent-summary-status" class="preview">No summary generated yet.</div>
  </section>
  <section class="panel">
    <header class="panel-header">
      <h3>Hook templates</h3>
      <div class="panel-toolbar">
        <label class="check-label hooks-capture-label">
          <input type="checkbox" id="hooks-capture-messages" checked />
          Include assistant-message capture
        </label>
        <button id="hooks-btn-refresh" class="btn" type="button">Refresh</button>
      </div>
    </header>
    <div id="hooks-agent-list" class="hooks-agent-list"></div>
  </section>
</section>

<style is:global>
  /* Hook cards are rendered at runtime into #hooks-agent-list. */
  .hooks-capture-label {
    color: var(--text);
    font-size: var(--font-size-xs);
  }
  .hooks-agent-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }
  @media (max-width: 900px) {
    .hooks-agent-list { grid-template-columns: 1fr; }
  }
  .hook-card {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    background: var(--surface-1);
  }
  .hook-card h3 {
    margin: 0 0 var(--space-2);
  }
  .hook-status {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-muted);
    word-break: break-word;
  }
  .hook-template {
    max-height: 16rem;
    overflow: auto;
    white-space: pre;
    background: var(--surface-2);
    border: 1px solid var(--line);
    padding: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
</style>
