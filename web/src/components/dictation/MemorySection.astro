---
// The Memory tab (HS-40-04): the "What HoldSpeak learned" digest (HS-48-01),
// the persistent corrections list, and the per-session depth telemetry.
// The digest body, the correction items, and the depth stats are all
// rendered at runtime by the memory behavior module, so their CSS is global.
---

<section id="view-memory" class="view" hidden>
  <h2>Copilot memory &amp; depth</h2>
  <p class="lede">
    What the copilot has <strong>learned</strong> (persists across restarts)
    and how <strong>deep</strong> it's running this session. Curate the
    memory here; tune the knobs in <strong>Runtime → Copilot depth</strong>.
  </p>
  <!-- HS-48-01: the "What HoldSpeak learned" digest hero. Reads as a
       reward at the top of the tab; the cards inside #learn-digest are
       rendered by the memory behavior module, so their CSS is global. -->
  <section class="learn-hero" aria-labelledby="learn-hero-title">
    <header class="learn-hero-head">
      <div>
        <p class="learn-eyebrow">The learning loop</p>
        <h3 id="learn-hero-title">What HoldSpeak learned</h3>
      </div>
      <div class="learn-window" role="tablist" aria-label="Digest window">
        <button id="learn-window-week" class="learn-window-btn is-active" type="button" role="tab" aria-selected="true">This week</button>
        <button id="learn-window-all" class="learn-window-btn" type="button" role="tab" aria-selected="false">All time</button>
      </div>
    </header>
    <div id="learn-digest" class="learn-digest">Loading…</div>
  </section>

  <div id="mem-meta-banner" class="meta-banner">Loading…</div>
  <div class="grid">
    <!-- ===== What the copilot has learned ===== -->
    <section class="panel">
      <header class="panel-header">
        <h3>What the copilot has learned</h3>
        <button id="mem-btn-clear" class="btn danger" type="button">Forget all</button>
      </header>

      <label class="depth-switch mem-toggle">
        <span class="depth-switch-text">
          <span class="depth-knob-title">Use corrections when routing</span>
          <span class="depth-knob-hint" id="mem-enabled-hint">When on, similar utterances are nudged toward what you corrected.</span>
        </span>
        <span class="switch">
          <input type="checkbox" id="mem-corrections-enabled" />
          <span class="switch-track"><span class="switch-knob"></span></span>
        </span>
      </label>

      <form id="mem-add-form" class="mem-add">
        <div class="row">
          <label>Kind
            <select id="mem-add-kind">
              <option value="intent">intent → block</option>
              <option value="target">target → profile</option>
            </select>
          </label>
          <label>Corrected to
            <input type="text" id="mem-add-value" placeholder="block id / target profile" />
          </label>
        </div>
        <label>When I say (gist)
          <input type="text" id="mem-add-text" placeholder="utterance this correction applies to" />
        </label>
        <div class="actions">
          <button class="btn primary" id="mem-add-btn" type="submit">Remember this</button>
        </div>
        <div id="mem-add-msg"></div>
      </form>

      <div id="mem-list" class="mem-list"></div>
    </section>

    <!-- ===== Pipeline depth (this session) ===== -->
    <section class="panel">
      <header class="panel-header">
        <h3>Pipeline depth · this session</h3>
        <button id="mem-btn-refresh" class="btn" type="button">Refresh</button>
      </header>
      <div id="mem-depth" class="mem-depth"></div>
      <p class="rt-counter-note">
        Latency telemetry is in-memory and resets on every
        <code>holdspeak</code> restart. Run a few
        <strong>dry-runs</strong> (or dictate) to populate it.
      </p>
    </section>
  </div>
</section>

<style is:global>
  /* ===== Memory + telemetry (HS-40-04) ===== */
  .mem-toggle {
    padding: var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-2);
    background: var(--canvas);
  }
  .mem-add {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3);
    border: 1px dashed var(--line);
    border-radius: var(--radius-2);
  }
  .mem-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .mem-empty {
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    text-align: center;
    padding: var(--space-5) var(--space-3);
    border: 1px dashed var(--line);
    border-radius: var(--radius-2);
  }
  .mem-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-subtle);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-2);
    background: var(--surface-2);
    box-shadow: var(--elev-1);
    animation: depth-reveal var(--duration-short) var(--ease-decelerate);
  }
  .mem-item.kind-target {
    border-left-color: var(--success);
  }
  .mem-item-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mem-kind {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow);
    color: var(--accent);
  }
  .mem-item.kind-target .mem-kind {
    color: var(--success);
  }
  .mem-gist {
    color: var(--text);
    font-size: var(--font-size-sm);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .mem-arrow {
    color: var(--text-muted);
  }
  .mem-value {
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .mem-when {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    white-space: nowrap;
    flex: 0 0 auto;
  }
  .mem-del {
    appearance: none;
    flex: 0 0 auto;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-1);
    border: 1px solid var(--line);
    background: var(--canvas-raised);
    color: var(--text-muted);
    cursor: pointer;
    font-size: var(--font-size-md);
    line-height: 1;
    transition: color var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard);
  }
  .mem-del:hover {
    color: var(--danger);
    border-color: var(--danger);
  }
  .mem-del:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  /* Depth telemetry */
  .mem-depth {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .depth-summary {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .depth-stat {
    flex: 1;
    min-width: 5rem;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-2);
    background: var(--canvas);
  }
  .depth-stat-num {
    font-family: var(--font-mono);
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text);
  }
  .depth-stat-label {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow);
  }
  .depth-stage {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .depth-stage-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .depth-stage-name {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--text);
  }
  .depth-stage-nums {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }
  .depth-track {
    position: relative;
    height: 8px;
    border-radius: var(--radius-pill);
    background: var(--canvas);
    border: 1px solid var(--line);
    overflow: hidden;
  }
  .depth-fill {
    position: absolute;
    inset: 0 auto 0 0;
    border-radius: var(--radius-pill);
    background: var(--accent);
    transition: width var(--duration-medium) var(--ease-decelerate);
  }
  .depth-fill.warn {
    background: var(--danger);
  }
  .depth-guidance {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--danger);
    border-radius: var(--radius-2);
    background: var(--danger-soft);
    color: var(--danger);
    font-size: var(--font-size-xs);
  }
  .depth-passes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }
  .depth-pass-chip {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    padding: 1px var(--space-2);
    border-radius: var(--radius-pill);
    border: 1px solid var(--line);
    background: var(--canvas);
    color: var(--text-muted);
  }

  /* === HS-48-01: the "What HoldSpeak learned" digest ================ */
  /* The hero shell is static markup; the digest body (#learn-digest) is
     rendered at runtime by the memory behavior module, so every rule here
     is global. */
  .learn-hero {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-3);
    background:
      radial-gradient(120% 120% at 0% 0%, color-mix(in srgb, var(--accent) 10%, transparent) 0%, transparent 60%),
      var(--surface-1);
    box-shadow: var(--elev-1);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-4);
  }
  .learn-hero-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }
  .learn-eyebrow {
    margin: 0 0 2px;
    font-size: var(--font-size-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
  }
  .learn-hero h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    color: var(--text);
  }
  .learn-window {
    display: inline-flex;
    padding: 2px;
    gap: 2px;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
  }
  .learn-window-btn {
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease;
  }
  .learn-window-btn:hover { color: var(--text); }
  .learn-window-btn.is-active {
    background: var(--accent);
    color: var(--text-on-accent);
    font-weight: 600;
  }

  .learn-digest { min-height: 2.5rem; }

  /* HS-48-02: the inline "learned from N similar" trust chip, shared by the
     dry-run result, journal entries, and the Memory list. Calm, not loud —
     honesty over celebration. */
  .learn-sig {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 1px var(--space-2);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--success) 13%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--success) 30%, var(--border-subtle));
    color: var(--text);
    font-size: var(--font-size-xs);
    white-space: nowrap;
  }
  .learn-sig svg { color: var(--success); flex: none; }

  /* The headline sentence — the honest one-liner. */
  .learn-sentence {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--text);
  }
  .learn-sentence .learn-reach-off { color: var(--text-muted); }

  /* Three headline numbers. */
  .learn-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .learn-stat {
    text-align: center;
    padding: var(--space-3) var(--space-2);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-2);
    background: var(--surface-2);
  }
  .learn-stat-num {
    font-family: var(--font-display);
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
  }
  .learn-stat.is-reach .learn-stat-num { color: var(--accent); }
  .learn-stat-label {
    margin-top: 2px;
    font-size: var(--font-size-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Breakdown chips — where the learning landed. */
  .learn-breakdown { display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-4); }
  .learn-break-row { display: flex; align-items: baseline; gap: var(--space-2); flex-wrap: wrap; }
  .learn-break-label {
    flex: none;
    min-width: 6.5rem;
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }
  .learn-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--accent) 12%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--border-subtle));
    color: var(--text);
    font-size: var(--font-size-sm);
  }
  .learn-chip-count { color: var(--text-muted); font-variant-numeric: tabular-nums; }

  /* Per-correction reach rows. */
  .learn-rows-head {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }
  .learn-rows { display: flex; flex-direction: column; gap: var(--space-2); }
  .learn-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-2);
    background: var(--surface-1);
  }
  .learn-row-kind {
    flex: none;
    font-size: var(--font-size-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .learn-row-gist {
    flex: 1 1 12rem;
    min-width: 0;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .learn-row-arrow { color: var(--text-muted); flex: none; }
  .learn-row-value { flex: none; color: var(--accent); font-weight: 600; }
  .learn-reach-chip {
    flex: none;
    margin-left: auto;
    padding: 1px var(--space-2);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--success) 14%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--success) 30%, var(--border-subtle));
    color: var(--text);
    font-size: var(--font-size-xs);
  }

  .learn-empty {
    text-align: center;
    padding: var(--space-5) var(--space-3);
  }
  .learn-empty-glyph { color: var(--accent); opacity: 0.6; margin-bottom: var(--space-2); }
  .learn-empty-head {
    margin: 0 0 var(--space-1);
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    color: var(--text);
  }
  .learn-empty-sub { margin: 0 auto; max-width: 46ch; color: var(--text-muted); }

  @media (max-width: 560px) {
    .learn-stats { grid-template-columns: 1fr; }
  }
</style>
