---
// HS-75-02: the dictation preview card — the app-wide shell surface for
// the opt-in preview-before-type mode (backlog candidate M).
//
// Mounted in AppLayout so an armed preview is visible on EVERY route (the
// desk front door included) — the mode must never swallow a dictation
// silently, and Qlippy's cards are double-gated so they cannot be the
// unconditional home. Markup here; the bus subscription + actions live in
// `web/src/scripts/preview-card.js` (fed by the shared `runtime-bus.js`).
//
// Keyboard-first (the arms-not-types deal): the primary button takes focus
// when the card arrives — Enter types, Escape (while the card has focus)
// discards. One card at a time (the hub enforces one active preview).
//
// CSS is `is:global` on purpose (the standing Astro-scoped-CSS-on-JS-DOM
// gotcha: JS toggles this DOM at runtime).
---

<div class="preview-card" data-preview-card hidden>
  <div class="pc-head">
    <span class="pc-title">Heard you</span>
    <span class="egress-badge egress-local" title="Nothing typed yet.">⌂ Local · not typed yet</span>
  </div>
  <pre class="pc-text" data-pc-text></pre>
  <p class="pc-error" data-pc-error hidden></p>
  <div class="pc-actions">
    <button type="button" class="pc-type" data-pc-type>Type it</button>
    <button type="button" class="pc-discard" data-pc-discard>Discard</button>
  </div>
</div>

<style is:global>
  /* The class's display beats the `hidden` attribute's UA default —
     restate it or the empty card renders on every page. */
  .preview-card[hidden] { display: none; }
  .preview-card {
    position: fixed;
    bottom: 110px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 40;
    width: min(460px, 90vw);
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--accent, #FF6B35) 40%, var(--border));
    background: rgba(14, 12, 20, 0.96);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255, 107, 53, 0.1);
    backdrop-filter: blur(8px);
  }
  .preview-card .pc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .preview-card .pc-title {
    font-weight: 600;
    font-size: var(--font-size-sm);
    color: var(--text);
  }
  .preview-card .pc-text {
    margin: 0;
    padding: 10px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(8, 7, 12, 0.7);
    color: var(--text);
    font-family: inherit;
    font-size: var(--font-size-sm);
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 160px;
    overflow-y: auto;
  }
  .preview-card .pc-error {
    margin: 0;
    color: var(--danger, #F87171);
    font-size: var(--font-size-xs);
  }
  .preview-card .pc-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
  }
  .preview-card .pc-type,
  .preview-card .pc-discard {
    padding: 7px 16px;
    border-radius: 999px;
    font-size: var(--font-size-sm);
    cursor: pointer;
  }
  .preview-card .pc-type {
    border: 1px solid var(--accent, #FF6B35);
    background: color-mix(in srgb, var(--accent, #FF6B35) 24%, transparent);
    color: var(--text);
    font-weight: 600;
  }
  .preview-card .pc-type:focus-visible {
    outline: 2px solid var(--accent, #FF6B35);
    outline-offset: 2px;
  }
  .preview-card .pc-discard {
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
  }
</style>

<script>
  import { mountPreviewCard } from "../scripts/preview-card.js";
  mountPreviewCard();
</script>
