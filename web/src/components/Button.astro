---
// HS-10-03 Button.
//
// Variants: primary | secondary | danger | ghost.
// Sizes: sm | md.
// Loading + disabled both block click via the native `disabled` attr;
// loading additionally sets aria-busy and renders a spinner glyph.
// iconOnly tightens the padding and forces an aria-label.

interface Props {
  variant?: "primary" | "secondary" | "danger" | "ghost";
  size?: "sm" | "md";
  loading?: boolean;
  disabled?: boolean;
  iconOnly?: boolean;
  type?: "button" | "submit" | "reset";
  ariaLabel?: string;
  class?: string;
}

const {
  variant = "primary",
  size = "md",
  loading = false,
  disabled = false,
  iconOnly = false,
  type = "button",
  ariaLabel,
  class: extraClass,
} = Astro.props;

const isInactive = disabled || loading;
const classes = [
  "btn",
  `btn--${variant}`,
  `btn--${size}`,
  iconOnly ? "btn--icon" : null,
  loading ? "is-loading" : null,
  extraClass,
]
  .filter(Boolean)
  .join(" ");
---

<button
  type={type}
  class={classes}
  disabled={isInactive}
  aria-busy={loading ? "true" : undefined}
  aria-label={ariaLabel}
>
  {loading && <span class="btn-spinner" aria-hidden="true"></span>}
  <span class="btn-content"><slot /></span>
</button>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-weight: 500;
    line-height: 1;
    letter-spacing: var(--letter-spacing-loose);
    border: 1px solid transparent;
    border-radius: var(--radius-2);
    cursor: pointer;
    user-select: none;
    transition:
      background var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard),
      color var(--duration-short) var(--ease-standard),
      transform var(--duration-short) var(--ease-standard);
  }

  .btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  /* HS-12-02: disabled buttons keep their *variant* colour but
   * receive a diagonal-hatch overlay — the Workbench "ghosted
   * gadget" idiom done in CSS. The label stays in its own
   * colour so the user can read what's not currently
   * available. The hatch is rendered via a repeating
   * linear-gradient on a pseudo-element so it composites over
   * the button without affecting the text layer. */
  .btn:disabled {
    cursor: not-allowed;
    position: relative;
  }
  .btn:disabled::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 3px,
      rgba(0, 0, 0, 0.22) 3px,
      rgba(0, 0, 0, 0.22) 4px
    );
  }
  .btn[aria-busy="true"] {
    cursor: progress;
    opacity: 0.75;
  }
  .btn[aria-busy="true"]::after {
    content: none;
  }

  .btn:not(:disabled):active {
    transform: translateY(1px);
  }

  /* Sizes */
  .btn--md {
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-md);
  }

  .btn--sm {
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
  }

  .btn--icon {
    padding: var(--space-2);
    aspect-ratio: 1;
  }

  /* Variants */
  .btn--primary {
    background: var(--accent);
    color: var(--accent-on);
    border-color: var(--accent);
  }

  .btn--primary:not(:disabled):hover {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
  }

  .btn--secondary {
    background: var(--canvas-raised);
    color: var(--text);
    border-color: var(--line-strong);
  }

  .btn--secondary:not(:disabled):hover {
    border-color: var(--line-emphasis);
    background: var(--canvas-elevated);
  }

  .btn--danger {
    background: var(--danger);
    color: var(--canvas);
    border-color: var(--danger);
  }

  .btn--danger:not(:disabled):hover {
    background: var(--danger-strong);
    border-color: var(--danger-strong);
  }

  /* HS-12-02: ghost button must read on both surfaces (white
   * panel + blue desktop). `color: inherit` lets it pick up the
   * parent's foreground (black inside panels, white on desktop).
   * Hover reveals a hairline border so the click target reads
   * unambiguously. */
  .btn--ghost {
    background: transparent;
    color: inherit;
    border-color: transparent;
  }

  .btn--ghost:not(:disabled):hover {
    border-color: currentColor;
    background: transparent;
  }

  /* Loading spinner */
  .btn-spinner {
    width: var(--space-3);
    height: var(--space-3);
    border-radius: 50%;
    border: 2px solid currentColor;
    border-right-color: transparent;
    animation: btn-spin var(--duration-long) linear infinite;
  }

  .is-loading .btn-content {
    opacity: 0.6;
  }

  @keyframes btn-spin {
    to { transform: rotate(360deg); }
  }
</style>
