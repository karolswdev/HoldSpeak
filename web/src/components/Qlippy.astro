---
// HS-69-06: Qlippy — the mascot dock + the sliding card shell, as a shared
// component so the SAME presence enhancer rides BOTH the native HUD page
// (/presence) and the main browser cockpit (mounted by AppLayout). The markup,
// styles, and the qlippy.js / qlippy-events.js drivers were lifted verbatim out
// of presence.astro (HS-56-02) — one source, two surfaces.
//
// Double-gated exactly as before: hidden until qlippy.js confirms BOTH
// presence.enabled AND presence.mascot from /api/settings; with either flag off
// this renders nothing. The card slides in for the four moments (decision /
// result / learned / aftercare) via qlippy-events.js on the runtime websocket.
//
// Positioned bottom-right (fixed); the Queue HUD lives top-center, so there is
// no collision in the cockpit.
---

<div id="qlippy" class="q-wrap" hidden>
  <section
    id="qlippy-card"
    class="q-card"
    role="group"
    aria-label="Qlippy has something for you"
    hidden
  >
    <button id="qlippy-dismiss" class="q-x" type="button" aria-label="Dismiss">✕</button>
    <div class="q-card-bay" aria-hidden="true">
      <span id="qlippy-card-sprite" class="q-sprite"></span>
      <span id="qlippy-card-glyph" class="q-glyph" hidden></span>
    </div>
    <div class="q-card-body">
      <p id="qlippy-headline" class="q-headline"></p>
      <p id="qlippy-detail" class="q-detail"></p>
      <pre id="qlippy-preview" class="q-preview" hidden></pre>
      {/* HS-62-01: the egress badge — one glance instead of a privacy
          paragraph: local ⌂, local+cloud ⌂+☁, or cloud ☁ (+ target). */}
      <span id="qlippy-egress" class="q-egress" hidden></span>
      <div id="qlippy-actions" class="q-actions"></div>
    </div>
    <span id="qlippy-queue-hint" class="q-queue-hint" hidden></span>
  </section>
  <div class="q-dock" aria-hidden="true">
    <span id="qlippy-dock-sprite" class="q-sprite"></span>
  </div>
  <span id="qlippy-announcer" class="q-sr-only" aria-live="polite"></span>
</div>

<script src="../scripts/qlippy.js"></script>
<script src="../scripts/qlippy-events.js"></script>

<style is:global>
  /* ===== HS-56-02 / HS-69-06: Qlippy — the dock + the card shell =====
     Authored is:global so the card paints in BOTH the cockpit and the native
     HUD (and qlippy.js drives it by id; some nodes are JS-touched). */
  .q-wrap {
    position: fixed;
    right: var(--space-3);
    bottom: var(--space-3);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
    z-index: 10;
  }
  .q-wrap[hidden] { display: none; }
  .q-sprite {
    display: block;
    width: 80px;
    height: 80px;
    background-repeat: no-repeat;
    background-size: 720px 80px;
    image-rendering: pixelated;
    animation: q-strip 1.2s steps(9) infinite;
  }
  @keyframes q-strip {
    from { background-position: 0 0; }
    to { background-position: -720px 0; }
  }
  /* The dock is a smaller Qlippy — scaled by transform so the 9-frame
     background-position math stays exact. */
  .q-dock .q-sprite { transform: scale(0.7); transform-origin: bottom right; }
  .q-glyph {
    position: absolute;
    top: -6px;
    right: -2px;
    width: 20px;
    height: 20px;
    background-size: contain;
    background-repeat: no-repeat;
    image-rendering: pixelated;
  }

  /* The card: slides in from the right edge ("Signal settle"). */
  .q-card {
    position: relative;
    display: grid;
    grid-template-columns: 88px minmax(0, 1fr);
    gap: var(--space-3);
    align-items: start;
    width: min(340px, calc(100vw - 2 * var(--space-3)));
    padding: var(--space-3) var(--space-4);
    background: var(--surface-1);
    border: 1px solid var(--line);
    border-radius: var(--radius-4);
    box-shadow: var(--elev-3);
    transform: translateX(112%);
    opacity: 0;
    transition:
      transform 420ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .q-card[hidden] { display: none; }
  .q-card.is-in { transform: translateX(0); opacity: 1; }
  .q-card.is-out {
    transform: translateX(112%);
    opacity: 0;
    transition-duration: 280ms;
  }
  .q-card.is-in.is-alert {
    border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
    box-shadow: var(--elev-3), 0 0 18px color-mix(in srgb, var(--accent) 28%, transparent);
    animation: q-settle 480ms cubic-bezier(0.16, 1, 0.3, 1) 420ms 1;
  }
  @keyframes q-settle {
    0%, 100% { transform: translateX(0) translateY(0); }
    40% { transform: translateX(0) translateY(-4px); }
  }
  .q-card-bay { position: relative; width: 80px; }
  .q-headline {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-sm);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text);
  }
  .q-detail {
    margin: var(--space-1) 0 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-normal);
    overflow-wrap: anywhere;
  }
  .q-preview {
    margin: var(--space-2) 0 0;
    max-height: 76px;
    overflow: auto;
    padding: var(--space-2);
    background: var(--canvas, var(--surface-2));
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  .q-egress {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    width: fit-content;
    margin: var(--space-2) 0 0;
    padding: 0.12rem 0.55rem;
    font-size: var(--font-size-xs);
    letter-spacing: 0.02em;
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
  }
  .q-egress.is-local {
    color: var(--ok);
    background: color-mix(in srgb, var(--ok) 10%, transparent);
    border-color: color-mix(in srgb, var(--ok) 30%, transparent);
  }
  .q-egress.is-mixed,
  .q-egress.is-cloud {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .q-x {
    position: absolute;
    top: 6px;
    right: 8px;
    appearance: none;
    border: none;
    background: none;
    color: var(--text-faint);
    font-size: var(--font-size-sm);
    cursor: pointer;
    padding: 2px 4px;
  }
  .q-x:hover { color: var(--text); }
  .q-queue-hint {
    position: absolute;
    bottom: 6px;
    right: 10px;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .q-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
  /* The action buttons are created at runtime by qlippy.js. */
  .q-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  .q-btn {
    appearance: none;
    border-radius: var(--radius-pill);
    padding: 5px var(--space-3);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    font-weight: 600;
    cursor: pointer;
    border: 1px solid var(--line);
    background: var(--surface-2);
    color: var(--text);
  }
  .q-btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-on, var(--text-on-accent));
  }
  .q-btn-danger {
    background: transparent;
    border-color: var(--danger);
    color: var(--danger);
  }
  .q-btn-ghost {
    background: transparent;
    color: var(--text-muted);
  }
  .q-btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  @media (prefers-reduced-motion: reduce) {
    .q-sprite { animation: none; }
    .q-card {
      transform: none;
      transition: opacity 200ms ease;
    }
    .q-card.is-in.is-alert { animation: none; }
    .q-card.is-out { transform: none; }
  }
</style>
