---
// HS-10-10 CommandPreview.
//
// Standardized monospaced read-only block for shell commands and
// command traces (gh enrichment preview, jira enrichment preview,
// dictation dry-run trace). Three tones drive border/edge color:
//
//   neutral — plan / preview-before-run
//   warn    — would-modify-on-run / requires confirmation
//   danger  — last-run-failed / dangerous-preview
//
// Slots:
//   default  — the command text (rendered inside <pre><code>).
//   caption  — optional copy above the block ("This will run if you
//              click Run").
//   meta     — optional pills/timing below the block.
//
// Long arguments wrap on whitespace + character boundaries; the block
// never produces horizontal scroll. Copy-to-clipboard lives inside the
// component as a small button with a transient "copied" pill.

interface Props {
  tone?: "neutral" | "warn" | "danger";
  command: string;
  ariaLabel?: string;
  class?: string;
}

const {
  tone = "neutral",
  command,
  ariaLabel = "Shell command preview",
  class: extraClass,
} = Astro.props;

const wrapperClass = ["cmd", `cmd--${tone}`, extraClass].filter(Boolean).join(" ");
---

<figure class={wrapperClass} aria-label={ariaLabel}>
  {Astro.slots.has("caption") && (
    <figcaption class="cmd-caption">
      <slot name="caption" />
    </figcaption>
  )}

  <div class="cmd-frame">
    <pre class="cmd-pre"><code class="cmd-code">{command}</code></pre>
    <button
      type="button"
      class="cmd-copy"
      data-cmd-copy
      data-command={command}
      aria-label="Copy command to clipboard"
    >
      <span class="cmd-copy-label" data-cmd-copy-label>Copy</span>
    </button>
  </div>

  {Astro.slots.has("meta") && (
    <div class="cmd-meta">
      <slot name="meta" />
    </div>
  )}
</figure>

<script>
  // One global delegator handles every CommandPreview on the page.
  // Idempotent: only attaches once even if multiple components render.
  if (!(window as any).__hsCommandPreviewWired) {
    (window as any).__hsCommandPreviewWired = true;
    document.addEventListener("click", async (event) => {
      const target = (event.target as HTMLElement | null)?.closest(
        "[data-cmd-copy]",
      );
      if (!target) return;
      const button = target as HTMLButtonElement;
      const cmd = button.getAttribute("data-command") ?? "";
      const label = button.querySelector(
        "[data-cmd-copy-label]",
      ) as HTMLElement | null;
      try {
        await navigator.clipboard.writeText(cmd);
        if (label) {
          const original = label.textContent ?? "Copy";
          label.textContent = "Copied";
          button.classList.add("is-copied");
          window.setTimeout(() => {
            label.textContent = original;
            button.classList.remove("is-copied");
          }, 1400);
        }
      } catch {
        if (label) {
          const original = label.textContent ?? "Copy";
          label.textContent = "Press ⌘C";
          window.setTimeout(() => {
            label.textContent = original;
          }, 1400);
        }
      }
    });
  }
</script>

<style>
  .cmd {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cmd-caption {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    line-height: var(--line-height-relaxed);
  }

  /* HS-12-02 (slice 4): cmd frame reads as a Workbench shell-
   * window. Pale grey-7 fill (the same sunken-field tone used
   * for inputs), hard 1px black border, and a 4px left edge
   * coloured by tone. The left edge is the tone signal —
   * nothing else changes per tone, so a stack of cmd previews
   * scans cleanly. */
  .cmd-frame {
    position: relative;
    background: var(--wb-gray-7);
    border: 1px solid var(--wb-black);
    border-left-width: 4px;
    overflow: hidden;
  }

  .cmd--neutral .cmd-frame { border-left-color: var(--wb-blue); }
  .cmd--warn .cmd-frame    { border-left-color: var(--warn); }
  .cmd--danger .cmd-frame  { border-left-color: var(--danger); }

  .cmd-pre {
    margin: 0;
    padding: var(--space-3) calc(var(--space-3) + 4.5rem) var(--space-3) var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--text);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
    overflow-x: hidden;
  }

  .cmd-code {
    font-family: inherit;
    color: inherit;
  }

  /* Copy gadget — small flat Workbench button anchored top-right
   * of the frame. Square corners, hard black border, white fill;
   * hover swaps to the orange accent. */
  .cmd-copy {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    appearance: none;
    background: var(--wb-white);
    border: 1px solid var(--wb-black);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-loose);
    padding: var(--space-1) var(--space-3);
    cursor: pointer;
    transition:
      background var(--duration-short) var(--ease-standard),
      color var(--duration-short) var(--ease-standard);
  }

  .cmd-copy:hover {
    background: var(--accent);
    color: var(--accent-on);
  }

  .cmd-copy.is-copied {
    background: var(--success);
    color: var(--wb-white);
    border-color: var(--success-strong);
  }

  .cmd-copy:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  .cmd-copy.is-copied {
    color: var(--success);
    border-color: var(--success);
    background: var(--success-soft);
  }

  .cmd-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .cmd-copy { transition: none; }
  }
</style>
