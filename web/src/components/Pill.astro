---
// HS-10-03 Pill.
//
// Tones: neutral | info | success | warn | danger | local.
// `local` is the privacy/local-only signal (HS-10-05 will reuse it).
// `dot` adds a tone-tinted leading dot. `interactive=true` swaps the
// rendered tag from <span> to <button> so it can take focus and click.

interface Props {
  tone?: "neutral" | "info" | "success" | "warn" | "danger" | "local";
  dot?: boolean;
  interactive?: boolean;
  ariaLabel?: string;
  class?: string;
}

const {
  tone = "neutral",
  dot = false,
  interactive = false,
  ariaLabel,
  class: extraClass,
} = Astro.props;

const Tag = interactive ? "button" : "span";

const classes = [
  "pill",
  `pill--${tone}`,
  interactive ? "pill--interactive" : null,
  extraClass,
]
  .filter(Boolean)
  .join(" ");
---

<Tag
  class={classes}
  aria-label={ariaLabel}
  type={interactive ? "button" : undefined}
>
  {dot && <span class="pill-dot" aria-hidden="true"></span>}
  <slot />
</Tag>

<style>
  .pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    font-size: var(--font-size-xs);
    font-weight: 500;
    letter-spacing: var(--letter-spacing-loose);
    border: 1px solid transparent;
    line-height: 1.4;
    background: var(--canvas-raised);
    color: var(--text-muted);
    border-color: var(--line);
  }

  .pill-dot {
    width: var(--space-2);
    height: var(--space-2);
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }

  /* HS-12-02 (slice 3): each tone uses its own hue + a hard
   * 1px border in the *deep* variant, so the pill reads as
   * a Workbench-style status tag rather than a soft fill.
   * Distinct hues mean a glance is enough to disambiguate
   * — info ≠ accent, warn ≠ accent, etc. */

  .pill--neutral {
    color: var(--wb-gray-1);
    background: var(--wb-gray-6);
    border-color: var(--wb-gray-3);
  }

  .pill--info {
    /* info is now purple — distinct from the local-only blue
     * and the orange accent. */
    color: var(--info-strong);
    background: var(--info-soft);
    border-color: var(--info);
  }

  .pill--success {
    color: var(--success-strong);
    background: var(--success-soft);
    border-color: var(--success);
  }

  .pill--warn {
    color: var(--warn-strong);
    background: var(--warn-soft);
    border-color: var(--warn);
  }

  .pill--danger {
    color: var(--danger-strong);
    background: var(--danger-soft);
    border-color: var(--danger);
  }

  .pill--local {
    color: var(--wb-blue-deep);
    background: var(--local-soft);
    border-color: var(--wb-blue);
  }

  .pill--interactive {
    cursor: pointer;
    font-family: var(--font-ui);
    transition:
      background var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard);
  }

  .pill--interactive:hover {
    border-color: var(--line-emphasis);
  }

  .pill--interactive:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
</style>
