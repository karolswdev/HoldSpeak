---
// HS-52-05: the Voice Commands board.
//
// The centerpiece surface of Phase 52: a dedicated /commands board where a user
// maps a spoken keyword to a real system action (open a URL, launch an app, run a
// shell command, type a snippet) and it fires when they speak the keyword while
// dictating. "What you see is what fires" — this is the consent surface, so every
// card and the editor read back exactly what runs.
//
// Cards + the editor are rendered at runtime by commands-app.js, so their CSS lives
// in a <style is:global> block (Astro scoped styles only match template DOM).
import AppLayout from "../layouts/AppLayout.astro";
import EmptyState from "../components/EmptyState.astro";
---

<AppLayout title="Voice Commands — HoldSpeak" current="commands">
  <div class="vc">
    <header class="vc-hero">
      <div class="vc-hero-text">
        <h1 class="vc-title">Voice Commands</h1>
        <p class="vc-lede">
          Say a keyword while dictating and HoldSpeak runs the action instead of typing it.
          You set every command, so you decide exactly what runs. Off until you turn it on.
        </p>
      </div>
      <label class="vc-master" data-vc-master-label>
        <span class="vc-master-text">Voice commands</span>
        <span class="vc-switch">
          <input type="checkbox" data-vc-master aria-label="Enable voice commands" />
          <span class="vc-switch-track" aria-hidden="true"></span>
        </span>
        <span class="vc-master-state" data-vc-master-state>Off</span>
      </label>
    </header>

    <div class="vc-flash" data-vc-flash hidden role="status" aria-live="polite"></div>

    <section class="vc-board" data-vc-board aria-busy="true">
      <p class="vc-loading" data-vc-loading>Loading your commands…</p>
    </section>

    <!-- The empty state (shown by JS when there are no commands). -->
    <template data-vc-empty-template>
      <div class="vc-empty">
        <EmptyState
          title="No voice commands yet"
          description="Map a keyword you speak to an action HoldSpeak runs. You set every command, so you decide what runs. They are off until you turn them on."
        >
          <svg slot="icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2a3 3 0 0 0-3 3v6a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z" />
            <path d="M19 10v1a7 7 0 0 1-14 0v-1M12 18v4" />
          </svg>
          <div slot="action" class="vc-empty-starters">
            <button type="button" class="vc-starter" data-vc-starter='{"keyword":"terminal","kind":"launch_app","payload":"Terminal"}'>"terminal" → open Terminal</button>
            <button type="button" class="vc-starter" data-vc-starter='{"keyword":"docs","kind":"open_url","payload":"https://github.com/karolswdev/HoldSpeak"}'>"docs" → open a URL</button>
            <button type="button" class="vc-starter" data-vc-starter='{"keyword":"standup","kind":"type_text","payload":"## Standup\n- Yesterday:\n- Today:\n- Blockers:"}'>"standup" → type a snippet</button>
            <button type="button" class="vc-starter vc-starter--build" data-vc-add>+ Build my own</button>
          </div>
        </EmptyState>
      </div>
    </template>

    <!-- The add/edit editor (a focused modal over a scrim). -->
    <div class="vc-editor-overlay" data-vc-editor hidden>
      <div class="vc-editor-scrim" data-vc-editor-close></div>
      <div class="vc-editor" role="dialog" aria-modal="true" aria-labelledby="vc-editor-title" tabindex="-1">
        <header class="vc-editor-head">
          <h2 id="vc-editor-title" class="vc-editor-title" data-vc-editor-title>New command</h2>
          <button type="button" class="vc-icon-btn" data-vc-editor-close aria-label="Close editor">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
          </button>
        </header>

        <form class="vc-form" data-vc-form>
          <label class="vc-field">
            <span class="vc-label">When I say</span>
            <input type="text" class="vc-input" data-vc-keyword placeholder="terminal" autocomplete="off" />
          </label>
          <p class="vc-hint"><span data-vc-match></span><span class="vc-conflict" data-vc-conflict hidden></span></p>

          <span class="vc-label">Do this</span>
          <div class="vc-kinds" role="radiogroup" aria-label="Action kind">
            <button type="button" class="vc-kind" data-vc-kind="open_url" role="radio" aria-checked="false">Open URL</button>
            <button type="button" class="vc-kind" data-vc-kind="launch_app" role="radio" aria-checked="false">Launch app</button>
            <button type="button" class="vc-kind" data-vc-kind="shell" role="radio" aria-checked="false">Shell</button>
            <button type="button" class="vc-kind" data-vc-kind="type_text" role="radio" aria-checked="false">Type text</button>
          </div>

          <div class="vc-payload" data-vc-payload>
            <!-- swapped by kind -->
            <label class="vc-field" data-vc-pf="open_url" hidden>
              <span class="vc-label">URL</span>
              <input type="url" class="vc-input" data-vc-payload-input="open_url" placeholder="https://example.com" autocomplete="off" />
            </label>
            <label class="vc-field" data-vc-pf="launch_app" hidden>
              <span class="vc-label">App</span>
              <input type="text" class="vc-input" data-vc-payload-input="launch_app" placeholder="Terminal" autocomplete="off" />
            </label>
            <label class="vc-field" data-vc-pf="shell" hidden>
              <span class="vc-label">Command</span>
              <textarea class="vc-input vc-mono" data-vc-payload-input="shell" rows="2" placeholder="git push origin HEAD" autocomplete="off" spellcheck="false"></textarea>
              <span class="vc-danger-note">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><path d="M12 9v4M12 17h.01" /></svg>
                Runs this on your machine when you say the keyword. No confirmation.
              </span>
            </label>
            <label class="vc-field" data-vc-pf="type_text" hidden>
              <span class="vc-label">Text</span>
              <textarea class="vc-input vc-mono" data-vc-payload-input="type_text" rows="3" placeholder="## Standup&#10;- Yesterday:" autocomplete="off"></textarea>
            </label>
          </div>

          <p class="vc-preview-line" data-vc-preview-wrap hidden>
            <span class="vc-preview-label">Preview</span>
            <span class="vc-preview" data-vc-preview></span>
          </p>

          <div class="vc-editor-foot">
            <button type="button" class="vc-btn vc-btn--ghost" data-vc-test>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z" /></svg>
              Test
            </button>
            <span class="vc-test-result" data-vc-test-result></span>
            <span class="vc-editor-spacer"></span>
            <button type="button" class="vc-btn vc-btn--ghost" data-vc-editor-close>Cancel</button>
            <button type="submit" class="vc-btn vc-btn--primary" data-vc-save>Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    import { mountVoiceCommands } from "../scripts/commands-app.js";
    mountVoiceCommands();
  </script>
</AppLayout>

<style>
  /* Static (template) markup — Astro-scoped is fine here. */
  .vc { max-width: 1100px; margin: 0 auto; padding: var(--space-6) var(--space-5) var(--space-8); }

  .vc-hero {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: var(--space-5); flex-wrap: wrap; margin-bottom: var(--space-5);
  }
  .vc-hero-text { max-width: 64ch; }
  .vc-title {
    margin: 0; font-family: var(--font-display); font-size: var(--font-size-3xl);
    font-weight: 700; letter-spacing: -0.01em; color: var(--text);
  }
  .vc-lede { margin: var(--space-2) 0 0; color: var(--text-muted); line-height: var(--line-height-relaxed); }

  /* Master switch */
  .vc-master { display: inline-flex; align-items: center; gap: var(--space-3); cursor: pointer; user-select: none; flex-shrink: 0; }
  .vc-master-text { font-size: var(--font-size-sm); color: var(--text-muted); font-weight: 600; }
  .vc-master-state { font-size: var(--font-size-sm); color: var(--text-faint); min-width: 2.2em; }
  .vc-switch { position: relative; width: 44px; height: 24px; flex-shrink: 0; }
  .vc-switch input { position: absolute; inset: 0; opacity: 0; margin: 0; cursor: pointer; }
  .vc-switch-track {
    position: absolute; inset: 0; border-radius: var(--radius-pill);
    background: var(--surface-3); border: 1px solid var(--border);
    transition: background var(--duration-short) var(--ease-standard);
  }
  .vc-switch-track::after {
    content: ""; position: absolute; top: 2px; left: 2px; width: 18px; height: 18px;
    border-radius: 50%; background: var(--text-muted);
    transition: transform var(--duration-short) var(--ease-standard), background var(--duration-short) var(--ease-standard);
  }
  .vc-switch input:checked + .vc-switch-track { background: var(--accent); border-color: var(--accent); }
  .vc-switch input:checked + .vc-switch-track::after { transform: translateX(20px); background: var(--accent-on); }
  .vc-switch input:focus-visible + .vc-switch-track { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }

  .vc-flash {
    margin-bottom: var(--space-4); padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md); font-size: var(--font-size-sm);
    border: 1px solid var(--border);
  }
  .vc-flash[data-tone="ok"] { color: var(--success-strong); background: var(--success-soft); border-color: var(--success); }
  .vc-flash[data-tone="error"] { color: var(--danger-strong); background: var(--danger-soft); border-color: var(--danger); }

  .vc-loading { color: var(--text-muted); padding: var(--space-6); text-align: center; }
  .vc-empty-starters { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; }
  .vc-starter {
    font-family: var(--font-ui); font-size: var(--font-size-sm);
    padding: var(--space-2) var(--space-3); border-radius: var(--radius-md);
    background: var(--surface-2); color: var(--text); border: 1px solid var(--border);
    cursor: pointer; transition: border-color var(--duration-short) var(--ease-standard);
  }
  .vc-starter:hover { border-color: var(--border-strong); }
  .vc-starter--build { color: var(--accent); border-color: var(--accent-tint); }
  .vc-starter:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }
</style>

<style is:global>
  /* JS-injected card + editor DOM — must be global (no data-astro-cid at runtime). */

  /* Author `display:` rules below override the UA `[hidden]{display:none}`, so
     restore it explicitly for the elements we toggle via the hidden attribute. */
  .vc-editor-overlay[hidden],
  .vc-field[hidden],
  .vc-preview-line[hidden] { display: none !important; }

  .vc-grid {
    display: grid; gap: var(--space-4);
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .vc-card {
    display: flex; flex-direction: column; gap: var(--space-3);
    background: var(--surface-1); border: 1px solid var(--border-subtle);
    border-left: 3px solid var(--border-strong); border-radius: var(--radius-lg);
    box-shadow: var(--elev-1); padding: var(--space-4);
  }
  .vc-card.kind-open_url { border-left-color: var(--info); }
  .vc-card.kind-launch_app { border-left-color: var(--accent); }
  .vc-card.kind-type_text { border-left-color: var(--ok); }
  .vc-card.kind-shell { border-left-color: var(--warn-strong); }

  .vc-card-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-2); }
  .vc-keyword {
    font-family: var(--font-mono); font-weight: 600; font-size: var(--font-size-sm);
    color: var(--text); background: var(--surface-hover);
    padding: var(--space-1) var(--space-3); border-radius: var(--radius-pill);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 60%;
  }
  .vc-badge {
    display: inline-flex; align-items: center; gap: var(--space-1); flex-shrink: 0;
    font-size: var(--font-size-xs); font-weight: 600; letter-spacing: var(--letter-spacing-loose);
    padding: 2px var(--space-2); border-radius: var(--radius-sm);
    border: 1px solid transparent;
  }
  .vc-badge.kind-open_url { color: var(--info-strong); background: var(--info-soft); border-color: var(--info); }
  .vc-badge.kind-launch_app { color: var(--accent); background: var(--accent-tint); border-color: var(--accent); }
  .vc-badge.kind-type_text { color: var(--success-strong); background: var(--success-soft); border-color: var(--success); }
  .vc-badge.kind-shell { color: var(--warn-strong); background: var(--warn-soft); border-color: var(--warn); }
  .vc-runs-code {
    display: inline-flex; align-items: center; gap: 3px; font-size: var(--font-size-xs);
    color: var(--warn-strong); font-weight: 600;
  }

  .vc-preview-text {
    font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--text);
    line-height: var(--line-height-normal); overflow-wrap: anywhere; margin: 0;
  }
  .vc-card.kind-shell .vc-preview-text {
    background: var(--danger-soft); border: 1px solid var(--danger-soft);
    border-radius: var(--radius-sm); padding: var(--space-2);
  }
  .vc-match { font-size: var(--font-size-xs); color: var(--text-faint); margin: 0; }

  .vc-card-foot { display: flex; align-items: center; gap: var(--space-2); margin-top: auto; padding-top: var(--space-2); border-top: 1px solid var(--border-subtle); }
  .vc-card-spacer { flex: 1; }
  .vc-test-chip { font-size: var(--font-size-xs); font-weight: 600; }
  .vc-test-chip.ok { color: var(--success-strong); }
  .vc-test-chip.err { color: var(--danger-strong); }

  .vc-btn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-ui); font-size: var(--font-size-sm); font-weight: 500;
    padding: var(--space-2) var(--space-3); border-radius: var(--radius-md);
    border: 1px solid transparent; cursor: pointer;
    transition: background var(--duration-short) var(--ease-standard), border-color var(--duration-short) var(--ease-standard);
  }
  .vc-btn:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }
  .vc-btn--primary { background: var(--accent); color: var(--accent-on); border-color: var(--accent); box-shadow: var(--glow-accent); }
  .vc-btn--primary:hover { background: var(--accent-hover); }
  .vc-btn--primary:disabled { background: var(--disabled-bg); color: var(--disabled-fg); border-color: var(--disabled-border); box-shadow: none; cursor: not-allowed; }
  .vc-btn--ghost { background: transparent; color: var(--text-muted); border-color: var(--border); }
  .vc-btn--ghost:hover { color: var(--text); border-color: var(--border-strong); }
  .vc-btn--danger { color: var(--danger-strong); border-color: var(--danger-soft); background: transparent; }
  .vc-btn--danger:hover { background: var(--danger-soft); border-color: var(--danger); }

  .vc-icon-btn {
    display: inline-grid; place-items: center; width: 32px; height: 32px;
    color: var(--text-muted); background: transparent; border: 1px solid var(--border);
    border-radius: var(--radius-sm); cursor: pointer;
  }
  .vc-icon-btn:hover { color: var(--text); border-color: var(--border-strong); }
  .vc-icon-btn:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }

  /* the trailing "add command" card */
  .vc-add-card {
    display: grid; place-content: center; gap: var(--space-2); text-align: center;
    min-height: 140px; border: 1px dashed var(--border-strong); border-radius: var(--radius-lg);
    background: transparent; color: var(--text-muted); cursor: pointer;
    font-family: var(--font-ui); font-size: var(--font-size-sm);
    transition: border-color var(--duration-short) var(--ease-standard), color var(--duration-short) var(--ease-standard);
  }
  .vc-add-card:hover { border-color: var(--accent); color: var(--accent); }
  .vc-add-card:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }
  .vc-add-plus { font-size: var(--font-size-2xl); line-height: 1; }

  /* delete inline confirm */
  .vc-confirm { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--font-size-xs); color: var(--text-muted); }

  /* ---- editor ---- */
  .vc-editor-overlay { position: fixed; inset: 0; z-index: var(--z-dialog); display: grid; place-items: center; }
  .vc-editor-scrim { position: absolute; inset: 0; background: var(--canvas-overlay); }
  .vc-editor {
    position: relative; width: min(560px, 94vw); max-height: 92vh; overflow-y: auto;
    background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-lg);
    box-shadow: var(--elev-3); padding: var(--space-5);
  }
  .vc-editor-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-4); }
  .vc-editor-title { margin: 0; font-family: var(--font-display); font-size: var(--font-size-xl); font-weight: 600; color: var(--text); }
  .vc-form { display: flex; flex-direction: column; gap: var(--space-3); }
  .vc-field { display: flex; flex-direction: column; gap: var(--space-2); }
  .vc-label { font-size: var(--font-size-xs); font-weight: 600; text-transform: uppercase; letter-spacing: var(--letter-spacing-eyebrow); color: var(--text-faint); }
  .vc-input {
    font-family: var(--font-ui); font-size: var(--font-size-md); color: var(--text);
    background: var(--field-bg); border: 1px solid var(--field-border); border-radius: var(--radius-md);
    padding: var(--space-3); width: 100%;
  }
  .vc-input:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px var(--accent-tint); }
  .vc-mono { font-family: var(--font-mono); }
  .vc-hint { margin: 0; font-size: var(--font-size-xs); color: var(--text-faint); display: flex; gap: var(--space-3); flex-wrap: wrap; }
  .vc-conflict { color: var(--warn-strong); font-weight: 600; }

  .vc-kinds { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .vc-kind {
    font-family: var(--font-ui); font-size: var(--font-size-sm); color: var(--text-muted);
    padding: var(--space-2) var(--space-3); border-radius: var(--radius-md);
    background: var(--surface-1); border: 1px solid var(--border); cursor: pointer;
  }
  .vc-kind:hover { color: var(--text); border-color: var(--border-strong); }
  .vc-kind[aria-checked="true"] { color: var(--text); background: var(--accent-tint); border-color: var(--accent); font-weight: 600; }
  .vc-kind:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }

  .vc-danger-note { display: flex; align-items: center; gap: var(--space-2); font-size: var(--font-size-xs); color: var(--warn-strong); }

  .vc-preview-line { display: flex; align-items: baseline; gap: var(--space-2); margin: 0; padding: var(--space-2) var(--space-3); background: var(--surface-1); border-radius: var(--radius-md); border: 1px solid var(--border-subtle); }
  .vc-preview-label { font-size: var(--font-size-xs); text-transform: uppercase; letter-spacing: var(--letter-spacing-eyebrow); color: var(--text-faint); }
  .vc-preview { font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--text); overflow-wrap: anywhere; }

  .vc-editor-foot { display: flex; align-items: center; gap: var(--space-2); margin-top: var(--space-3); }
  .vc-editor-spacer { flex: 1; }
  .vc-test-result { font-size: var(--font-size-xs); font-weight: 600; }
  .vc-test-result.ok { color: var(--success-strong); }
  .vc-test-result.err { color: var(--danger-strong); }
</style>
