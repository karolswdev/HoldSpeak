---
// The Web Desk — DeskOS on the unified Primitive Framework.
//
// "Web is king": this is a first-class AUTHORING port, not a viewer. Every
// primitive is type-legible (meeting / artifact / note / KB / agent / chain /
// workflow / coder), grouped by sync class, and reads from the desktop hub
// where the route exists. You can author a Note and an Agent here and they
// POST to the hub (with a clearly-flagged local fallback where the route is
// not built yet). The Coder lane is a live presence stream off
// /api/companion/status with an Answer affordance.
//
// The descriptor table (DESK_META) is the single visual-language source —
// mirrors web/src/lib/primitives.ts so web / iPad / desktop agree. The
// renderer is fully data-driven from it.

import AppLayout from "../layouts/AppLayout.astro";

// Server-rendered descriptor table (type-legible language). Icon = 24×24
// stroke path. Mirrors lib/primitives.ts PRIMITIVES + DESK_GROUPS.
const META = {
  meeting: { label: "Meeting", plural: "Meetings", sync: "content", tone: "info", icon: "M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H8l-5 4z" },
  artifact: { label: "Artifact", plural: "Artifacts", sync: "content", tone: "accent", icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M9 13h6M9 17h6" },
  note: { label: "Note", plural: "Notes", sync: "content", tone: "ok", icon: "M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z" },
  agent: { label: "Agent", plural: "Agents", sync: "capability", tone: "accent", icon: "M12 8V4H8M4 8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2zM9 13h.01M15 13h.01M9 17h6" },
  chain: { label: "Chain", plural: "Chains", sync: "capability", tone: "info", icon: "M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1" },
  workflow: { label: "Workflow", plural: "Workflows", sync: "capability", tone: "info", icon: "M6 3v12M18 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6zM6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM6 15a9 9 0 0 0 9 9" },
  kb: { label: "Knowledge base", plural: "Knowledge bases", sync: "organization", tone: "warn", icon: "M2 7l10-4 10 4-10 4zM2 7v10l10 4 10-4V7M2 12l10 4 10-4" },
  coder: { label: "Coder", plural: "Coder sessions", sync: "presence", tone: "accent", icon: "M16 18l6-6-6-6M8 6l-6 6 6 6" },
};

const GROUPS = [
  { label: "Content", blurb: "Bodies of record — synced through the hub.", kinds: ["meeting", "artifact", "note"] },
  { label: "Capabilities", blurb: "Things that can run.", kinds: ["agent", "chain", "workflow"] },
  { label: "Organization", blurb: "Groupings that ground your agents.", kinds: ["kb"] },
];
---

<AppLayout title="HoldSpeak Desk" description="DeskOS on the unified Primitive Framework — author meetings, artifacts, notes, agents, chains and more on the web." current="desk">
  <div class="desk" x-data="DeskApp()" x-init="init()" x-cloak>
    <header class="desk-head">
      <div class="desk-head-text">
        <p class="eyebrow">DeskOS · Primitive Framework</p>
        <h1>The Desk</h1>
        <p class="lead">
          Every primitive, first-class on the web — authored here, living on
          your desktop hub. Notes and agents read and write live; meetings,
          artifacts, KBs, chains and workflows read live from the hub.
        </p>
      </div>
      <div class="desk-head-actions">
        <div class="desk-stat" aria-live="polite">
          <strong x-text="total()">0</strong>
          <span>primitives</span>
        </div>
        <button type="button" class="btn primary" @click="openCreate('note')">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
          New note
        </button>
        <button type="button" class="btn" @click="openCreate('agent')">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
          New agent
        </button>
        <button type="button" class="btn ghost" @click="refresh()" :disabled="loading">
          <span x-text="loading ? 'Refreshing…' : 'Refresh'">Refresh</span>
        </button>
      </div>
    </header>

    <div class="desk-meta-row">
      <span class="meta-pill" x-text="`Synced ${updatedLabel()}`">not loaded</span>
      <span class="meta-pill error" x-show="error" x-cloak x-text="error"></span>
    </div>

    {/* ── primitive sections, grouped by sync class ── */}
    {GROUPS.map((group) => (
      <section class="group" aria-label={group.label}>
        <div class="group-head">
          <div>
            <h2>{group.label}</h2>
            <p>{group.blurb}</p>
          </div>
        </div>

        {group.kinds.map((kind) => {
          const m = META[kind];
          return (
            <div class={`kind kind--${m.tone}`} data-kind={kind}>
              <div class="kind-head">
                <span class="kind-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={m.icon} /></svg>
                </span>
                <span class="kind-title">{m.plural}</span>
                <span class="kind-count" x-text={`count('${kind}')`}>0</span>
                <span class="kind-sync">{m.sync}</span>
                {/* honest per-lane status: live (no badge) · read-only · hub unreachable */}
                <span class="kind-flag readonly" x-show={`isReadonly('${kind}')`} x-cloak title="Lives on the hub — no web create route yet">read-only</span>
                <span class="kind-flag down" x-show={`isUnreachable('${kind}')`} x-cloak title="Could not reach the desktop hub">hub unreachable</span>
                {(kind === "note" || kind === "agent") && (
                  <button type="button" class="kind-add" @click={`openCreate('${kind}')`} aria-label={`New ${m.label}`}>
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
                  </button>
                )}
              </div>

              <div class="cards">
                {/* meeting card */}
                {kind === "meeting" && (
                  <template x-for={`item in items.meeting`} {...{ ":key": "item.id" }}>
                    <article class="card card--info">
                      <div class="card-type"><span class="dot"></span><span x-text="'meeting'"></span></div>
                      <h3 class="card-title" x-text="item.title">Meeting</h3>
                      <p class="card-sub"><span x-text="relTime(item.startedAt)"></span><span x-show="item.segmentCount" x-cloak> · <span x-text="item.segmentCount"></span> segs</span><span x-show="item.actionItemCount" x-cloak> · <span x-text="item.actionItemCount"></span> actions</span></p>
                      <div class="card-foot">
                        <span class="tag" x-show="item.intelStatus" x-cloak x-text="item.intelStatus"></span>
                        <a class="card-link" :href="`/history?meeting=${item.id}`">Open</a>
                      </div>
                    </article>
                  </template>
                )}

                {/* artifact card */}
                {kind === "artifact" && (
                  <template x-for={`item in items.artifact`} {...{ ":key": "item.id" }}>
                    <article class="card card--accent">
                      <div class="card-type"><span class="dot"></span><span x-text="item.artifactType || 'artifact'"></span></div>
                      <h3 class="card-title" x-text="item.title">Artifact</h3>
                      <p class="card-body" x-text="(item.bodyMarkdown || '').slice(0, 160)"></p>
                      <div class="card-foot">
                        <span class="tag" x-text="item.status"></span>
                        <span class="tag" x-show="item.confidence != null" x-cloak x-text="`conf ${Math.round((item.confidence||0)*100)}%`"></span>
                      </div>
                    </article>
                  </template>
                )}

                {/* note card */}
                {kind === "note" && (
                  <template x-for={`item in items.note`} {...{ ":key": "item.id" }}>
                    <article class="card card--ok">
                      <div class="card-type"><span class="dot"></span><span>note</span></div>
                      <h3 class="card-title" x-text="item.title">Note</h3>
                      <p class="card-body" x-text="(item.bodyMarkdown || '').slice(0, 160)"></p>
                      <div class="card-foot">
                        <template x-for="t in item.tags" {...{ ":key": "t" }}><span class="tag" x-text="t"></span></template>
                        <span class="card-time" x-text="relTime(item.createdAt)"></span>
                      </div>
                    </article>
                  </template>
                )}

                {/* agent card */}
                {kind === "agent" && (
                  <template x-for={`item in items.agent`} {...{ ":key": "item.id" }}>
                    <article class="card card--accent agent-card">
                      <div class="agent-top">
                        <span class="agent-avatar" x-text="item.avatar">🤖</span>
                        <div>
                          <div class="card-type"><span class="dot"></span><span>agent</span></div>
                          <h3 class="card-title" x-text="item.name">Agent</h3>
                        </div>
                      </div>
                      <p class="card-body" x-text="item.role"></p>
                      <div class="card-foot">
                        <template x-for="t in item.tools" {...{ ":key": "t" }}><span class="tag mono" x-text="t"></span></template>
                        <span class="tag" x-show="item.kbId" x-cloak x-text="`kb: ${item.kbId}`"></span>
                      </div>
                    </article>
                  </template>
                )}

                {/* chain card */}
                {kind === "chain" && (
                  <template x-for={`item in items.chain`} {...{ ":key": "item.id" }}>
                    <article class="card card--info">
                      <div class="card-type"><span class="dot"></span><span>chain</span></div>
                      <h3 class="card-title" x-text="item.name">Chain</h3>
                      <p class="card-sub"><span x-text="item.steps.length"></span> step<span x-show="item.steps.length !== 1">s</span></p>
                      <div class="card-foot chain-steps">
                        <template x-for="(s, i) in item.steps" {...{ ":key": "i" }}>
                          <span class="tag mono" x-text="s"></span>
                        </template>
                      </div>
                    </article>
                  </template>
                )}

                {/* workflow card */}
                {kind === "workflow" && (
                  <template x-for={`item in items.workflow`} {...{ ":key": "item.id" }}>
                    <article class="card card--info">
                      <div class="card-type"><span class="dot"></span><span>workflow</span></div>
                      <h3 class="card-title" x-text="item.name">Workflow</h3>
                      <p class="card-body" x-text="item.prompt || (item.graphJson ? 'graph workflow' : '')"></p>
                    </article>
                  </template>
                )}

                {/* kb card */}
                {kind === "kb" && (
                  <template x-for={`item in items.kb`} {...{ ":key": "item.id" }}>
                    <article class="card card--warn">
                      <div class="card-type"><span class="dot"></span><span>kb</span></div>
                      <h3 class="card-title" x-text="item.name">Knowledge base</h3>
                      <p class="card-sub"><span x-text="item.memberIds.length"></span> member<span x-show="item.memberIds.length !== 1">s</span></p>
                    </article>
                  </template>
                )}

                {/* empty state — honest about reachability */}
                <div class="cards-empty" x-show={`count('${kind}') === 0`} x-cloak>
                  <span x-show={`isUnreachable('${kind}')`} x-cloak>Could not reach the desktop hub for {m.plural.toLowerCase()}.</span>
                  <span x-show={`!isUnreachable('${kind}')`} x-cloak>No {m.plural.toLowerCase()} yet.</span>
                  {(kind === "note" || kind === "agent") && (
                    <button type="button" class="card-link" x-show={`!isUnreachable('${kind}')`} x-cloak @click={`openCreate('${kind}')`}>Create the first {m.label.toLowerCase()}</button>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </section>
    ))}

    {/* ── the Coder lane (live presence stream) ── */}
    <section class="group coder-lane" aria-label="Live coder sessions">
      <div class="group-head">
        <div>
          <h2>Live coders</h2>
          <p>Claude / Codex sessions from your hub — answer the coder by voice.</p>
        </div>
        <span class="coder-status" :class="coderReady ? 'ready' : 'idle'" x-text="coderReady ? 'Ready to answer' : 'Idle'">Idle</span>
      </div>

      <div class="coder-cards">
        <template x-for="c in items.coder" {...{ ":key": "c.sessionId" }}>
          <article class="coder-card" :class="{ selected: c.selected, waiting: c.question }">
            <div class="coder-card-head">
              <span class="coder-badge" :class="c.agent" x-text="c.agent === 'codex' ? 'Codex' : 'Claude'">Claude</span>
              <span class="coder-state" :class="coderTone(c)" x-text="c.state">running</span>
              <span class="coder-pin" x-show="c.pinned" x-cloak>pinned</span>
            </div>
            <p class="coder-project" x-text="c.project || c.sessionId"></p>
            <p class="coder-q" x-show="c.question" x-cloak x-text="c.question"></p>
            <p class="coder-q muted" x-show="!c.question" x-cloak>Working — no question pending.</p>
            <div class="coder-events" x-show="c.events && c.events.length" x-cloak>
              <template x-for="(e, i) in c.events.slice(-4)" {...{ ":key": "i" }}>
                <span class="coder-event"><span class="ev-kind" x-text="e.kind"></span> <span x-text="(e.text || '').slice(0, 60)"></span></span>
              </template>
            </div>
            <div class="coder-actions">
              <button type="button" class="btn primary sm" @click="answerCoder(c)" :disabled="c.selected">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3zM19 10v2a7 7 0 0 1-14 0v-2M12 19v4" /></svg>
                <span x-text="c.selected ? 'Selected' : 'Answer by voice'">Answer</span>
              </button>
            </div>
          </article>
        </template>
        <div class="cards-empty" x-show="items.coder.length === 0" x-cloak>
          <span>No live coder sessions. Start Claude or Codex with the companion hooks installed.</span>
        </div>
      </div>
    </section>

    {/* ── create overlay (Note + Agent authoring) ── */}
    <div class="create-overlay" x-show="creating" x-cloak @keydown.escape.window="closeCreate()">
      <div class="create-backdrop" @click="closeCreate()"></div>

      {/* Note form */}
      <aside class="create-panel" x-show="creating === 'note'" role="dialog" aria-modal="true" aria-label="New note">
        <header class="create-head">
          <div>
            <span class="create-eyebrow">Content · syncs to hub</span>
            <h2>New note</h2>
          </div>
          <button type="button" class="create-close" @click="closeCreate()" aria-label="Close">✕</button>
        </header>
        <form class="create-body" @submit.prevent="submitNote()">
          <label class="field">
            <span>Title</span>
            <input type="text" x-model="noteForm.title" placeholder="Standup decisions" />
          </label>
          <label class="field">
            <span>Body (markdown)</span>
            <textarea rows="7" x-model="noteForm.body" placeholder="- Decided to ship the Desk on web…"></textarea>
          </label>
          <label class="field">
            <span>Tags (comma-separated)</span>
            <input type="text" x-model="noteForm.tags" placeholder="desk, web" />
          </label>
          <p class="field-note">Saves live to <code>/api/notes</code> on your desktop hub.</p>
          <div class="create-foot">
            <button type="button" class="btn ghost" @click="closeCreate()">Cancel</button>
            <button type="submit" class="btn primary" :disabled="busy"><span x-text="busy ? 'Saving…' : 'Create note'">Create note</span></button>
          </div>
        </form>
      </aside>

      {/* Agent form */}
      <aside class="create-panel wide" x-show="creating === 'agent'" role="dialog" aria-modal="true" aria-label="New agent">
        <header class="create-head">
          <div>
            <span class="create-eyebrow">Capability · syncs to hub</span>
            <h2>New agent</h2>
          </div>
          <button type="button" class="create-close" @click="closeCreate()" aria-label="Close">✕</button>
        </header>
        <form class="create-body" @submit.prevent="submitAgent()">
          <div class="field-row">
            <label class="field avatar-field">
              <span>Avatar</span>
              <input type="text" x-model="agentForm.avatar" maxlength="2" />
            </label>
            <label class="field grow">
              <span>Name</span>
              <input type="text" x-model="agentForm.name" placeholder="Standup Synthesizer" />
            </label>
          </div>
          <label class="field">
            <span>Role</span>
            <input type="text" x-model="agentForm.role" placeholder="Turns a standup into decisions + actions." />
          </label>
          <label class="field">
            <span>System prompt</span>
            <textarea rows="4" x-model="agentForm.systemPrompt" placeholder="You are a precise meeting analyst…"></textarea>
          </label>
          <label class="field">
            <span>User template</span>
            <textarea rows="3" x-model="agentForm.userTemplate" placeholder="Summarize:\n{{transcript}}"></textarea>
          </label>
          <div class="field-row">
            <label class="field grow">
              <span>Tools (comma-separated)</span>
              <input type="text" x-model="agentForm.tools" placeholder="summarize, extract_actions" />
            </label>
            <label class="field grow">
              <span>KB id (optional)</span>
              <input type="text" x-model="agentForm.kbId" placeholder="mock-kb-1" />
            </label>
          </div>
          <p class="field-note">Saves live to <code>/api/agents</code> on your desktop hub. The persona is runnable via <code>{"/api/agents/{id}/run"}</code>.</p>
          <div class="create-foot">
            <button type="button" class="btn ghost" @click="closeCreate()">Cancel</button>
            <button type="submit" class="btn primary" :disabled="busy"><span x-text="busy ? 'Saving…' : 'Create agent'">Create agent</span></button>
          </div>
        </form>
      </aside>
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import factorySource from "../scripts/desk-app.js?raw";

    const fn = new Function(factorySource + "; return DeskApp;");
    window.DeskApp = fn();
    window.Alpine = Alpine;
    Alpine.start();
  </script>
</AppLayout>

<style>
  [x-cloak] { display: none !important; }

  .desk {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-5);
    color: var(--text);
    max-width: 1320px;
    margin: 0 auto;
  }

  /* ── header ── */
  .desk-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .desk-head-text { max-width: 46rem; }
  .eyebrow {
    margin: 0 0 var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow);
    color: var(--accent);
  }
  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-3xl);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-tight);
  }
  .lead {
    margin: var(--space-3) 0 0;
    color: var(--text-muted);
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
  }
  .desk-head-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .desk-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding-right: var(--space-3);
    margin-right: var(--space-1);
    border-right: 1px solid var(--border-subtle);
  }
  .desk-stat strong {
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    line-height: 1;
  }
  .desk-stat span {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow);
    color: var(--text-faint);
  }

  /* ── buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    min-height: 2.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface-1);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    font-weight: 500;
    cursor: pointer;
    transition: border-color var(--duration-short) var(--ease-standard), background var(--duration-short) var(--ease-standard), transform var(--duration-short) var(--ease-standard);
  }
  .btn:hover { border-color: var(--border-strong); background: var(--surface-2); }
  .btn:active { transform: translateY(1px); }
  .btn:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }
  .btn:disabled { opacity: 0.55; cursor: default; }
  .btn.primary {
    background: var(--accent);
    border-color: transparent;
    color: var(--text-on-accent);
    font-weight: 600;
    box-shadow: var(--glow-accent);
  }
  .btn.primary:hover { background: var(--accent-hover); }
  .btn.ghost { background: transparent; }
  .btn.sm { min-height: 1.9rem; padding: var(--space-1) var(--space-3); }

  /* ── meta row ── */
  .desk-meta-row { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; margin-top: calc(-1 * var(--space-3)); }
  .meta-pill {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-faint);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-pill);
  }
  .meta-pill.error { color: var(--danger); border-color: var(--danger-soft); background: var(--danger-soft); }

  /* ── group ── */
  .group { display: flex; flex-direction: column; gap: var(--space-4); }
  .group-head { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--space-4); }
  .group-head h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: 600;
  }
  .group-head p { margin: var(--space-1) 0 0; color: var(--text-faint); font-size: var(--font-size-sm); }

  /* ── per-kind lane ── */
  .kind {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: var(--surface-1);
    padding: var(--space-4);
