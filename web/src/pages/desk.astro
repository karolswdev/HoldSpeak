---
// The Web Desk — DeskOS on the unified Primitive Framework.
//
// "Web is king": a first-class AUTHORING port, not a viewer. Every primitive
// is type-legible (meeting / artifact / note / KB / agent / chain / workflow /
// coder), grouped by sync class, reading live from the desktop hub. You can
// AUTHOR notes, agents, KBs, chains and workflows here (POST to the hub), and
// RUN an agent persona against a prompt. The Coder lane is a live presence feed
// off /api/companion/status.
//
// The descriptor table (META) is the single visual-language source — mirrors
// web/src/lib/primitives.ts (icon + tone per kind) so web / iPad / desktop
// agree. The renderer is fully data-driven from it.

import AppLayout from "../layouts/AppLayout.astro";

// Server-rendered descriptor table (type-legible language). Icon = 24×24
// stroke path. `tone` keys the per-kind colour identity. Mirrors
// lib/primitives.ts PRIMITIVES + DESK_GROUPS.
//   author: this kind can be authored on the web (drawer + POST route).
const META = {
  meeting:  { label: "Meeting",        plural: "Meetings",        sync: "content",      tone: "info",     author: false, icon: "M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H8l-5 4z" },
  artifact: { label: "Artifact",       plural: "Artifacts",       sync: "content",      tone: "accent",   author: false, icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M9 13h6M9 17h6" },
  note:     { label: "Note",           plural: "Notes",           sync: "content",      tone: "ok",       author: true,  icon: "M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z" },
  agent:    { label: "Agent",          plural: "Agents",          sync: "capability",   tone: "accent",   author: true,  icon: "M12 8V4H8M4 8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2zM9 13h.01M15 13h.01M9 17h6" },
  chain:    { label: "Chain",          plural: "Chains",          sync: "capability",   tone: "violet",   author: true,  icon: "M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1" },
  workflow: { label: "Workflow",       plural: "Workflows",       sync: "capability",   tone: "info",     author: true,  icon: "M6 3v12M18 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6zM6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM6 15a9 9 0 0 0 9 9" },
  directory:{ label: "Directory",      plural: "Directories",     sync: "organization", tone: "folder",   author: true,  icon: "M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM3 11h18" },
  kb:       { label: "Knowledge base", plural: "Knowledge bases", sync: "organization", tone: "warn",     author: true,  icon: "M2 7l10-4 10 4-10 4zM2 7v10l10 4 10-4V7M2 12l10 4 10-4" },
  coder:    { label: "Coder",          plural: "Coder sessions",  sync: "presence",     tone: "accent",   author: false, icon: "M16 18l6-6-6-6M8 6l-6 6 6 6" },
};

const GROUPS = [
  { label: "Content",      blurb: "Bodies of record — meetings, artifacts, notes.", kinds: ["meeting", "artifact", "note"] },
  { label: "Capabilities", blurb: "Personas, crews and workflows that can run.",     kinds: ["agent", "chain", "workflow"] },
  { label: "Organization", blurb: "Containers that hold and ground your primitives.", kinds: ["directory", "kb"] },
];
---

<AppLayout title="HoldSpeak Desk" description="DeskOS on the unified Primitive Framework — author meetings, artifacts, notes, agents, chains, workflows and KBs on the web." current="desk">
  <div class="desk" x-data="DeskApp()" x-init="init()" x-cloak>
    <header class="desk-head">
      <div class="desk-head-text">
        <p class="eyebrow">DeskOS · Primitive Framework</p>
        <h1>The Desk</h1>
        <p class="lead">
          Every primitive, first-class on the web — authored here, living on
          your desktop hub. Write notes, build agents, KBs, chains and
          workflows, then run a persona on demand.
        </p>
      </div>
      <div class="desk-head-actions">
        <div class="desk-stat" aria-live="polite">
          <strong x-text="total()">0</strong>
          <span>primitives</span>
        </div>
        <button type="button" class="btn primary" @click="openCreate('note')">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
          New note
        </button>
        <button type="button" class="btn" @click="openCreate('agent')">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
          New agent
        </button>
        <button type="button" class="btn ghost icon-btn" @click="refresh()" :disabled="loading" :aria-busy="loading" aria-label="Refresh from hub" title="Refresh from hub">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" :class="loading ? 'spin' : ''"><path d="M21 12a9 9 0 1 1-3-6.7M21 3v5h-5" /></svg>
        </button>
      </div>
    </header>

    {/* ── hub connection + sync indicator ── */}
    <div class="hub-bar" aria-live="polite">
      <span class="hub-status" :class="hubState()">
        <span class="hub-dot"></span>
        <span x-text="hubLabel()">Connecting…</span>
      </span>
      <span class="hub-synced">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7M21 3v5h-5" /></svg>
        <span x-text="`Synced ${updatedLabel()}`">not synced</span>
      </span>
      {/* ── ambient trust: the canonical egress badge + a readiness line,
            both sourced from GET /api/setup/status (no reassurance prose;
            POSITIONING canon — ONE structured badge, never a sentence). ── */}
      <a class="hub-egress egress-badge" :class="`is-${egressBadge().scope}`"
         x-show="setupLoaded" x-cloak href="/setup"
         :title="egressBadge().title" :aria-label="egressBadge().title"
         x-text="egressBadge().text">Local</a>
      <a class="hub-ready" :class="readyTone()" x-show="setupLoaded" x-cloak
         href="/setup" :title="readyTitle()">
        <span class="hub-ready-dot"></span>
        <span x-text="readyLine()">Ready</span>
      </a>
      <span class="hub-error" x-show="error" x-cloak x-text="error"></span>
    </div>

    {/* ── primitive sections, grouped by sync class ── */}
    {GROUPS.map((group) => (
      <section class="group" aria-label={group.label}>
        <div class="group-head">
          <div class="group-head-text">
            <h2>{group.label}</h2>
            <p>{group.blurb}</p>
          </div>
        </div>

        <div class="group-lanes">
        {group.kinds.map((kind) => {
          const m = META[kind];
          return (
            <div class={`kind kind--${m.tone}`} data-kind={kind}>
              <div class="kind-head">
                <span class="kind-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={m.icon} /></svg>
                </span>
                <span class="kind-title">{m.plural}</span>
                <span class="kind-count" x-text={`count('${kind}')`}>0</span>
                <span class="kind-sync" title={`sync class: ${m.sync}`}>{m.sync}</span>
                {/* honest per-lane status: live (no badge) · read-only (content-derived) · hub unreachable */}
                {!m.author && (
                  <span class="kind-flag readonly" title="Synthesized on the hub — read-only on the web">read-only</span>
                )}
                <span class="kind-flag down" x-show={`isUnreachable('${kind}')`} x-cloak title="Could not reach the desktop hub">unreachable</span>
                {m.author && (
                  <button type="button" class="kind-add" @click={`openCreate('${kind}')`} aria-label={`New ${m.label}`} title={`New ${m.label}`}>
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
                  </button>
                )}
              </div>

              <div class="cards">
                {/* meeting card */}
                {kind === "meeting" && (
                  <template x-for={`item in items.meeting`} {...{ ":key": "item.id" }}>
                    <article class="card card--info">
                      <div class="card-type"><span class="dot"></span><span>meeting</span></div>
                      <h3 class="card-title" x-text="item.title">Meeting</h3>
                      <p class="card-sub"><span x-text="relTime(item.startedAt)"></span><span x-show="item.segmentCount" x-cloak> · <span x-text="item.segmentCount"></span> segs</span><span x-show="item.actionItemCount" x-cloak> · <span x-text="item.actionItemCount"></span> actions</span></p>
                      <div class="card-foot">
                        <span class="tag" x-show="item.intelStatus" x-cloak x-text="item.intelStatus"></span>
                        <a class="card-link" :href="`/history?meeting=${item.id}`">Open</a>
                      </div>
                      <div class="filed-row">
                        <template x-for="d in directoriesFor(item.id)" {...{ ":key": "d.id" }}>
                          <span class="filed-chip"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg><span x-text="d.name"></span></span>
                        </template>
                        <button type="button" class="file-btn" @click="openFile('meeting', item)" title="File into a directory"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>Move to…</button>
                      </div>
                    </article>
                  </template>
                )}

                {/* artifact card */}
                {kind === "artifact" && (
                  <template x-for={`item in items.artifact`} {...{ ":key": "item.id" }}>
                    <article class="card card--accent">
                      <div class="card-type"><span class="dot"></span><span x-text="item.artifactType || 'artifact'"></span></div>
                      <h3 class="card-title" x-text="item.title">Artifact</h3>
                      <p class="card-body" x-text="(item.bodyMarkdown || '').slice(0, 160)"></p>
                      {/* lineage — where this artifact came from + what produced it */}
                      <p class="lineage" x-show="hasLineage(item.sources)" x-cloak title="Provenance">
                        <svg class="lineage-glyph" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3v12M18 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6zM6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM6 15a9 9 0 0 0 9 9" /></svg>
                        <template x-for="(src, i) in lineage(item.sources).from" {...{ ":key": "i" }}>
                          <span class="lineage-part"><span x-show="i > 0" x-cloak class="lineage-sep">·</span><span class="lineage-from">from</span> <span class="lineage-ref" :class="{ unresolved: !src.resolved }" x-text="src.label"></span></span>
                        </template>
                        <span class="lineage-part" x-show="lineage(item.sources).via" x-cloak><span class="lineage-sep">·</span><span class="lineage-via">via</span> <span class="lineage-ref" :class="{ unresolved: !lineage(item.sources).via.resolved }" x-text="lineage(item.sources).via && lineage(item.sources).via.label"></span></span>
                      </p>
                      <div class="card-foot">
                        <span class="tag" x-text="item.status"></span>
                        <span class="tag" x-show="item.confidence != null" x-cloak x-text="`conf ${Math.round((item.confidence||0)*100)}%`"></span>
                      </div>
                      <div class="filed-row">
                        <template x-for="d in directoriesFor(item.id)" {...{ ":key": "d.id" }}>
                          <span class="filed-chip"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg><span x-text="d.name"></span></span>
                        </template>
                        <button type="button" class="file-btn" @click="openFile('artifact', item)" title="File into a directory"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>Move to…</button>
                      </div>
                    </article>
                  </template>
                )}

                {/* note card */}
                {kind === "note" && (
                  <template x-for={`item in items.note`} {...{ ":key": "item.id" }}>
                    <article class="card card--ok">
                      <div class="card-type"><span class="dot"></span><span>note</span></div>
                      <h3 class="card-title" x-text="item.title">Note</h3>
                      <p class="card-body" x-text="(item.bodyMarkdown || '').slice(0, 160)"></p>
                      <div class="card-foot">
                        <template x-for="t in item.tags" {...{ ":key": "t" }}><span class="tag" x-text="t"></span></template>
                        <span class="card-time" x-text="relTime(item.createdAt)"></span>
                      </div>
                      <div class="filed-row">
                        <template x-for="d in directoriesFor(item.id)" {...{ ":key": "d.id" }}>
                          <span class="filed-chip"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg><span x-text="d.name"></span></span>
                        </template>
                        <button type="button" class="file-btn" @click="openFile('note', item)" title="File into a directory"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>Move to…</button>
                      </div>
                    </article>
                  </template>
                )}

                {/* agent card — with a live Run affordance */}
                {kind === "agent" && (
                  <template x-for={`item in items.agent`} {...{ ":key": "item.id" }}>
                    <article class="card card--accent agent-card">
                      <div class="agent-top">
                        <span class="agent-avatar" x-text="item.avatar">🤖</span>
                        <div class="agent-id">
                          <div class="card-type"><span class="dot"></span><span>agent</span></div>
                          <h3 class="card-title" x-text="item.name">Agent</h3>
                        </div>
                      </div>
                      <p class="card-body" x-text="item.role"></p>
                      <div class="card-foot">
                        <template x-for="t in item.tools" {...{ ":key": "t" }}><span class="tag mono" x-text="t"></span></template>
                        <span class="tag warn-tag" x-show="item.kbId" x-cloak x-text="`kb · ${item.kbId}`"></span>
                      </div>
                      <div class="filed-row">
                        <template x-for="d in directoriesFor(item.id)" {...{ ":key": "d.id" }}>
                          <span class="filed-chip"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg><span x-text="d.name"></span></span>
                        </template>
                        <button type="button" class="file-btn" @click="openFile('agent', item)" title="File into a directory"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>Move to…</button>
                      </div>
                      <div class="card-actions">
                        <button type="button" class="btn primary sm run-btn" @click="openRun(item, 'agent')">
                          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l14 9-14 9z" /></svg>
                          Run
                        </button>
                      </div>
                    </article>
                  </template>
                )}

                {/* chain card */}
                {kind === "chain" && (
                  <template x-for={`item in items.chain`} {...{ ":key": "item.id" }}>
                    <article class="card card--violet">
                      <div class="card-type"><span class="dot"></span><span>chain</span></div>
                      <h3 class="card-title" x-text="item.name">Chain</h3>
                      <p class="card-sub"><span x-text="item.steps.length"></span> step<span x-show="item.steps.length !== 1">s</span></p>
                      <ol class="chain-flow" x-show="item.steps.length" x-cloak>
                        <template x-for="(s, i) in item.steps" {...{ ":key": "i" }}>
                          <li class="chain-node"><span class="chain-num" x-text="i + 1"></span><span class="chain-name" x-text="agentName(s)"></span></li>
                        </template>
                      </ol>
                      <div class="filed-row">
                        <template x-for="d in directoriesFor(item.id)" {...{ ":key": "d.id" }}>
                          <span class="filed-chip"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg><span x-text="d.name"></span></span>
                        </template>
                        <button type="button" class="file-btn" @click="openFile('chain', item)" title="File into a directory"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>Move to…</button>
                      </div>
                      <div class="card-actions">
                        <button type="button" class="btn primary sm run-btn" @click="openRun(item, 'chain')" :disabled="!item.steps.length" :title="item.steps.length ? 'Run the crew' : 'Add steps to run this chain'">
                          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l14 9-14 9z" /></svg>
                          Run crew
                        </button>
                      </div>
                    </article>
                  </template>
                )}

                {/* workflow card */}
                {kind === "workflow" && (
                  <template x-for={`item in items.workflow`} {...{ ":key": "item.id" }}>
                    <article class="card card--info">
                      <div class="card-type"><span class="dot"></span><span>workflow</span></div>
                      <h3 class="card-title" x-text="item.name">Workflow</h3>
                      <p class="card-body" x-show="item.prompt" x-cloak x-text="item.prompt"></p>
                      <div class="card-foot">
                        <span class="tag mono" x-show="item.hasGraph" x-cloak>graph</span>
                        <span class="tag" x-show="!item.hasGraph && item.prompt" x-cloak>prompt</span>
                      </div>
                      <div class="filed-row">
                        <template x-for="d in directoriesFor(item.id)" {...{ ":key": "d.id" }}>
                          <span class="filed-chip"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg><span x-text="d.name"></span></span>
                        </template>
                        <button type="button" class="file-btn" @click="openFile('workflow', item)" title="File into a directory"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>Move to…</button>
                      </div>
                      <div class="card-actions">
                        <button type="button" class="btn primary sm run-btn" @click="openRun(item, 'workflow')" title="Run the workflow">
                          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l14 9-14 9z" /></svg>
                          Run
                        </button>
                      </div>
                    </article>
                  </template>
                )}

                {/* directory card — a folder that holds filed primitives */}
                {kind === "directory" && (
                  <template x-for={`item in items.directory`} {...{ ":key": "item.id" }}>
                    <article class="card card--folder dir-card">
                      <div class="dir-top">
                        <span class="dir-folder-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>
                        </span>
                        <div class="dir-id">
                          <div class="card-type"><span class="dot"></span><span>directory</span></div>
                          <h3 class="card-title" x-text="item.name">Directory</h3>
                        </div>
                        <span class="dir-count" x-text="`${item.memberIds.length}`">0</span>
                      </div>
                      <p class="card-sub" x-show="item.parentId" x-cloak>in <span class="mono-inline" x-text="item.parentId"></span></p>

                      {/* what's filed in this directory */}
                      <ul class="dir-members" x-show="item.memberIds.length" x-cloak>
                        <template x-for="mid in item.memberIds.slice(0, 8)" {...{ ":key": "mid" }}>
                          <li class="dir-member">
                            <span class="dir-member-kind" x-text="memberOf(mid).kind"></span>
                            <span class="dir-member-label" x-text="memberOf(mid).label"></span>
                          </li>
                        </template>
                        <li class="dir-more" x-show="item.memberIds.length > 8" x-cloak x-text="`+${item.memberIds.length - 8} more`"></li>
                      </ul>
                      <p class="dir-empty" x-show="!item.memberIds.length" x-cloak>Empty — file a primitive here with “Move to…”.</p>
                    </article>
                  </template>
                )}

                {/* kb card */}
                {kind === "kb" && (
                  <template x-for={`item in items.kb`} {...{ ":key": "item.id" }}>
                    <article class="card card--warn">
                      <div class="card-type"><span class="dot"></span><span>kb</span></div>
                      <h3 class="card-title" x-text="item.name">Knowledge base</h3>
                      <p class="card-sub"><span x-text="item.memberIds.length"></span> member<span x-show="item.memberIds.length !== 1">s</span></p>
                      <div class="card-foot" x-show="item.memberIds.length" x-cloak>
                        <template x-for="(mid, i) in item.memberIds.slice(0, 6)" {...{ ":key": "i" }}><span class="tag mono" x-text="mid"></span></template>
                      </div>
                      <div class="filed-row">
                        <template x-for="d in directoriesFor(item.id)" {...{ ":key": "d.id" }}>
                          <span class="filed-chip"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg><span x-text="d.name"></span></span>
                        </template>
                        <button type="button" class="file-btn" @click="openFile('kb', item)" title="File into a directory"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>Move to…</button>
                      </div>
                    </article>
                  </template>
                )}

                {/* empty / unreachable state — honest about reachability */}
                <div class="cards-empty" x-show={`count('${kind}') === 0`} x-cloak>
                  <template x-if={`isUnreachable('${kind}')`}>
                    <div class="empty-inner unreachable">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 1l22 22M16.72 11.06A10.94 10.94 0 0 1 19 12.55M5 12.55a10.94 10.94 0 0 1 5.17-2.39M10.71 5.05A16 16 0 0 1 22.58 9M1.42 9a15.91 15.91 0 0 1 4.7-2.88M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01" /></svg>
                      <span>Could not reach the desktop hub for {m.plural.toLowerCase()}.</span>
                    </div>
                  </template>
                  <template x-if={`!isUnreachable('${kind}')`}>
                    <div class="empty-inner">
                      <span>No {m.plural.toLowerCase()} yet.</span>
                      {m.author && (
                        <button type="button" class="card-link" @click={`openCreate('${kind}')`}>Create the first {m.label.toLowerCase()}</button>
                      )}
                    </div>
                  </template>
                </div>
              </div>
            </div>
          );
        })}
        </div>
      </section>
    ))}

    {/* ── the Coder lane (live presence stream) ── */}
    <section class="group coder-lane" aria-label="Live coder sessions">
      <div class="group-head">
        <div class="group-head-text">
          <h2>Live coders</h2>
          <p>Claude / Codex sessions from your hub — answer the coder by voice.</p>
        </div>
        <span class="coder-status" :class="coderReady ? 'ready' : 'idle'">
          <span class="coder-status-dot"></span>
          <span x-text="coderReady ? 'Ready to answer' : 'Idle'">Idle</span>
        </span>
      </div>

      <div class="coder-cards">
        <template x-for="c in items.coder" {...{ ":key": "c.sessionId" }}>
          <article class="coder-card" :class="{ selected: c.selected, waiting: c.question }">
            <div class="coder-card-head">
              <span class="coder-badge" :class="c.agent" x-text="c.agent === 'codex' ? 'Codex' : 'Claude'">Claude</span>
              <span class="coder-state" :class="coderTone(c)" x-text="c.state">running</span>
              <span class="coder-pin" x-show="c.pinned" x-cloak title="Pinned">📌</span>
            </div>
            <p class="coder-project" x-text="c.project || c.sessionId"></p>
            <p class="coder-meta" x-show="c.model || c.tokensUsed" x-cloak>
              <span x-show="c.model" x-cloak x-text="c.model"></span>
              <span x-show="c.model && c.tokensUsed" x-cloak> · </span>
              <span x-show="c.tokensUsed" x-cloak x-text="`${c.tokensUsed} tok`"></span>
            </p>
            <div class="coder-q-wrap" :class="{ asking: c.question }">
              <p class="coder-q" x-show="c.question" x-cloak x-text="c.question"></p>
              <p class="coder-q muted" x-show="!c.question" x-cloak>Working — no question pending.</p>
            </div>
            <div class="coder-events" x-show="c.events && c.events.length" x-cloak>
              <template x-for="(e, i) in c.events.slice(-4)" {...{ ":key": "i" }}>
                <span class="coder-event"><span class="ev-kind" :class="e.kind" x-text="e.kind"></span> <span class="ev-text" x-text="(e.text || '').slice(0, 64)"></span></span>
              </template>
            </div>
            <div class="coder-actions">
              <button type="button" class="btn primary sm" @click="answerCoder(c)" :disabled="c.selected">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3zM19 10v2a7 7 0 0 1-14 0v-2M12 19v4" /></svg>
                <span x-text="c.selected ? 'Selected' : 'Answer by voice'">Answer</span>
              </button>
            </div>
          </article>
        </template>
        <div class="cards-empty" x-show="items.coder.length === 0" x-cloak>
          <div class="empty-inner">
            <span>No live coder sessions. Start Claude or Codex with the companion hooks installed.</span>
          </div>
        </div>
      </div>
    </section>

    {/* ── create overlay (authoring drawers) ── */}
    <div class="drawer-overlay" x-show="creating" x-cloak @keydown.escape.window="closeCreate()">
      <div class="drawer-backdrop" @click="closeCreate()"></div>

      {/* Note form */}
      <aside class="drawer" x-show="creating === 'note'" role="dialog" aria-modal="true" aria-label="New note">
        <header class="drawer-head">
          <div>
            <span class="drawer-eyebrow ok">Content · syncs to hub</span>
            <h2>New note</h2>
          </div>
          <button type="button" class="drawer-close" @click="closeCreate()" aria-label="Close">✕</button>
        </header>
        <form class="drawer-body" @submit.prevent="submitNote()">
          <p class="drawer-err" x-show="error" x-cloak x-text="error"></p>
          <label class="field"><span>Title</span><input type="text" x-model="noteForm.title" placeholder="Standup decisions" /></label>
          <label class="field"><span>Body (markdown)</span><textarea rows="8" x-model="noteForm.body" placeholder="- Decided to ship the Desk on web…"></textarea></label>
          <label class="field"><span>Tags (comma-separated)</span><input type="text" x-model="noteForm.tags" placeholder="desk, web" /></label>
          <p class="field-note">Saves to <code>POST /api/notes</code> on your desktop hub.</p>
          <div class="drawer-foot">
            <button type="button" class="btn ghost" @click="closeCreate()">Cancel</button>
            <button type="submit" class="btn primary" :disabled="busy"><span x-text="busy ? 'Saving…' : 'Create note'">Create note</span></button>
          </div>
        </form>
      </aside>

      {/* Agent form */}
      <aside class="drawer wide" x-show="creating === 'agent'" role="dialog" aria-modal="true" aria-label="New agent">
        <header class="drawer-head">
          <div>
            <span class="drawer-eyebrow accent">Capability · syncs to hub</span>
            <h2>New agent</h2>
          </div>
          <button type="button" class="drawer-close" @click="closeCreate()" aria-label="Close">✕</button>
        </header>
        <form class="drawer-body" @submit.prevent="submitAgent()">
          <p class="drawer-err" x-show="error" x-cloak x-text="error"></p>
          <div class="field-row">
            <label class="field avatar-field"><span>Avatar</span><input type="text" x-model="agentForm.avatar" maxlength="2" /></label>
            <label class="field grow"><span>Name</span><input type="text" x-model="agentForm.name" placeholder="Standup Synthesizer" /></label>
          </div>
          <label class="field"><span>Role</span><input type="text" x-model="agentForm.role" placeholder="Turns a standup into decisions + actions." /></label>
          <label class="field"><span>System prompt</span><textarea rows="4" x-model="agentForm.systemPrompt" placeholder="You are a precise meeting analyst…"></textarea></label>
          <label class="field"><span>User template</span><textarea rows="3" x-model="agentForm.userTemplate" placeholder="Summarize:\n{{transcript}}"></textarea></label>
          <div class="field-row">
            <label class="field grow"><span>Tools (comma-separated)</span><input type="text" x-model="agentForm.tools" placeholder="summarize, extract_actions" /></label>
            <label class="field grow"><span>KB id (optional)</span><input type="text" x-model="agentForm.kbId" placeholder="kb-…" /></label>
          </div>
          <p class="field-note">Saves to <code>POST /api/agents</code>. Runnable via <code>{"/api/agents/{id}/run"}</code>.</p>
          <div class="drawer-foot">
            <button type="button" class="btn ghost" @click="closeCreate()">Cancel</button>
            <button type="submit" class="btn primary" :disabled="busy"><span x-text="busy ? 'Saving…' : 'Create agent'">Create agent</span></button>
          </div>
        </form>
      </aside>

      {/* Directory form */}
      <aside class="drawer" x-show="creating === 'directory'" role="dialog" aria-modal="true" aria-label="New directory">
        <header class="drawer-head">
          <div>
            <span class="drawer-eyebrow folder">Organization · identity + membership sync</span>
            <h2>New directory</h2>
          </div>
          <button type="button" class="drawer-close" @click="closeCreate()" aria-label="Close">✕</button>
        </header>
        <form class="drawer-body" @submit.prevent="submitDirectory()">
          <p class="drawer-err" x-show="error" x-cloak x-text="error"></p>
          <label class="field"><span>Name</span><input type="text" x-model="directoryForm.name" placeholder="Q3 planning" /></label>
          <label class="field"><span>Parent directory id (optional — for nesting)</span>
            <select x-model="directoryForm.parentId">
              <option value="">— none (top level) —</option>
              <template x-for="d in items.directory" {...{ ":key": "d.id" }}>
                <option :value="d.id" x-text="d.name"></option>
              </template>
            </select>
          </label>
          <p class="field-note">A directory is the iPad <strong>zone</strong> — a folder that holds primitives. Its name + nesting + membership sync; its geometry stays per-device. Saves to <code>POST /api/directories</code>. File primitives in with “Move to…”.</p>
          <div class="drawer-foot">
            <button type="button" class="btn ghost" @click="closeCreate()">Cancel</button>
            <button type="submit" class="btn primary" :disabled="busy"><span x-text="busy ? 'Saving…' : 'Create directory'">Create directory</span></button>
          </div>
        </form>
      </aside>

      {/* KB form */}
      <aside class="drawer" x-show="creating === 'kb'" role="dialog" aria-modal="true" aria-label="New knowledge base">
        <header class="drawer-head">
          <div>
            <span class="drawer-eyebrow warn">Organization · syncs to hub</span>
            <h2>New knowledge base</h2>
          </div>
          <button type="button" class="drawer-close" @click="closeCreate()" aria-label="Close">✕</button>
        </header>
        <form class="drawer-body" @submit.prevent="submitKb()">
          <p class="drawer-err" x-show="error" x-cloak x-text="error"></p>
          <label class="field"><span>Name</span><input type="text" x-model="kbForm.name" placeholder="Product context" /></label>
          <label class="field"><span>Member ids (comma-separated, optional)</span><input type="text" x-model="kbForm.memberIds" placeholder="note-1, meeting-2" /></label>
          <p class="field-note">A KB groups primitives to ground an agent. Saves to <code>POST /api/kbs</code>.</p>
          <div class="drawer-foot">
            <button type="button" class="btn ghost" @click="closeCreate()">Cancel</button>
            <button type="submit" class="btn primary" :disabled="busy"><span x-text="busy ? 'Saving…' : 'Create KB'">Create KB</span></button>
          </div>
        </form>
      </aside>

      {/* Chain form */}
      <aside class="drawer" x-show="creating === 'chain'" role="dialog" aria-modal="true" aria-label="New chain">
        <header class="drawer-head">
          <div>
            <span class="drawer-eyebrow violet">Capability · syncs to hub</span>
            <h2>New chain</h2>
          </div>
          <button type="button" class="drawer-close" @click="closeCreate()" aria-label="Close">✕</button>
        </header>
        <form class="drawer-body" @submit.prevent="submitChain()">
          <p class="drawer-err" x-show="error" x-cloak x-text="error"></p>
          <label class="field"><span>Name</span><input type="text" x-model="chainForm.name" placeholder="Standup → actions → ticket" /></label>
          <label class="field"><span>Steps — agent ids, in order (comma-separated)</span><input type="text" x-model="chainForm.steps" placeholder="agent-summarize, agent-actions" /></label>
          <p class="field-note">A chain runs agents in order, output flowing into the next. Saves to <code>POST /api/chains</code>.</p>
          <div class="drawer-foot">
            <button type="button" class="btn ghost" @click="closeCreate()">Cancel</button>
            <button type="submit" class="btn primary" :disabled="busy"><span x-text="busy ? 'Saving…' : 'Create chain'">Create chain</span></button>
          </div>
        </form>
      </aside>

      {/* Workflow form */}
      <aside class="drawer" x-show="creating === 'workflow'" role="dialog" aria-modal="true" aria-label="New workflow">
        <header class="drawer-head">
          <div>
            <span class="drawer-eyebrow info">Capability · syncs to hub</span>
            <h2>New workflow</h2>
          </div>
          <button type="button" class="drawer-close" @click="closeCreate()" aria-label="Close">✕</button>
        </header>
        <form class="drawer-body" @submit.prevent="submitWorkflow()">
          <p class="drawer-err" x-show="error" x-cloak x-text="error"></p>
          <label class="field"><span>Name</span><input type="text" x-model="workflowForm.name" placeholder="Weekly digest" /></label>

          {/* mode toggle — a saved prompt OR a linear chain */}
          <div class="field">
            <span>How it runs</span>
            <div class="seg" role="tablist" aria-label="Workflow authoring mode">
              <button type="button" class="seg-opt" :class="{ on: workflowForm.mode === 'prompt' }" @click="workflowForm.mode = 'prompt'" role="tab" :aria-selected="workflowForm.mode === 'prompt'">Prompt</button>
              <button type="button" class="seg-opt" :class="{ on: workflowForm.mode === 'graph' }" @click="workflowForm.mode = 'graph'" role="tab" :aria-selected="workflowForm.mode === 'graph'">Linear chain</button>
            </div>
          </div>

          {/* prompt mode */}
          <template x-if="workflowForm.mode === 'prompt'">
            <div class="field">
              <span>Prompt</span>
              <textarea rows="6" x-model="workflowForm.prompt" placeholder="Summarize this week's meetings into a digest…"></textarea>
            </div>
          </template>

          {/* linear chain mode — ordered steps, entry → … → output */}
          <template x-if="workflowForm.mode === 'graph'">
            <div class="field">
              <span>Steps — run top to bottom, each feeding the next</span>
              <ol class="wf-chain" x-show="workflowForm.nodes.length" x-cloak>
                <template x-for="(step, i) in workflowForm.nodes" {...{ ":key": "i" }}>
                  <li class="wf-step">
                    <div class="wf-step-head">
                      <span class="wf-step-num" x-text="i + 1"></span>
                      <select class="wf-step-kind" x-model="step.kind">
                        <template x-for="k in workflowStepKinds" {...{ ":key": "k.kind" }}>
                          <option :value="k.kind" x-text="k.label"></option>
                        </template>
                      </select>
                      <div class="wf-step-ctl">
                        <button type="button" class="wf-icon" :disabled="i === 0" @click="moveWorkflowStep(i, -1)" aria-label="Move step up">↑</button>
                        <button type="button" class="wf-icon" :disabled="i === workflowForm.nodes.length - 1" @click="moveWorkflowStep(i, 1)" aria-label="Move step down">↓</button>
                        <button type="button" class="wf-icon danger" @click="removeWorkflowStep(i)" aria-label="Remove step">✕</button>
                      </div>
                    </div>
                    {/* per-kind payload */}
                    <textarea class="wf-step-field" rows="2" x-show="step.kind === 'llm'" x-cloak x-model="step.prompt" placeholder="Your instruction. Use {input} for the prior step's text…"></textarea>
                    <input class="wf-step-field" type="text" x-show="step.kind === 'rewrite'" x-cloak x-model="step.tone" placeholder="Tone (e.g. concise, formal)" />
                    <input class="wf-step-field" type="text" x-show="step.kind === 'extract'" x-cloak x-model="step.artifactType" placeholder="Artifact (e.g. decisions, action_items)" />
                  </li>
                </template>
              </ol>
              <p class="wf-empty" x-show="!workflowForm.nodes.length" x-cloak>No steps yet. Add one to start the chain.</p>
              <div class="wf-add">
                <template x-for="k in workflowStepKinds" {...{ ":key": "k.kind" }}>
                  <button type="button" class="btn sm ghost" @click="addWorkflowStep(k.kind)"><span aria-hidden="true">+</span> <span x-text="k.label"></span></button>
                </template>
              </div>
            </div>
          </template>

          <p class="field-note" x-show="workflowForm.mode === 'prompt'" x-cloak>A saved prompt that wires primitives into a run. Saves to <code>POST /api/workflows</code>.</p>
          <p class="field-note" x-show="workflowForm.mode === 'graph'" x-cloak>A <strong>linear chain</strong> (entry → steps → output) emitting the same <code>graph_json</code> the iPad Workbench produces and the hub linearizes. Branch and loop authoring lives in the Workbench; the web Desk ships the chain. Saves to <code>POST /api/workflows</code>.</p>

          <div class="drawer-foot">
            <button type="button" class="btn ghost" @click="closeCreate()">Cancel</button>
            <button type="submit" class="btn primary" :disabled="busy"><span x-text="busy ? 'Saving…' : 'Create workflow'">Create workflow</span></button>
          </div>
        </form>
      </aside>
    </div>

    {/* ── capability run drawer (agent · chain · workflow) ── */}
    <div class="drawer-overlay" x-show="running" x-cloak @keydown.escape.window="closeRun()">
      <div class="drawer-backdrop" @click="closeRun()"></div>
      <aside class="drawer wide run-drawer" role="dialog" aria-modal="true" aria-label="Run capability">
        <header class="drawer-head">
          <div class="run-head-id">
            {/* agent gets its avatar; chain/workflow get a kind glyph */}
            <span class="run-avatar" x-show="runningKind === 'agent'" x-cloak x-text="running && running.avatar">🤖</span>
            <span class="run-glyph violet" x-show="runningKind === 'chain'" x-cloak aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1" /></svg>
            </span>
            <span class="run-glyph info" x-show="runningKind === 'workflow'" x-cloak aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v12M18 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6zM6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM6 15a9 9 0 0 0 9 9" /></svg>
            </span>
            <div>
              <span class="drawer-eyebrow accent" x-show="runningKind === 'agent'" x-cloak>Run persona</span>
              <span class="drawer-eyebrow violet" x-show="runningKind === 'chain'" x-cloak>Run crew</span>
              <span class="drawer-eyebrow info" x-show="runningKind === 'workflow'" x-cloak>Run workflow</span>
              <h2 x-text="runTitle()">Run</h2>
              <p class="run-role" x-show="runningKind === 'agent' && running && running.role" x-cloak x-text="running && running.role"></p>
              <p class="run-role" x-show="runningKind === 'chain' && running" x-cloak x-text="`${(running && running.steps || []).length} agent${((running && running.steps || []).length) === 1 ? '' : 's'}, output flowing into the next`"></p>
              <p class="run-role" x-show="runningKind === 'workflow' && running && running.prompt" x-cloak x-text="running && running.prompt"></p>
            </div>
          </div>
          <button type="button" class="drawer-close" @click="closeRun()" aria-label="Close">✕</button>
        </header>
        <div class="drawer-body">
          {/* chain crew preview — the ordered roster before you run */}
          <div class="crew-roster" x-show="runningKind === 'chain' && running && running.steps.length" x-cloak>
            <span class="run-result-label">Crew</span>
            <ol class="chain-flow">
              <template x-for="(s, i) in (running ? running.steps : [])" {...{ ":key": "i" }}>
                <li class="chain-node"><span class="chain-num" x-text="i + 1"></span><span class="chain-name" x-text="agentName(s)"></span></li>
              </template>
            </ol>
          </div>

          <label class="field">
            <span x-text="runningKind === 'chain' ? 'Input — fed to the first agent' : 'Input'">Input</span>
            <textarea rows="5" x-model="runInput"
              :placeholder="runningKind === 'chain' ? 'Paste a transcript, a brief, or anything the first agent should work on…' : (runningKind === 'workflow' ? 'Anything the workflow should work on (optional for a graph workflow)…' : 'Paste a transcript, a question, or anything the persona should work on…')"
              @keydown.cmd.enter="submitRun()" @keydown.ctrl.enter="submitRun()"></textarea>
          </label>
          <p class="field-note" x-show="runningKind === 'agent'" x-cloak>Runs <code>{"POST /api/agents/{id}/run"}</code> through your configured provider. <kbd>⌘</kbd>+<kbd>Enter</kbd> to run.</p>
          <p class="field-note" x-show="runningKind === 'chain'" x-cloak>Runs <code>{"POST /api/chains/{id}/run"}</code> — each agent runs in order, its output flowing into the next. <kbd>⌘</kbd>+<kbd>Enter</kbd> to run.</p>
          <p class="field-note" x-show="runningKind === 'workflow'" x-cloak>Runs <code>{"POST /api/workflows/{id}/run"}</code> through your configured provider. <kbd>⌘</kbd>+<kbd>Enter</kbd> to run.</p>

          <p class="drawer-err" x-show="runError" x-cloak x-text="runError"></p>

          {/* loading */}
          <div class="run-loading" x-show="runBusy" x-cloak>
            <span class="run-spinner"></span>
            <span x-text="runningKind === 'chain' ? 'Running the crew…' : (runningKind === 'workflow' ? 'Running the workflow…' : 'Running the persona…')">Running…</span>
          </div>

          {/* honest hub notice — a graph it would not guess an order for ran the
              prompt fallback; surface that verbatim so the run is never silent */}
          <div class="run-notice" x-show="runWarning && !runBusy" x-cloak>
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><path d="M12 9v4M12 17h.01" /></svg>
            <span x-text="runWarning"></span>
          </div>

          {/* workflow graph trail — the per-node execution path the hub ran */}
          <div class="crew-result" x-show="runningKind === 'workflow' && workflowSteps && !runBusy" x-cloak>
            <span class="run-result-label">Graph trail</span>
            <ol class="crew-steps">
              <template x-for="(step, i) in (workflowSteps || [])" {...{ ":key": "i" }}>
                <li class="crew-step">
                  <div class="crew-step-head">
                    <span class="chain-num" x-text="i + 1"></span>
                    <span class="crew-step-name" x-text="step.nodeId || step.kind"></span>
                    <span class="crew-step-kind" x-show="step.kind" x-cloak x-text="step.kind" title="Node kind"></span>
                    <span class="crew-step-provider" x-show="step.provider" x-cloak x-text="step.provider" title="Ran on"></span>
                    <svg class="crew-step-arrow" x-show="i < (workflowSteps.length - 1)" x-cloak viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7" /></svg>
                  </div>
                  <pre class="crew-step-output" x-text="step.output"></pre>
                </li>
              </template>
            </ol>
          </div>

          {/* chain crew result — each step in sequence, then the final output */}
          <div class="crew-result" x-show="runningKind === 'chain' && chainSteps && !runBusy" x-cloak>
            <span class="run-result-label">Crew run</span>
            <ol class="crew-steps">
              <template x-for="(step, i) in (chainSteps || [])" {...{ ":key": "i" }}>
                <li class="crew-step">
                  <div class="crew-step-head">
                    <span class="chain-num" x-text="i + 1"></span>
                    <span class="crew-step-name" x-text="step.agentName"></span>
                    <span class="crew-step-provider" x-show="step.provider" x-cloak x-text="step.provider" title="Ran on"></span>
                    <svg class="crew-step-arrow" x-show="i < (chainSteps.length - 1)" x-cloak viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7" /></svg>
                  </div>
                  <pre class="crew-step-output" x-text="step.output"></pre>
                </li>
              </template>
            </ol>
          </div>

          {/* result — final output (all kinds) */}
          <div class="run-result" x-show="runResult && !runBusy" x-cloak>
            <div class="run-result-head">
              <span class="run-result-label" x-text="(runningKind === 'chain' || (runningKind === 'workflow' && workflowSteps)) ? 'Final output' : 'Output'">Output</span>
              <span class="egress" :class="runEgress().scope" :title="runEgress().label">
                <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                <span x-text="runEgress().scope === 'local' ? 'on-device' : (runEgress().scope === 'cloud' ? 'cloud' : 'egress')">egress</span>
              </span>
              <button type="button" class="run-copy" @click="copyRun()" title="Copy output">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" x-show="!runCopied" x-cloak><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
                <span x-show="!runCopied" x-cloak>Copy</span>
                <span x-show="runCopied" x-cloak class="copied">Copied ✓</span>
              </button>
            </div>
            {/* provenance ribbon — produced by + what it was fed + provider */}
            <div class="run-provenance">
              <span class="prov-produced" x-show="runProducedBy()" x-cloak>
                <span class="prov-label">Produced by</span>
                <span class="prov-name" x-text="runProducedBy() && runProducedBy().label"></span>
                <span class="prov-kind" x-show="runProducedBy() && runProducedBy().kind" x-cloak x-text="runProducedBy() && runProducedBy().kind"></span>
              </span>
              <span class="prov-from" x-show="runFrom().length" x-cloak>
                <span class="prov-label">from</span>
                <template x-for="(src, i) in runFrom()" {...{ ":key": "i" }}>
                  <span class="prov-ref" :class="{ unresolved: !src.resolved }" x-text="src.label"></span>
                </template>
              </span>
              <span class="prov-provider" x-show="runResult && runResult.provider" x-cloak title="The provider that ran this">
                <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9z" /></svg>
                <span x-text="runResult && runResult.provider"></span>
              </span>
            </div>
            <pre class="run-output" x-text="runResult && runResult.output"></pre>
          </div>
        </div>
        <div class="drawer-foot run-foot">
          <button type="button" class="btn ghost" @click="closeRun()">Close</button>
          <button type="button" class="btn primary" @click="submitRun()" :disabled="runBusy">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l14 9-14 9z" /></svg>
            <span x-text="runBusy ? 'Running…' : ((runResult || chainSteps) ? 'Run again' : 'Run')">Run</span>
          </button>
        </div>
      </aside>
    </div>

    {/* ── filing picker (Move to… a directory) ── */}
    <div class="drawer-overlay file-overlay" x-show="filing" x-cloak @keydown.escape.window="closeFile()">
      <div class="drawer-backdrop" @click="closeFile()"></div>
      <aside class="drawer file-drawer" role="dialog" aria-modal="true" aria-label="File into a directory">
        <header class="drawer-head">
          <div>
            <span class="drawer-eyebrow folder">File into a directory</span>
            <h2 x-text="filing && filing.title">Primitive</h2>
            <p class="run-role"><span class="file-kind" x-text="filing && filing.kind"></span> · toggle the directories it’s filed in</p>
          </div>
          <button type="button" class="drawer-close" @click="closeFile()" aria-label="Close">✕</button>
        </header>
        <div class="drawer-body">
          <p class="drawer-err" x-show="filingError" x-cloak x-text="filingError"></p>

          {/* unreachable directories */}
          <template x-if="isUnreachable('directory')">
            <div class="empty-inner unreachable">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 1l22 22M16.72 11.06A10.94 10.94 0 0 1 19 12.55M5 12.55a10.94 10.94 0 0 1 5.17-2.39M10.71 5.05A16 16 0 0 1 22.58 9M1.42 9a15.91 15.91 0 0 1 4.7-2.88M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01" /></svg>
              <span>Could not reach the hub for directories — filing is unavailable.</span>
            </div>
          </template>

          {/* no directories yet */}
          <div class="empty-inner" x-show="!isUnreachable('directory') && items.directory.length === 0" x-cloak>
            <span>No directories yet.</span>
            <button type="button" class="card-link" @click="closeFile(); openCreate('directory')">Create one first</button>
          </div>

          {/* directory checklist */}
          <ul class="file-list" x-show="items.directory.length" x-cloak>
            <template x-for="d in items.directory" {...{ ":key": "d.id" }}>
              <li>
                <button type="button" class="file-option" :class="{ on: isFiledIn(filing.id, d.id) }" :disabled="filingBusy === d.id" @click="toggleFile(d)">
                  <span class="file-check" :class="{ on: isFiledIn(filing.id, d.id) }">
                    <svg x-show="isFiledIn(filing.id, d.id)" x-cloak viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>
                  </span>
                  <span class="file-option-body">
                    <span class="file-option-name" x-text="d.name"></span>
                    <span class="file-option-meta" x-text="`${d.memberIds.length} item${d.memberIds.length === 1 ? '' : 's'}`"></span>
                  </span>
                  <span class="file-option-state" x-show="filingBusy === d.id" x-cloak>…</span>
                  <span class="file-option-state filed" x-show="filingBusy !== d.id && isFiledIn(filing.id, d.id)" x-cloak>filed</span>
                </button>
              </li>
            </template>
          </ul>
          <p class="field-note">Toggling files (<code>PUT</code>) or unfiles (<code>DELETE</code>) via <code>{"/api/directories/{id}/members/{primitive_id}"}</code>. Membership syncs to every surface; it is organization, not layout.</p>
        </div>
        <div class="drawer-foot">
          <button type="button" class="btn primary" @click="closeFile()">Done</button>
        </div>
      </aside>
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import factorySource from "../scripts/desk-app.js?raw";

    const fn = new Function(factorySource + "; return DeskApp;");
    window.DeskApp = fn();
    window.Alpine = Alpine;
    Alpine.start();
  </script>
</AppLayout>

<style>
  [x-cloak] { display: none !important; }

  .desk {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-5);
    color: var(--text);
    max-width: 1320px;
    margin: 0 auto;
  }

  /* per-kind colour identity (source: lib/primitives.ts tone) */
  .kind--info   { --k: var(--info); }
  .kind--accent { --k: var(--accent); }
  .kind--ok     { --k: var(--ok); }
  .kind--warn   { --k: var(--warn-signal); }
  .kind--violet { --k: #A78BFA; }
  .kind--folder { --k: #E0A458; } /* a warm folder/manila tone */

  /* ── header ── */
  .desk-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .desk-head-text { max-width: 46rem; }
  .eyebrow {
    margin: 0 0 var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow);
    color: var(--accent);
  }
  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-3xl);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-tight);
  }
  .lead {
    margin: var(--space-3) 0 0;
    color: var(--text-muted);
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
  }
  .desk-head-actions { display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap; }
  .desk-stat {
    display: flex; flex-direction: column; align-items: flex-end;
    padding-right: var(--space-3); margin-right: var(--space-1);
    border-right: 1px solid var(--border-subtle);
  }
  .desk-stat strong { font-family: var(--font-display); font-size: var(--font-size-xl); line-height: 1; }
  .desk-stat span {
    font-family: var(--font-mono); font-size: var(--font-size-xs);
    text-transform: uppercase; letter-spacing: var(--letter-spacing-eyebrow); color: var(--text-faint);
  }

  /* ── buttons ── */
  .btn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-2) var(--space-4); min-height: 2.25rem;
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    background: var(--surface-1); color: var(--text);
    font-family: var(--font-ui); font-size: var(--font-size-sm); font-weight: 500; cursor: pointer;
    transition: border-color var(--duration-short) var(--ease-standard), background var(--duration-short) var(--ease-standard), transform var(--duration-short) var(--ease-standard);
  }
  .btn:hover { border-color: var(--border-strong); background: var(--surface-2); }
  .btn:active { transform: translateY(1px); }
  .btn:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }
  .btn:disabled { opacity: 0.55; cursor: default; }
  .btn.primary { background: var(--accent); border-color: transparent; color: var(--text-on-accent); font-weight: 600; box-shadow: var(--glow-accent); }
  .btn.primary:hover { background: var(--accent-hover); }
  .btn.primary:disabled:hover { background: var(--accent); }
  .btn.ghost { background: transparent; }
  .btn.sm { min-height: 1.9rem; padding: var(--space-1) var(--space-3); }
  .icon-btn { padding: var(--space-2); min-width: 2.25rem; justify-content: center; }
  .spin { animation: spin 0.9s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── hub connection bar ── */
  .hub-bar {
    display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap;
    margin-top: calc(-1 * var(--space-3));
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-subtle); border-radius: var(--radius-md);
    background: var(--surface-1);
  }
  .hub-status {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 600;
    padding: var(--space-1) var(--space-3); border-radius: var(--radius-pill);
    border: 1px solid var(--border-subtle);
  }
  .hub-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-faint); }
  .hub-status.connecting { color: var(--text-faint); }
  .hub-status.connected  { color: var(--ok-strong); background: var(--ok-soft); border-color: transparent; }
  .hub-status.connected .hub-dot  { background: var(--ok); box-shadow: 0 0 0 3px var(--ok-soft); animation: pulse 2.4s var(--ease-standard) infinite; }
  .hub-status.partial    { color: var(--warn-strong); background: var(--warn-soft); border-color: transparent; }
  .hub-status.partial .hub-dot    { background: var(--warn-signal); }
  .hub-status.unreachable{ color: var(--danger); background: var(--danger-soft); border-color: transparent; }
  .hub-status.unreachable .hub-dot{ background: var(--danger-signal); }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.45; } }
  .hub-synced { display: inline-flex; align-items: center; gap: var(--space-2); font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--text-faint); }
  /* ambient trust: the egress badge (canonical .egress-badge styling) + a
     one-line readiness chip, both linking through to /setup. */
  .hub-egress { font-family: var(--font-mono); text-decoration: none; cursor: pointer; }
  .hub-egress:hover { filter: brightness(1.15); }
  .hub-egress:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }
  .hub-ready {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-mono); font-size: var(--font-size-xs); text-decoration: none;
    padding: var(--space-1) var(--space-3); border-radius: var(--radius-pill);
    border: 1px solid var(--border-subtle); color: var(--text-faint);
  }
  .hub-ready:hover { border-color: var(--border-strong); color: var(--text-muted); }
  .hub-ready:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }
  .hub-ready-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
  .hub-ready.ready   { color: var(--ok-strong); }
  .hub-ready.warn    { color: var(--warn-strong); }
  .hub-ready.blocked { color: var(--danger); }
  .hub-error { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--danger); margin-left: auto; max-width: 50%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* ── group ── */
  .group { display: flex; flex-direction: column; gap: var(--space-4); }
  .group-head { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--space-4); }
  .group-head-text h2 { margin: 0; font-family: var(--font-display); font-size: var(--font-size-xl); font-weight: 600; letter-spacing: var(--letter-spacing-tight); }
  .group-head-text p { margin: var(--space-1) 0 0; color: var(--text-faint); font-size: var(--font-size-sm); }
  .group-lanes { display: flex; flex-direction: column; gap: var(--space-3); }

  /* ── per-kind lane ── */
  .kind {
    position: relative;
    border: 1px solid var(--border-subtle); border-radius: var(--radius-lg);
    background: var(--surface-1); padding: var(--space-4) var(--space-4) var(--space-4) var(--space-5);
    box-shadow: var(--elev-1);
    overflow: hidden;
  }
  /* the colour spine + a faint top wash, keyed by --k */
  .kind::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--k); }
  .kind::after  { content: ""; position: absolute; left: 0; right: 0; top: 0; height: 1px; background: linear-gradient(90deg, color-mix(in srgb, var(--k) 60%, transparent), transparent 55%); }

  .kind-head { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-4); }
  .kind-icon {
    display: inline-grid; place-items: center; width: 34px; height: 34px;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--k) 14%, var(--surface-3));
    color: var(--k);
    border: 1px solid color-mix(in srgb, var(--k) 30%, transparent);
  }
  .kind-title { font-family: var(--font-display); font-weight: 600; font-size: var(--font-size-lg); }
  .kind-count {
    font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--text-muted);
    background: var(--surface-3); border-radius: var(--radius-pill); padding: 1px var(--space-2);
    min-width: 1.4rem; text-align: center;
  }
  .kind-sync {
    font-family: var(--font-mono); font-size: 0.6875rem; text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow); color: var(--text-faint);
  }
  .kind-flag { font-family: var(--font-mono); font-size: 0.6875rem; border-radius: var(--radius-pill); padding: 1px var(--space-2); border: 1px solid transparent; }
  .kind-flag.readonly { color: var(--text-faint); background: var(--surface-3); border-color: var(--border-subtle); }
  .kind-flag.down { color: var(--danger); background: var(--danger-soft); border-color: var(--danger-soft); }
  .kind-add {
    margin-left: auto; display: inline-grid; place-items: center; width: 30px; height: 30px;
    border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--surface-2);
    color: var(--text-muted); cursor: pointer;
    transition: color var(--duration-short) var(--ease-standard), border-color var(--duration-short) var(--ease-standard), background var(--duration-short) var(--ease-standard);
  }
  .kind-add:hover { color: var(--k); border-color: var(--k); background: color-mix(in srgb, var(--k) 12%, var(--surface-2)); }

  /* ── cards grid ── */
  .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 250px), 1fr)); gap: var(--space-3); }
  .card {
    display: flex; flex-direction: column; gap: var(--space-2);
    padding: var(--space-4); border: 1px solid var(--border-subtle); border-radius: var(--radius-md);
    background: var(--surface-2);
    transition: transform var(--duration-short) var(--ease-standard), border-color var(--duration-short) var(--ease-standard), box-shadow var(--duration-short) var(--ease-standard);
  }
  .card:hover { transform: translateY(-2px); border-color: color-mix(in srgb, var(--ck, var(--border-strong)) 45%, var(--border)); box-shadow: var(--elev-2); }
  .card--info   { --ck: var(--info); }
  .card--accent { --ck: var(--accent); }
  .card--ok     { --ck: var(--ok); }
  .card--warn   { --ck: var(--warn-signal); }
  .card--violet { --ck: #A78BFA; }
  .card--folder { --ck: #E0A458; }
  .card-type { display: inline-flex; align-items: center; gap: var(--space-2); font-family: var(--font-mono); font-size: 0.6875rem; text-transform: uppercase; letter-spacing: var(--letter-spacing-eyebrow); color: var(--text-faint); }
  .card-type .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--ck, var(--text-faint)); }
  .card-title { margin: 0; font-family: var(--font-display); font-size: var(--font-size-md); font-weight: 600; line-height: var(--line-height-tight); overflow-wrap: anywhere; }
  .card-sub { margin: 0; color: var(--text-muted); font-size: var(--font-size-sm); }
  .card-body { margin: 0; color: var(--text-muted); font-size: var(--font-size-sm); line-height: var(--line-height-normal); display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .card-foot { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); margin-top: auto; padding-top: var(--space-2); }
  .tag { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-muted); background: var(--surface-3); border-radius: var(--radius-xs); padding: 1px var(--space-2); }
  .tag.mono { color: var(--ck, var(--accent)); }
  .tag.warn-tag { color: var(--warn-strong); background: var(--warn-soft); }
  .card-time { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-faint); margin-left: auto; }
  .card-link { color: var(--accent); font-size: var(--font-size-sm); text-decoration: none; background: none; border: none; cursor: pointer; padding: 0; margin-left: auto; font-family: var(--font-ui); }
  .card-link:hover { text-decoration: underline; }

  /* agent card */
  .agent-card .agent-top { display: flex; gap: var(--space-3); align-items: flex-start; }
  .agent-avatar { font-size: 1.7rem; line-height: 1; filter: saturate(1.1); }
  .agent-id { min-width: 0; }
  .card-actions { display: flex; gap: var(--space-2); margin-top: var(--space-2); }
  .run-btn { width: 100%; justify-content: center; }

  /* chain flow */
  .chain-flow { list-style: none; margin: var(--space-1) 0 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-1); }
  .chain-node { display: flex; align-items: center; gap: var(--space-2); font-size: var(--font-size-sm); color: var(--text-muted); position: relative; }
  .chain-node:not(:last-child)::after { content: ""; position: absolute; left: 9px; top: 22px; width: 1px; height: var(--space-1); background: var(--ck); opacity: 0.5; }
  .chain-num { display: inline-grid; place-items: center; width: 18px; height: 18px; border-radius: 50%; background: color-mix(in srgb, var(--ck) 18%, var(--surface-3)); color: var(--ck); font-family: var(--font-mono); font-size: 0.625rem; font-weight: 600; flex-shrink: 0; }
  .chain-name { font-family: var(--font-mono); font-size: 0.75rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* ── directory card (a folder holding primitives) ── */
  .dir-card {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--ck) 8%, var(--surface-2)), var(--surface-2));
    /* a folder "tab" notch along the top edge */
    border-top: 2px solid color-mix(in srgb, var(--ck) 55%, transparent);
  }
  .dir-top { display: flex; align-items: flex-start; gap: var(--space-3); }
  .dir-folder-icon {
    display: inline-grid; place-items: center; width: 32px; height: 32px; flex-shrink: 0;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--ck) 16%, var(--surface-3));
    color: var(--ck);
    border: 1px solid color-mix(in srgb, var(--ck) 32%, transparent);
  }
  .dir-id { min-width: 0; flex: 1; }
  .dir-count {
    font-family: var(--font-mono); font-size: var(--font-size-sm); font-weight: 600;
    color: var(--ck); background: color-mix(in srgb, var(--ck) 14%, var(--surface-3));
    border-radius: var(--radius-pill); padding: 1px var(--space-2); min-width: 1.6rem; text-align: center;
    border: 1px solid color-mix(in srgb, var(--ck) 26%, transparent); flex-shrink: 0;
  }
  .mono-inline { font-family: var(--font-mono); color: var(--text-faint); }
  .dir-members { list-style: none; margin: var(--space-1) 0 0; padding: 0; display: flex; flex-direction: column; gap: 4px; }
  .dir-member {
    display: flex; align-items: center; gap: var(--space-2);
    padding: var(--space-1) var(--space-2);
    background: var(--surface-1); border: 1px solid var(--border-subtle); border-radius: var(--radius-xs);
  }
  .dir-member-kind {
    font-family: var(--font-mono); font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--ck); background: color-mix(in srgb, var(--ck) 12%, transparent);
    border-radius: var(--radius-xs); padding: 0 4px; flex-shrink: 0;
  }
  .dir-member-label { font-size: var(--font-size-sm); color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .dir-more { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-faint); padding-left: var(--space-1); }
  .dir-empty { margin: var(--space-1) 0 0; font-size: var(--font-size-sm); color: var(--text-faint); font-style: italic; }

  /* ── filed-into-directory row (on filable cards) ── */
  .filed-row { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); margin-top: var(--space-2); padding-top: var(--space-2); border-top: 1px dashed var(--border-subtle); }
  .filed-chip {
    display: inline-flex; align-items: center; gap: 4px;
    font-family: var(--font-mono); font-size: 0.625rem;
    color: #E0A458; background: color-mix(in srgb, #E0A458 14%, var(--surface-3));
    border: 1px solid color-mix(in srgb, #E0A458 28%, transparent);
    border-radius: var(--radius-pill); padding: 1px var(--space-2);
  }
  .file-btn {
    display: inline-flex; align-items: center; gap: 4px; margin-left: auto;
    font-family: var(--font-ui); font-size: 0.6875rem; color: var(--text-muted);
    background: transparent; border: 1px solid var(--border); border-radius: var(--radius-xs);
    padding: 2px var(--space-2); cursor: pointer;
    transition: color var(--duration-short) var(--ease-standard), border-color var(--duration-short) var(--ease-standard);
  }
  .file-btn:hover { color: #E0A458; border-color: color-mix(in srgb, #E0A458 50%, var(--border)); }

  /* ── filing picker drawer ── */
  .file-drawer .file-kind { font-family: var(--font-mono); color: #E0A458; text-transform: uppercase; font-size: 0.6875rem; }
  .drawer-eyebrow.folder { color: #E0A458; }
  .file-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-2); }
  .file-option {
    width: 100%; display: flex; align-items: center; gap: var(--space-3); text-align: left;
    padding: var(--space-3); border: 1px solid var(--border); border-radius: var(--radius-md);
    background: var(--surface-2); color: var(--text); cursor: pointer;
    transition: border-color var(--duration-short) var(--ease-standard), background var(--duration-short) var(--ease-standard);
  }
  .file-option:hover { border-color: color-mix(in srgb, #E0A458 50%, var(--border)); background: var(--surface-3); }
  .file-option:disabled { opacity: 0.6; cursor: default; }
  .file-option.on { border-color: color-mix(in srgb, #E0A458 55%, transparent); background: color-mix(in srgb, #E0A458 8%, var(--surface-2)); }
  .file-check {
    display: inline-grid; place-items: center; width: 22px; height: 22px; flex-shrink: 0;
    border-radius: var(--radius-xs); border: 1.5px solid var(--border-strong); color: var(--text-on-accent);
  }
  .file-check.on { background: #E0A458; border-color: #E0A458; }
  .file-option-body { display: flex; flex-direction: column; gap: 1px; min-width: 0; flex: 1; }
  .file-option-name { font-family: var(--font-display); font-weight: 600; font-size: var(--font-size-md); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .file-option-meta { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-faint); }
  .file-option-state { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-faint); flex-shrink: 0; }
  .file-option-state.filed { color: #E0A458; }

  /* ── lineage / provenance line (on artifact cards) ── */
  .lineage {
    display: flex; flex-wrap: wrap; align-items: center; gap: 4px;
    margin: 0; font-family: var(--font-mono); font-size: 0.6875rem;
    color: var(--text-faint); line-height: var(--line-height-normal);
  }
  .lineage-glyph { color: var(--ck, var(--accent)); opacity: 0.8; flex-shrink: 0; }
  .lineage-part { display: inline-flex; align-items: center; gap: 4px; }
  .lineage-sep { color: var(--text-faint); opacity: 0.6; }
  .lineage-from, .lineage-via { color: var(--text-faint); text-transform: lowercase; }
  .lineage-via { color: var(--ck, var(--accent)); }
  .lineage-ref { color: var(--text-muted); font-weight: 600; }
  .lineage-ref.unresolved { color: var(--text-faint); font-weight: 400; opacity: 0.85; }

  /* empty / unreachable */
  .cards-empty { grid-column: 1 / -1; }
  .empty-inner { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4); border: 1px dashed var(--border); border-radius: var(--radius-md); color: var(--text-faint); font-size: var(--font-size-sm); }
  .empty-inner.unreachable { color: var(--danger); border-color: var(--danger-soft); background: var(--danger-soft); }
  .empty-inner .card-link { margin-left: 0; }

  /* ── coder lane ── */
  .coder-lane { border-top: 1px solid var(--border-subtle); padding-top: var(--space-5); }
  .coder-status { display: inline-flex; align-items: center; gap: var(--space-2); font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 600; padding: var(--space-1) var(--space-3); border-radius: var(--radius-pill); }
  .coder-status-dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; }
  .coder-status.ready { color: var(--ok-strong); background: var(--ok-soft); }
  .coder-status.ready .coder-status-dot { animation: pulse 2.4s var(--ease-standard) infinite; }
  .coder-status.idle { color: var(--text-faint); background: var(--surface-2); }
  .coder-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr)); gap: var(--space-3); }
  .coder-card {
    display: flex; flex-direction: column; gap: var(--space-2); padding: var(--space-4);
    border: 1px solid var(--border); border-radius: var(--radius-md);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-1));
    border-left: 3px solid var(--accent);
    transition: border-color var(--duration-short) var(--ease-standard), box-shadow var(--duration-short) var(--ease-standard);
  }
  .coder-card.selected { box-shadow: var(--glow-accent); }
  .coder-card.waiting { border-left-color: var(--warn-signal); }
  .coder-card-head { display: flex; align-items: center; gap: var(--space-2); }
  .coder-badge { font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 600; padding: 1px var(--space-2); border-radius: var(--radius-xs); background: var(--accent-tint); color: var(--accent); }
  .coder-badge.codex { background: var(--info-soft); color: var(--info); }
  .coder-state { font-family: var(--font-mono); font-size: var(--font-size-xs); padding: 1px var(--space-2); border-radius: var(--radius-xs); }
  .coder-state.ready { color: var(--ok-strong); background: var(--ok-soft); }
  .coder-state.warn { color: var(--warn-strong); background: var(--warn-soft); }
  .coder-state.neutral { color: var(--text-muted); background: var(--surface-3); }
  .coder-pin { margin-left: auto; font-size: 0.75rem; }
  .coder-project { margin: 0; font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--text); overflow-wrap: anywhere; }
  .coder-meta { margin: 0; font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-faint); }
  .coder-q-wrap { padding: var(--space-2) var(--space-3); border-radius: var(--radius-sm); background: var(--surface-3); border-left: 2px solid var(--border-strong); }
  .coder-q-wrap.asking { background: var(--warn-soft); border-left-color: var(--warn-signal); }
  .coder-q { margin: 0; font-size: var(--font-size-sm); color: var(--text); line-height: var(--line-height-normal); }
  .coder-q.muted { color: var(--text-faint); }
  .coder-events { display: flex; flex-direction: column; gap: 3px; border-top: 1px solid var(--border-subtle); padding-top: var(--space-2); }
  .coder-event { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ev-kind { color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.04em; }
  .ev-kind.result { color: var(--ok-strong); }
  .ev-kind.approval, .ev-kind.command { color: var(--warn-strong); }
  .ev-kind.tool { color: var(--info); }
  .ev-kind.assistant { color: var(--accent); }
  .ev-text { color: var(--text-muted); }
  .coder-actions { margin-top: var(--space-2); }

  /* ── drawers ── */
  .drawer-overlay { position: fixed; inset: 0; z-index: var(--z-dialog); display: flex; justify-content: flex-end; }
  .drawer-backdrop { position: absolute; inset: 0; background: var(--canvas-overlay); backdrop-filter: blur(2px); }
  .drawer {
    position: relative; height: 100%; width: min(460px, 96vw);
    display: flex; flex-direction: column;
    background: var(--surface-1); border-left: 1px solid var(--border);
    box-shadow: var(--elev-3); animation: slidein var(--duration-long) var(--ease-emphasized);
  }
  .drawer.wide { width: min(600px, 96vw); }
  @keyframes slidein { from { transform: translateX(2rem); opacity: 0.4; } to { transform: translateX(0); opacity: 1; } }
  .drawer-head { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-3); padding: var(--space-5); border-bottom: 1px solid var(--border-subtle); }
  .drawer-head h2 { margin: var(--space-1) 0 0; font-family: var(--font-display); font-size: var(--font-size-xl); }
  .drawer-eyebrow { font-family: var(--font-mono); font-size: var(--font-size-xs); text-transform: uppercase; letter-spacing: var(--letter-spacing-eyebrow); }
  .drawer-eyebrow.accent { color: var(--accent); }
  .drawer-eyebrow.ok { color: var(--ok-strong); }
  .drawer-eyebrow.warn { color: var(--warn-strong); }
  .drawer-eyebrow.info { color: var(--info); }
  .drawer-eyebrow.violet { color: #A78BFA; }
  .drawer-close { width: 32px; height: 32px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: transparent; color: var(--text-muted); cursor: pointer; flex-shrink: 0; }
  .drawer-close:hover { color: var(--text); border-color: var(--border-strong); }
  .drawer-body { flex: 1; overflow-y: auto; padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-4); }
  .drawer-err { margin: 0; padding: var(--space-2) var(--space-3); border-radius: var(--radius-sm); background: var(--danger-soft); color: var(--danger); font-size: var(--font-size-sm); border: 1px solid var(--danger-soft); }
  .field { display: flex; flex-direction: column; gap: var(--space-2); }
  .field > span { font-family: var(--font-mono); font-size: var(--font-size-xs); text-transform: uppercase; letter-spacing: var(--letter-spacing-eyebrow); color: var(--text-faint); }
  .field input, .field textarea { font-family: var(--font-ui); font-size: var(--font-size-sm); color: var(--text); background: var(--field-bg); border: 1px solid var(--field-border); border-radius: var(--radius-sm); padding: var(--space-2) var(--space-3); resize: vertical; }
  .field textarea { font-family: var(--font-mono); line-height: var(--line-height-normal); }
  .field input:focus, .field textarea:focus { outline: none; border-color: var(--field-focus-border); box-shadow: 0 0 0 2px var(--accent-tint); }
  .field-row { display: flex; gap: var(--space-3); }
  .field-row .grow { flex: 1; }
  .avatar-field input { text-align: center; width: 4rem; font-size: 1.25rem; }
  .field-note { margin: 0; font-size: var(--font-size-xs); color: var(--text-faint); line-height: var(--line-height-normal); }
  .field-note code { font-family: var(--font-mono); color: var(--accent); }
  .field-note kbd { font-family: var(--font-mono); font-size: 0.6875rem; background: var(--surface-3); border: 1px solid var(--border); border-radius: var(--radius-xs); padding: 0 4px; color: var(--text-muted); }
  .drawer-foot { display: flex; justify-content: flex-end; gap: var(--space-2); padding: var(--space-4) var(--space-5); border-top: 1px solid var(--border-subtle); }

  /* ── segmented mode toggle (prompt | linear chain) ── */
  .seg { display: inline-flex; gap: 2px; padding: 2px; background: var(--surface-3); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); }
  .seg-opt { flex: 1; font-family: var(--font-ui); font-size: var(--font-size-sm); color: var(--text-muted); background: transparent; border: none; border-radius: var(--radius-xs); padding: var(--space-1) var(--space-3); cursor: pointer; min-height: 1.9rem; }
  .seg-opt:hover { color: var(--text); }
  .seg-opt.on { color: var(--text-on-accent); background: var(--info); font-weight: 600; }
  .seg-opt:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }

  /* ── linear chain builder ── */
  .wf-chain { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-2); --ck: var(--info); }
  .wf-step { position: relative; display: flex; flex-direction: column; gap: var(--space-2); padding: var(--space-3); background: var(--surface-2); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); }
  .wf-step:not(:last-child)::after { content: ""; position: absolute; left: 50%; bottom: calc(-1 * var(--space-2)); width: 1px; height: var(--space-2); background: var(--ck); opacity: 0.5; }
  .wf-step-head { display: flex; align-items: center; gap: var(--space-2); }
  .wf-step-num { flex: none; width: 1.4rem; height: 1.4rem; display: grid; place-items: center; font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--info); background: color-mix(in srgb, var(--info) 16%, var(--surface-3)); border-radius: var(--radius-pill); }
  .wf-step-kind { flex: 1; font-family: var(--font-ui); font-size: var(--font-size-sm); color: var(--text); background: var(--field-bg); border: 1px solid var(--field-border); border-radius: var(--radius-sm); padding: var(--space-1) var(--space-2); }
  .wf-step-kind:focus { outline: none; border-color: var(--field-focus-border); box-shadow: 0 0 0 2px var(--accent-tint); }
  .wf-step-ctl { display: flex; gap: 2px; }
  .wf-icon { width: 1.6rem; height: 1.6rem; display: grid; place-items: center; font-size: var(--font-size-sm); color: var(--text-muted); background: transparent; border: 1px solid var(--border-subtle); border-radius: var(--radius-xs); cursor: pointer; }
  .wf-icon:hover { color: var(--text); border-color: var(--border-strong); }
  .wf-icon.danger:hover { color: var(--danger, #F87171); border-color: var(--danger, #F87171); }
  .wf-icon:disabled { opacity: 0.4; cursor: default; }
  .wf-step-field { font-family: var(--font-mono); font-size: var(--font-size-sm); color: var(--text); background: var(--field-bg); border: 1px solid var(--field-border); border-radius: var(--radius-sm); padding: var(--space-2) var(--space-3); resize: vertical; }
  .wf-step-field:focus { outline: none; border-color: var(--field-focus-border); box-shadow: 0 0 0 2px var(--accent-tint); }
  .wf-empty { margin: 0; font-size: var(--font-size-sm); color: var(--text-faint); font-style: italic; }
  .wf-add { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-1); }

  /* ── run drawer ── */
  .run-head-id { display: flex; gap: var(--space-3); align-items: flex-start; min-width: 0; }
  .run-avatar { font-size: 2rem; line-height: 1; }
  .run-role { margin: var(--space-1) 0 0; color: var(--text-muted); font-size: var(--font-size-sm); }
  .run-loading { display: flex; align-items: center; gap: var(--space-3); color: var(--text-muted); font-size: var(--font-size-sm); padding: var(--space-4); border: 1px dashed var(--border); border-radius: var(--radius-md); }
  .run-spinner { width: 16px; height: 16px; border-radius: 50%; border: 2px solid var(--surface-3); border-top-color: var(--accent); animation: spin 0.8s linear infinite; }
  .run-result {
    display: flex; flex-direction: column;
    border: 1px solid var(--border); border-radius: var(--radius-md);
    background: var(--surface-2); overflow: hidden;
    box-shadow: var(--elev-2);
    animation: resultin var(--duration-medium) var(--ease-emphasized);
  }
  /* a thin accent crown so the final output reads as the moment of the surface */
  .run-result::before { content: ""; display: block; height: 2px; background: linear-gradient(90deg, var(--accent), color-mix(in srgb, var(--accent) 30%, transparent) 70%, transparent); }
  @keyframes resultin { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  .run-result-head { display: flex; align-items: center; gap: var(--space-2); padding: var(--space-3); border-bottom: 1px solid var(--border-subtle); background: var(--surface-1); }
  .run-result-label { font-family: var(--font-mono); font-size: var(--font-size-xs); text-transform: uppercase; letter-spacing: var(--letter-spacing-eyebrow); color: var(--text-muted); font-weight: 600; }
  .egress { display: inline-flex; align-items: center; gap: 4px; font-family: var(--font-mono); font-size: 0.6875rem; padding: 1px var(--space-2); border-radius: var(--radius-pill); font-weight: 600; }
  .egress.local { color: var(--ok-strong); background: var(--ok-soft); }
  .egress.cloud { color: var(--info); background: var(--info-soft); }
  .egress.unknown { color: var(--text-faint); background: var(--surface-3); }
  .run-copy { margin-left: auto; display: inline-flex; align-items: center; gap: 4px; background: transparent; border: 1px solid var(--border); border-radius: var(--radius-xs); color: var(--text-muted); font-family: var(--font-mono); font-size: 0.6875rem; padding: 2px var(--space-2); cursor: pointer; transition: color var(--duration-short) var(--ease-standard), border-color var(--duration-short) var(--ease-standard); }
  .run-copy:hover { color: var(--text); border-color: var(--border-strong); }
  .run-copy .copied { color: var(--ok-strong); }

  /* provenance ribbon — produced by / from / provider, under the head */
  .run-provenance {
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2) var(--space-3);
    padding: var(--space-2) var(--space-3);
    background: color-mix(in srgb, var(--accent) 5%, var(--surface-1));
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-mono); font-size: 0.6875rem;
  }
  .prov-produced, .prov-from, .prov-provider { display: inline-flex; align-items: center; gap: 5px; }
  .prov-label { color: var(--text-faint); text-transform: lowercase; }
  .prov-produced .prov-label { text-transform: none; }
  .prov-name { color: var(--text); font-weight: 600; }
  .prov-kind {
    color: var(--accent); background: var(--accent-tint);
    border-radius: var(--radius-xs); padding: 0 5px; text-transform: uppercase;
    letter-spacing: 0.04em; font-size: 0.625rem;
  }
  .prov-from .prov-ref { color: var(--text-muted); font-weight: 600; }
  .prov-from .prov-ref + .prov-ref::before { content: ", "; color: var(--text-faint); font-weight: 400; }
  .prov-from .prov-ref.unresolved { color: var(--text-faint); font-weight: 400; }
  .prov-provider { margin-left: auto; color: var(--text-muted); }
  .prov-provider svg { color: var(--warn-signal); }

