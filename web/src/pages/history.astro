                            </thead>
                            <tbody>
                              <template x-for="(r, ri) in risksFor(artifact)" :key="`risk${ri}`">
                                <tr>
                                  <td x-text="r.risk"></td>
                                  <td><span class="level-pill" :class="`level-${r.impact}`" x-text="r.impact"></span></td>
                                  <td><span class="level-pill" :class="`level-${r.likelihood}`" x-text="r.likelihood"></span></td>
                                  <td x-text="r.mitigation || '—'"></td>
