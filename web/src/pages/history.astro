    font-size: var(--font-size-sm);
  }
  .check-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* Workbench gadgets — flat with hard 1px black border. The
   * `.btn.primary` / `.btn.danger` legacy modifiers stay in
   * the markup contract; we just paint them the new way. */
  .btn {
    appearance: none;
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    cursor: pointer;
    transition: background var(--duration-short) var(--ease-standard),
                color var(--duration-short) var(--ease-standard);
  }
  .btn:hover:not(:disabled) { background: var(--surface-2); }
  .btn:disabled {
    background: var(--disabled-bg);
    color: var(--disabled-fg);
    border-color: var(--disabled-border);
    cursor: not-allowed;
  }
  .btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .btn.primary {
    background: var(--accent);
    border-color: var(--border);
    color: var(--accent-on);
  }
  .btn.primary:hover:not(:disabled) { background: var(--accent-strong); }
  .btn.danger, .btn--ghost.danger {
    color: var(--danger);
    border-color: var(--border);
    background: var(--danger-soft);
  }
  .btn.danger:hover:not(:disabled),
  .btn--ghost.danger:hover:not(:disabled) {
    background: var(--danger);
    color: var(--text);
  }

  /* === Cards (meetings, actions, intel) ================== */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-3);
  }
  .layout-split {
    display: grid;
    grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 800px) {
    .layout-split { grid-template-columns: 1fr; }
  }

  /* Workbench rows — square, hard black border, hover lights
   * background; selected row uses the inverse-bar idiom (blue
   * fill, white text). */
  .meeting-card, .action-card, .speaker-card, .segment {
    appearance: none;
    text-align: left;
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: var(--space-3);
    color: var(--text);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    cursor: pointer;
    transition: background var(--duration-short) var(--ease-standard),
                color var(--duration-short) var(--ease-standard);
  }
  .segment, .meeting-card--static { cursor: default; }
  .meeting-card:hover:not(.meeting-card--static):not(.meeting-card--selected),
  .action-card:hover,
  .speaker-card:hover:not(.active) { background: var(--accent-tint); }
  .speaker-card.active,
  .meeting-card--selected {
    background: var(--selected-bg);
    color: var(--selected-fg);
    border-color: var(--border);
