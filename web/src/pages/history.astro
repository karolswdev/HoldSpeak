                      <template x-if="customerSignalsFor(artifact).length">
                        <ul class="signal-list">
                          <template x-for="(s, si) in customerSignalsFor(artifact)" :key="`sig${si}`">
                            <li class="signal-item">
                              <span class="signal-type" :class="s.type" x-text="(s.type || '').replace('_',' ')"></span>
                              <span class="signal-text" x-text="s.signal"></span>
                              <span class="signal-quote" x-show="s.quote" x-cloak x-text="` “${s.quote}”`"></span>
                            </li>
                          </template>
                        </ul>
                      </template>
                      <template x-if="incidentEventsFor(artifact).length">
                        <ol class="incident-timeline">
                          <template x-for="(e, ei) in incidentEventsFor(artifact)" :key="`evt${ei}`">
                            <li>
                              <span class="evt-time" x-show="e.time" x-cloak x-text="e.time"></span>
                              <span class="evt-text" x-text="e.event"></span>
                            </li>
                          </template>
                        </ol>
                      </template>
                      <template x-if="runbookChangesFor(artifact).length">
                        <ul class="runbook-list">
                          <template x-for="(c, ci) in runbookChangesFor(artifact)" :key="`rbk${ci}`">
                            <li class="runbook-change">
                              <span class="runbook-type" :class="c.type" x-text="c.type"></span>
                              <span class="runbook-text" x-text="c.change"></span>
                              <span class="runbook-detail" x-show="c.detail" x-cloak x-text="` — ${c.detail}`"></span>
                            </li>
                          </template>
                        </ul>
                      </template>
                      <template x-if="stakeholderUpdateFor(artifact)">
                        <div class="stakeholder-update">
                          <p class="su-headline" x-show="stakeholderUpdateFor(artifact).headline" x-cloak x-text="stakeholderUpdateFor(artifact).headline"></p>
                          <template x-for="(sec, sx) in stakeholderSections(artifact)" :key="`su${sx}`">
                            <div class="su-section">
                              <p class="subhead" x-text="sec.label"></p>
                              <ul class="su-list">
                                <template x-for="(it, ix) in sec.items" :key="`sui${sx}-${ix}`">
                                  <li x-text="it"></li>
                                </template>
                              </ul>
                            </div>
                          </template>
                        </div>
                      </template>
                      <template x-if="announcementsFor(artifact).length">
                        <div class="announcement-artifact">
                          <template x-for="(a, ax) in announcementsFor(artifact)" :key="`ann${ax}`">
                            <div class="announcement">
                              <div class="ann-head">
                                <span class="ann-title" x-text="a.title"></span>
                                <span class="pill" x-show="a.audience" x-cloak x-text="a.audience"></span>
                              </div>
                              <p class="ann-message" x-show="a.message" x-cloak x-text="a.message"></p>
                            </div>
                          </template>
                        </div>
                      </template>
                      <p class="meta-line"
                         x-show="artifact.body_markdown && !hasStructuredRender(artifact)"
                         x-cloak x-text="artifact.body_markdown"></p>
                      </div>
                    </div>
                  </template>
                </div>
              </div>

              <!-- HS-37-03: actuator proposals — preview → approve/reject.
                   Viewing never acts; approval is required before anything runs. -->
              <div class="detail-card" x-show="selectedMeetingProposals.length" x-cloak>
                <h4>Proposed actions</h4>
                <p class="proposal-note">Actuator proposals — review the preview, then approve or reject. Viewing never triggers the action; nothing runs without your approval.</p>
                <div class="artifact-stack">
                  <template x-for="p in selectedMeetingProposals" :key="p.id">
                    <div class="artifact-card proposal-card" :class="`accent-${proposalAccent(p)}`" x-data="{ open: true, copyState: 'idle' }">
                      <div class="artifact-card__header">
                        <span class="artifact-card__icon" aria-hidden="true" x-text="proposalIcon(p)"></span>
                        <div class="artifact-card__heading">
                          <p class="artifact-card__title" x-text="`${p.action} → ${p.target}`"></p>
                          <div class="artifact-card__meta">
                            <span class="status-pill" :class="`proposal-${p.status}`" x-text="proposalStatusLabel(p.status)"></span>
                            <span class="pill" x-text="p.reversible ? 'reversible' : 'irreversible'"></span>
                            <span class="pill" x-show="p.decided_by" x-cloak x-text="`by ${p.decided_by}`"></span>
                          </div>
                        </div>
                        <div class="artifact-card__actions">
                          <button type="button" class="artifact-card__copy"
                                  :class="{ 'is-copied': copyState === 'done' }"
                                  title="Copy the preview + payload"
                                  @click="copyState = (await copyProposal(p)) ? 'done' : 'fail'; setTimeout(() => copyState = 'idle', 1400)"
                                  x-text="copyState === 'done' ? 'Copied' : copyState === 'fail' ? 'Press ⌘C' : 'Copy'"></button>
                          <button type="button" class="artifact-card__toggle"
                                  :aria-expanded="open ? 'true' : 'false'"
                                  :title="open ? 'Collapse' : 'Expand'"
                                  @click="open = !open" x-text="open ? '−' : '+'"></button>
                        </div>
                      </div>
                      <div class="artifact-card__body" x-show="open" x-cloak>
                        <pre class="proposal-preview"><code x-text="proposalPreviewText(p)"></code></pre>
                        <div class="proposal-actions" x-show="p.status === 'proposed'" x-cloak>
                          <button type="button" class="btn primary" @click="decideProposal(p, 'approved')">Approve</button>
                          <button type="button" class="btn" @click="decideProposal(p, 'rejected')">Reject</button>
                          <span class="proposal-guard">Nothing runs without your approval — this only records your decision.</span>
                        </div>
                        <p class="proposal-decided" x-show="p.status !== 'proposed'" x-cloak
                           x-text="proposalStatusLabel(p.status) + (p.decided_by ? ` · ${p.decided_by}` : '')"></p>
                      </div>
                    </div>
                  </template>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import factorySource from "../scripts/history-app.js?raw";
    import briefingMdSource from "../scripts/briefing-markdown.js?raw";

    // HS-13-09: prepend the shared briefing markdown renderer
    // so historyApp's project-briefing timeline can call
    // `renderBriefingMarkdown` / `briefingFirstLine` without
    // duplicating the implementation.
    const sharedSource = briefingMdSource
      .replace(/^\s*export\s+function/gm, "function");
    const fn = new Function(
      sharedSource + "\n" + factorySource + "; return historyApp;"
    );
    window.historyApp = fn();

    // HS-16-04: lazy mermaid loader. The dynamic import() lives in this real
    // module so the bundler code-splits mermaid.js into its own chunk, fetched
    // only when a diagram artifact is actually rendered (renderMermaid). The
    // raw-string historyApp can't carry a resolvable bare import itself.
    window.__loadMermaid = () => import("mermaid").then((m) => m.default ?? m);

    if (!window.Alpine) {
      window.Alpine = Alpine;
      Alpine.start();
    }
  </script>
</AppLayout>

<style>
  /* All values flow from tokens.css. */

  .shell {
    max-width: 88rem;
    margin: 0 auto;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* === Hero =============================================== */
  /* HS-12-02: history hero is the page's overview pane — keep
   * the white panel (Workbench window border) but tighten the
   * cavernous padding, scale the h1 to a sensible display
   * size, and brighten the eyebrow so it reads against white. */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--surface-2);
    border: 1px solid var(--border);
  }
  .hero h1 {
    margin: var(--space-1) 0 var(--space-2);
    font-family: var(--font-display);
    font-size: var(--font-size-2xl);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--text);
  }
  .eyebrow {
    margin: 0;
    color: var(--accent-strong);
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .hero-copy {
    margin: 0;
    color: var(--text-muted);
    line-height: var(--line-height-relaxed);
  }
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; }
  }

  /* === Metrics ============================================ */
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }
  .metric-grid--inline {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .metric {
    padding: var(--space-3);
    background: var(--surface-1);
    border: 1px solid var(--border);
  }
  .metric-label {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose);
  }
  .metric-value {
    margin-top: var(--space-1);
    color: var(--text);
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    line-height: 1.1;
  }
  .metric-note {
    margin-top: var(--space-1);
    color: var(--text-faint);
    font-size: var(--font-size-xs);
    line-height: var(--line-height-normal);
  }

  /* === Section + tabs (HS-12-02 Workbench window grammar) === */
  .section {
    background: var(--surface-2);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .section-head {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    justify-content: space-between;
    background: var(--surface-2);
    color: var(--text);
    border-bottom: 1px solid var(--border);
    padding: var(--space-2) var(--space-4);
  }
  .section-head h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: 400;
    color: var(--text);
    letter-spacing: 0.04em;
    line-height: 1.2;
  }
  .section-head p {
    margin: var(--space-1) 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: var(--font-size-sm);
  }
  .section-body {
    padding: var(--space-4);
  }
  .tab-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-3);
  }
  /* Tabs read as Workbench notebook tabs — square corners, hard
   * border on three sides, the active tab "merges" into the
   * panel below by losing its bottom border. */
  .tab {
    appearance: none;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-bottom: none;
    margin-right: -1px;
    margin-bottom: -1px;
    padding: var(--space-2) var(--space-3);
    color: var(--text-muted);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    cursor: pointer;
    transition: background var(--duration-short) var(--ease-standard),
                color var(--duration-short) var(--ease-standard);
  }
  .tab:hover { color: var(--text); background: var(--surface-2); }
  .tab.active {
    background: var(--surface-2);
    color: var(--text);
    font-weight: 500;
  }
  .tab:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: -2px;
    z-index: 1;
  }

  /* === Notice bar ======================================== */
  .notice {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-2);
    margin-bottom: var(--space-4);
    font-size: var(--font-size-sm);
  }
  .notice.ok {
    background: var(--success-soft, var(--accent-soft));
    color: var(--success, var(--text));
    border: 1px solid var(--success, var(--accent));
  }
  .notice.error {
    background: var(--danger-soft, var(--canvas));
    color: var(--danger);
    border: 1px solid var(--danger);
  }

  /* === Form / list controls ============================== */
  .stack { display: flex; flex-direction: column; gap: var(--space-3); }
  .stack-top { margin-top: var(--space-3); }
  .search-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }
  /* Sunken Workbench fields. */
  .input, .select {
    flex: 1 1 auto;
    min-width: 0;
    padding: var(--space-2) var(--space-3);
    background: var(--field-bg);
    border: 1px solid var(--field-border);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
