  .speaker-card:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: -2px;
  }

  .card-top {
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
    justify-content: space-between;
  }
  .card-id { min-width: 0; flex: 1 1 auto; text-align: left; }
  .card-title {
    margin: 0;
    color: var(--text);
    font-weight: 500;
    overflow-wrap: anywhere;
    line-height: var(--line-height-normal);
  }
  .card-subtitle {
    margin: var(--space-1) 0 0;
    color: var(--text-muted);
    font-size: var(--font-size-xs);
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    align-items: center;
  }
  .pill {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-pill);
    background: var(--canvas-raised);
    border: 1px solid var(--line);
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    font-family: var(--font-mono);
  }
  .status-pill {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-pill);
    font-size: var(--font-size-xs);
    font-family: var(--font-ui);
    border: 1px solid var(--line);
    color: var(--text-muted);
    background: var(--canvas-raised);
    text-transform: capitalize;
  }
  .status-pill.ready, .status-pill.completed, .status-pill.done,
  .status-pill.review-accepted {
    color: var(--success);
    border-color: var(--success);
    background: var(--success-soft, var(--accent-soft));
  }
  .status-pill.queued, .status-pill.scheduled, .status-pill.running,
  .status-pill.pending, .status-pill.review-pending {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .status-pill.failed, .status-pill.dismissed, .status-pill.error {
    color: var(--danger);
    border-color: var(--danger);
    background: var(--danger-soft, var(--canvas-raised));
  }
  .status-pill.disabled, .status-pill.unknown { color: var(--text-faint); }

  .meta-line {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    line-height: var(--line-height-normal);
    overflow-wrap: anywhere;
  }
  .meta-inline { margin-left: var(--space-3); }
  .mono { font-family: var(--font-mono); color: var(--text-faint); }

  /* HS-27-02: structured action-item checklist render. */
  .action-item-list {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  /* HS-36-03: action items read as ok-accented sub-cards within the shell. */
  .action-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    background: var(--surface-3);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid var(--ok);
    border-radius: var(--radius-sm);
  }
  .action-item .ai-task {
    font-size: var(--font-size-sm);
    font-weight: 600;
    overflow-wrap: anywhere;
  }
  .action-item .ai-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .pill.warn {
    color: var(--warn-strong, #b45309);
    border-color: var(--warn-strong, #b45309);
  }

  /* HS-27-03: decisions + open-questions render. */
  .decisions-artifact {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .decisions-artifact .subhead {
    margin: 0 0 var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose, 0.05em);
    color: var(--text-muted);
  }
  .decision-list {
    list-style: none;
    margin: 0;
    padding-left: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
  }
  .decision-list li {
    position: relative;
    overflow-wrap: anywhere;
  }
  .decision-list li::before {
    content: "▸";
    position: absolute;
    left: calc(-1 * var(--space-4) + 2px);
    color: var(--accent);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-normal);
  }
  .decision-list .rationale {
    color: var(--text-muted);
  }

  /* HS-27-04: requirements render, classified by type. */
  .requirement-list {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
  }
  .requirement-item {
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }
  /* HS-36-03: requirement type → typed Signal badge (not plain mono text). */
  .requirement-item .req-type {
    flex: none;
    display: inline-block;
    min-width: 6.5rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose, 0.05em);
    padding: 0 var(--space-1);
    border-radius: var(--radius-sm);
    color: var(--info);
    background: var(--info-soft);
    border: 1px solid var(--info);
  }
  .requirement-item .req-type.functional {
    color: var(--ok); background: var(--ok-soft); border-color: var(--ok);
  }
  .requirement-item .req-type.non_functional {
    color: var(--info); background: var(--info-soft); border-color: var(--info);
  }
  .requirement-item .req-type.constraint {
    color: var(--warn-signal); background: var(--warn-soft); border-color: var(--warn-signal);
  }
  .requirement-item .req-type.acceptance {
    color: var(--accent); background: var(--accent-soft); border-color: var(--accent);
  }
  .requirement-item .req-text { overflow-wrap: anywhere; }

  /* HS-28-02: Architecture Decision Records render. */
  .adr-artifact {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .adr-record {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    background: var(--surface-3);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid var(--info);
    border-radius: var(--radius-sm);
  }
  .adr-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .adr-head .adr-title {
    font-weight: 600;
  }
  .adr-line {
    margin: 0;
    font-size: var(--font-size-sm);
  }
  .adr-line .adr-label {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose, 0.05em);
    color: var(--text-muted);
    margin-right: var(--space-1);
  }

  /* HS-28-03: milestone plan render. */
  .milestone-artifact {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .milestone-record {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    background: var(--surface-3);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid var(--info);
    border-radius: var(--radius-sm);
  }
  .milestone-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .milestone-head .milestone-name {
    font-weight: 600;
  }
  .milestone-line {
    margin: 0;
    font-size: var(--font-size-sm);
  }
  .milestone-line .milestone-label {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose, 0.05em);
    color: var(--text-muted);
    margin-right: var(--space-1);
  }

  /* HS-28-04: risk register table. */
  /* HS-36-01: elevated artifact cards (Signal). Each meeting artifact is a card
     with a type-colored accent edge, a header (icon + title + type chip + meta +
     collapse toggle), and an overflow-safe body. The accent group is set by
     `artifactAccent()` and exposed to the children via the --artifact-accent var. */
  .artifact-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }
  .artifact-card {
    position: relative;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--elev-1);
    overflow: hidden;
    min-width: 0;
    --artifact-accent: var(--border-strong);
    transition: box-shadow var(--duration-short) var(--ease-standard),
                border-color var(--duration-short) var(--ease-standard);
  }
  .artifact-card:hover { box-shadow: var(--elev-2); border-color: var(--border-strong); }
  .artifact-card.accent-danger { --artifact-accent: var(--danger-signal); }
  .artifact-card.accent-warn   { --artifact-accent: var(--warn-signal); }
  .artifact-card.accent-accent { --artifact-accent: var(--accent); }
  .artifact-card.accent-info   { --artifact-accent: var(--info); }
  .artifact-card.accent-ok     { --artifact-accent: var(--ok); }
  .artifact-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--artifact-accent);
  }
  .artifact-card__header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-3);
    padding-left: calc(var(--space-3) + 4px);
  }
  .artifact-card__icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.875rem;
    height: 1.875rem;
    border-radius: var(--radius-sm);
    background: var(--surface-3);
    border: 1px solid var(--border-subtle);
    font-size: 1rem;
    line-height: 1;
  }
  .artifact-card__heading { flex: 1 1 auto; min-width: 0; }
  .artifact-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text);
    line-height: var(--line-height-tight);
    overflow-wrap: anywhere;
  }
  .artifact-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    align-items: center;
    margin-top: var(--space-2);
  }
  .artifact-chip {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose, 0.04em);
    color: var(--artifact-accent);
    background: var(--surface-3);
    border: 1px solid var(--artifact-accent);
  }
  .artifact-card__actions {
    flex: 0 0 auto;
    display: flex;
    gap: var(--space-1);
    align-items: center;
  }
  .artifact-card__toggle {
    appearance: none;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface-3);
    color: var(--text-muted);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--font-size-md);
    line-height: 1;
  }
  .artifact-card__toggle:hover { color: var(--text); border-color: var(--border-strong); }
  .artifact-card__toggle:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: 1px;
  }

  /* HS-36-02: per-artifact "Copy as Markdown" gadget — small Signal button in
   * the card header actions, beside the collapse toggle. Mirrors the
   * CommandPreview copy affordance (hover → accent, copied → success). */
  .artifact-card__copy {
    appearance: none;
    height: 1.5rem;
    padding: 0 var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface-3);
    color: var(--text-muted);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-loose, 0.04em);
    line-height: 1;
    white-space: nowrap;
    transition:
      background var(--duration-short) var(--ease-standard),
      color var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard);
  }
  .artifact-card__copy:hover { background: var(--accent); color: var(--accent-on); border-color: var(--accent); }
  .artifact-card__copy.is-copied {
    background: var(--success-soft, var(--surface-3));
    color: var(--success);
    border-color: var(--success);
  }
  .artifact-card__copy:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: 1px;
  }

  /* HS-36-02: Artifacts section header — title + "Copy all" on one row. */
  .artifact-section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .artifact-section-head h4 { margin: 0; }
  .artifact-copy-all {
    appearance: none;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface-3);
    color: var(--text-muted);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-loose, 0.04em);
    white-space: nowrap;
    transition:
      background var(--duration-short) var(--ease-standard),
      color var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard);
  }
  .artifact-copy-all:hover { background: var(--accent); color: var(--accent-on); border-color: var(--accent); }
  .artifact-copy-all.is-copied {
    background: var(--success-soft, var(--surface-3));
    color: var(--success);
    border-color: var(--success);
  }
  .artifact-copy-all:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: 1px;
  }
  .artifact-card__body {
    padding: 0 var(--space-3) var(--space-3);
    padding-left: calc(var(--space-3) + 4px);
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  /* Wide content (tables) scrolls within the card instead of forcing the modal
     wider — fixes the risk-table horizontal overflow. */
  .table-scroll {
    overflow-x: auto;
    max-width: 100%;
    -webkit-overflow-scrolling: touch;
  }

  .risk-table {
    width: 100%;
    min-width: 540px;
    border-collapse: collapse;
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
  }
  .risk-table td { overflow-wrap: anywhere; }
  .risk-table th,
  .risk-table td {
    text-align: left;
    padding: var(--space-1) var(--space-2);
    border-bottom: 1px solid var(--border-subtle, rgba(255, 255, 255, 0.08));
    vertical-align: top;
  }
  .risk-table th {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose, 0.05em);
    color: var(--text-muted);
    border-bottom-color: var(--border);
  }
  .risk-table tbody tr:hover { background: var(--surface-3); }
  /* HS-36-03: severity pills on the Signal palette (was off-palette --color-*). */
  .level-pill {
    display: inline-block;
    padding: 0 var(--space-1);
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
  }
  .level-pill.level-high {
    background: var(--danger-soft);
    color: var(--danger-signal);
    border-color: var(--danger-signal);
  }
  .level-pill.level-medium {
    background: var(--warn-soft);
    color: var(--warn-signal);
    border-color: var(--warn-signal);
  }
  .level-pill.level-low {
    background: var(--ok-soft);
    color: var(--ok);
    border-color: var(--ok);
  }

  /* HS-29-01: dependency map / scope review / customer signals. */
  .dependency-list,
  .scope-list,
  .signal-list {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
  }
  /* HS-36-03: dependency nodes read as chips with an accented flow arrow. */
  .dependency-list li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-1);
  }
  .dependency-list .dep-from,
  .dependency-list .dep-to {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    padding: 0 var(--space-1);
    border-radius: var(--radius-sm);
    background: var(--surface-3);
    border: 1px solid var(--border-subtle);
    overflow-wrap: anywhere;
  }
  .dependency-list .dep-arrow {
    color: var(--accent);
    font-weight: 600;
    margin: 0 var(--space-1);
  }
  .dependency-list .dep-note,
  .scope-rationale,
  .signal-quote {
    color: var(--text-muted);
  }
  .signal-quote { font-style: italic; }
  .scope-finding,
  .signal-item {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-2);
    align-items: baseline;
  }
  /* HS-36-03: scope/signal type chips → bordered Signal badges. */
  .scope-verdict,
  .signal-type {
    flex: none;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose, 0.05em);
    padding: 0 var(--space-1);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
  }
  .scope-verdict.scope_creep,
  .signal-type.churn_risk,
  .signal-type.pain {
    background: var(--warn-soft);
    color: var(--warn-signal);
    border-color: var(--warn-signal);
  }
  .scope-verdict.out_of_scope {
    background: var(--surface-3);
    color: var(--text-muted);
  }
  .scope-verdict.in_scope,
  .signal-type.praise {
    background: var(--ok-soft);
    color: var(--ok);
    border-color: var(--ok);
  }
  .signal-type.request {
    background: var(--info-soft);
    color: var(--info);
    border-color: var(--info);
  }

  /* HS-29-02 / HS-36-03: incident timeline as a real rail (vertical line +
     node dots), not a bare ordered list. The <ol class="incident-timeline">
     + <li> structure is preserved (asserted by the spoken-e2e). */
  .incident-timeline {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0 0 0 var(--space-4);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-size: var(--font-size-sm);
  }
  .incident-timeline::before {
    content: "";
    position: absolute;
    top: 0.4rem;
    bottom: 0.4rem;
    left: var(--space-2);
    width: 2px;
    background: var(--danger-soft);
  }
  .incident-timeline li {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-1) var(--space-2);
  }
  .incident-timeline li::before {
    content: "";
    position: absolute;
    left: calc(var(--space-2) - var(--space-4) - 3px);
    top: 0.35rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--danger-signal);
    border: 2px solid var(--surface-2);
    box-shadow: 0 0 0 1px var(--danger-signal);
  }
  .incident-timeline .evt-time {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--danger-signal);
    background: var(--danger-soft);
    padding: 0 var(--space-1);
    border-radius: var(--radius-sm);
  }
  .incident-timeline .evt-text { overflow-wrap: anywhere; }
  .runbook-list {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
  }
  .runbook-change {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-2);
    align-items: baseline;
  }
  .runbook-type {
    flex: none;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose, 0.05em);
    padding: 0 var(--space-1);
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
  }
  .runbook-type.added {
    background: var(--ok-soft);
    color: var(--ok);
    border-color: var(--ok);
  }
  .runbook-type.removed {
    background: var(--danger-soft);
    color: var(--danger-signal);
    border-color: var(--danger-signal);
  }
  .runbook-type.modified {
    background: var(--warn-soft);
    color: var(--warn-signal);
    border-color: var(--warn-signal);
  }
  .runbook-detail {
    color: var(--text-muted);
  }

  /* HS-29-03: stakeholder update / decision announcements. */
  .stakeholder-update,
  .announcement-artifact {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .su-headline {
    margin: 0;
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--accent);
  }
  .su-section .subhead,
  .announcement .ann-title {
    margin: 0 0 var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose, 0.05em);
    color: var(--text-muted);
  }
  /* HS-36-03: stakeholder sections get typed markers per label. */
  .su-list {
    list-style: none;
    margin: 0;
    padding-left: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
  }
  .su-list li {
    position: relative;
    overflow-wrap: anywhere;
  }
  .su-list li::before {
    content: "•";
    position: absolute;
    left: calc(-1 * var(--space-4) + 2px);
    color: var(--accent);
  }
  /* HS-36-03: each announcement is an accent-edged comms sub-card. */
  .announcement {
    padding: var(--space-2) var(--space-3);
    background: var(--surface-3);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid var(--accent);
    border-radius: var(--radius-sm);
  }
  .announcement .ann-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .announcement .ann-title {
    color: var(--text);
    text-transform: none;
    font-family: inherit;
    font-size: var(--font-size-sm);
    font-weight: 600;
  }
  .announcement .ann-message {
    margin: var(--space-1) 0 0;
    font-size: var(--font-size-sm);
    white-space: pre-wrap;
  }

  /* HS-16-04: rendered Mermaid diagram artifact. */
  .mermaid-artifact {
    margin-top: var(--space-2);
