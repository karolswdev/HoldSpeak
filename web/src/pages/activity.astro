---
// HS-10-07: `/activity` rebuilt on the design system.
//
// The legacy page used vanilla JS (no Alpine) that grabs DOM by ID
// and renders content via innerHTML / template literals. To keep
// product behavior unchanged, the JS module is shipped verbatim from
// web/src/scripts/activity-app.js and the page preserves every DOM
// ID it touches plus every class name it emits inside content
// (`.record`, `.record-top`, `.record-title`, `.record-meta`,
// `.rule-item`, `.rule-item.candidate-preview-item`,
// `.rule-item.candidate-saved-item`, `.rule-actions`, `.row`,
// `.label`, `.value`, `.tag`, `.empty`).
//
// Astro components are not used directly because (a) the JS injects
// nested HTML into containers via innerHTML and (b) class names like
// `.danger` / `.primary` on raw <button>s would conflict with the
// component-scoped CSS. The page consumes tokens directly.

import AppLayout from "../layouts/AppLayout.astro";
import CommandPreview from "../components/CommandPreview.astro";
---

<AppLayout title="HoldSpeak Activity" current="activity">
  <div class="activity">
    <header class="page-head">
      <div>
        <h1>Local activity</h1>
        <p class="sub">
          Private browser-history metadata used as plugin context.
          Local-only, inspectable, pausable, deletable.
        </p>
      </div>
      <span id="enabled-pill" class="pill pill--neutral"><span class="pill-dot"></span>Loading</span>
    </header>

    <div class="grid">
      <!-- Side rail (controls + sources + excluded) -->
      <aside class="rail">
        <section class="panel">
          <header class="panel-header"><div class="panel-title">Controls</div></header>
          <div class="panel-body">
            <div class="row"><span class="label">Records</span><span id="record-count" class="value mono">0</span></div>
            <div class="row"><span class="label">Retention days</span><span id="retention-value" class="value mono">30</span></div>
            <div class="button-row">
              <button id="toggle-enabled" class="btn btn--primary btn--sm primary" type="button">Pause</button>
              <button id="refresh" class="btn btn--secondary btn--sm" type="button">Refresh</button>
              <button id="clear" class="btn btn--ghost btn--sm danger" type="button">Clear imported</button>
            </div>
            <div class="form-row">
              <input id="retention-input" class="input" type="number" min="1" max="3650" value="30" aria-label="Retention days"/>
              <button id="save-retention" class="btn btn--secondary btn--sm" type="button">Save</button>
            </div>
            <p id="message" class="sub"></p>
            <p id="error" class="error"></p>
          </div>
        </section>

        <section class="panel">
          <header class="panel-header"><div class="panel-title">Sources</div></header>
          <div class="panel-body">
            <div id="sources"></div>
          </div>
        </section>

        <section class="panel">
          <header class="panel-header"><div class="panel-title">Excluded domains</div></header>
          <div class="panel-body">
            <div class="form-row">
              <input id="domain-input" class="input" placeholder="example.com" aria-label="Domain to exclude"/>
              <button id="exclude-domain" class="btn btn--secondary btn--sm" type="button">Exclude</button>
            </div>
            <p id="domains-message" class="panel-message"></p>
            <div id="domains"></div>
          </div>
        </section>
      </aside>

      <!-- Main column (rules + candidates + records) -->
      <div class="main">
        <section class="panel">
          <header class="panel-header"><div class="panel-title">Project rules</div></header>
          <div class="panel-body">
            <input id="rule-id" type="hidden"/>
            <div class="field-grid">
              <div class="field"><label for="rule-project">Project</label><select id="rule-project" class="input"></select></div>
              <div class="field"><label for="rule-match-type">Match</label>
                <select id="rule-match-type" class="input">
                  <option value="domain">Domain</option>
                  <option value="url_contains">URL contains</option>
                  <option value="title_contains">Title contains</option>
                  <option value="entity_type">Entity type</option>
                  <option value="entity_id_prefix">Entity ID prefix</option>
                  <option value="github_repo">GitHub repo</option>
                  <option value="source_browser">Source browser</option>
                </select>
              </div>
              <div class="field"><label for="rule-pattern">Pattern</label><input id="rule-pattern" class="input" placeholder="example.com"/></div>
              <div class="field"><label for="rule-entity-type">Entity type</label><input id="rule-entity-type" class="input" placeholder="optional"/></div>
              <div class="field"><label for="rule-name">Name</label><input id="rule-name" class="input" placeholder="HoldSpeak Jira"/></div>
              <div class="field"><label for="rule-priority">Priority</label><input id="rule-priority" class="input" type="number" value="100"/></div>
            </div>
            <label class="toggle-field">
              <input id="rule-enabled" type="checkbox" checked/>
              <span>Enabled</span>
            </label>
            <div class="button-row">
              <button id="preview-rule" class="btn btn--secondary btn--sm" type="button">Preview</button>
              <button id="save-rule" class="btn btn--primary btn--sm primary" type="button">Save rule</button>
              <button id="reset-rule" class="btn btn--ghost btn--sm" type="button">New</button>
              <button id="apply-rules" class="btn btn--secondary btn--sm" type="button">Apply all</button>
            </div>
            <p id="rules-message" class="panel-message"></p>
            <div id="rule-preview" class="preview-list"></div>
            <div id="rules" class="rule-list"></div>
          </div>
        </section>

        <section class="panel">
          <header class="panel-header"><div class="panel-title">Connectors</div></header>
          <div class="panel-body">
            <p class="sub">
              Local-only enrichment connectors. None run unless explicitly
              enabled. Output (annotations, candidates) lives on this machine
              and can be cleared per connector.
            </p>
            <p id="connectors-message" class="panel-message"></p>
            <div id="connectors" class="connector-list"></div>
          </div>
        </section>

        <section class="panel">
          <header class="panel-header">
            <div class="panel-title">Meeting candidates</div>
            <div class="panel-toolbar">
              <select id="candidate-status-filter" class="input input--sm" aria-label="Candidate status filter">
                <option value="">All saved</option>
                <option value="candidate">Candidates</option>
                <option value="armed">Armed</option>
                <option value="started">Started</option>
                <option value="dismissed">Dismissed</option>
              </select>
            </div>
          </header>
          <div class="panel-body">
            <div class="button-row">
              <button id="preview-candidates" class="btn btn--secondary btn--sm" type="button">Preview</button>
              <button id="refresh-candidates" class="btn btn--ghost btn--sm" type="button">Refresh saved</button>
              <button id="clear-dismissed-candidates" class="btn btn--ghost btn--sm danger" type="button">Clear dismissed</button>
            </div>
            <p id="candidates-message" class="panel-message"></p>
            <div id="candidate-preview" class="candidate-list"></div>
            <div id="meeting-candidates" class="candidate-list"></div>
          </div>
        </section>

        <section class="panel">
          <header class="panel-header"><div class="panel-title">Recent activity</div></header>
          <div class="panel-body">
            <div id="records" class="records"></div>
          </div>
        </section>
      </div>
    </div>
  </div>

  {/* HS-9-13: hidden CommandPreview anchor — bundles the scoped
      .cmd CSS + the document-wide [data-cmd-copy] delegator with this
      page so the dynamically-rendered cmd figures inside each
      connector card's dry-run output get the same copy behaviour as
      everywhere else. */}
  <div hidden aria-hidden="true">
    <CommandPreview command="gh pr view 1" />
  </div>

  <script>
    import factorySource from "../scripts/activity-app.js?raw";
    // The activity JS is a top-level IIFE-style script that registers
    // event handlers and calls load() at the end. Eval it once on
    // module import; the browser handles handler binding from there.
    new Function(factorySource)();
  </script>
</AppLayout>

<style>
  /* All values flow from tokens.css. Class names below are split:
     prefixed `.btn`/`.pill`/`.panel` mirror the design system; the
     bare `.row`/`.label`/`.value`/`.record*`/`.rule-item` etc. are
     contracts the JS module emits and we style here without
     renaming. */

  .activity {
    max-width: 88rem;
    margin: 0 auto;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .page-head {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: var(--space-4); flex-wrap: wrap;
  }
  .page-head h1 {
    margin: 0; font-size: var(--font-size-3xl);
    letter-spacing: var(--letter-spacing-tight);
  }
  .page-head .sub {
    margin: var(--space-2) 0 0;
    color: var(--text-muted);
    line-height: var(--line-height-relaxed);
    max-width: 64ch;
  }

  .grid {
    display: grid;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    gap: var(--space-5);
    align-items: start;
  }
  .rail, .main { display: flex; flex-direction: column; gap: var(--space-4); }

  /* === Pills === */
  .pill {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    font-size: var(--font-size-xs); font-weight: 500;
    letter-spacing: var(--letter-spacing-loose);
    border: 1px solid var(--line);
    background: var(--canvas-raised); color: var(--text-muted);
  }
  .pill-dot { width: var(--space-2); height: var(--space-2); border-radius: 50%; background: currentColor; }
  .pill--success { color: var(--success); background: var(--success-soft); border-color: transparent; }
  .pill--warn { color: var(--warn); background: var(--warn-soft); border-color: transparent; }
  .pill--danger { color: var(--danger); background: var(--danger-soft); border-color: transparent; }

  /* === Panels === */
  /* HS-12-02: Workbench window treatment — blue title strip,
   * white VT323 caption, hard black border, no shadow. */
  .panel {
    background: var(--canvas-raised);
    border: 1px solid var(--wb-black);
    overflow: hidden;
  }
  .panel-header {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    background: var(--wb-blue);
    color: var(--wb-white);
    border-bottom: 1px solid var(--wb-black);
  }
  .panel-title {
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: 400;
    color: var(--wb-white);
    letter-spacing: 0.04em;
    line-height: 1.2;
  }
  .panel-body { padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-3); }
  .panel-toolbar { display: flex; align-items: center; gap: var(--space-2); }
  .panel-toolbar .btn--ghost { color: var(--wb-white); }

  /* === Form / row primitives (JS-emitted contracts) === */
  .row {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--line);
  }
  .row:last-child { border-bottom: 0; }
  .label { color: var(--text-muted); font-size: var(--font-size-sm); }
  .value { color: var(--text); font-size: var(--font-size-md); }
  .value.mono { font-family: var(--font-mono); }

  .form-row {
    display: flex; align-items: center; gap: var(--space-2);
    flex-wrap: wrap;
  }
  .form-row .input { flex: 1 1 auto; min-width: 0; }

  .field-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-3);
  }
  .field { display: flex; flex-direction: column; gap: var(--space-1); }
  .field label {
    color: var(--text-muted); font-size: var(--font-size-xs);
    text-transform: uppercase; letter-spacing: var(--letter-spacing-loose);
  }
  .toggle-field {
    display: inline-flex; align-items: center; gap: var(--space-2);
    color: var(--text-muted); font-size: var(--font-size-sm);
    cursor: pointer;
  }

  /* HS-12-02 (slice 3): sunken Workbench-style fields. The
   * pale-grey fill + slate border reads as "data goes here";
   * focus shifts the border to the orange accent. */
  .input {
    width: 100%; padding: var(--space-2) var(--space-3);
    background: var(--field-bg);
    border: 1px solid var(--field-border);
    color: var(--text);
    font-family: var(--font-ui); font-size: var(--font-size-sm);
  }
  .input--sm { width: auto; }
  .input:focus-visible {
    outline: none;
    border-color: var(--field-focus-border);
    background: var(--wb-white);
  }

  .button-row {
    display: flex; flex-wrap: wrap; gap: var(--space-2);
  }

  /* === Buttons (Workbench gadgets — flat with hard 1px black
   * border; mirrors the same scoped CSS now in /history). */
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-ui); font-weight: 500;
    font-size: var(--font-size-sm); line-height: 1;
    letter-spacing: var(--letter-spacing-loose);
    background: var(--wb-white);
    border: 1px solid var(--wb-black);
    color: var(--text);
    cursor: pointer;
    transition: background var(--duration-short) var(--ease-standard),
                color var(--duration-short) var(--ease-standard);
  }
  .btn:hover:not(:disabled) { background: var(--wb-gray-6); }
  .btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .btn:disabled {
    background: var(--disabled-bg);
    color: var(--disabled-fg);
    border-color: var(--disabled-border);
    cursor: not-allowed;
  }
  .btn--primary, .btn.primary {
    background: var(--accent); color: var(--accent-on); border-color: var(--wb-black);
  }
  .btn--primary:not(:disabled):hover, .btn.primary:not(:disabled):hover {
    background: var(--accent-strong);
  }
  .btn--secondary {
    background: var(--wb-white); color: var(--text); border-color: var(--wb-black);
  }
  .btn--secondary:not(:disabled):hover { background: var(--wb-gray-6); }
  .btn--ghost {
    background: transparent; color: inherit; border-color: transparent;
  }
  .btn--ghost:not(:disabled):hover { border-color: currentColor; background: transparent; }
  /* Destructive: clearly red, full chrome (not ghost-soft) so the
   * action reads as the destructive thing it is. */
  .btn.danger, .btn--ghost.danger {
    color: var(--wb-white);
    background: var(--danger);
    border-color: var(--wb-black);
  }
  .btn.danger:not(:disabled):hover,
  .btn--ghost.danger:not(:disabled):hover {
    background: var(--danger-strong);
  }

  /* === Empty / error / message text === */
  .empty {
    padding: var(--space-4);
    color: var(--text-muted);
    background: var(--canvas);
    border: 1px dashed var(--line-strong);
    border-radius: var(--radius-2);
    line-height: var(--line-height-relaxed);
    font-size: var(--font-size-sm);
  }
  .empty strong {
    display: block; color: var(--text); margin-bottom: var(--space-1);
    font-weight: 600;
  }
  .error { margin: 0; color: var(--danger); font-size: var(--font-size-sm); }
  .panel-message { margin: 0; color: var(--text-muted); font-size: var(--font-size-sm); }
  .panel-message.error { color: var(--danger); }

  /* === Records list (JS-emitted) === */
  .records, .rule-list, .candidate-list, .preview-list, .connector-list {
    display: flex; flex-direction: column; gap: var(--space-2);
  }

  /* === Connector cards (HS-9-12) === */
  /* HS-12-02: connector cards as Workbench tool windows. The
   * is-disabled state desaturates the surface rather than
   * lowering opacity (more legible). has-error swaps the top
   * border to the danger ramp so a glance picks it out. */
  .connector-card {
    padding: var(--space-3);
    background: var(--wb-white);
    border: 1px solid var(--wb-black);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .connector-card.is-disabled { background: var(--wb-gray-7); }
  .connector-card.has-error {
    border-top: 3px solid var(--danger);
  }
  .connector-head {
    display: flex; align-items: center; flex-wrap: wrap;
    gap: var(--space-2); justify-content: space-between;
  }
  .connector-head-left {
    display: flex; align-items: center; gap: var(--space-2);
    min-width: 0; flex-wrap: wrap;
  }
  .connector-title {
    color: var(--text); font-weight: 600;
    font-size: var(--font-size-md);
    overflow-wrap: anywhere;
  }
  .connector-id {
    font-family: var(--font-mono); font-size: var(--font-size-xs);
    color: var(--text-muted);
  }
  .connector-meta {
    color: var(--text-muted); font-size: var(--font-size-xs);
    overflow-wrap: anywhere;
  }
  .connector-body { color: var(--text-muted); font-size: var(--font-size-sm); margin: 0; line-height: var(--line-height-relaxed); }
  .connector-error {
    color: var(--danger-strong);
    font-size: var(--font-size-sm);
    background: var(--danger-soft);
    border: 1px solid var(--danger);
    padding: var(--space-2) var(--space-3);
    margin: 0;
    word-break: break-word;
  }
  .connector-actions {
    display: flex; flex-wrap: wrap; gap: var(--space-2);
  }

  /* === Dry-run output (HS-9-13) === */
  .dry-run-output {
    display: flex; flex-direction: column; gap: var(--space-3);
    padding: var(--space-3);
    background: var(--canvas-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
  }
  .dry-section { display: flex; flex-direction: column; gap: var(--space-2); }
  .dry-section-title {
    margin: 0; font-size: var(--font-size-sm); font-weight: 600;
    color: var(--text-muted); letter-spacing: var(--letter-spacing-loose);
    text-transform: uppercase;
  }
  .dry-list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: var(--space-1);
  }
  .dry-list-item {
    display: flex; flex-direction: column; gap: 2px;
    padding: var(--space-2) var(--space-3);
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
  }
  .dry-list-title { color: var(--text); font-weight: 500; overflow-wrap: anywhere; }
  .dry-list-meta {
    color: var(--text-muted); font-size: var(--font-size-xs);
    overflow-wrap: anywhere;
  }
  .dry-note {
    margin: 0; padding: var(--space-2) var(--space-3);
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    color: var(--text-muted); font-size: var(--font-size-sm);
  }
  .dry-note--warn {
    background: var(--warn-soft);
    border-color: transparent;
    color: var(--warn);
  }

  .record {
    padding: var(--space-3);
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
  }
  .record-top {
    display: flex; flex-wrap: wrap; align-items: center;
    gap: var(--space-2); margin-bottom: var(--space-1);
  }
  .record-title {
    color: var(--text); font-weight: 500;
    overflow-wrap: anywhere; word-break: break-word;
    line-height: var(--line-height-normal);
  }
  .record-meta {
    color: var(--text-faint); font-size: var(--font-size-xs);
    overflow-wrap: anywhere; word-break: break-word;
    margin-top: var(--space-1);
  }

  /* === Rule + candidate items (JS-emitted) ===
     Preview vs saved candidate visual grammar is the AC payoff:
     - .candidate-preview-item: dashed border + accent-soft tint
       reads as "transient, not yet committed"
     - .candidate-saved-item: solid accent border + filled accent-
       soft background reads as "saved, anchored"
     A user scanning a list of mixed rows can tell preview from
     saved at a 2-second glance from shape alone (border style)
     plus tone (transparent vs filled).
  */
  .rule-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-3);
    padding: var(--space-3);
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
  }
  .rule-item .record-title { font-weight: 500; }
  .rule-item.candidate-preview-item {
    border-style: dashed;
    border-color: var(--line-emphasis);
    background: var(--canvas);
  }
  .rule-item.candidate-saved-item {
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .rule-actions {
    display: flex; flex-wrap: wrap; gap: var(--space-2);
    align-items: flex-start;
  }

  /* === Tag (rule preview matches) === */
  .tag {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-pill);
    font-size: var(--font-size-xs);
    font-family: var(--font-mono);
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid transparent;
    margin-right: var(--space-1);
  }

  /* === Sources / domains list === */
  #sources > div, #domains > div {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--space-2);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--line);
    color: var(--text);
    font-size: var(--font-size-sm);
  }
  #sources > div:last-child, #domains > div:last-child { border-bottom: 0; }

  .sub { color: var(--text-muted); font-size: var(--font-size-sm); margin: 0; line-height: var(--line-height-relaxed); }

  /* === Status pill (#enabled-pill) tones via JS class swap === */
  #enabled-pill.status-pill { color: var(--text-muted); }
  #enabled-pill.success { color: var(--success); background: var(--success-soft); border-color: transparent; }
  #enabled-pill.warn { color: var(--warn); background: var(--warn-soft); border-color: transparent; }
  #enabled-pill.danger { color: var(--danger); background: var(--danger-soft); border-color: transparent; }
  #enabled-pill.danger .pill-dot, #enabled-pill.warn .pill-dot, #enabled-pill.success .pill-dot { background: currentColor; }

  @media (max-width: 960px) {
    .grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .activity { padding: var(--space-3); gap: var(--space-3); }
    .page-head { flex-direction: column; align-items: flex-start; }
  }
</style>
