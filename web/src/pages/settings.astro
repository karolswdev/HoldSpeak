---
// HS-42-02: the global Settings surface.
//
// The "History → Settings" content lifted into a real, shell-level route
// (completing the HS-30-08 move). Reachable from the TopNav gear on every page.
// Every field is global runtime config, backed by GET/PUT /api/settings via the
// `settingsApp()` factory (src/scripts/settings-app.js). Page-local settings
// (e.g. the /dictation Copilot-depth cockpit) stay on their own routes.
import AppLayout from "../layouts/AppLayout.astro";
---

<AppLayout title="HoldSpeak — Settings" description="Global HoldSpeak runtime settings">
  <div class="settings-page" x-data="settingsApp()" x-init="init()">
    <header class="set-header">
      <p class="eyebrow">Configuration</p>
      <h1>Settings</h1>
      <p class="lead">
        Every global HoldSpeak setting, in one place. Changes apply to your local
        runtime — nothing here leaves your machine unless you point intel at a
        cloud endpoint below.
      </p>
      <span class="local-chip" aria-hidden="true">
        <span class="dot"></span> Local · 127.0.0.1
      </span>
    </header>

    <div x-show="loading" class="set-loading" x-cloak>Loading settings…</div>

    <div class="set-notice error" x-show="errors.length > 0" x-cloak role="alert">
      <p class="set-notice-title">Fix these before saving</p>
      <template x-for="err in errors" :key="err">
        <p class="set-notice-line" x-text="`• ${err}`"></p>
      </template>
    </div>

    <template x-if="settings">
      <form class="set-form" @submit.prevent="save">
        <!-- Appearance & UI -->
        <section class="set-card">
          <div class="set-card-head">
            <h2>Appearance &amp; UI</h2>
            <p>How the dashboard looks and how much transcript it keeps on screen.</p>
          </div>
          <div class="set-grid">
            <div class="field">
              <label>Theme</label>
              <select class="select" x-model="settings.ui.theme">
                <option value="dark">Dark</option>
                <option value="light">Light</option>
                <option value="dracula">Dracula</option>
                <option value="monokai">Monokai</option>
              </select>
            </div>
            <div class="field">
              <label>History lines</label>
              <input class="input" type="number" min="1" max="100" x-model.number="settings.ui.history_lines" />
            </div>
            <label class="check field full">
              <input type="checkbox" x-model="settings.ui.show_audio_meter" />
              <span>Show audio meter</span>
            </label>
          </div>
        </section>

        <!-- Core -->
        <section class="set-card">
          <div class="set-card-head">
            <h2>Core</h2>
            <p>Hotkey, transcription model, and meeting capture defaults.</p>
          </div>
          <div class="set-grid">
            <div class="field">
              <label>Hotkey</label>
              <select class="select" x-model="settings.hotkey.key">
                <option value="alt_r">Alt Right</option>
                <option value="alt_l">Alt Left</option>
                <option value="ctrl_r">Ctrl Right</option>
                <option value="ctrl_l">Ctrl Left</option>
                <option value="cmd_r">Cmd Right</option>
                <option value="cmd_l">Cmd Left</option>
                <option value="shift_r">Shift Right</option>
                <option value="shift_l">Shift Left</option>
                <option value="caps_lock">Caps Lock</option>
                <option value="fn">Fn</option>
                <option value="f1">F1</option><option value="f2">F2</option>
                <option value="f3">F3</option><option value="f4">F4</option>
                <option value="f5">F5</option><option value="f6">F6</option>
                <option value="f7">F7</option><option value="f8">F8</option>
                <option value="f9">F9</option><option value="f10">F10</option>
                <option value="f11">F11</option><option value="f12">F12</option>
              </select>
            </div>
            <div class="field">
              <label>Whisper model</label>
              <select class="select" x-model="settings.model.name">
                <option value="tiny">tiny</option>
                <option value="base">base</option>
                <option value="small">small</option>
                <option value="medium">medium</option>
                <option value="large">large</option>
              </select>
            </div>
            <label class="check field full">
              <input type="checkbox" x-model="settings.model.warm_on_start" />
              <span>Warm Whisper on web startup <em>— preloads transcription so the first utterance isn't slow.</em></span>
            </label>
            <div class="field">
              <label>Mic label</label>
              <input class="input" type="text" x-model="settings.meeting.mic_label" />
            </div>
            <div class="field">
              <label>Remote label</label>
              <input class="input" type="text" x-model="settings.meeting.remote_label" />
            </div>
            <div class="field">
              <label>Export format</label>
              <select class="select" x-model="settings.meeting.export_format">
                <option value="txt">txt</option>
                <option value="markdown">markdown</option>
                <option value="json">json</option>
                <option value="srt">srt</option>
              </select>
            </div>
            <div class="field">
              <label>Intel provider</label>
              <select class="select" x-model="settings.meeting.intel_provider">
                <option value="local">local</option>
                <option value="cloud">cloud</option>
                <option value="auto">auto</option>
              </select>
            </div>
            <div class="field">
              <label>MIR profile</label>
              <select class="select" x-model="settings.meeting.mir_profile">
                <option value="balanced">Balanced</option>
                <option value="architect">Architect</option>
                <option value="delivery">Delivery</option>
                <option value="product">Product</option>
                <option value="incident">Incident</option>
              </select>
            </div>
            <div class="field full">
              <label>Local realtime model path</label>
              <input class="input" type="text" x-model="settings.meeting.intel_realtime_model" />
            </div>
            <div class="field full">
              <label>Local summary model path <span class="hint">(optional, falls back to realtime)</span></label>
              <input class="input" type="text" placeholder="Leave empty to use realtime model" x-model="settings.meeting.intel_summary_model" />
            </div>
            <div class="field">
              <label>Mic device <span class="hint">(optional)</span></label>
              <input class="input" type="text" placeholder="System default" x-model="settings.meeting.mic_device" />
            </div>
            <div class="field">
              <label>System audio device <span class="hint">(optional)</span></label>
              <input class="input" type="text" placeholder="System default" x-model="settings.meeting.system_audio_device" />
            </div>
          </div>
          <div class="check-row">
            <label class="check"><input type="checkbox" x-model="settings.meeting.auto_export" /> <span>Auto-export on meeting end</span></label>
            <label class="check"><input type="checkbox" x-model="settings.meeting.mir_enabled" /> <span>MIR routing enabled</span></label>
            <label class="check"><input type="checkbox" x-model="settings.meeting.diarization_enabled" /> <span>System audio diarization</span></label>
            <label class="check"><input type="checkbox" x-model="settings.meeting.diarize_mic" /> <span>Mic diarization</span></label>
            <label class="check"><input type="checkbox" x-model="settings.meeting.cross_meeting_recognition" /> <span>Cross-meeting speaker recognition</span></label>
            <label class="check"><input type="checkbox" x-model="settings.meeting.web_auto_open" /> <span>Auto-open dashboard</span></label>
          </div>
        </section>

        <!-- Cloud intel -->
        <section class="set-card">
          <div class="set-card-head">
            <h2>Cloud intel</h2>
            <p class="warn-note">
              These only apply when intel provider is <code>cloud</code> or
              <code>auto</code> — the only settings here that can send a transcript
              off your machine.
            </p>
          </div>
          <div class="set-grid">
            <div class="field">
              <label>Cloud model</label>
              <input class="input" type="text" x-model="settings.meeting.intel_cloud_model" />
            </div>
            <div class="field">
              <label>API key env var</label>
              <input class="input" type="text" x-model="settings.meeting.intel_cloud_api_key_env" />
            </div>
            <div class="field">
              <label>Cloud reasoning effort <span class="hint">(optional)</span></label>
              <input class="input" type="text" placeholder="e.g. low, medium, high" x-model="settings.meeting.intel_cloud_reasoning_effort" />
            </div>
            <div class="field full">
              <label>OpenAI-compatible base URL</label>
              <input class="input" type="text" placeholder="https://api.openai.com/v1" x-model="settings.meeting.intel_cloud_base_url" />
            </div>
            <div class="field">
              <label>Intel queue poll (seconds)</label>
              <input class="input" type="number" min="5" x-model.number="settings.meeting.intel_queue_poll_seconds" />
            </div>
            <div class="field">
              <label>Retry base delay (seconds)</label>
              <input class="input" type="number" min="1" x-model.number="settings.meeting.intel_retry_base_seconds" />
            </div>
            <div class="field">
              <label>Retry max delay (seconds)</label>
              <input class="input" type="number" min="1" x-model.number="settings.meeting.intel_retry_max_seconds" />
            </div>
            <div class="field">
              <label>Retry max attempts</label>
              <input class="input" type="number" min="1" x-model.number="settings.meeting.intel_retry_max_attempts" />
            </div>
            <div class="field">
              <label>Failure alert threshold (%)</label>
              <input class="input" type="number" min="0" max="100" step="0.1" x-model.number="settings.meeting.intel_retry_failure_alert_percent" />
            </div>
            <div class="field">
              <label>Failure alert hysteresis (minutes)</label>
              <input class="input" type="number" min="0" step="0.5" x-model.number="settings.meeting.intel_retry_failure_hysteresis_minutes" />
            </div>
            <div class="field full">
              <label>Failure alert webhook URL <span class="hint">(optional)</span></label>
              <input class="input" type="text" placeholder="https://ops.example.com/hooks/holdspeak" x-model="settings.meeting.intel_retry_failure_webhook_url" />
            </div>
            <div class="field">
              <label>Webhook header name <span class="hint">(optional)</span></label>
              <input class="input" type="text" placeholder="Authorization" x-model="settings.meeting.intel_retry_failure_webhook_header_name" />
            </div>
            <div class="field">
              <label>Webhook header value <span class="hint">(optional)</span></label>
              <input class="input" type="text" placeholder="Bearer <token>" x-model="settings.meeting.intel_retry_failure_webhook_header_value" />
            </div>
            <div class="field">
              <label>Speaker similarity threshold</label>
              <input class="input" type="number" min="0" max="1" step="0.01" x-model.number="settings.meeting.similarity_threshold" />
            </div>
          </div>
          <div class="check-row">
            <label class="check"><input type="checkbox" x-model="settings.meeting.intel_enabled" /> <span>Intel enabled</span></label>
            <label class="check"><input type="checkbox" x-model="settings.meeting.intel_deferred_enabled" /> <span>Deferred intel enabled</span></label>
            <label class="check"><input type="checkbox" x-model="settings.meeting.intel_cloud_store" /> <span>Allow cloud response storage</span></label>
          </div>
        </section>

        <!-- Sticky save bar -->
        <div class="save-bar">
          <div class="save-msg" x-show="message" x-cloak :class="{ error: isError }" x-text="message"></div>
          <div class="save-actions">
            <button type="button" class="btn" @click="load" :disabled="saving">Reload</button>
            <button type="submit" class="btn primary" :disabled="saving || !settings" x-text="saving ? 'Saving…' : 'Save settings'"></button>
          </div>
        </div>
      </form>
    </template>
  </div>

  <script>
    import Alpine from "alpinejs";
    import factorySource from "../scripts/settings-app.js?raw";
    const fn = new Function(factorySource + "; return settingsApp;");
    window.settingsApp = fn();
    window.Alpine = Alpine;
    Alpine.start();
  </script>
</AppLayout>

<style>
  .settings-page {
    max-width: 980px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-5) calc(var(--space-8) * 2);
  }
  [x-cloak] { display: none !important; }

  .set-header { margin-bottom: var(--space-6); }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 var(--space-2);
  }
  .set-header h1 {
    font-family: var(--font-display);
    font-size: var(--font-size-3xl);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 var(--space-2);
  }
  .lead {
    color: var(--text-muted);
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    max-width: 60ch;
    margin: 0 0 var(--space-4);
  }
  .local-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    background: var(--local-soft, var(--surface-2));
    color: var(--local, var(--text-muted));
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .local-chip .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--local, var(--ok)); box-shadow: 0 0 8px var(--local, var(--ok));
  }

  .set-loading { color: var(--text-muted); padding: var(--space-5) 0; }

  .set-notice {
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-5);
    border: 1px solid var(--danger);
    background: var(--danger-soft);
  }
  .set-notice-title { margin: 0 0 var(--space-2); font-weight: 600; color: var(--danger-strong, var(--danger)); }
  .set-notice-line { margin: 0; color: var(--text-muted); font-size: var(--font-size-sm); }

  .set-form { display: flex; flex-direction: column; gap: var(--space-5); }

  .set-card {
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--elev-1);
    overflow: hidden;
  }
  .set-card-head {
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-subtle);
    border-left: 3px solid var(--accent);
    background: var(--surface-3);
  }
  .set-card-head h2 {
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text);
    margin: 0 0 var(--space-1);
  }
  .set-card-head p { margin: 0; color: var(--text-muted); font-size: var(--font-size-sm); }
  .warn-note code,
  .set-card-head code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 1px 5px;
    border-radius: var(--radius-xs);
    background: var(--warn-soft);
    color: var(--warn-strong, var(--warn));
  }

  .set-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
    padding: var(--space-5);
  }
  .field { display: flex; flex-direction: column; gap: var(--space-2); min-width: 0; }
  .field.full { grid-column: 1 / -1; }
  .field > label {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--text-muted);
  }
  .field .hint { color: var(--text-faint); font-weight: 400; }

  .input, .select {
    width: 100%;
    padding: var(--space-2) var(--space-3);
    background: var(--field-bg);
    border: 1px solid var(--field-border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    transition: border-color var(--duration-short) var(--ease-standard);
  }
  .input:focus, .select:focus {
    outline: none;
    border-color: var(--field-focus-border, var(--accent));
    box-shadow: 0 0 0 3px var(--accent-tint);
  }
  .select { cursor: pointer; }

  .check-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
    padding: 0 var(--space-5) var(--space-5);
  }
  .check {
    display: inline-flex;
    align-items: flex-start;
    gap: var(--space-2);
    color: var(--text);
    font-size: var(--font-size-sm);
    cursor: pointer;
  }
  .check.full { flex-direction: row; }
  .check input[type="checkbox"] {
    margin-top: 2px;
    width: 16px; height: 16px;
    accent-color: var(--accent);
    cursor: pointer;
  }
  .check em { color: var(--text-faint); font-style: normal; }

  .save-bar {
    position: sticky;
    bottom: 0;
    z-index: var(--z-sticky);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-2);
    padding: var(--space-4) var(--space-5);
    background: var(--canvas-elevated, var(--surface-3));
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--elev-3);
  }
  .save-msg { color: var(--ok, var(--accent)); font-size: var(--font-size-sm); }
  .save-msg.error { color: var(--danger); }
  .save-actions { display: flex; gap: var(--space-3); margin-left: auto; }

  .btn {
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-strong);
    background: var(--surface-2);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    font-weight: 600;
    cursor: pointer;
    transition: border-color var(--duration-short) var(--ease-standard),
      background var(--duration-short) var(--ease-standard);
  }
  .btn:hover:not(:disabled) { border-color: var(--accent); }
  .btn:disabled { opacity: 0.55; cursor: default; }
  .btn.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--text-on-accent, var(--accent-on));
  }
  .btn.primary:hover:not(:disabled) { background: var(--accent-hover, var(--accent)); }
  .btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  @media (max-width: 720px) {
    .set-grid { grid-template-columns: 1fr; }
    .save-bar { flex-direction: column; align-items: stretch; }
    .save-actions { margin-left: 0; }
  }
</style>
