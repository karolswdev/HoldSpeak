---

<AppLayout title="HoldSpeak — Settings" description="Global HoldSpeak runtime settings">
  <div class="settings-page" x-data="settingsApp()" x-init="init()">
    <header class="set-header">
      <p class="eyebrow">Configuration</p>
      <h1>Settings</h1>
      <p class="lead">Every global HoldSpeak setting. Changes apply to your local runtime.</p>
    </header>

    <div x-show="loading" class="set-loading" x-cloak>Loading settings…</div>

    <div class="set-notice error" x-show="errors.length > 0" x-cloak role="alert">
      <p class="set-notice-title">Fix these before saving</p>
      <template x-for="err in errors" :key="err"><p class="set-notice-line" x-text="`• ${err}`"></p></template>
    </div>

    <template x-if="settings">
      <div class="set-shell">
        <!-- left nav + search -->
        <aside class="set-nav">
          <div class="set-search">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
            <input type="search" placeholder="Search settings…" x-model="query" aria-label="Search settings" />
          </div>
          <nav class="set-nav-list" :class="{ dim: searching }">
            <template x-for="s in sections" :key="s.id">
              <button type="button" class="set-nav-item" :class="{ active: active === s.id && !searching }" @click="active = s.id; query = ''" x-text="s.label"></button>
            </template>
          </nav>
          <label class="set-adv-toggle">
            <input type="checkbox" x-model="showAdvanced" />
            <span>Show advanced</span>
          </label>
          <span class="local-chip" aria-hidden="true"><span class="dot"></span> Local · 127.0.0.1</span>
        </aside>

        <!-- panel -->
        <form class="set-panel signal-card" @submit.prevent="save">
          <p class="set-search-hint" x-show="searching" x-cloak x-text="`Showing settings matching “${query}”`"></p>

          <!-- Appearance -->
          <h2 class="set-sec-h" x-show="sectionVisible('appearance')" x-cloak>Appearance</h2>
          <div class="set-grid">
            <div class="field" x-show="fieldVisible('appearance','common','theme appearance dark light color')" x-cloak>
              <label>Theme</label>
              <select class="select" x-model="settings.ui.theme"><option value="dark">Dark</option><option value="light">Light</option><option value="dracula">Dracula</option><option value="monokai">Monokai</option></select>
            </div>
            <div class="field" x-show="fieldVisible('appearance','common','history lines transcript')" x-cloak>
              <label>History lines</label>
              <input class="input" type="number" min="1" max="100" x-model.number="settings.ui.history_lines" />
            </div>
            <label class="check field full" x-show="fieldVisible('appearance','common','audio meter level')" x-cloak><input type="checkbox" x-model="settings.ui.show_audio_meter" /> <span>Show audio meter</span></label>
          </div>

          <!-- Voice typing -->
          <h2 class="set-sec-h" x-show="sectionVisible('voice')" x-cloak>Voice typing</h2>
          <div class="set-grid">
            <div class="field" x-show="fieldVisible('voice','common','hotkey key hold push to talk')" x-cloak>
              <label>Hotkey</label>
              <select class="select" x-model="settings.hotkey.key">
                <option value="alt_r">Alt Right</option><option value="alt_l">Alt Left</option><option value="ctrl_r">Ctrl Right</option><option value="ctrl_l">Ctrl Left</option><option value="cmd_r">Cmd Right</option><option value="cmd_l">Cmd Left</option><option value="shift_r">Shift Right</option><option value="shift_l">Shift Left</option><option value="caps_lock">Caps Lock</option><option value="fn">Fn</option><option value="f1">F1</option><option value="f2">F2</option><option value="f3">F3</option><option value="f4">F4</option><option value="f5">F5</option><option value="f6">F6</option><option value="f7">F7</option><option value="f8">F8</option><option value="f9">F9</option><option value="f10">F10</option><option value="f11">F11</option><option value="f12">F12</option>
              </select>
            </div>
            <div class="field" x-show="fieldVisible('voice','common','whisper model transcription tiny base small medium large')" x-cloak>
              <label>Whisper model</label>
              <select class="select" x-model="settings.model.name"><option value="tiny">tiny</option><option value="base">base</option><option value="small">small</option><option value="medium">medium</option><option value="large">large</option></select>
            </div>
            <div class="field" x-show="fieldVisible('voice','common','spoken language transcription auto detect polish german spanish')" x-cloak>
              <label>Spoken language</label>
              <select class="select" x-model="settings.model.language">
                <option value="auto">Auto-detect</option>
                {WHISPER_LANGUAGES.map((l) => <option value={l.code}>{l.name}</option>)}
              </select>
              <p class="hint">Pins transcription for dictation, meetings, and import. Auto-detect works well for longer speech; pin your language if short utterances get misdetected.</p>
            </div>
            <label class="check field full" x-show="fieldVisible('voice','common','warm whisper startup preload')" x-cloak><input type="checkbox" x-model="settings.model.warm_on_start" /> <span>Warm Whisper on web startup <em>— preloads transcription so the first utterance isn't slow.</em></span></label>

            <div class="field full sym-dict" x-show="fieldVisible('voice','common','spoken symbol dictionary tilde arrow custom vocabulary')" x-cloak>
              <label>Spoken-symbol dictionary</label>
              <p class="hint">Your own spoken words for symbols, merged over the built-in punctuation commands (yours win). Say the phrase while dictating and the symbol is typed. Attach controls spacing: none keeps it, left/right/both glue the symbol to its neighbors.</p>
              <template x-for="(entry, idx) in settings.dictation.spoken_symbols" :key="idx">
                <div class="sym-row">
                  <input class="input sym-spoken" type="text" placeholder="spoken phrase (e.g. tilde)" x-model="entry.spoken" />
                  <input class="input sym-symbol" type="text" placeholder="symbol (e.g. ~)" x-model="entry.symbol" />
                  <select class="select sym-attach" x-model="entry.attach">
                    <option value="none">none</option>
                    <option value="left">left</option>
                    <option value="right">right</option>
                    <option value="both">both</option>
                  </select>
                  <button type="button" class="btn sym-remove" @click="settings.dictation.spoken_symbols.splice(idx, 1)">Remove</button>
                </div>
              </template>
              <p class="sym-empty" x-show="!settings.dictation.spoken_symbols || settings.dictation.spoken_symbols.length === 0" x-cloak>No custom symbols yet. The built-in commands (period, comma, dash, new line) always work.</p>
              <button type="button" class="btn sym-add" @click="(settings.dictation.spoken_symbols = settings.dictation.spoken_symbols || []).push({ spoken: '', symbol: '', attach: 'none' })">Add a symbol</button>
            </div>
          </div>

          <!-- The wake word (HS-60) -->
          <h2 class="set-sec-h" x-show="sectionVisible('voice')" x-cloak>Wake word</h2>
          <div class="set-grid" x-show="fieldVisible('voice','common','wake word hands free arm jarvis preview type')" x-cloak>
            <label class="switch-field field full">
              <button type="button" class="switch" role="switch" :aria-checked="settings.wake_word.enabled ? 'true':'false'" :class="{ on: settings.wake_word.enabled }" @click="settings.wake_word.enabled = !settings.wake_word.enabled"><span class="switch-knob"></span></button>
              <span><strong>Wake word</strong> <em>— say the phrase, HoldSpeak arms for a few seconds, and your next sentence runs the dictation pipeline. By default the result is previewed, never typed. First enable downloads the detection models once (about 7 MB) from the openWakeWord GitHub releases.</em></span>
            </label>
            <div class="field">
              <label>Wake phrase model</label>
              <input class="input" type="text" placeholder="hey_jarvis" x-model="settings.wake_word.model" />
              <p class="hint">The openWakeWord model name. "hey_jarvis" ships pretrained.</p>
            </div>
            <div class="field">
              <label>After it hears you</label>
              <select class="select" x-model="settings.wake_word.action">
                <option value="preview">Preview first (recommended)</option>
                <option value="type">Type immediately</option>
              </select>
              <p class="hint">Preview shows the result with a Type it button; nothing is typed until you confirm. Type immediately is your call to make: a false detection would type into whatever app is focused.</p>
            </div>
            <div class="field">
              <label>Detection threshold</label>
              <input class="input" type="number" min="0" max="1" step="0.05" x-model.number="settings.wake_word.threshold" />
            </div>
            <div class="field">
              <label>Armed window (seconds)</label>
              <input class="input" type="number" min="2" max="30" step="1" x-model.number="settings.wake_word.armed_window_seconds" />
            </div>
            <p class="hint field full">Turn on Desktop presence too: it is the always-visible armed indicator while you work in other apps.</p>
          </div>

          <!-- Desktop presence -->
          <h2 class="set-sec-h" x-show="sectionVisible('presence')" x-cloak>Desktop presence</h2>
          <div class="set-grid" x-show="fieldVisible('presence','common','desktop presence hud tray notification env')" x-cloak>
            <label class="switch-field field full">
              <button type="button" class="switch" role="switch" :aria-checked="settings.presence.enabled ? 'true':'false'" :class="{ on: settings.presence.enabled }" @click="settings.presence.enabled = !settings.presence.enabled"><span class="switch-knob"></span></button>
              <span class="switch-copy"><span class="switch-title">Show an ambient desktop HUD</span><span class="switch-note">A native floating HUD / tray that shows what HoldSpeak is doing while you dictate — and never steals keyboard focus. Save to apply live. (No environment variable.)</span></span>
            </label>
            {/* HS-56-01: the Qlippy mascot sub-toggle — subordinate to the HUD
                toggle (inert + dimmed when presence itself is off). */}
            <label class="switch-field field full mascot-subfield" :class="{ 'is-inert': !settings.presence.enabled }">
              <button type="button" class="switch" role="switch" :aria-checked="settings.presence.mascot ? 'true':'false'" :aria-disabled="!settings.presence.enabled ? 'true':'false'" :class="{ on: settings.presence.mascot && settings.presence.enabled }" @click="settings.presence.enabled && (settings.presence.mascot = !settings.presence.mascot)"><span class="switch-knob"></span></button>
              <span class="switch-copy"><span class="switch-title">Qlippy, the mascot</span><span class="switch-note">Give the HUD a face: an ambient pixel-art helper that reflects what HoldSpeak is doing, and a small card for moments that need you (an approval, something learned). He only ever offers. Off keeps the minimal status ring.</span></span>
            </label>
          </div>

          <!-- Meetings & intel -->
          <h2 class="set-sec-h" x-show="sectionVisible('meetings')" x-cloak>Meetings &amp; intel</h2>
          <div class="set-grid">
            <div class="field" x-show="fieldVisible('meetings','common','intel provider local cloud auto')" x-cloak><label>Intel provider</label><select class="select" x-model="settings.meeting.intel_provider"><option value="local">local</option><option value="cloud">cloud</option><option value="auto">auto</option></select></div>
            <div class="field" x-show="fieldVisible('meetings','common','mir profile routing balanced architect delivery product incident')" x-cloak><label>MIR profile</label><select class="select" x-model="settings.meeting.mir_profile"><option value="balanced">Balanced</option><option value="architect">Architect</option><option value="delivery">Delivery</option><option value="product">Product</option><option value="incident">Incident</option></select></div>
            <div class="field" x-show="fieldVisible('meetings','common','export format txt markdown json srt')" x-cloak><label>Export format</label><select class="select" x-model="settings.meeting.export_format"><option value="txt">txt</option><option value="markdown">markdown</option><option value="json">json</option><option value="srt">srt</option></select></div>
            <div class="field" x-show="fieldVisible('meetings','common','mic label speaker')" x-cloak><label>Mic label</label><input class="input" type="text" x-model="settings.meeting.mic_label" /></div>
            <div class="field" x-show="fieldVisible('meetings','common','remote label speaker')" x-cloak><label>Remote label</label><input class="input" type="text" x-model="settings.meeting.remote_label" /></div>
            <div class="field full" x-show="fieldVisible('meetings','advanced','local realtime model path gguf')" x-cloak><label>Local realtime model path <span class="hint">(advanced)</span></label><input class="input" type="text" x-model="settings.meeting.intel_realtime_model" /></div>
            <div class="field full" x-show="fieldVisible('meetings','advanced','local summary model path')" x-cloak><label>Local summary model path <span class="hint">(advanced, falls back to realtime)</span></label><input class="input" type="text" placeholder="Leave empty to use realtime model" x-model="settings.meeting.intel_summary_model" /></div>
            <div class="field" x-show="fieldVisible('meetings','advanced','mic device input')" x-cloak><label>Mic device <span class="hint">(advanced)</span></label><input class="input" type="text" placeholder="System default" x-model="settings.meeting.mic_device" /></div>
            <div class="field" x-show="fieldVisible('meetings','advanced','system audio device output capture')" x-cloak><label>System audio device <span class="hint">(advanced)</span></label><input class="input" type="text" placeholder="System default" x-model="settings.meeting.system_audio_device" /></div>
            <div class="field" x-show="fieldVisible('meetings','advanced','speaker similarity threshold diarization')" x-cloak><label>Speaker similarity threshold <span class="hint">(advanced)</span></label><input class="input" type="number" min="0" max="1" step="0.01" x-model.number="settings.meeting.similarity_threshold" /></div>
            {/* HS-61-02: the Send-to-Slack door. Setting the URL is the consent
                for exactly its host; the honest copy states what leaves and when. */}
            <div class="field full" x-show="fieldVisible('meetings','common','slack webhook url send export aftercare')" x-cloak>
              <label>Send to Slack webhook URL</label>
              <input class="input" type="text" placeholder="https://hooks.slack.com/services/…" x-model="settings.meeting.slack_webhook_url" />
              <p class="hint">Adds a Send to Slack button to each meeting's aftercare. Sends exactly what you preview, after you approve each send, only to this URL's host. Leave empty to turn the feature off.</p>
            </div>
            {/* HSM-14: the iPad desk's Webhook connector. Same consent posture as
                Slack — setting the URL is the consent for exactly its host. */}
            <div class="field full" x-show="fieldVisible('meetings','common','companion webhook url ipad desk connector discord zapier n8n')" x-cloak>
              <label>Companion Webhook URL</label>
              <input class="input" type="text" placeholder="https://hooks.example.com/…" x-model="settings.meeting.companion_webhook_url" />
              <p class="hint">Powers the iPad desk's Webhook connector (Discord, Zapier, n8n, any endpoint). Sends exactly what you approve, only to this URL's host. Leave empty to turn the connector off.</p>
            </div>
            {/* HSM-14: the iPad desk's GitHub connector. Auth is the host's local
                gh — no token is stored or crosses the wire. */}
            <div class="field full" x-show="fieldVisible('meetings','common','companion github repo ipad desk connector issue')" x-cloak>
              <label>Companion GitHub repo</label>
              <input class="input" type="text" placeholder="owner/name" x-model="settings.meeting.companion_github_repo" />
              <p class="hint">The default repo the iPad desk's GitHub connector files issues into via your host's signed-in gh. No token is stored or sent. Leave empty to turn the connector off.</p>
            </div>
          </div>
          <div class="check-row" x-show="sectionVisible('meetings') || searching">
            <label class="check" x-show="fieldVisible('meetings','common','intel enabled meeting intelligence')" x-cloak><input type="checkbox" x-model="settings.meeting.intel_enabled" /> <span>Intel enabled</span></label>
            <label class="check" x-show="fieldVisible('meetings','advanced','deferred intel queue homelab')" x-cloak><input type="checkbox" x-model="settings.meeting.intel_deferred_enabled" /> <span>Deferred intel enabled</span></label>
            <label class="check" x-show="fieldVisible('meetings','advanced','auto export meeting end')" x-cloak><input type="checkbox" x-model="settings.meeting.auto_export" /> <span>Auto-export on meeting end</span></label>
            <label class="check" x-show="fieldVisible('meetings','advanced','mir routing enabled')" x-cloak><input type="checkbox" x-model="settings.meeting.mir_enabled" /> <span>MIR routing enabled</span></label>
            <label class="check" x-show="fieldVisible('meetings','advanced','system audio diarization speakers')" x-cloak><input type="checkbox" x-model="settings.meeting.diarization_enabled" /> <span>System audio diarization</span></label>
            <label class="check" x-show="fieldVisible('meetings','advanced','mic diarization speakers')" x-cloak><input type="checkbox" x-model="settings.meeting.diarize_mic" /> <span>Mic diarization</span></label>
            <label class="check" x-show="fieldVisible('meetings','advanced','cross meeting speaker recognition')" x-cloak><input type="checkbox" x-model="settings.meeting.cross_meeting_recognition" /> <span>Cross-meeting speaker recognition</span></label>
          </div>

          <!-- Cloud & advanced -->
          <h2 class="set-sec-h" x-show="sectionVisible('cloud')" x-cloak>Cloud &amp; advanced</h2>
          <p class="warn-note" x-show="sectionVisible('cloud')" x-cloak>These apply only when intel provider is <code>cloud</code> or <code>auto</code> — the only settings that can send a transcript off your machine.</p>
          <div class="set-grid">
            <div class="field" x-show="fieldVisible('cloud','common','cloud model gpt')" x-cloak><label>Cloud model</label><input class="input" type="text" x-model="settings.meeting.intel_cloud_model" /></div>
            <div class="field" x-show="fieldVisible('cloud','common','api key env var openai')" x-cloak><label>API key env var</label><input class="input" type="text" x-model="settings.meeting.intel_cloud_api_key_env" /></div>
            <div class="field full" x-show="fieldVisible('cloud','common','openai compatible base url endpoint')" x-cloak><label>OpenAI-compatible base URL</label><input class="input" type="text" placeholder="https://api.openai.com/v1" x-model="settings.meeting.intel_cloud_base_url" /></div>
            <div class="field" x-show="fieldVisible('cloud','advanced','cloud reasoning effort')" x-cloak><label>Cloud reasoning effort <span class="hint">(advanced)</span></label><input class="input" type="text" placeholder="low / medium / high" x-model="settings.meeting.intel_cloud_reasoning_effort" /></div>
            <div class="field" x-show="fieldVisible('cloud','advanced','intel queue poll seconds')" x-cloak><label>Intel queue poll (s) <span class="hint">(advanced)</span></label><input class="input" type="number" min="5" x-model.number="settings.meeting.intel_queue_poll_seconds" /></div>
            <div class="field" x-show="fieldVisible('cloud','advanced','retry base delay seconds')" x-cloak><label>Retry base delay (s) <span class="hint">(advanced)</span></label><input class="input" type="number" min="1" x-model.number="settings.meeting.intel_retry_base_seconds" /></div>
            <div class="field" x-show="fieldVisible('cloud','advanced','retry max delay seconds')" x-cloak><label>Retry max delay (s) <span class="hint">(advanced)</span></label><input class="input" type="number" min="1" x-model.number="settings.meeting.intel_retry_max_seconds" /></div>
            <div class="field" x-show="fieldVisible('cloud','advanced','retry max attempts')" x-cloak><label>Retry max attempts <span class="hint">(advanced)</span></label><input class="input" type="number" min="1" x-model.number="settings.meeting.intel_retry_max_attempts" /></div>
