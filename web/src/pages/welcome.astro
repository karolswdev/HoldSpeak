      .ma-cmd-lite:hover { border-color: var(--accent); }
      .pres-noenv { margin-top: var(--space-4); color: var(--text-faint); font-size: var(--font-size-xs); font-family: var(--font-mono); }
      @media (max-width: 860px) { .pres-row { flex-direction: column; align-items: flex-start; } .pres-hud { width: 100%; } }

      /* ── Nav ── */
      .wz-nav { display: flex; align-items: center; gap: var(--space-4); padding-top: var(--space-6); margin-top: var(--space-5); border-top: 1px solid var(--border-subtle); }
      .wz-nav-count { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--text-faint); }
      .wz-link { margin-left: auto; background: none; border: none; color: var(--text-muted); font-size: var(--font-size-sm); cursor: pointer; text-decoration: underline; text-underline-offset: 3px; }
      .wz-link:hover { color: var(--text); }
      .wz-btn { font-family: var(--font-ui); font-weight: 600; font-size: var(--font-size-md); padding: var(--space-3) var(--space-6); border-radius: var(--radius-md); cursor: pointer; border: 1px solid transparent; transition: transform var(--duration-short) var(--ease-standard), box-shadow var(--duration-short) var(--ease-standard), background var(--duration-short) var(--ease-standard); }
      .wz-btn.ghost { background: transparent; border-color: var(--border-strong); color: var(--text-muted); }
      .wz-btn.ghost:hover { color: var(--text); border-color: var(--text-faint); }
      .wz-btn.primary { background: var(--accent); color: var(--text-on-accent, #0b0d10); box-shadow: 0 6px 20px color-mix(in srgb, var(--accent) 35%, transparent); }
      .wz-btn.primary:hover { transform: translateY(-1px); box-shadow: 0 10px 28px color-mix(in srgb, var(--accent) 45%, transparent); }
      .wz-btn:not(.wz-link) ~ .wz-link { margin-left: auto; }
      .wz-btn:focus-visible, .wz-link:focus-visible, .wz-exit:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }
      /* when Back is hidden, push counter from the left */
      .wz-nav > .wz-nav-count:first-child { margin-left: 0; }

      @media (max-width: 860px) {
        .wz { grid-template-columns: 1fr; }
        .wz-rail { display: none; }
        .wz-mobile-progress { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-6); }
        .wz-mobile-bar { flex: 1; height: 6px; border-radius: var(--radius-pill); background: var(--surface-3); overflow: hidden; }
        .wz-mobile-bar span { display: block; height: 100%; background: var(--accent); border-radius: var(--radius-pill); transition: width .3s var(--ease-emphasized); }
        .wz-mobile-count { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--text-faint); }
        .wz-panels { min-height: 360px; }
      }
    </style>
