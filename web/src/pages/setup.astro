---
// HS-42-03: the welcome / setup surface.
//
// Driven by GET /api/setup/status (HS-42-01). One primary action, a
// status-grouped checklist (every doctor FAIL surfaces), and a trust/presence
// summary. `/` redirects here for a first-run or hard-blocked user (the dashboard
// guard in index.astro); a healthy returning user never sees it.
import AppLayout from "../layouts/AppLayout.astro";
---

<AppLayout title="HoldSpeak — Setup" description="Get HoldSpeak ready for voice typing">
  <div class="setup" x-data="setupApp()" x-init="init()">

    <div x-show="loading" class="setup-loading" x-cloak>Checking your setup…</div>
    <div x-show="error" class="setup-error" x-cloak x-text="error"></div>

    <template x-if="status">
      <div>
        <!-- Hero -->
        <header class="setup-hero" :class="`is-${overall}`">
          <img class="setup-mark" src="/_built/holdspeak-mark.png" alt="" width="72" height="72" />
          <div class="setup-hero-text">
            <p class="eyebrow">Welcome to HoldSpeak</p>
            <h1 x-text="headline"></h1>
            <p class="lead" x-text="subhead"></p>
            <div class="setup-progress" role="img" :aria-label="`${passCount} of ${total} checks ready`">
              <div class="setup-progress-track">
                <div class="setup-progress-fill" :style="`width: ${progressPct}%`"></div>
              </div>
              <span class="setup-progress-label" x-text="`${passCount} / ${total} ready`"></span>
            </div>
          </div>
          <span class="local-chip" aria-hidden="true"><span class="dot"></span> Local · 127.0.0.1</span>
        </header>

        <!-- Primary action -->
        <template x-if="status.primary_action">
          <a class="primary-action" :href="status.primary_action.route">
            <div class="primary-action-body">
              <span class="primary-action-eyebrow">Next step</span>
              <span class="primary-action-label" x-text="status.primary_action.label"></span>
            </div>
            <svg class="primary-action-arrow" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </template>

        <!-- Needs attention -->
        <template x-if="unmet.length">
          <section class="setup-group">
            <h2 class="setup-group-title">Needs attention</h2>
            <ul class="check-list">
              <template x-for="s in unmet" :key="s.id">
                <li class="check-row" :id="s.id" :class="`st-${s.status}`">
                  <span class="check-glyph" x-text="statusGlyph(s.status)"></span>
                  <div class="check-main">
                    <span class="check-label" x-text="s.label"></span>
                    <span class="check-detail" x-text="s.detail"></span>
                    <span class="check-fix" x-show="s.fix" x-cloak x-text="s.fix"></span>
                  </div>
                </li>
              </template>
            </ul>
          </section>
        </template>

        <!-- Guided first dictation (HS-42-04) -->
        <section class="first-dictation" id="first-dictation" :class="{ primed: overall === 'ready', done: firstDone || dictation.ok }">
          <div class="fd-head">
            <h2>Try your first dictation</h2>
            <span class="fd-badge" x-show="firstDone || dictation.ok" x-cloak>✓ Done</span>
          </div>

          <!-- Success -->
          <template x-if="dictation.ok || firstDone">
            <div class="fd-success">
              <p class="fd-success-line">It worked — text landed in your app. You're all set.</p>
              <p class="fd-transcript" x-show="dictation.transcript" x-cloak>
                <span class="fd-quote">“</span><span x-text="dictation.transcript"></span><span class="fd-quote">”</span>
              </p>
            </div>
          </template>

          <!-- Guide -->
          <template x-if="!(dictation.ok || firstDone)">
            <div class="fd-guide">
              <p class="fd-intro">Hold your hotkey, speak, release — HoldSpeak types it into whatever app is focused, locally.</p>
              <ol class="fd-steps">
                <li><span class="fd-step-n">1</span> Open an editor, note, or chat box and click into a text field.</li>
                <li><span class="fd-step-n">2</span> Press &amp; hold your hotkey (set it in <a href="/settings">Settings</a>), say a sentence, then release.</li>
                <li><span class="fd-step-n">3</span> Watch the words appear — we'll confirm it here.</li>
              </ol>

              <!-- Live status -->
              <div class="fd-live" x-show="liveLabel" x-cloak>
                <span class="fd-live-dot"></span> <span x-text="liveLabel"></span>
              </div>

              <!-- Readiness mini-row -->
              <div class="fd-ready" x-show="sectionById('global-hotkey') || sectionById('text-injection') || sectionById('transcription-backend')" x-cloak>
                <template x-for="id in ['global-hotkey','text-injection','transcription-backend']" :key="id">
                  <span class="fd-chip" x-show="sectionById(id)" :class="`st-${sectionById(id)?.status}`">
                    <span class="fd-chip-glyph" x-text="statusGlyph(sectionById(id)?.status)"></span>
                    <span x-text="sectionById(id)?.label"></span>
                  </span>
                </template>
              </div>

              <p class="fd-fallback">
                Hotkey blocked (e.g. Wayland) or text not appearing? Keep the HoldSpeak
                window focused for the hold-to-talk fallback, or paste from the
                clipboard — see <a href="/dictation">the dictation cockpit</a>.
              </p>
            </div>
          </template>
        </section>

        <!-- Model setup assistant (HS-42-06) -->
        <section class="model-assistant" id="runtime">
          <div class="ma-head">
            <h2>The dictation pipeline (optional)</h2>
            <p>Add a model and HoldSpeak rewrites rough speech into clean, project-aware text. Pick a path — basic voice typing already works without one.</p>
          </div>
          <ul class="ma-choices">
            <template x-for="c in runtimeChoices" :key="c.id">
              <li class="ma-choice">
                <div class="ma-choice-top">
                  <span class="ma-choice-label" x-text="c.label"></span>
                  <span class="ma-choice-affects" x-text="c.affects"></span>
                </div>
                <p class="ma-choice-needs" x-text="c.needs"></p>
                <button class="ma-cmd" type="button" x-show="c.extra" x-cloak @click="copy(c.extra)" :title="copied === c.extra ? 'Copied!' : 'Click to copy'">
                  <code x-text="c.extra"></code>
                  <span class="ma-cmd-state" x-text="copied === c.extra ? '✓ copied' : 'copy'"></span>
                </button>
              </li>
            </template>
          </ul>
          <div class="ma-actions">
            <button class="btn primary" type="button" @click="testRuntime" :disabled="runtimeTest.state === 'testing'" x-text="runtimeTest.state === 'testing' ? 'Testing…' : 'Test my runtime'"></button>
            <a class="btn" href="/dictation">Advanced runtime settings</a>
            <div class="ma-result" x-show="runtimeTest.state === 'done'" x-cloak :class="runtimeTest.ok ? 'ok' : 'bad'">
              <span x-text="runtimeTest.ok ? '✓' : '✕'"></span> <span x-text="runtimeTest.detail"></span>
            </div>
          </div>
        </section>

        <!-- Presence onboarding (HS-42-07) -->
        <section class="presence-setup" id="presence-setup">
          <div class="ps-head">
            <h2>Desktop presence (optional)</h2>
            <span class="ps-status" :class="presence.enabled ? 'on' : (presence.available ? 'avail' : 'na')"
                  x-text="presence.enabled ? 'On' : (presence.available ? 'Available · off' : 'Not on this platform')"></span>
          </div>
          <div class="ps-body">
            <div class="ps-copy">
              <p>See what the copilot is doing — <em>listening · transcribing · typing</em> — on your desktop while you dictate into another app, without the dashboard visible.</p>
              <p class="ps-tier" x-text="presenceTier"></p>
              <p class="ps-focus">🔒 It <strong>never takes keyboard focus</strong> — your keystrokes keep landing in the app you're typing into.</p>
              <div class="ps-install" x-show="!presence.enabled" x-cloak>
                <p class="ps-install-h">Turn it on:</p>
                <template x-for="cmd in presenceInstall" :key="cmd">
                  <button class="ma-cmd" type="button" @click="copy(cmd)" :title="copied === cmd ? 'Copied!' : 'Click to copy'">
                    <code x-text="cmd"></code>
                    <span class="ma-cmd-state" x-text="copied === cmd ? '✓ copied' : 'copy'"></span>
                  </button>
                </template>
              </div>
              <p class="ps-docs"><a href="/docs/dictation-runtime">Presence docs</a> · <a href="/presence" target="_blank" rel="noopener">Preview the live HUD ↗</a></p>
            </div>
            <!-- Faithful inline preview of the Signal HUD card -->
            <div class="ps-preview" aria-label="Preview of the presence HUD">
              <div class="ps-hud">
                <span class="ps-hud-ring"></span>
                <div class="ps-hud-text">
                  <div class="ps-hud-label">Transcribing</div>
                  <div class="ps-hud-detail">Turning your speech into text…</div>
                  <div class="ps-hud-src">Hotkey</div>
                </div>
              </div>
              <span class="ps-preview-tag">Preview</span>
            </div>
          </div>
        </section>

        <!-- Ready -->
        <template x-if="ready.length">
          <section class="setup-group">
            <h2 class="setup-group-title">Ready <span class="muted" x-text="`(${ready.length})`"></span></h2>
            <ul class="ready-grid">
              <template x-for="s in ready" :key="s.id">
                <li class="ready-chip"><span class="ready-tick">✓</span> <span x-text="s.label"></span></li>
              </template>
            </ul>
          </section>
        </template>

        <!-- Trust + presence summary -->
        <section class="setup-summary">
          <a class="summary-card" href="/settings">
            <span class="summary-eyebrow">Privacy</span>
            <span class="summary-value" x-text="egressLabel()"></span>
            <span class="summary-meta" x-show="status.trust.configured_endpoints.length" x-cloak x-text="status.trust.configured_endpoints[0]"></span>
            <span class="summary-meta" x-show="!status.trust.configured_endpoints.length">Transcripts stay on this machine</span>
          </a>
          <div class="summary-card">
            <span class="summary-eyebrow">Desktop presence</span>
            <span class="summary-value" x-text="presenceLabel()"></span>
            <span class="summary-meta">Ambient status while you dictate</span>
          </div>
        </section>
      </div>
    </template>
  </div>

  <script>
    import Alpine from "alpinejs";
    import factorySource from "../scripts/setup-app.js?raw";
    const fn = new Function(factorySource + "; return setupApp;");
    window.setupApp = fn();
    window.Alpine = Alpine;
    Alpine.start();
  </script>
</AppLayout>

<style>
  .setup { max-width: 880px; margin: 0 auto; padding: var(--space-6) var(--space-5) calc(var(--space-8) * 2); }
  [x-cloak] { display: none !important; }
  .setup-loading, .setup-error { color: var(--text-muted); padding: var(--space-6) 0; }
  .setup-error { color: var(--danger); }

  /* Hero */
  .setup-hero {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4) var(--space-5);
    align-items: center;
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background:
      radial-gradient(120% 140% at 0% 0%, var(--accent-tint), transparent 55%),
      var(--surface-2);
    margin-bottom: var(--space-5);
    overflow: hidden;
  }
  .setup-hero.is-ready { border-color: var(--ok); }
  .setup-hero.is-blocked { border-color: var(--danger); }
  .setup-mark { border-radius: var(--radius-md); image-rendering: pixelated; align-self: start; }
  .eyebrow {
    font-family: var(--font-mono); font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-eyebrow); text-transform: uppercase;
    color: var(--accent); margin: 0 0 var(--space-2);
  }
  .setup-hero h1 {
    font-family: var(--font-display); font-size: var(--font-size-2xl); font-weight: 700;
    color: var(--text); margin: 0 0 var(--space-2); line-height: var(--line-height-tight);
  }
  .lead { color: var(--text-muted); font-size: var(--font-size-md); line-height: var(--line-height-relaxed); margin: 0 0 var(--space-4); max-width: 56ch; }
  .setup-progress { display: flex; align-items: center; gap: var(--space-3); }
  .setup-progress-track { flex: 1; max-width: 280px; height: 8px; border-radius: var(--radius-pill); background: var(--surface-active, var(--surface-3)); overflow: hidden; }
  .setup-progress-fill { height: 100%; border-radius: var(--radius-pill); background: var(--accent); transition: width var(--duration-long) var(--ease-emphasized); }
  .is-ready .setup-progress-fill { background: var(--ok); }
  .setup-progress-label { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--text-muted); }
  .local-chip {
    position: absolute; top: var(--space-4); right: var(--space-5);
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-1) var(--space-3); border: 1px solid var(--border);
    border-radius: var(--radius-pill); background: var(--local-soft, var(--surface-3));
    color: var(--local, var(--text-muted)); font-family: var(--font-mono); font-size: var(--font-size-xs);
  }
  .local-chip .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--local, var(--ok)); box-shadow: 0 0 8px var(--local, var(--ok)); }

  /* Primary action */
  .primary-action {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-4);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    background: var(--accent); color: var(--text-on-accent, var(--accent-on));
    text-decoration: none; box-shadow: var(--elev-2);
    margin-bottom: var(--space-6);
    transition: transform var(--duration-short) var(--ease-standard), box-shadow var(--duration-short) var(--ease-standard);
  }
  .primary-action:hover { transform: translateY(-1px); box-shadow: var(--elev-3); }
  .primary-action-body { display: flex; flex-direction: column; gap: 2px; }
  .primary-action-eyebrow { font-family: var(--font-mono); font-size: var(--font-size-xs); text-transform: uppercase; letter-spacing: var(--letter-spacing-eyebrow); opacity: 0.8; }
  .primary-action-label { font-family: var(--font-display); font-size: var(--font-size-lg); font-weight: 600; }
  .primary-action-arrow { flex: none; }

  /* Groups */
  .setup-group { margin-bottom: var(--space-6); }
  .setup-group-title { font-family: var(--font-display); font-size: var(--font-size-md); font-weight: 600; color: var(--text); margin: 0 0 var(--space-3); }
  .setup-group-title .muted { color: var(--text-faint); font-weight: 400; }

  .check-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-2); }
  .check-row {
    display: grid; grid-template-columns: auto 1fr; gap: var(--space-3); align-items: start;
    padding: var(--space-4); border-radius: var(--radius-md);
    background: var(--surface-2); border: 1px solid var(--border-subtle);
    border-left: 3px solid var(--border);
    scroll-margin-top: var(--space-6);
  }
  .check-row.st-fail { border-left-color: var(--danger); background: var(--danger-soft); }
  .check-row.st-warn { border-left-color: var(--warn); }
  .check-glyph {
    display: inline-grid; place-items: center; width: 24px; height: 24px; border-radius: 50%;
    font-size: var(--font-size-sm); font-weight: 700;
  }
  .st-fail .check-glyph { background: var(--danger); color: var(--text-on-accent, #fff); }
  .st-warn .check-glyph { background: var(--warn); color: var(--bg, #111); }
  .check-main { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .check-label { font-weight: 600; color: var(--text); font-size: var(--font-size-sm); }
  .check-detail { color: var(--text-muted); font-size: var(--font-size-sm); }
  .check-fix { color: var(--accent); font-size: var(--font-size-sm); margin-top: var(--space-1); }

  /* Guided first dictation */
  .first-dictation {
    padding: var(--space-5); margin-bottom: var(--space-6);
    border-radius: var(--radius-lg); border: 1px solid var(--border-subtle);
    border-left: 3px solid var(--accent);
    background: var(--surface-2); scroll-margin-top: var(--space-6);
  }
  .first-dictation.primed { border-left-color: var(--ok); }
  .first-dictation.done { border-left-color: var(--ok); background: var(--ok-soft, var(--surface-2)); }
  .fd-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); margin-bottom: var(--space-3); }
  .fd-head h2 { font-family: var(--font-display); font-size: var(--font-size-lg); font-weight: 600; color: var(--text); margin: 0; }
  .fd-badge {
    font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 600;
    padding: var(--space-1) var(--space-3); border-radius: var(--radius-pill);
    background: var(--ok); color: var(--bg, #0b0d10);
  }

  .fd-intro { color: var(--text-muted); font-size: var(--font-size-sm); margin: 0 0 var(--space-4); max-width: 60ch; }
  .fd-steps { list-style: none; margin: 0 0 var(--space-4); padding: 0; display: flex; flex-direction: column; gap: var(--space-3); }
  .fd-steps li { display: flex; align-items: baseline; gap: var(--space-3); color: var(--text); font-size: var(--font-size-sm); }
  .fd-steps a { color: var(--accent); }
  .fd-step-n {
    flex: none; display: inline-grid; place-items: center; width: 22px; height: 22px;
    border-radius: 50%; background: var(--accent-tint); color: var(--accent);
    font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 700;
    transform: translateY(2px);
  }

  .fd-live {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-2) var(--space-4); margin-bottom: var(--space-4);
    border-radius: var(--radius-pill); background: var(--accent-tint); color: var(--accent);
    font-size: var(--font-size-sm); font-weight: 600;
  }
  .fd-live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); animation: fd-pulse 1.1s ease-in-out infinite; }
  @keyframes fd-pulse { 0%,100% { opacity: 0.35; transform: scale(0.85); } 50% { opacity: 1; transform: scale(1.15); } }
  @media (prefers-reduced-motion: reduce) { .fd-live-dot { animation: none; } }

  .fd-ready { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-4); }
  .fd-chip {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-1) var(--space-3); border-radius: var(--radius-pill);
    background: var(--surface-3); border: 1px solid var(--border-subtle);
    color: var(--text-muted); font-size: var(--font-size-xs);
  }
  .fd-chip.st-pass { color: var(--ok); border-color: var(--ok); }
  .fd-chip.st-warn { color: var(--warn-strong, var(--warn)); border-color: var(--warn); }
  .fd-chip.st-fail { color: var(--danger); border-color: var(--danger); }
  .fd-chip-glyph { font-weight: 700; }

  .fd-fallback { color: var(--text-faint); font-size: var(--font-size-xs); margin: 0; max-width: 64ch; }
  .fd-fallback a { color: var(--text-muted); }

  .fd-success-line { color: var(--text); font-size: var(--font-size-md); font-weight: 600; margin: 0 0 var(--space-2); }
  .fd-transcript { color: var(--text-muted); font-size: var(--font-size-sm); font-style: italic; margin: 0; }
  .fd-quote { color: var(--accent); font-weight: 700; }

  /* Model setup assistant */
  .model-assistant {
    padding: var(--space-5); margin-bottom: var(--space-6);
    border-radius: var(--radius-lg); border: 1px solid var(--border-subtle);
    background: var(--surface-2); scroll-margin-top: var(--space-6);
  }
  .ma-head h2 { font-family: var(--font-display); font-size: var(--font-size-lg); font-weight: 600; color: var(--text); margin: 0 0 var(--space-1); }
  .ma-head p { color: var(--text-muted); font-size: var(--font-size-sm); margin: 0 0 var(--space-4); max-width: 64ch; }
  .ma-choices { list-style: none; margin: 0 0 var(--space-4); padding: 0; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-3); }
  .ma-choice { padding: var(--space-4); border-radius: var(--radius-md); background: var(--surface-3); border: 1px solid var(--border-subtle); }
  .ma-choice-top { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-3); margin-bottom: var(--space-1); }
  .ma-choice-label { font-weight: 600; color: var(--text); font-size: var(--font-size-sm); }
  .ma-choice-affects { color: var(--text-faint); font-size: var(--font-size-xs); white-space: nowrap; }
  .ma-choice-needs { color: var(--text-muted); font-size: var(--font-size-xs); margin: 0 0 var(--space-3); }
  .ma-cmd {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); width: 100%;
    padding: var(--space-2) var(--space-3); border-radius: var(--radius-sm);
    background: var(--canvas, var(--bg)); border: 1px solid var(--border); cursor: pointer; text-align: left;
  }
  .ma-cmd:hover { border-color: var(--accent); }
  .ma-cmd code { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .ma-cmd-state { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--accent); flex: none; }
  .ma-actions { display: flex; align-items: center; flex-wrap: wrap; gap: var(--space-3); }
  .ma-result { font-size: var(--font-size-sm); }
  .ma-result.ok { color: var(--ok); }
  .ma-result.bad { color: var(--danger); }

  /* Presence onboarding */
  .presence-setup {
    padding: var(--space-5); margin-bottom: var(--space-6);
    border-radius: var(--radius-lg); border: 1px solid var(--border-subtle);
    background: var(--surface-2); scroll-margin-top: var(--space-6);
  }
  .ps-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); margin-bottom: var(--space-4); }
  .ps-head h2 { font-family: var(--font-display); font-size: var(--font-size-lg); font-weight: 600; color: var(--text); margin: 0; }
  .ps-status { font-family: var(--font-mono); font-size: var(--font-size-xs); padding: var(--space-1) var(--space-3); border-radius: var(--radius-pill); border: 1px solid var(--border); color: var(--text-muted); }
  .ps-status.on { color: var(--ok); border-color: var(--ok); }
  .ps-status.avail { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 45%, transparent); }
