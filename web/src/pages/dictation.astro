  .template-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2);
    margin-top: var(--space-2);
    background: var(--canvas);
  }
  .template-card .template-title { font-weight: 600; }
  .template-card .template-desc {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    margin: var(--space-1) 0 var(--space-2);
  }

  /* === Form controls ===================================== */
  label {
    display: block;
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }
  .check-label { display: flex; align-items: center; gap: var(--space-2); color: var(--text); }
  input[type="text"],
  input[type="number"],
  input[type="range"],
  textarea,
  select {
    width: 100%;
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    margin-top: var(--space-1);
  }
  input[type="checkbox"] { width: auto; margin: 0; }
  input:focus-visible, textarea:focus-visible, select:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
    border-color: var(--accent);
  }
  textarea { min-height: 5.5rem; resize: vertical; }
  .row { display: flex; gap: var(--space-3); }
  .row > * { flex: 1; }

  /* === Buttons =========================================== */
  .btn {
    appearance: none;
    background: var(--canvas-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    transition: border-color var(--duration-short) var(--ease-standard),
                background var(--duration-short) var(--ease-standard);
  }
  .btn:hover:not(:disabled) { border-color: var(--line-strong); }
  .btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .btn.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-on);
  }
  .btn.danger { color: var(--danger); border-color: var(--danger); }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  /* === Preview / boxes (used by JS-rendered editor previews) === */
  .preview {
    background: var(--canvas);
    border: 1px dashed var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-3);
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    white-space: pre-wrap;
    min-height: 5rem;
  }
  .preview .missing { color: var(--warn); }

  .error-box {
    background: var(--danger-soft);
    border: 1px solid var(--danger);
    color: var(--danger);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    font-family: var(--font-mono);
  }
  .ok-box {
    background: var(--success-soft);
    border: 1px solid var(--success);
    color: var(--success);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
  }

  /* === Trace (dry-run) =================================== */
  .trace-stage {
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-3);
    background: var(--canvas);
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .trace-stage-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .trace-stage-head strong { color: var(--text); }
  .trace-stage-elapsed { color: var(--text-faint); }
  .trace-intent {
    margin: 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .trace-metadata {
    margin: 0;
    background: var(--canvas-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  .trace-empty {
    margin: 0;
    color: var(--text-faint);
    font-size: var(--font-size-sm);
  }

  /* === Readiness ========================================= */
  .readiness-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-2);
  }
  @media (max-width: 900px) { .readiness-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .readiness-grid { grid-template-columns: 1fr; } }
  .readiness-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-3);
    background: var(--canvas);
    min-height: 6.5rem;
    /* HS-44-02: depth + motion to match the wizard's bar. */
    transition: transform var(--duration-short) var(--ease-standard),
                border-color var(--duration-short) var(--ease-standard),
                box-shadow var(--duration-short) var(--ease-standard);
  }
  .readiness-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--elev-1);
  }
  @media (prefers-reduced-motion: reduce) {
    .readiness-card:hover { transform: none; }
  }
  .readiness-card strong { display: block; margin-bottom: var(--space-2); color: var(--text); }
  .readiness-card .value {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }
  .readiness-card.ok { border-color: var(--success); }
  .readiness-card.warn { border-color: var(--warn); }
  .readiness-card.error { border-color: var(--danger); }

  .warning-list { display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-2); }
  .guidance-block {
    border-top: 1px solid var(--line);
    margin-top: var(--space-2);
    padding-top: var(--space-2);
  }
  .guidance-block p { margin: var(--space-1) 0; color: var(--text-muted); }
  .command-snippet {
    display: flex;
    align-items: stretch;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  .command-snippet code {
    flex: 1;
    min-width: 0;
    overflow-wrap: anywhere;
    white-space: pre-wrap;
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }

  /* ===== Project-knowledge explainer + empty states (HS-47-02) =====
   * All markup here is static (or static-toggled), so this scoped CSS
   * applies. The empty states are toggled by dictation-app.js setting the
   * `hidden` attribute, never re-rendered via innerHTML — that sidesteps the
   * Astro scoped-CSS-on-injected-DOM trap. */
  .kn-explainer {
    display: grid;
    grid-template-columns: 1fr minmax(0, 23rem);
    gap: var(--space-4);
    align-items: start;
    padding: var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-1));
    box-shadow: var(--elev-1);
  }
  @media (max-width: 760px) {
    .kn-explainer { grid-template-columns: 1fr; }
  }
  .kn-explainer-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .kn-explainer-eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
  }
  .kn-explainer-what {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
  }
  .kn-explainer-why {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    max-width: 52ch;
  }
  /* Worked example: a small monospace transform panel. */
  .kn-example {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--canvas);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
  }
  .kn-example figcaption {
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .kn-example-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .kn-example-tag {
    flex: 0 0 5.5rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .kn-example code {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text);
    overflow-wrap: anywhere;
  }
  .kn-example-arrow {
    color: var(--accent);
    font-size: var(--font-size-sm);
    line-height: 1;
    padding-left: 5.5rem;
  }
  .kn-example-out code { color: var(--accent); font-weight: 600; }

  /* Teaching empty states (KB rows / .hs files). */
  .kn-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2);
    padding: var(--space-5) var(--space-4);
    border: 1px dashed var(--line);
    border-radius: var(--radius-md);
    background: var(--canvas);
  }
  .kn-empty[hidden] { display: none; }
  .kn-empty-glyph { color: var(--accent); opacity: 0.85; }
  .kn-empty-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text);
  }
  .kn-empty-text {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    max-width: 46ch;
  }
  .kn-empty-eg {
    margin: var(--space-1) 0 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }
  .kn-empty-eg code { color: var(--accent); }
  .kn-empty-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  /* ===== Guided setup (HS-47-03) ===== */
  .kn-setup[hidden] { display: none; }
  .kn-setup-lede {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    max-width: 64ch;
  }
  .kn-setup-lede strong { color: var(--text); }
  .kn-linkbtn {
    appearance: none;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    font: inherit;
    color: var(--accent);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .kn-linkbtn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
    border-radius: var(--radius-1);
  }
  .kn-setup-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  @media (max-width: 760px) { .kn-setup-grid { grid-template-columns: 1fr; } }
  .kn-setup-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--surface-2);
  }
  .kn-setup-card-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text);
  }
  .kn-setup-card-text {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    flex: 1;
  }
  .kn-setup-card .btn { align-self: flex-start; }
  .kn-agent-prompt {
    margin: var(--space-1) 0 0;
    max-height: 14rem;
    overflow: auto;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    line-height: var(--line-height-relaxed);
  }

  /* ===== Discovery nudge (HS-47-04) ===== */
  .kn-nudge {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--accent);
    border-radius: var(--radius-md);
    background:
      linear-gradient(90deg, var(--accent-tint, var(--accent-soft)), transparent 70%),
      var(--surface-2);
    box-shadow: var(--elev-1);
  }
  .kn-nudge[hidden] { display: none; }
  .kn-nudge-glyph { flex: 0 0 auto; color: var(--accent); }
  .kn-nudge-text {
    flex: 1;
    min-width: 0;
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-normal);
  }
  .kn-nudge-text strong { color: var(--text); }
  #kn-nudge-project { color: var(--text); font-family: var(--font-mono); font-size: var(--font-size-xs); }
  .kn-nudge-actions {
    flex: 0 0 auto;
    display: flex;
    gap: var(--space-2);
  }
  .kn-nudge-off {
    flex: 0 0 auto;
    appearance: none;
    background: none;
    border: none;
    padding: var(--space-1);
    color: var(--text-faint);
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .kn-nudge-off:hover { color: var(--text-muted); }
  .kn-nudge-off:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
    border-radius: var(--radius-1);
  }
  @media (max-width: 760px) {
    .kn-nudge { flex-wrap: wrap; }
    .kn-nudge-text { flex: 1 1 100%; }
  }

  /* Misc small JS-injected helpers */
  .rt-latency-vis {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }
  .rt-counters {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
  }
  .rt-counter-note {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    margin-top: var(--space-3);
  }

  /* ===== Copilot depth (HS-40-03) ===== */
  .depth-group {
    margin: var(--space-3) 0 0;
    padding: var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-3);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-1));
    box-shadow: var(--elev-1);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .depth-legend {
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .depth-legend-title {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
  }
  .depth-legend-title::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: var(--radius-pill);
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .depth-legend-sub {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    line-height: var(--line-height-normal);
  }
  .depth-knob {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .depth-knob--group {
    gap: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-subtle);
  }
  .depth-knob-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .depth-knob-title {
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text);
  }
  .depth-knob-badge {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid var(--accent);
    border-radius: var(--radius-pill);
    padding: 1px var(--space-2);
    min-width: 2.4em;
    text-align: center;
  }
  .depth-knob-hint {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    line-height: var(--line-height-normal);
    margin: 0;
  }
  .depth-knob-desc {
    color: var(--text);
    font-size: var(--font-size-xs);
    font-family: var(--font-mono);
    margin: 0;
  }

  /* Segmented control (rewrite passes) */
  .seg {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-1);
    padding: var(--space-1);
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
  }
  .seg-btn {
    appearance: none;
    border: 1px solid transparent;
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    font-weight: 600;
    padding: var(--space-2) 0;
    border-radius: var(--radius-1);
    cursor: pointer;
    transition: background var(--duration-short) var(--ease-standard),
      color var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard);
  }
  .seg-btn:hover:not([aria-pressed="true"]) {
    color: var(--text);
    background: var(--canvas-raised);
  }
  .seg-btn[aria-pressed="true"] {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-on);
    box-shadow: var(--elev-1);
  }
  .seg-btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  /* Toggle switch */
  .depth-switch {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    cursor: pointer;
  }
  .depth-switch-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .switch {
    position: relative;
    flex: 0 0 auto;
    margin-top: 2px;
  }
  .switch input {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    cursor: pointer;
  }
  .switch-track {
    display: block;
    width: 40px;
    height: 22px;
    border-radius: var(--radius-pill);
    background: var(--canvas);
    border: 1px solid var(--line-strong);
    transition: background var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard);
  }
  .switch-knob {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 16px;
    height: 16px;
    border-radius: var(--radius-pill);
    background: var(--text-muted);
    transition: transform var(--duration-short) var(--ease-emphasized),
      background var(--duration-short) var(--ease-standard);
  }
  .switch input:checked + .switch-track {
    background: var(--accent);
    border-color: var(--accent);
  }
  .switch input:checked + .switch-track .switch-knob {
    transform: translateX(18px);
    background: var(--accent-on);
  }
  .switch input:focus-visible + .switch-track {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .depth-subknob {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3);
    border-radius: var(--radius-2);
    background: var(--canvas);
    border: 1px solid var(--border-subtle);
    animation: depth-reveal var(--duration-medium) var(--ease-decelerate);
  }
  .depth-subknob[hidden] {
    display: none;
  }
  @keyframes depth-reveal {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
