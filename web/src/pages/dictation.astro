---
// HS-10-09: `/dictation` rebuilt on the design system.
//
// The legacy page was a single 1,381-line static/dictation.html with
// inline <style> (~177 lines), inline vanilla JS (~1,004 lines), and
// markup that hand-rolled a topbar/navigation. This rebuild:
//
//   - Wraps the page in AppLayout (TopNav + LocalPill + skip link).
//   - Loads dictation-app.js verbatim from src/scripts/.
//   - Replaces inline <style> with scoped CSS that flows from
//     tokens.css.
//   - Preserves every DOM id the JS reads via getElementById.
//   - Routes the dry-run trace through the standardized
//     CommandPreview markup (HS-10-10) — final text + each stage
//     emit `.cmd` figures whose copy buttons are picked up by
//     CommandPreview's document-level click delegator.

import AppLayout from "../layouts/AppLayout.astro";
import CommandPreview from "../components/CommandPreview.astro";
---

<AppLayout title="HoldSpeak Dictation" current="dictation">
  <main id="app" class="dictation">
    {/* HS-44-02: cockpit hero — carry the Phase-43 wizard's bar (eyebrow +
        display title + lede) so the daily-driver surface reads premium, not
        like a bare tab dump. Presentation only; the Alpine-free app below is
        untouched. */}
    <header class="cockpit-hero">
      <p class="cockpit-eyebrow">Dictation</p>
      <h1 class="cockpit-h">Dictation cockpit</h1>
      <p class="cockpit-lede">
        Tune intelligent typing end-to-end — readiness, blocks, project
        context, runtime, and a live dry-run — without hand-editing a single
        config file.
      </p>
    </header>

    <div class="scope-row cockpit-tabs" role="tablist" aria-label="Dictation sections">
      <button id="section-readiness" data-section="readiness" type="button" role="tab">Readiness</button>
      <button id="section-blocks" data-section="blocks" class="active" type="button" role="tab">Blocks</button>
      <button id="section-kb" data-section="kb" type="button" role="tab">Project KB</button>
      <button id="section-hs" data-section="hs" type="button" role="tab">Project Context</button>
      <button id="section-hooks" data-section="hooks" type="button" role="tab">Agent Hooks</button>
      <span class="tab-tier-sep" aria-hidden="true" title="Runtime &amp; test"></span>
      <button id="section-runtime" data-section="runtime" type="button" role="tab">Runtime</button>
      <button id="section-memory" data-section="memory" type="button" role="tab">Memory</button>
      <button id="section-dry-run" data-section="dry-run" type="button" role="tab">Dry-run</button>
    </div>

    <div class="meta-banner project-root-row">
      <strong>Project root</strong>
      <input
        type="text"
        id="project-root-override"
        placeholder="current holdspeak cwd"
        class="project-root-input"
      />
      <button class="btn primary" id="project-root-apply" type="button">Apply</button>
      <button class="btn" id="project-root-clear" type="button">Use cwd</button>
      <select id="project-root-recent" class="project-root-recent" aria-label="Recent project roots">
        <option value="">Recent roots</option>
      </select>
      <span id="project-root-status" class="project-root-status"></span>
    </div>

    <div id="agent-context-banner" class="meta-banner agent-context-banner" hidden>
      <div>
        <strong id="agent-context-title">Agent waiting</strong>
        <span id="agent-context-text"></span>
      </div>
      <button class="btn" id="agent-context-clear" type="button">Clear</button>
    </div>

    <!-- ============= Readiness ============= -->
    <section id="view-readiness" class="view" hidden>
      <h2>Dictation readiness</h2>
      <p class="lede">
        One snapshot of the selected project's dictation setup:
        pipeline, blocks, project KB, runtime model, and next actions.
      </p>
      <div id="ready-meta" class="meta-banner">Loading…</div>
      <div id="ready-cards" class="readiness-grid"></div>
      <section class="panel">
        <header class="panel-header">
          <h3>Next actions</h3>
          <button class="btn" id="ready-btn-refresh" type="button">Refresh</button>
        </header>
        <div id="ready-actions" class="warning-list"></div>
      </section>
    </section>

    <!-- ============= Blocks ============= -->
    <section id="view-blocks" class="view">
      <h2>Block editor</h2>
      <p class="lede">
        Author dictation blocks (DIR-01) without hand-editing
        <code>blocks.yaml</code>. Changes write atomically to the
        underlying file (<code>WFS-CFG-006</code>) and are validated
        before persisting.
      </p>

      <div class="scope-row" role="tablist" aria-label="Block scope">
        <button id="scope-global" data-scope="global" class="active" type="button" role="tab">Global</button>
        <button id="scope-project" data-scope="project" type="button" role="tab">Project</button>
      </div>

      <div id="meta-banner" class="meta-banner">Loading…</div>

      <div class="grid">
        <section class="panel">
          <header class="panel-header">
            <h3>Blocks</h3>
            <button id="btn-new" class="btn primary" type="button">+ New block</button>
          </header>
          <div id="block-list" class="block-list"></div>
          <div class="panel-divider">
            <h3 class="subhead">Starter templates</h3>
            <div id="template-list"></div>
            <div id="template-msg"></div>
          </div>
        </section>

        <section class="panel">
          <header class="panel-header">
            <h3 id="editor-title">Select a block to edit</h3>
          </header>
          <div id="editor"></div>
        </section>
      </div>
    </section>

    <!-- ============= Runtime ============= -->
    <section id="view-runtime" class="view" hidden>
      <h2>Dictation runtime</h2>
      <p class="lede">
        Configure the DIR-01 pipeline without editing
        <code>~/.config/holdspeak/config.json</code>. Counters are
        process-scoped (since runtime start). The cold-start cap is
        <code>max_total_latency_ms × 5</code> — first
        <code>classify()</code> after launch slower than the cap
        disables the LLM stage for the session
        (<code>DIR-R-003</code>).
      </p>
      <div id="rt-meta-banner" class="meta-banner">Loading…</div>
      <div class="grid">
        <section class="panel">
          <header class="panel-header"><h3>Pipeline + runtime</h3></header>
          <label class="check-label"><input type="checkbox" id="rt-enabled" /> Enable dictation pipeline</label>
          <label class="check-label"><input type="checkbox" id="rt-stage-rewriter" /> Enable project-aware rewrite stage (<code>.hs/</code>)</label>
          <label>Target profile override
            <select id="rt-target-profile">
              <option value="auto">Auto-detect target</option>
              <option value="codex_cli">Codex CLI</option>
              <option value="claude_code">Claude Code</option>
              <option value="terminal_shell">Terminal shell</option>
              <option value="browser">Browser</option>
              <option value="editor">Editor</option>
              <option value="chat">Chat</option>
            </select>
          </label>
          <button class="btn" id="rt-target-auto" type="button">Reset target to auto</button>
          <label>Backend
            <select id="rt-backend">
              <option value="auto">auto (prefer MLX)</option>
              <option value="mlx">mlx</option>
              <option value="llama_cpp">llama_cpp</option>
              <option value="openai_compatible">OpenAI-compatible endpoint</option>
            </select>
          </label>
          <label>MLX model path <input type="text" id="rt-mlx-model" /></label>
          <label>llama_cpp GGUF path <input type="text" id="rt-llama-path" /></label>
          <label>OpenAI-compatible model <input type="text" id="rt-openai-model" /></label>
          <label>OpenAI-compatible base URL <input type="text" id="rt-openai-base-url" /></label>
          <label>OpenAI-compatible API key env <input type="text" id="rt-openai-api-key-env" /></label>
          <label>OpenAI-compatible timeout seconds <input type="number" id="rt-openai-timeout" min="1" step="0.5" /></label>
          <label class="check-label"><input type="checkbox" id="rt-warm" /> warm_on_start (load model at launch)</label>
          <label>max_total_latency_ms
            <input type="range" id="rt-latency" min="100" max="5000" step="50" />
          </label>
          <div id="rt-latency-vis" class="rt-latency-vis"></div>

          <!-- ===== Copilot depth (HS-40-03): the Phase-39 knobs ===== -->
          <fieldset class="depth-group">
            <legend class="depth-legend">
              <span class="depth-legend-title">Copilot depth</span>
              <span class="depth-legend-sub">Opt-in refinement — off by default. Nothing here changes how the copilot behaves until you turn it on.</span>
            </legend>

            <!-- rewrite_passes -->
            <div class="depth-knob">
              <div class="depth-knob-head">
                <span class="depth-knob-title">Rewrite passes</span>
                <span class="depth-knob-badge" id="rt-rewrite-badge">1×</span>
              </div>
              <p class="depth-knob-hint">Draft&nbsp;→&nbsp;critique&nbsp;→&nbsp;refine. Each extra pass tightens the rewrite; any pass that would breach your latency budget is skipped automatically.</p>
              <div class="seg" id="rt-rewrite-seg" role="group" aria-label="Rewrite passes, 1 to 5">
                <button type="button" class="seg-btn" data-value="1" aria-pressed="true">1</button>
                <button type="button" class="seg-btn" data-value="2" aria-pressed="false">2</button>
                <button type="button" class="seg-btn" data-value="3" aria-pressed="false">3</button>
                <button type="button" class="seg-btn" data-value="4" aria-pressed="false">4</button>
                <button type="button" class="seg-btn" data-value="5" aria-pressed="false">5</button>
              </div>
              <input type="hidden" id="rt-rewrite-passes" value="1" />
              <p class="depth-knob-desc" id="rt-rewrite-desc">Single pass — fastest; byte-identical to a plain rewrite.</p>
            </div>

            <!-- corrections_enabled -->
            <label class="depth-switch">
              <span class="depth-switch-text">
                <span class="depth-knob-title">Learn from my corrections</span>
                <span class="depth-knob-hint">Correct a route once and similar utterances get nudged the same way — the memory now <strong>survives a restart</strong> (curate it in Memory).</span>
              </span>
              <span class="switch">
                <input type="checkbox" id="rt-corrections-enabled" />
                <span class="switch-track"><span class="switch-knob"></span></span>
              </span>
            </label>

            <!-- target_detect_llm_enabled + _below -->
            <div class="depth-knob depth-knob--group">
              <label class="depth-switch">
                <span class="depth-switch-text">
                  <span class="depth-knob-title">Infer the target when unsure</span>
                  <span class="depth-knob-hint">When heuristic target detection is low-confidence, ask the model to classify it. A manual override always wins.</span>
                </span>
                <span class="switch">
                  <input type="checkbox" id="rt-target-detect-llm-enabled" />
                  <span class="switch-track"><span class="switch-knob"></span></span>
                </span>
              </label>
              <div class="depth-subknob" id="rt-target-below-wrap" hidden>
                <div class="depth-knob-head">
                  <span class="depth-knob-title">Ask the model below confidence</span>
                  <span class="depth-knob-badge" id="rt-target-below-val">0.80</span>
                </div>
                <input type="range" id="rt-target-detect-llm-below" min="0" max="1" step="0.05" />
                <p class="depth-knob-hint">Lower = trust the heuristic (rarely ask the model). Higher = ask more often.</p>
              </div>
            </div>
          </fieldset>

          <div id="rt-msg"></div>
          <div class="actions">
            <button class="btn primary" id="rt-btn-save" type="button">Save</button>
            <button class="btn" id="rt-btn-test" type="button">Save &amp; test in dry-run</button>
            <button class="btn" id="rt-btn-reset" type="button">Reset</button>
          </div>
        </section>
        <section class="panel">
          <header class="panel-header">
            <h3>Runtime status</h3>
            <button id="rt-btn-refresh" class="btn" type="button">Refresh</button>
          </header>
          <div id="rt-session-banner"></div>
          <div id="rt-guidance"></div>
          <div id="rt-counters" class="rt-counters"></div>
          <p class="rt-counter-note">
            Counters reset on every <code>holdspeak</code> restart.
            <code>classify_failures</code> includes both LLM errors
            and constraint-rejected outputs;
            <code>constrained_retries</code> is the count of
            GBNF-grammar re-prompts.
          </p>
        </section>
      </div>
    </section>

    <!-- ============= Memory + telemetry (HS-40-04) ============= -->
    <section id="view-memory" class="view" hidden>
      <h2>Copilot memory &amp; depth</h2>
      <p class="lede">
        What the copilot has <strong>learned</strong> (persists across restarts)
        and how <strong>deep</strong> it's running this session. Curate the
        memory here; tune the knobs in <strong>Runtime → Copilot depth</strong>.
      </p>
      <div id="mem-meta-banner" class="meta-banner">Loading…</div>
      <div class="grid">
        <!-- ===== What the copilot has learned ===== -->
        <section class="panel">
          <header class="panel-header">
            <h3>What the copilot has learned</h3>
            <button id="mem-btn-clear" class="btn danger" type="button">Forget all</button>
          </header>

          <label class="depth-switch mem-toggle">
            <span class="depth-switch-text">
              <span class="depth-knob-title">Use corrections when routing</span>
              <span class="depth-knob-hint" id="mem-enabled-hint">When on, similar utterances are nudged toward what you corrected.</span>
            </span>
            <span class="switch">
              <input type="checkbox" id="mem-corrections-enabled" />
              <span class="switch-track"><span class="switch-knob"></span></span>
            </span>
          </label>

          <form id="mem-add-form" class="mem-add">
            <div class="row">
              <label>Kind
                <select id="mem-add-kind">
                  <option value="intent">intent → block</option>
                  <option value="target">target → profile</option>
                </select>
              </label>
              <label>Corrected to
                <input type="text" id="mem-add-value" placeholder="block id / target profile" />
              </label>
            </div>
            <label>When I say (gist)
              <input type="text" id="mem-add-text" placeholder="utterance this correction applies to" />
            </label>
            <div class="actions">
              <button class="btn primary" id="mem-add-btn" type="submit">Remember this</button>
            </div>
            <div id="mem-add-msg"></div>
          </form>

          <div id="mem-list" class="mem-list"></div>
        </section>

        <!-- ===== Pipeline depth (this session) ===== -->
        <section class="panel">
          <header class="panel-header">
            <h3>Pipeline depth · this session</h3>
            <button id="mem-btn-refresh" class="btn" type="button">Refresh</button>
          </header>
          <div id="mem-depth" class="mem-depth"></div>
          <p class="rt-counter-note">
            Latency telemetry is in-memory and resets on every
            <code>holdspeak</code> restart. Run a few
            <strong>dry-runs</strong> (or dictate) to populate it.
          </p>
        </section>
      </div>
    </section>

    <!-- ============= Dry-run ============= -->
    <section id="view-dry-run" class="view" hidden>
      <h2>Dry-run preview</h2>
      <p class="lede">
        Run the current DIR-01 pipeline against typed text without
        touching the keyboard. The trace uses the current project
        detected from the <code>holdspeak</code> process cwd.
      </p>
      <div class="grid">
        <section class="panel">
          <header class="panel-header"><h3>Input</h3></header>
          <label>Utterance
            <textarea id="dry-utterance" placeholder="Type the utterance to preview"></textarea>
          </label>
          <div id="dry-msg"></div>
          <div class="actions">
            <button class="btn primary" id="dry-btn-run" type="button">Run dry-run</button>
            <button class="btn" id="dry-btn-clear" type="button">Clear</button>
          </div>
        </section>
        <section class="panel">
          <header class="panel-header"><h3>Result</h3></header>
          <div id="dry-meta" class="meta-banner">No dry-run yet.</div>
          <div id="dry-final"></div>
          <div id="dry-trace"></div>
        </section>
      </div>
    </section>

    <!-- ============= Project KB ============= -->
    <section id="view-kb" class="view" hidden>
      <h2>Project knowledge base</h2>
      <p class="lede">
        Edit the <code>kb</code> mapping in
        <code>&lt;project_root&gt;/.holdspeak/project.yaml</code>.
        Keys become <code>{`{project.kb.<key>}`}</code> placeholders
        inside block templates. Keys must match
        <code>[A-Za-z_][A-Za-z0-9_]*</code>; values are strings (or null).
      </p>
      <div id="kb-meta-banner" class="meta-banner">Loading…</div>
      <section class="panel">
        <header class="panel-header">
          <h3>Knowledge-base entries</h3>
          <div class="panel-toolbar">
            <button id="kb-btn-starter" class="btn" type="button">Use starter</button>
            <button id="kb-btn-add" class="btn primary" type="button">+ New entry</button>
          </div>
        </header>
        <div id="kb-rows"></div>
        <div id="kb-msg"></div>
        <div class="actions">
          <button class="btn primary" id="kb-btn-save" type="button">Save</button>
          <button class="btn" id="kb-btn-reset" type="button">Reset</button>
          <button class="btn danger" id="kb-btn-delete" type="button">Delete file</button>
        </div>
      </section>
    </section>

    <!-- ============= Project Context ============= -->
    <section id="view-hs" class="view" hidden>
      <h2>Project context</h2>
      <p class="lede">
        Edit repo-local <code>.hs/</code> files used by project-aware dictation.
        These files guide prompt rewrites, context injection, memory, workflows,
        active issues, vocabulary, and ignore rules. Legacy <code>.hs_*</code>
        files are shown as read-only compatibility inputs; saving creates or
        updates the canonical <code>.hs/</code> copy.
      </p>
      <div id="hs-meta-banner" class="meta-banner">Loading…</div>
      <section class="panel hs-suggestion-panel" id="hs-suggestion-panel" hidden>
        <header class="panel-header">
          <h3>Suggested project doc update</h3>
        </header>
        <p class="rt-counter-note">
          Local intelligence can propose one narrow project-memory file after
          a dry-run. Review and edit before applying; HoldSpeak never writes
          these suggestions silently.
        </p>
        <label>
          Target path
          <input id="hs-suggestion-path" type="text" placeholder=".hs/memory/specific-slug.md" />
        </label>
        <p id="hs-suggestion-rationale" class="rt-counter-note"></p>
        <label>
          Suggested content
          <textarea id="hs-suggestion-content" placeholder="No suggestion loaded."></textarea>
        </label>
        <div id="hs-suggestion-msg"></div>
        <div class="actions">
          <button class="btn primary" id="hs-suggestion-apply" type="button">Apply to .hs</button>
          <button class="btn" id="hs-suggestion-dismiss" type="button">Dismiss</button>
        </div>
      </section>
      <div class="grid">
        <section class="panel">
          <header class="panel-header"><h3>Files</h3></header>
          <div id="hs-file-list" class="block-list"></div>
        </section>
        <section class="panel">
          <header class="panel-header"><h3 id="hs-editor-title">Select a .hs file</h3></header>
          <p id="hs-editor-help" class="rt-counter-note"></p>
          <textarea id="hs-editor" placeholder="Select a .hs file to edit"></textarea>
          <div id="hs-msg"></div>
          <div class="actions">
            <button class="btn primary" id="hs-btn-save" type="button">Save</button>
            <button class="btn" id="hs-btn-reset" type="button">Reset</button>
          </div>
        </section>
      </div>
    </section>

    <!-- ============= Agent Hooks ============= -->
    <section id="view-hooks" class="view" hidden>
      <h2>Agent hooks</h2>
      <p class="lede">
        Inspect Claude/Codex hook status and copy the HoldSpeak hook templates.
        The browser does not write agent settings files directly; paste the
        template into the target tool's hook settings after review.
      </p>
      <div id="hooks-meta-banner" class="meta-banner">Loading…</div>
      <section class="panel">
        <header class="panel-header">
          <h3>External agent summary</h3>
        </header>
        <p class="lede">
          Compress the latest captured Claude/Codex question into compact
          context for intelligent typing. HoldSpeak uses safe read-only /
          no-tools defaults and only runs this when you click the button.
        </p>
        <div class="row">
          <label>
            Provider
            <select id="agent-summary-provider">
              <option value="codex">Codex CLI</option>
              <option value="claude">Claude Code</option>
            </select>
          </label>
          <label>
            Timeout seconds
            <input id="agent-summary-timeout" type="number" min="1" max="60" value="20" />
          </label>
        </div>
        <div class="actions">
          <button class="btn primary" id="agent-summary-run" type="button">Summarize latest agent context</button>
          <button class="btn" id="agent-summary-refresh" type="button">Refresh captured context</button>
        </div>
        <div id="agent-summary-provider-status" class="hook-status">Provider status loads with hook status.</div>
        <div id="agent-summary-status" class="preview">No summary generated yet.</div>
      </section>
      <section class="panel">
        <header class="panel-header">
          <h3>Hook templates</h3>
          <div class="panel-toolbar">
            <label class="check-label hooks-capture-label">
              <input type="checkbox" id="hooks-capture-messages" checked />
              Include assistant-message capture
            </label>
            <button id="hooks-btn-refresh" class="btn" type="button">Refresh</button>
          </div>
        </header>
        <div id="hooks-agent-list" class="hooks-agent-list"></div>
      </section>
    </section>
  </main>

  {/* Render a hidden CommandPreview so its scoped CSS + script
      delegator are bundled with this page. The delegator handles
      every `[data-cmd-copy]` button on the document, including the
      ones rendered dynamically by dictation-app.js into #dry-final
      and #dry-trace. */}
  <div hidden aria-hidden="true">
    <CommandPreview command="holdspeak doctor --json" />
  </div>

  <script>
    import factorySource from "../scripts/dictation-app.js?raw";

    // The legacy script ran at module level (no factory wrapper) and
    // attached to DOM via window.addEventListener("DOMContentLoaded",
    // ...). Astro hoists this script after the body — DOM is ready,
    // so Function-eval'd execution runs immediately and the
    // DOMContentLoaded handler inside the legacy code still fires
    // because Astro emits the script as type="module" which deferrs
    // until the document is parsed.
    new Function(factorySource)();
  </script>
</AppLayout>

<style>
  /* All values flow from tokens.css. */

  .dictation {
    position: relative;
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* HS-44-02: an ambient accent glow behind the cockpit, the same
   * treatment as the dashboard home + the wizard. */
  .dictation::before {
    content: "";
    position: fixed;
    inset: 0 0 auto 0;
    height: 340px;
    pointer-events: none;
    z-index: -1;
    background: radial-gradient(
      60% 100% at 50% 0%,
      color-mix(in srgb, var(--accent) 8%, transparent),
      transparent 70%
    );
  }

  /* HS-44-02: cockpit hero — eyebrow + display title + lede. */
  .cockpit-hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .cockpit-eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
  }
  .cockpit-h {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(var(--font-size-2xl), 3.2vw, var(--font-size-3xl));
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--text);
  }
  .cockpit-lede {
    margin: var(--space-1) 0 0;
    color: var(--text-muted);
    line-height: var(--line-height-relaxed);
    max-width: 62ch;
  }

  /* HS-44-02: the section nav reads as a premium contained pill bar
   * (elevated surface, blur) rather than loose buttons on the canvas.
   * Scoped to `.cockpit-tabs` so the in-panel block-scope row keeps its
   * lighter treatment. */
  .cockpit-tabs {
    padding: var(--space-1);
    background: color-mix(in srgb, var(--surface-2) 82%, transparent);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-pill);
    box-shadow: var(--elev-1);
    backdrop-filter: blur(8px);
  }
  /* Specificity beats the later `.scope-row button.active` so the active
   * section reads as a punchy solid accent, not the soft block-scope look. */
  .scope-row.cockpit-tabs button.active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-on);
    box-shadow: 0 0 16px color-mix(in srgb, var(--accent) 32%, transparent);
  }

  .lede {
    margin: 0 0 var(--space-3);
    color: var(--text-muted);
    line-height: var(--line-height-relaxed);
    max-width: 48rem;
  }

  h2 {
    margin: 0 0 var(--space-2);
    font-family: var(--font-display);
    color: var(--text);
  }

  .view {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .view[hidden] { display: none; }

  /* === Tab + scope row =================================== */
  .scope-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-1);
  }
  /* HS-30-07: divides the section tabs into two tiers — Setup
   * (Readiness…Agent Hooks) and Runtime & test (Runtime, Dry-run). */
  .tab-tier-sep {
    align-self: stretch;
    width: 1px;
    margin: var(--space-1) var(--space-2);
    background: var(--border);
  }
  .scope-row button {
    appearance: none;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    padding: var(--space-2) var(--space-3);
    color: var(--text-muted);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    cursor: pointer;
    transition: border-color var(--duration-short) var(--ease-standard),
                color var(--duration-short) var(--ease-standard),
                background var(--duration-short) var(--ease-standard);
  }
  .scope-row button:hover { color: var(--text); border-color: var(--line-strong); }
  .scope-row button.active {
    background: var(--accent-soft);
    border-color: var(--accent);
    color: var(--text);
  }
  .scope-row button:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  /* HS-12-02: meta-banner reads as a Workbench tool tray —
   * white surface, hard black border, no rounding. The .warn
   * / .error variants swap the border colour to the matching
   * status ramp. */
  .meta-banner {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--text);
    font-family: var(--font-mono);
    line-height: var(--line-height-relaxed);
  }
  .meta-banner strong {
    color: var(--text);
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: 400;
    letter-spacing: 0.04em;
  }
  .meta-banner.warn  { border-color: var(--warn);  background: var(--warn-soft);  color: var(--warn-strong); }
  .meta-banner.error { border-color: var(--danger); background: var(--danger-soft); color: var(--danger-strong); }

  .project-root-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }
  .project-root-input { flex: 1 1 26rem; min-width: 0; }
  .project-root-recent { flex: 0 1 16rem; }
  .project-root-status {
    flex: 1 1 100%;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .agent-context-banner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-3);
    border-color: var(--accent);
    background:
      linear-gradient(90deg, var(--accent-tint), transparent 60%),
      var(--surface-2);
  }
  .agent-context-banner[hidden] { display: none; }
  .agent-context-banner > div {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  #agent-context-text {
    color: var(--text-muted);
    overflow-wrap: anywhere;
  }
  .hooks-capture-label {
    color: var(--text);
    font-size: var(--font-size-xs);
  }
  .hooks-agent-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }
  @media (max-width: 900px) {
    .hooks-agent-list { grid-template-columns: 1fr; }
  }
  .hook-card {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    background: var(--surface-1);
  }
  .hook-card h3 {
    margin: 0 0 var(--space-2);
  }
  .hook-status {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-muted);
    word-break: break-word;
  }
  .hook-template {
    max-height: 16rem;
    overflow: auto;
    white-space: pre;
    background: var(--surface-2);
    border: 1px solid var(--line);
    padding: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }

  /* === Grid ============================================== */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }
  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr; }
  }

  /* === Panel (HS-12-02 Workbench window grammar) ===========
   * Markup keeps padding on `.panel` rather than a body div, so
   * we use a negative margin on `.panel-header` to push the
   * blue title strip out to the panel edges. */
  .panel {
    background: var(--surface-1);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--elev-1);
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    overflow: hidden;
  }
  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    background: var(--surface-2);
    color: var(--text);
    border-bottom: 1px solid var(--border-subtle);
    padding: var(--space-3);
    margin: calc(var(--space-3) * -1) calc(var(--space-3) * -1) 0;
  }
  .panel-header h3 {
    margin: 0;
    color: var(--text);
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    line-height: 1.3;
  }
  /* Sub-headings inside panel bodies (e.g. "Starter templates")
   * read as black-on-white labels, not as title strips. */
  .panel h3:not(.panel-header h3):not(.subhead) {
    margin: 0;
    color: var(--text);
    font-family: var(--font-display);
    font-size: var(--font-size-md);
  }
  .panel-toolbar {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .panel-toolbar .btn--ghost { color: var(--text-muted); }
  .panel-divider {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-subtle);
  }
  .subhead {
    font-size: var(--font-size-sm);
    font-family: var(--font-ui);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
  }

  /* === Block list ======================================== */
  .block-list { display: flex; flex-direction: column; gap: var(--space-1); }
  .block-card {
    border: 1px solid var(--border-subtle);
    border-left: 3px solid transparent;
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    background: var(--surface-2);
    cursor: pointer;
    transition: background var(--duration-short) var(--ease-standard),
                color var(--duration-short) var(--ease-standard),
                border-color var(--duration-short) var(--ease-standard);
  }
  /* HS-44-02: a hover accent edge gives the list tactile feedback. */
  .block-card:hover:not(.selected) {
    background: var(--surface-hover);
    border-left-color: var(--accent);
  }
  .block-card.selected {
    background: var(--selected-bg);
    color: var(--selected-fg);
  }
  .block-card.selected .block-id,
  .block-card.selected .block-desc { color: var(--selected-fg); }
  .block-id { font-family: var(--font-mono); font-weight: 600; color: var(--text); }
  .block-desc {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    margin-top: var(--space-1);
  }
  .block-card .pill {
    display: inline-block;
    padding: 0 var(--space-2);
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    color: var(--accent);
    font-size: var(--font-size-xs);
    margin-left: var(--space-2);
  }
  .template-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2);
    margin-top: var(--space-2);
    background: var(--canvas);
  }
  .template-card .template-title { font-weight: 600; }
  .template-card .template-desc {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    margin: var(--space-1) 0 var(--space-2);
  }

  /* === Form controls ===================================== */
  label {
    display: block;
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }
  .check-label { display: flex; align-items: center; gap: var(--space-2); color: var(--text); }
  input[type="text"],
  input[type="number"],
  input[type="range"],
  textarea,
  select {
    width: 100%;
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    margin-top: var(--space-1);
  }
  input[type="checkbox"] { width: auto; margin: 0; }
  input:focus-visible, textarea:focus-visible, select:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
    border-color: var(--accent);
  }
  textarea { min-height: 5.5rem; resize: vertical; }
  .row { display: flex; gap: var(--space-3); }
  .row > * { flex: 1; }

  /* === Buttons =========================================== */
  .btn {
    appearance: none;
    background: var(--canvas-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    transition: border-color var(--duration-short) var(--ease-standard),
                background var(--duration-short) var(--ease-standard);
  }
  .btn:hover:not(:disabled) { border-color: var(--line-strong); }
  .btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .btn.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-on);
  }
  .btn.danger { color: var(--danger); border-color: var(--danger); }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  /* === Preview / boxes (used by JS-rendered editor previews) === */
  .preview {
    background: var(--canvas);
    border: 1px dashed var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-3);
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    white-space: pre-wrap;
    min-height: 5rem;
  }
  .preview .missing { color: var(--warn); }

  .error-box {
    background: var(--danger-soft);
    border: 1px solid var(--danger);
    color: var(--danger);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    font-family: var(--font-mono);
  }
  .ok-box {
    background: var(--success-soft);
    border: 1px solid var(--success);
    color: var(--success);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
  }

  /* === Trace (dry-run) =================================== */
  .trace-stage {
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-3);
    background: var(--canvas);
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .trace-stage-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .trace-stage-head strong { color: var(--text); }
  .trace-stage-elapsed { color: var(--text-faint); }
  .trace-intent {
    margin: 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .trace-metadata {
    margin: 0;
    background: var(--canvas-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  .trace-empty {
    margin: 0;
    color: var(--text-faint);
    font-size: var(--font-size-sm);
  }

  /* === Readiness ========================================= */
  .readiness-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-2);
  }
  @media (max-width: 900px) { .readiness-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .readiness-grid { grid-template-columns: 1fr; } }
  .readiness-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-3);
    background: var(--canvas);
    min-height: 6.5rem;
    /* HS-44-02: depth + motion to match the wizard's bar. */
    transition: transform var(--duration-short) var(--ease-standard),
                border-color var(--duration-short) var(--ease-standard),
                box-shadow var(--duration-short) var(--ease-standard);
  }
  .readiness-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--elev-1);
  }
  @media (prefers-reduced-motion: reduce) {
    .readiness-card:hover { transform: none; }
  }
  .readiness-card strong { display: block; margin-bottom: var(--space-2); color: var(--text); }
  .readiness-card .value {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }
  .readiness-card.ok { border-color: var(--success); }
  .readiness-card.warn { border-color: var(--warn); }
  .readiness-card.error { border-color: var(--danger); }

  .warning-list { display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-2); }
  .guidance-block {
    border-top: 1px solid var(--line);
    margin-top: var(--space-2);
    padding-top: var(--space-2);
  }
  .guidance-block p { margin: var(--space-1) 0; color: var(--text-muted); }
  .command-snippet {
    display: flex;
    align-items: stretch;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  .command-snippet code {
    flex: 1;
    min-width: 0;
    overflow-wrap: anywhere;
    white-space: pre-wrap;
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }

  /* Misc small JS-injected helpers */
  .rt-latency-vis {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }
  .rt-counters {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
  }
  .rt-counter-note {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    margin-top: var(--space-3);
  }

  /* ===== Copilot depth (HS-40-03) ===== */
  .depth-group {
    margin: var(--space-3) 0 0;
    padding: var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-3);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-1));
    box-shadow: var(--elev-1);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .depth-legend {
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .depth-legend-title {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
  }
  .depth-legend-title::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: var(--radius-pill);
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .depth-legend-sub {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    line-height: var(--line-height-normal);
  }
  .depth-knob {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .depth-knob--group {
    gap: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-subtle);
  }
  .depth-knob-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .depth-knob-title {
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text);
  }
  .depth-knob-badge {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid var(--accent);
    border-radius: var(--radius-pill);
    padding: 1px var(--space-2);
    min-width: 2.4em;
    text-align: center;
  }
  .depth-knob-hint {
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    line-height: var(--line-height-normal);
    margin: 0;
  }
  .depth-knob-desc {
    color: var(--text);
    font-size: var(--font-size-xs);
    font-family: var(--font-mono);
    margin: 0;
  }

  /* Segmented control (rewrite passes) */
  .seg {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-1);
    padding: var(--space-1);
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
  }
  .seg-btn {
    appearance: none;
    border: 1px solid transparent;
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    font-weight: 600;
    padding: var(--space-2) 0;
    border-radius: var(--radius-1);
    cursor: pointer;
    transition: background var(--duration-short) var(--ease-standard),
      color var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard);
  }
  .seg-btn:hover:not([aria-pressed="true"]) {
    color: var(--text);
    background: var(--canvas-raised);
  }
  .seg-btn[aria-pressed="true"] {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-on);
    box-shadow: var(--elev-1);
  }
  .seg-btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  /* Toggle switch */
  .depth-switch {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    cursor: pointer;
  }
  .depth-switch-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .switch {
    position: relative;
    flex: 0 0 auto;
    margin-top: 2px;
  }
  .switch input {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    cursor: pointer;
  }
  .switch-track {
    display: block;
    width: 40px;
    height: 22px;
    border-radius: var(--radius-pill);
    background: var(--canvas);
    border: 1px solid var(--line-strong);
    transition: background var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard);
  }
  .switch-knob {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 16px;
    height: 16px;
    border-radius: var(--radius-pill);
    background: var(--text-muted);
    transition: transform var(--duration-short) var(--ease-emphasized),
      background var(--duration-short) var(--ease-standard);
  }
