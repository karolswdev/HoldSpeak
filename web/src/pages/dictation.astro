  </div>

  <script>
    import factorySource from "../scripts/dictation-app.js?raw";

    // The legacy script ran at module level (no factory wrapper) and
    // attached to DOM via window.addEventListener("DOMContentLoaded",
    // ...). Astro hoists this script after the body — DOM is ready,
    // so Function-eval'd execution runs immediately and the
    // DOMContentLoaded handler inside the legacy code still fires
    // because Astro emits the script as type="module" which deferrs
    // until the document is parsed.
    new Function(factorySource)();
  </script>
