---
// HS-10-09: `/dictation` rebuilt on the design system; decomposed into
// section partials + behavior modules (Phase 54).
//
// This page is a thin composition. Each tab section is an Astro component
// under ../components/dictation/ carrying its own markup + styles; the
// behavior lives in ES modules under ../scripts/dictation/ (one module per
// section, entered through ../scripts/dictation-app.js). The page keeps only
// the cockpit spine: hero, section tabs, the project-root override row, and
// the agent-context banner.
//
// Style architecture (the rules that bite):
//   - SharedStyles.astro is imported FIRST: it emits the cross-section
//     design primitives once, before any per-section styles, preserving the
//     base-then-feature cascade order.
//   - Styles targeting JS-rendered DOM are `is:global` in their partial
//     (Astro scoped CSS only matches template elements, never runtime-
//     injected DOM). Static-markup styles stay scoped.
//   - Every DOM id the behavior modules read via getElementById is preserved.

import AppLayout from "../layouts/AppLayout.astro";
import CommandPreview from "../components/CommandPreview.astro";
import SharedStyles from "../components/dictation/SharedStyles.astro";
import KnowledgeStyles from "../components/dictation/KnowledgeStyles.astro";
import DepthControlStyles from "../components/dictation/DepthControlStyles.astro";
import KnNudge from "../components/dictation/KnNudge.astro";
import ActivityNudges from "../components/dictation/ActivityNudges.astro";
import ReadinessSection from "../components/dictation/ReadinessSection.astro";
import BlocksSection from "../components/dictation/BlocksSection.astro";
import RuntimeSection from "../components/dictation/RuntimeSection.astro";
import MemorySection from "../components/dictation/MemorySection.astro";
import JournalSection from "../components/dictation/JournalSection.astro";
import DryRunSection from "../components/dictation/DryRunSection.astro";
import FactsSection from "../components/dictation/FactsSection.astro";
import ContextSection from "../components/dictation/ContextSection.astro";
import HooksSection from "../components/dictation/HooksSection.astro";
---

<AppLayout title="HoldSpeak Dictation" current="dictation">
  <SharedStyles />
  <KnowledgeStyles />
  <DepthControlStyles />
  <main id="app" class="dictation">
    {/* HS-44-02: cockpit hero — carry the Phase-43 wizard's bar (eyebrow +
        display title + lede) so the daily-driver surface reads premium, not
        like a bare tab dump. Presentation only; the app below is untouched. */}
    <header class="cockpit-hero">
      <p class="cockpit-eyebrow">Dictation</p>
      <h1 class="cockpit-h">Dictation cockpit</h1>
      <p class="cockpit-lede">
        Tune the dictation pipeline end-to-end — readiness, blocks, project
        context, runtime, and a live dry-run — without hand-editing a single
        config file.
      </p>
    </header>

    <KnNudge />

    <ActivityNudges />

    <div class="scope-row cockpit-tabs" role="tablist" aria-label="Dictation sections">
      <button id="section-readiness" data-section="readiness" type="button" role="tab">Readiness</button>
      <button id="section-blocks" data-section="blocks" class="active" type="button" role="tab">Blocks</button>
      <button id="section-kb" data-section="kb" type="button" role="tab">Project Facts</button>
      <button id="section-hs" data-section="hs" type="button" role="tab">Project Context</button>
      <button id="section-hooks" data-section="hooks" type="button" role="tab">Agent Hooks</button>
      <span class="tab-tier-sep" aria-hidden="true" title="Runtime &amp; test"></span>
      <button id="section-runtime" data-section="runtime" type="button" role="tab">Runtime</button>
      <button id="section-memory" data-section="memory" type="button" role="tab">Memory</button>
      <button id="section-journal" data-section="journal" type="button" role="tab">Journal</button>
      <button id="section-dry-run" data-section="dry-run" type="button" role="tab">Dry-run</button>
    </div>

    <div class="meta-banner project-root-row">
      <strong>Project root</strong>
      <input
        type="text"
        id="project-root-override"
        placeholder="current holdspeak cwd"
        class="project-root-input"
      />
      <button class="btn primary" id="project-root-apply" type="button">Apply</button>
      <button class="btn" id="project-root-clear" type="button">Use cwd</button>
      <select id="project-root-recent" class="project-root-recent" aria-label="Recent project roots">
        <option value="">Recent roots</option>
      </select>
      <span id="project-root-status" class="project-root-status"></span>
    </div>

    <div id="agent-context-banner" class="meta-banner agent-context-banner" hidden>
      <div>
        <strong id="agent-context-title">Agent waiting</strong>
        <span id="agent-context-text"></span>
      </div>
      <button class="btn" id="agent-context-clear" type="button">Clear</button>
    </div>

    <ReadinessSection />
    <BlocksSection />
    <RuntimeSection />
    <MemorySection />
    <JournalSection />
    <DryRunSection />
    <FactsSection />
    <ContextSection />
    <HooksSection />
  </main>

  {/* Render a hidden CommandPreview so its scoped CSS + script
      delegator are bundled with this page. The delegator handles
      every `[data-cmd-copy]` button on the document, including the
      ones rendered dynamically by the dryrun behavior module into
      #dry-final and #dry-trace. */}
  <div hidden aria-hidden="true">
    <CommandPreview command="holdspeak doctor --json" />
  </div>

  <script>
    // The page behavior is a real ES module bundled by Astro (it emits
    // this script as type="module", deferred until the document is
    // parsed — DOM is ready when it runs, same timing as the previous
    // `?raw` + new Function() eval shim this replaced). The entry
    // imports its carved behavior modules from scripts/dictation/.
    import "../scripts/dictation-app.js";
  </script>
</AppLayout>

<style>
  /* The cockpit spine. All values flow from tokens.css. */

  .dictation {
    position: relative;
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* HS-44-02: an ambient accent glow behind the cockpit, the same
   * treatment as the dashboard home + the wizard. */
  .dictation::before {
    content: "";
    position: fixed;
    inset: 0 0 auto 0;
    height: 340px;
    pointer-events: none;
    z-index: -1;
    background: radial-gradient(
      60% 100% at 50% 0%,
      color-mix(in srgb, var(--accent) 8%, transparent),
      transparent 70%
    );
  }

  /* HS-44-02: cockpit hero — eyebrow + display title + lede. */
  .cockpit-hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .cockpit-eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
  }
  .cockpit-h {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(var(--font-size-2xl), 3.2vw, var(--font-size-3xl));
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--text);
  }
  .cockpit-lede {
    margin: var(--space-1) 0 0;
    color: var(--text-muted);
    line-height: var(--line-height-relaxed);
    max-width: 62ch;
  }

  /* HS-44-02: the section nav reads as a premium contained pill bar
   * (elevated surface, blur) rather than loose buttons on the canvas.
   * Scoped to `.cockpit-tabs` so the in-panel block-scope row keeps its
   * lighter treatment. */
  .cockpit-tabs {
    padding: var(--space-1);
    background: color-mix(in srgb, var(--surface-2) 82%, transparent);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-pill);
    box-shadow: var(--elev-1);
    backdrop-filter: blur(8px);
  }
  /* Specificity beats the shared `.scope-row button.active` so the active
   * section reads as a punchy solid accent, not the soft block-scope look. */
  .scope-row.cockpit-tabs button.active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-on);
    box-shadow: 0 0 16px color-mix(in srgb, var(--accent) 32%, transparent);
  }

  /* HS-30-07: divides the section tabs into two tiers — Setup
   * (Readiness…Agent Hooks) and Runtime & test (Runtime, Dry-run). */
  .tab-tier-sep {
    align-self: stretch;
    width: 1px;
    margin: var(--space-1) var(--space-2);
    background: var(--border);
  }

  .project-root-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }
  .project-root-input { flex: 1 1 26rem; min-width: 0; }
  .project-root-recent { flex: 0 1 16rem; }
  .project-root-status {
    flex: 1 1 100%;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .agent-context-banner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-3);
    border-color: var(--accent);
    background:
      linear-gradient(90deg, var(--accent-tint), transparent 60%),
      var(--surface-2);
  }
  .agent-context-banner[hidden] { display: none; }
  .agent-context-banner > div {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  #agent-context-text {
    color: var(--text-muted);
    overflow-wrap: anywhere;
  }
</style>
