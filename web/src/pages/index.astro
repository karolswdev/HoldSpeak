  .stat-value.mono { font-family: var(--font-mono); }
  .conn-dot { width: var(--space-2); height: var(--space-2); border-radius: 50%; background: var(--text-faint); }
  .conn-dot.connected { background: var(--success); }
  .conn-dot.connecting { background: var(--warn); }
  .conn-dot.error { background: var(--danger); }

  /* === Buttons (mirrors components/Button.astro) ========== */
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: var(--space-2); padding: var(--space-3) var(--space-4);
    font-family: var(--font-ui); font-weight: 500; font-size: var(--font-size-md);
    line-height: 1; letter-spacing: var(--letter-spacing-loose);
    border: 1px solid transparent; border-radius: var(--radius-2);
    cursor: pointer; user-select: none;
    transition:
      background var(--duration-short) var(--ease-standard),
      border-color var(--duration-short) var(--ease-standard),
      color var(--duration-short) var(--ease-standard);
  }
  .btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .btn:disabled { cursor: not-allowed; opacity: 0.55; }
  .btn--sm { padding: var(--space-2) var(--space-3); font-size: var(--font-size-sm); }
  .btn--hero { width: 100%; padding: var(--space-4) var(--space-5); font-size: var(--font-size-lg); }
  .btn--primary { background: var(--accent); color: var(--accent-on); border-color: var(--accent); box-shadow: var(--glow-accent); }
  .btn--primary:not(:disabled):hover { background: var(--accent-hover); border-color: var(--accent-hover); }
  .btn--secondary { background: var(--surface-2); color: var(--text); border-color: var(--border); }
  .btn--secondary:not(:disabled):hover { border-color: var(--border-strong); background: var(--surface-3); }
