---
// The front door IS the Desk (HS-73-02, owner decision 2026-07-02: "the desk
// is absolutely the main surface"). Phase 70's orientation Home is retired;
// its two duties live on: the first-run guard below (verbatim), and the
// guiding empty state inside the island (a fresh desk answers "what is
// this" in the world's own voice).
import AppLayout from "../layouts/AppLayout.astro";
import DeskApp from "../desk/DeskApp";
---

<AppLayout
  title="HoldSpeak"
  description="Your desk: dictation, meetings, notes, agents and more as a spatial world."
  current="home"
  immersive
>
  {/* HS-70-02/03: the first-run guard on the front door. A first-run user
      (no successful dictation yet) goes to the /welcome wizard; a hard-blocked
      user goes to /setup; everyone else arrives on the Desk. Inline so it runs
      early and its intent is visible in the served HTML. */}
  <script is:inline>
    (async () => {
      try {
        const r = await fetch("/api/setup/status");
        if (!r.ok) return;
        const s = await r.json();
        if (s && s.first_run) { window.location.replace("/welcome"); return; }
        if (s && s.overall === "blocked") { window.location.replace("/setup"); return; }
      } catch (_e) {}
    })();
  </script>

  <DeskApp client:only="react" />
</AppLayout>

<style is:global>
  /* HS-73-02: the front door is full-bleed — the world owns the viewport. */
  .app-immersive main#main {
    max-width: none;
    padding: 0;
    margin: 0;
  }
</style>
