    .presence-ring.is-live { animation: none; }
  }

  .action-stage {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; gap: var(--space-3);
    padding: var(--space-4);
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-3);
  }
  .action-hint {
    margin: 0; color: var(--text-muted);
    font-size: var(--font-size-sm); line-height: var(--line-height-relaxed);
  }

  .stats {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2); padding: var(--space-3);
    background: var(--canvas); border: 1px solid var(--line);
    border-radius: var(--radius-2);
  }
  .stat { display: flex; flex-direction: column; gap: var(--space-1); }
  .stat-label {
    color: var(--text-faint); font-size: var(--font-size-xs);
