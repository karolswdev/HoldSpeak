---
// HS-70-02: Home — the orientation front door.
//
// Answers the two questions a confused user (or the owner) has in the first
// ten seconds: WHAT IS THIS (the positioning one-liner) and WHAT DO I DO NOW
// (the two modes as co-equal cards + a single next-action from
// /api/setup/status). This is NOT a data dashboard: the live-meeting runtime
// that used to live at `/` moved to `/live` (Meetings-mode content).
//
// Dynamic bits fill pre-rendered elements' textContent only — no
// innerHTML-injected structural DOM — so the scoped CSS below stays valid
// (the Astro/Alpine JS-DOM scoping trap does not apply).

import AppLayout from "../layouts/AppLayout.astro";
---

<AppLayout title="HoldSpeak" current="home">
  {/* HS-70-02/03: the first-run guard on the front door. A first-run user
      (no successful dictation yet) goes to the /welcome wizard; a hard-blocked
      user goes to /setup; everyone else stays on Home. Inline so it runs early
      and its intent is visible in the served HTML. */}
  <script is:inline>
    (async () => {
      try {
        const r = await fetch("/api/setup/status");
        if (!r.ok) return;
        const s = await r.json();
        if (s && s.first_run) { window.location.replace("/welcome"); return; }
        if (s && s.overall === "blocked") { window.location.replace("/setup"); return; }
      } catch (_e) {}
    })();
  </script>

  <div class="home">
    <header class="home-hero">
      <p class="home-eyebrow">Your local voice copilot</p>
      <h1 class="home-title">One copilot, two modes.</h1>
      <p class="home-lede">
        Dictation that types anywhere and learns how you work, and meetings
        that end with decisions, actions, and follow-ups instead of a recording.
      </p>
    </header>

    <a id="home-next" class="home-next" href="#" hidden>
      <span class="home-next-eyebrow">Next</span>
      <span id="home-next-label" class="home-next-label"></span>
      <span class="home-next-arrow" aria-hidden="true">→</span>
    </a>

    <div class="home-modes">
      <div class="home-mode signal-card">
        <span class="home-mode-glyph glyph-chip" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" />
            <path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8" />
          </svg>
        </span>
        <h2 class="home-mode-name">Dictation</h2>
        <p class="home-mode-what">Hold a key, speak, and it types. It learns your corrections.</p>
        <p id="home-dictation-sub" class="home-mode-sub">Loading recent activity.</p>
        <div class="home-mode-actions">
          <a href="/dictation" class="home-mode-go">Open Dictation</a>
        </div>
      </div>

      <div class="home-mode signal-card">
        <span class="home-mode-glyph glyph-chip" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 8h2a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2" />
            <path d="M9 12h6M9 16h4M12 3v5M9 6l3-3 3 3" />
          </svg>
        </span>
        <h2 class="home-mode-name">Meetings</h2>
        <p class="home-mode-what">Capture or import a meeting. It ends with decisions, actions, and follow-ups.</p>
        <p id="home-meetings-sub" class="home-mode-sub">Loading recent activity.</p>
        <div class="home-mode-actions">
          <a href="/live" class="home-mode-go">Start a meeting</a>
          <a href="/history" class="home-mode-go home-mode-go--ghost">Browse the archive</a>
        </div>
      </div>
    </div>

    {/* HS-71-07: celebrate the Desk (the spatial world) as a front-door entry,
        while the two modes stay the primary path and the Desk also lives in Studio. */}
    <div class="home-secondary">
      <a class="home-desk" href="/desk">
        <span class="home-desk-glyph glyph-chip" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="7" height="6" rx="1.5" /><rect x="14" y="4" width="7" height="6" rx="1.5" /><rect x="3" y="14" width="7" height="6" rx="1.5" /><rect x="14" y="14" width="7" height="6" rx="1.5" />
          </svg>
        </span>
        <span class="home-desk-text">
          <span class="home-desk-label">The Desk</span>
          <span class="home-desk-hint">Your primitives as a spatial world.</span>
        </span>
        <span class="home-desk-arrow" aria-hidden="true">→</span>
      </a>
      <a class="home-studio" href="/studio">
        <span class="home-studio-label">Studio</span>
        <span class="home-studio-hint">Workbench, Agent Desk, Cadence, and more</span>
        <span class="home-studio-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</AppLayout>

<script>
  (async () => {
    const j = async (url) => {
      try {
        const r = await fetch(url);
        if (!r.ok) return null;
        return await r.json();
      } catch {
        return null;
      }
    };
    const arr = (v, ...keys) => {
      if (Array.isArray(v)) return v;
      for (const k of keys) if (v && Array.isArray(v[k])) return v[k];
      return [];
    };

    // Next action — surface the setup primary action until the user is set up.
    const s = await j("/api/setup/status");
    if (s && (s.first_run || s.overall !== "ready") && s.primary_action) {
      const el = document.getElementById("home-next");
      document.getElementById("home-next-label").textContent =
        s.primary_action.label || "Finish setting up";
      el.setAttribute("href", s.primary_action.route || "/setup");
      el.hidden = false;
    }

    // Dictation subtitle — latest, or the one guiding move when empty.
    const jn = await j("/api/dictation/journal?limit=1");
    const dItems = arr(jn, "items", "entries", "journal");
    const dSub = document.getElementById("home-dictation-sub");
    if (dItems.length) {
      const t = String(dItems[0].transcript || dItems[0].typed || "").trim().slice(0, 64);
      dSub.textContent = t ? `Last: “${t}”` : "You have recent dictations.";
    } else {
      dSub.textContent = "Nothing yet. Hold your key and speak.";
    }

    // Meetings subtitle — latest, or the one guiding move when empty.
    const mn = await j("/api/meetings?limit=1");
    const mItems = arr(mn, "meetings", "items");
    const mSub = document.getElementById("home-meetings-sub");
    if (mItems.length) {
      mSub.textContent = `Last: ${String(mItems[0].title || "Untitled meeting").trim()}`;
    } else {
      mSub.textContent = "Nothing yet. Capture or import your first meeting.";
    }
  })();
</script>

<style>
  .home {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-5) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Identity */
  .home-hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .home-eyebrow {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
  }
  .home-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .home-lede {
    margin: 0 auto;
    max-width: 620px;
    color: var(--text-muted);
    font-size: var(--font-size-md);
    line-height: 1.55;
  }

  /* Next action */
  .home-next {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--accent);
    border-radius: var(--radius-md);
    background: var(--accent-tint);
    text-decoration: none;
    transition: background var(--duration-short) var(--ease-standard);
  }
  .home-next:hover {
    background: var(--accent-tint-strong, var(--accent-tint));
  }
  .home-next:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .home-next-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
  }
  .home-next-label {
    flex: 1 1 auto;
    color: var(--text);
    font-weight: 600;
  }
  .home-next-arrow {
    color: var(--accent);
    font-weight: 700;
  }

  /* The two modes */
  .home-modes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }
  .home-mode {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
  }
  .home-mode-glyph {
    margin-bottom: var(--space-2);
  }
  .home-mode-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
  }
  .home-mode-what {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: 1.5;
  }
  .home-mode-sub {
    margin: var(--space-1) 0 0;
    color: var(--text-faint);
    font-size: var(--font-size-sm);
    font-style: italic;
    min-height: 1.4em;
  }
  .home-mode-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }
  .home-mode-go {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    background: var(--accent);
    color: var(--accent-contrast, #06121f);
    font-weight: 600;
    font-size: var(--font-size-sm);
    text-decoration: none;
    transition: filter var(--duration-short) var(--ease-standard);
  }
  .home-mode-go:hover {
    filter: brightness(1.08);
  }
  .home-mode-go:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .home-mode-go--ghost {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
  .home-mode-go--ghost:hover {
    color: var(--text);
    border-color: var(--border-strong);
    filter: none;
  }

  /* HS-71-07: the Desk (celebrated) + the quiet Studio, side by side */
  .home-secondary {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--space-3);
  }
  .home-desk {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--border));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--accent) 7%, transparent);
    text-decoration: none;
    color: var(--text);
    transition:
      border-color var(--duration-short) var(--ease-standard),
      background var(--duration-short) var(--ease-standard),
      transform var(--duration-short) var(--ease-standard);
  }
  .home-desk:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    transform: translateY(-1px);
  }
  .home-desk:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .home-desk-glyph { width: 40px; height: 40px; flex: none; }
  .home-desk-text { display: flex; flex-direction: column; flex: 1 1 auto; }
  .home-desk-label { font-family: var(--font-display); font-weight: 700; color: var(--text); }
  .home-desk-hint { font-size: var(--font-size-sm); color: var(--text-muted); }
  .home-desk-arrow { color: var(--accent); font-weight: 700; }

  /* Quiet Studio */
  .home-studio {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text-muted);
    transition:
      border-color var(--duration-short) var(--ease-standard),
      color var(--duration-short) var(--ease-standard);
  }
  @media (max-width: 720px) {
    .home-secondary { grid-template-columns: 1fr; }
  }
  .home-studio:hover {
    border-color: var(--border-strong);
    color: var(--text);
  }
  .home-studio:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  .home-studio-label {
    font-weight: 600;
    color: var(--text);
  }
  .home-studio-hint {
    flex: 1 1 auto;
    font-size: var(--font-size-sm);
    color: var(--text-faint);
  }
  .home-studio-arrow {
    color: var(--text-muted);
  }

  @media (max-width: 720px) {
    .home-modes {
      grid-template-columns: 1fr;
    }
  }
</style>
