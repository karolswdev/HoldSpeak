    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .presence-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
  }
  .presence-card.tone-recording .presence-ring { color: var(--accent); }
  .presence-card.tone-working .presence-ring { color: var(--info); }
  .presence-card.tone-complete .presence-ring { color: var(--success); }
  .presence-card.tone-error {
    border-color: var(--danger);
    background: var(--danger-soft);
  }
  .presence-card.tone-error .presence-ring { color: var(--danger); }
  .presence-card.tone-idle .presence-ring { color: var(--text-faint); }

