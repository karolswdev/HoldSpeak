---
// HS-10-06: `/` runtime dashboard rebuilt on the design system.
//
// State machine + WebSocket + API behavior is preserved from the
// legacy dashboard.html: the same Alpine `HoldSpeakDashboard()` factory
// drives the page (imported from src/scripts/dashboard-app.js, served
// alongside Alpine.js — both self-hosted, no CDN). All x-data /
// x-text / x-show / @click bindings are preserved verbatim.
//
// Astro components (Button, Pill, etc.) are intentionally NOT used
// in this file: Astro silently drops non-prop attributes like
// `x-show` / `:disabled` / `@click` on custom-component invocations,
// which would break Alpine bindings. Instead this page renders raw
// HTML using locally-scoped CSS that consumes the same design tokens.

import AppLayout from "../layouts/AppLayout.astro";
import HoldMark from "../components/HoldMark.astro";
---

<AppLayout title="HoldSpeak Runtime" current="runtime">
  <div class="runtime" x-data="HoldSpeakDashboard()" x-init="init()">

    <!-- Hero -->
    <section class="hero" :class="{
      'state-idle': !meetingActive && !stopInProgress,
      'state-active': meetingActive && !stopInProgress,
      'state-stopping': stopInProgress,
    }">
      <div class="hero-id">
        <div class="hero-pills">
          <span class="pill pill--local"><span class="pill-dot"></span>local-only</span>
          <span class="pill pill--info" x-show="meetingActive" x-cloak><span class="pill-dot"></span>recording</span>
          <span class="pill pill--warn" x-show="stopInProgress" x-cloak><span class="pill-dot"></span>stopping</span>
        </div>

        <div class="hero-title">
          <h1 x-text="meetingTitle || 'HoldSpeak'"></h1>
          <button type="button" class="title-edit" :disabled="!meetingActive" @click="openMetadataModal()" title="Edit meeting details">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 113 3L7 19l-4 1 1-4z"/>
            </svg>
            <span class="sr-only">Edit meeting details</span>
          </button>
        </div>

        <p class="hero-copy">
          Real-time transcript, live meeting intelligence, and export controls
          in one focused workspace. Recording, transcription, and intel run
          locally on this machine.
        </p>

        <div class="hero-tags">
          <template x-for="tag in meetingTags" :key="tag">
            <span class="tag-chip" x-text="tag"></span>
          </template>
          <span class="tag-chip-faint" x-show="meetingTags.length === 0" x-cloak>No tags yet</span>
        </div>
      </div>

      <div class="hero-action">
        <div class="action-stage" x-show="!meetingActive && !stopInProgress" x-cloak>
          <HoldMark size={72} ariaLabel="Hold to talk — runtime ready" />
          <p class="action-hint">
            Press start, then hold to talk. Audio, transcript, and intel
            stay on this machine.
          </p>
        </div>

        <button type="button" class="btn btn--primary btn--hero" x-show="!meetingActive" x-cloak :disabled="startInProgress" :class="{ 'is-loading': startInProgress }" @click="startMeeting()">
          <span class="btn-spinner" x-show="startInProgress" x-cloak></span>
          <span x-text="startInProgress ? 'Starting...' : 'Start meeting'"></span>
        </button>
        <button type="button" class="btn btn--danger btn--hero" x-show="meetingActive" x-cloak :disabled="stopInProgress" :class="{ 'is-loading': stopInProgress }" @click="stopMeeting()">
          <span class="btn-spinner" x-show="stopInProgress" x-cloak></span>
          <span x-text="stopInProgress ? 'Stopping...' : 'Stop meeting'"></span>
        </button>

        <div class="stats">
          <div class="stat">
            <span class="stat-label">Connection</span>
            <span class="stat-value">
              <span class="conn-dot" :class="connectionTone()"></span>
              <span x-text="connectionLabel()"></span>
            </span>
          </div>
          <div class="stat">
            <span class="stat-label">Duration</span>
            <span class="stat-value mono" x-text="duration"></span>
          </div>
          <div class="stat">
            <span class="stat-label">Segments</span>
            <span class="stat-value mono" x-text="segments.length"></span>
          </div>
          <div class="stat">
            <span class="stat-label">Open actions</span>
            <span class="stat-value mono" x-text="activeActionItems().filter(i => i.status !== 'done').length"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- Two-column board -->
    <div class="board">
      <!-- Transcript -->
      <section class="panel panel--comfortable">
        <header class="panel-header">
          <div class="panel-title">Transcript stream</div>
          <div class="panel-toolbar">
            <button type="button" class="btn btn--ghost btn--sm" @click="scrollTranscriptToBottom()">Jump to latest</button>
          </div>
        </header>
        <div class="panel-body">
          <div class="transcript-scroll" x-ref="transcriptScroll">
            <template x-if="entries.length === 0">
              <div class="transcript-empty">
                <HoldMark size={56} pulse={false} ariaLabel="Idle" />
                <h3 x-text="meetingActive ? 'Waiting for transcript' : 'Meeting idle'"></h3>
                <p x-text="meetingActive
                  ? 'Once audio arrives, segments stream in here with speaker chips, timestamps, and bookmark callouts.'
                  : 'Start a meeting to begin recording, transcription, and live intelligence updates.'"></p>
              </div>
            </template>

            <template x-for="entry in entries" :key="entry.id">
              <div class="entry">
                <template x-if="entry.kind === 'segment'">
                  <article class="segment" :class="`tone-${speakerTone(entry.speaker)}`" tabindex="0" @click="copySegment(entry)" @keydown.enter="copySegment(entry)">
                    <div class="segment-meta">
                      <span class="speaker-pill" :class="`tone-${speakerTone(entry.speaker)}`">
                        <span class="speaker-dot"></span>
                        <span x-text="speakerLabel(entry.speaker)"></span>
                      </span>
                      <span class="ts mono" x-text="entry.start ? `[${entry.start}${entry.end ? `-${entry.end}` : ''}]` : 'live'"></span>
                      <span class="copy-hint">Click to copy</span>
                    </div>
                    <p class="segment-text" x-text="entry.text"></p>
                  </article>
                </template>
                <template x-if="entry.kind === 'bookmark'">
                  <article class="bookmark">
                    <div class="bookmark-meta">
                      <span class="bookmark-flag">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M7 3h10v18l-5-3-5 3V3z"/></svg>
                        <span>Bookmark</span>
                      </span>
                      <span class="ts mono" x-text="entry.timestamp ? `at ${entry.timestamp}` : 'live'"></span>
                    </div>
                    <p class="bookmark-text" x-text="entry.label"></p>
                  </article>
                </template>
              </div>
            </template>
          </div>
        </div>
        <footer class="panel-footer">
          <div class="dock">
            <button type="button" class="btn btn--secondary btn--sm" :disabled="!meetingActive" @click="openBookmarkModal()">Bookmark</button>
            <button type="button" class="btn btn--secondary btn--sm" @click="copyAll()">Copy all</button>
            <div class="export-wrap">
              <button type="button" class="btn btn--primary btn--sm" @click="exportOpen = !exportOpen">Export</button>
              <div class="export-menu" x-show="exportOpen" x-cloak @click.outside="exportOpen = false">
                <button type="button" class="export-item" @click="exportAs('md')"><span>Meeting notes</span><span class="mono">.md</span></button>
                <button type="button" class="export-item" @click="exportAs('txt')"><span>Plain transcript</span><span class="mono">.txt</span></button>
                <button type="button" class="export-item" @click="exportAs('json')"><span>Structured data</span><span class="mono">.json</span></button>
              </div>
            </div>
          </div>
        </footer>
      </section>

      <!-- Side rail -->
      <aside class="rail">
        <!-- Live intel -->
        <section class="panel panel--dense" x-show="intelStreaming" x-cloak>
          <header class="panel-header">
            <div class="panel-title">
              <span class="pill pill--info"><span class="pill-dot"></span>analyzing</span>
            </div>
          </header>
          <div class="panel-body">
            <p class="streaming-text"><span x-text="intelBuffer"></span><span class="caret"></span></p>
          </div>
        </section>

        <!-- Intelligence -->
        <section class="panel panel--dense">
          <header class="panel-header"><div class="panel-title">Intelligence</div></header>
          <div class="panel-body">
            <p class="rail-title" x-text="intelStatusTitle()"></p>
            <p class="rail-muted" x-text="intelStatusCopy()"></p>
          </div>
        </section>

        <!-- Topics -->
        <section class="panel panel--dense">
          <header class="panel-header"><div class="panel-title">Topics</div></header>
          <div class="panel-body">
            <template x-if="intel.topics.length === 0">
              <p class="rail-muted">Topics will appear once enough transcript has accumulated.</p>
            </template>
            <div class="topics" x-show="intel.topics.length > 0" x-cloak>
              <template x-for="topic in intel.topics" :key="topic">
                <span class="topic-pill" x-text="topic"></span>
              </template>
            </div>
          </div>
        </section>

        <!-- Summary -->
        <section class="panel panel--dense">
          <header class="panel-header"><div class="panel-title">Summary</div></header>
          <div class="panel-body">
            <template x-if="!intel.summary">
              <p class="rail-muted">No summary yet.</p>
            </template>
            <p class="summary-text" x-show="intel.summary" x-cloak x-text="intel.summary"></p>
          </div>
        </section>

        <!-- Action items -->
        <section class="panel panel--dense">
          <header class="panel-header">
            <div class="panel-title">Action items</div>
            <div class="panel-toolbar">
              <span class="rail-faint" x-text="meetingActive ? 'Live' : 'Read-only while idle'"></span>
            </div>
          </header>
          <div class="panel-body">
            <template x-if="activeActionItems().length === 0">
              <p class="rail-muted" x-text="meetingActive ? 'No action items yet.' : 'No active action items loaded for this session yet.'"></p>
            </template>
            <ul class="action-list" x-show="activeActionItems().length > 0" x-cloak>
              <template x-for="(item, idx) in activeActionItems()" :key="item.id || `${idx}-${item.task}`">
                <li class="action-item" :class="{ 'is-done': item.status === 'done' }">
                  <button type="button" class="check" :disabled="!meetingActive" @click="toggleActionItemStatus(item)" :title="item.status === 'done' ? 'Mark pending' : 'Mark done'">
                    <svg x-show="item.status === 'done'" x-cloak viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    <span class="sr-only">Toggle status</span>
                  </button>
                  <div class="action-body">
                    <p class="action-task" x-text="item.task || 'Action item'"></p>
                    <div class="action-meta">
                      <span class="meta-chip" x-show="item.owner" x-cloak x-text="`Owner ${item.owner}`"></span>
                      <span class="meta-chip" x-show="item.due" x-cloak x-text="`Due ${item.due}`"></span>
                      <span class="meta-chip status" :class="statusClass(item.status)" x-text="statusLabel(item.status)"></span>
                      <span class="meta-chip status" :class="reviewStatusClass(item.review_state)" x-text="reviewStatusLabel(item.review_state)"></span>
                    </div>
                    <div class="action-controls">
                      <button type="button" class="btn btn--ghost btn--sm" :disabled="!meetingActive || item.review_state === 'accepted'" @click="acceptActionItem(item)">Accept</button>
                      <button type="button" class="btn btn--secondary btn--sm" :disabled="!meetingActive" @click="editActionItem(item)">Edit</button>
                    </div>
                  </div>
                  <button type="button" class="dismiss" :disabled="!meetingActive" @click="dismissActionItem(item)" title="Dismiss">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18"/></svg>
                    <span class="sr-only">Dismiss</span>
                  </button>
                </li>
              </template>
            </ul>
            <p class="rail-faint" x-show="dismissedCount() > 0" x-cloak x-text="`${dismissedCount()} dismissed item${dismissedCount() === 1 ? '' : 's'}`"></p>
          </div>
        </section>

        <!-- Plugin jobs -->
        <section class="panel panel--dense">
          <header class="panel-header"><div class="panel-title">Deferred plugin jobs</div></header>
          <div class="panel-body">
            <div class="topics">
              <span class="topic-pill" x-text="`Total ${pluginJobSummary?.total_jobs ?? 0}`"></span>
              <span class="topic-pill" x-text="`Queued ${pluginJobSummary?.queued_jobs ?? 0}`"></span>
              <span class="topic-pill" x-text="`Running ${pluginJobSummary?.running_jobs ?? 0}`"></span>
              <span class="topic-pill" x-text="`Failed ${pluginJobSummary?.failed_jobs ?? 0}`"></span>
              <span class="topic-pill" x-text="`Failure ${pluginQueueFailureRateLabel()}`"></span>
            </div>
            <p class="rail-muted" x-text="pluginQueueNextRetryLabel()"></p>
            <div class="jobs-controls">
              <select class="rail-input" x-model="pluginJobStatusFilter" @change="loadPluginJobs()">
                <option value="all">All jobs</option>
                <option value="queued">Queued</option>
                <option value="running">Running</option>
                <option value="failed">Failed</option>
              </select>
              <input class="rail-input rail-input--sm" type="number" min="1" x-model.number="pluginJobLimit" placeholder="Limit"/>
              <button type="button" class="btn btn--secondary btn--sm" :disabled="loadingPluginJobs" @click="loadPluginJobs()">Refresh</button>
              <button type="button" class="btn btn--primary btn--sm" :disabled="processingPluginJobs" @click="processPluginJobs('respect_backoff')">Process due</button>
              <button type="button" class="btn btn--ghost btn--sm" :disabled="processingPluginJobs" @click="processPluginJobs('retry_now')">Retry scheduled</button>
            </div>
            <template x-if="loadingPluginJobs">
              <p class="rail-muted">Loading deferred plugin jobs...</p>
            </template>
            <template x-if="!loadingPluginJobs && pluginJobs.length === 0">
              <p class="rail-muted">No deferred plugin jobs match this filter.</p>
            </template>
            <ul class="action-list" x-show="!loadingPluginJobs && pluginJobs.length > 0" x-cloak>
              <template x-for="job in pluginJobs" :key="job.id">
                <li class="action-item">
                  <span class="meta-chip status" :class="statusClass(job.status)" x-text="job.status"></span>
                  <div class="action-body">
                    <p class="action-task" x-text="job.plugin_id"></p>
                    <div class="action-meta">
                      <span class="meta-chip mono" x-text="job.meeting_id"></span>
                      <span class="meta-chip mono" x-text="job.window_id"></span>
                      <span class="meta-chip" x-text="`Attempts ${job.attempts}`"></span>
                      <span class="meta-chip" x-show="job.retry_scheduled" x-cloak x-text="pluginJobScheduleLabel(job)"></span>
                    </div>
                    <p class="rail-muted" x-show="job.last_error" x-cloak x-text="job.last_error"></p>
                    <div class="action-controls">
                      <button type="button" class="btn btn--primary btn--sm" :disabled="processingPluginJobs || job.status === 'running'" @click="retryPluginJob(job.id)">Retry now</button>
                      <button type="button" class="btn btn--ghost btn--sm" :disabled="processingPluginJobs || job.status === 'running'" @click="cancelPluginJob(job.id)">Cancel</button>
                    </div>
                  </div>
                </li>
              </template>
            </ul>
          </div>
        </section>

        <!-- Intent routing -->
        <section class="panel panel--dense" x-show="intentControls.enabled" x-cloak>
          <header class="panel-header"><div class="panel-title">Intent routing</div></header>
          <div class="panel-body">
            <p class="rail-muted">Profile and override controls for deterministic MIR preview routing.</p>
            <label class="rail-label" for="routing-profile">Profile</label>
            <select id="routing-profile" class="rail-input" x-model="intentProfile" :disabled="intentControlSaving">
              <template x-for="profile in intentControls.available_profiles" :key="profile">
                <option :value="profile" x-text="profile"></option>
              </template>
            </select>
            <label class="rail-label" for="routing-override">Override</label>
            <input id="routing-override" class="rail-input" type="text" x-model="intentOverrideInput" placeholder="architecture, delivery"/>
            <div class="jobs-controls">
              <button type="button" class="btn btn--secondary btn--sm" :disabled="intentControlSaving" @click="saveIntentProfile()">Save profile</button>
              <button type="button" class="btn btn--secondary btn--sm" :disabled="intentControlSaving" @click="saveIntentOverride()">Save override</button>
              <button type="button" class="btn btn--primary btn--sm" :disabled="routePreviewLoading" @click="previewIntentRoute()">
                <span x-text="routePreviewLoading ? 'Previewing...' : 'Preview route'"></span>
              </button>
            </div>
            <p class="rail-muted" x-show="routePreview && routePreview.active_intents" x-cloak>
              <strong>Active intents:</strong> <span x-text="(routePreview.active_intents || []).join(', ') || 'none'"></span>
            </p>
            <p class="rail-muted" x-show="routePreview && routePreview.plugin_chain" x-cloak>
              <strong>Plugin chain:</strong> <span x-text="(routePreview.plugin_chain || []).join(' -> ') || 'none'"></span>
            </p>
          </div>
        </section>
      </aside>
    </div>

    <!-- Toasts -->
    <div class="toast-stack" aria-live="polite">
      <template x-for="note in notifications" :key="note.id">
        <div class="toast"><p x-text="note.message"></p></div>
      </template>
    </div>

    <!-- Bookmark modal -->
    <div class="modal" x-show="bookmarkModalOpen" x-cloak @keydown.escape.window="bookmarkModalOpen = false">
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="bm-title">
        <h3 id="bm-title">Add bookmark</h3>
        <p class="rail-muted">Leave the label blank for a generic marker, or add a short reason so the moment is easy to spot later.</p>
        <label class="rail-label" for="bookmark-label">Label</label>
        <input id="bookmark-label" x-ref="bookmarkInput" class="rail-input" type="text" x-model="bookmarkLabel" placeholder="Decision on rollout window" @keydown.enter.prevent="submitBookmark()"/>
        <div class="modal-actions">
          <button type="button" class="btn btn--ghost btn--sm" @click="bookmarkModalOpen = false">Cancel</button>
          <button type="button" class="btn btn--primary btn--sm" @click="submitBookmark()">Save bookmark</button>
        </div>
      </div>
    </div>

    <!-- Metadata modal -->
    <div class="modal" x-show="metadataModalOpen" x-cloak @keydown.escape.window="metadataModalOpen = false">
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="md-title">
        <h3 id="md-title">Edit meeting details</h3>
        <p class="rail-muted">Update the title and comma-separated tags while the meeting is in progress.</p>
        <label class="rail-label" for="meeting-title">Title</label>
        <input id="meeting-title" x-ref="titleInput" class="rail-input" type="text" x-model="editingTitle" placeholder="Engineering review"/>
        <label class="rail-label" for="meeting-tags">Tags</label>
        <input id="meeting-tags" class="rail-input" type="text" x-model="editingTags" placeholder="planning, roadmap, follow-up" @keydown.enter.prevent="saveMetadata()"/>
        <div class="modal-actions">
          <button type="button" class="btn btn--ghost btn--sm" @click="metadataModalOpen = false">Cancel</button>
          <button type="button" class="btn btn--primary btn--sm" @click="saveMetadata()">Save details</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import Alpine from "alpinejs";
    import factorySource from "../scripts/dashboard-app.js?raw";

    // Eval the factory in global scope so x-data="HoldSpeakDashboard()"
    // resolves to it; the factory body lives unmodified in
    // src/scripts/dashboard-app.js.
    const fn = new Function(factorySource + "; return HoldSpeakDashboard;");
    window.HoldSpeakDashboard = fn();

    window.Alpine = Alpine;
    Alpine.start();
  </script>
</AppLayout>

<style>
  /* All values flow from tokens.css; no raw hex / radius / duration. */

  .runtime {
    max-width: 88rem;
    margin: 0 auto;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* === Hero =============================================== */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    gap: var(--space-5);
    padding: var(--space-6);
    background: var(--canvas-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-4);
  }
  .hero.state-active { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent-soft); }
  .hero.state-stopping { border-color: var(--warn); }

  .hero-id { display: flex; flex-direction: column; gap: var(--space-3); min-width: 0; }
  .hero-pills { display: flex; flex-wrap: wrap; gap: var(--space-2); }

  .hero-title { display: flex; align-items: center; gap: var(--space-2); }
  .hero-title h1 {
    margin: 0; font-size: var(--font-size-3xl);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-tight); word-break: break-word;
  }
  .title-edit {
    background: transparent; border: 1px solid transparent;
    color: var(--text-muted); padding: var(--space-1);
    border-radius: var(--radius-1); cursor: pointer;
  }
  .title-edit:hover { color: var(--text); border-color: var(--line); }
  .title-edit:disabled { opacity: 0.4; cursor: not-allowed; }
  .title-edit:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  .hero-copy {
    margin: 0; color: var(--text-muted);
    line-height: var(--line-height-relaxed); max-width: 60ch;
  }

  .hero-tags { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .tag-chip, .tag-chip-faint {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-pill);
    font-size: var(--font-size-xs);
    font-family: var(--font-mono);
    border: 1px solid var(--line);
  }
  .tag-chip { background: var(--canvas); color: var(--text-muted); }
  .tag-chip-faint { color: var(--text-faint); border-style: dashed; }

  .hero-action { display: flex; flex-direction: column; gap: var(--space-3); }

  .action-stage {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; gap: var(--space-3);
    padding: var(--space-4);
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-3);
  }
  .action-hint {
    margin: 0; color: var(--text-muted);
    font-size: var(--font-size-sm); line-height: var(--line-height-relaxed);
  }

  .stats {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2); padding: var(--space-3);
    background: var(--canvas); border: 1px solid var(--line);
    border-radius: var(--radius-2);
  }
  .stat { display: flex; flex-direction: column; gap: var(--space-1); }
  .stat-label {
    color: var(--text-faint); font-size: var(--font-size-xs);
    text-transform: uppercase; letter-spacing: var(--letter-spacing-loose);
  }
  .stat-value {
    color: var(--text); font-size: var(--font-size-md);
    display: inline-flex; align-items: center; gap: var(--space-2);
  }
  .stat-value.mono { font-family: var(--font-mono); }
  .conn-dot { width: var(--space-2); height: var(--space-2); border-radius: 50%; background: var(--text-faint); }
  .conn-dot.connected { background: var(--success); }
  .conn-dot.connecting { background: var(--warn); }
  .conn-dot.error { background: var(--danger); }

