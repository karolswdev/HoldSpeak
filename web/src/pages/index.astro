---
// HS-10-06: `/` runtime dashboard rebuilt on the design system.
//
// State machine + WebSocket + API behavior is preserved from the
// legacy dashboard.html: the same Alpine `HoldSpeakDashboard()` factory
// drives the page (imported from src/scripts/dashboard-app.js, served
// alongside Alpine.js — both self-hosted, no CDN). All x-data /
// x-text / x-show / @click bindings are preserved verbatim.
//
// Astro components (Button, Pill, etc.) are intentionally NOT used
// in this file: Astro silently drops non-prop attributes like
// `x-show` / `:disabled` / `@click` on custom-component invocations,
// which would break Alpine bindings. Instead this page renders raw
// HTML using locally-scoped CSS that consumes the same design tokens.

import AppLayout from "../layouts/AppLayout.astro";
import HoldMark from "../components/HoldMark.astro";
---

<AppLayout title="HoldSpeak Runtime" current="home">
  <div class="runtime" x-data="HoldSpeakDashboard()" x-init="init()">

    <!-- Hero -->
    <section class="hero" :class="{
      'state-idle': !meetingActive && !stopInProgress,
      'state-active': meetingActive && !stopInProgress,
      'state-stopping': stopInProgress,
    }">
      <div class="hero-id">
        <div class="hero-pills">
          <span class="pill pill--local"><span class="pill-dot"></span>local-only</span>
          <span class="pill pill--info" x-show="meetingActive" x-cloak><span class="pill-dot is-live"></span>recording</span>
          <span class="pill pill--warn" x-show="stopInProgress" x-cloak><span class="pill-dot is-live"></span>stopping</span>
        </div>

        {/* HS-12-03: hero h1 only renders when there is a real
            meeting title; the bare "HoldSpeak" fallback duplicated
            the TopNav brand at idle. */}
        <div class="hero-title" x-show="meetingTitle" x-cloak>
          <h1 x-text="meetingTitle"></h1>
          <button type="button" class="title-edit" :disabled="!meetingActive" @click="openMetadataModal()" title="Edit meeting details">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 113 3L7 19l-4 1 1-4z"/>
            </svg>
            <span class="sr-only">Edit meeting details</span>
          </button>
        </div>

        {/* HS-44-01: a warm idle headline so the home doesn't read empty. */}
        <h1 class="hero-idle-h" x-show="!meetingActive && !stopInProgress" x-cloak>Ready when you are.</h1>

        {/* The "...run locally on this machine" sentence used to
            duplicate the side-rail message; trimmed to the
            workspace summary only. */}
        <p class="hero-copy">
          Real-time transcript, live meeting intelligence, and export
          controls in one focused workspace.
        </p>

        {/* Tags only shown when a meeting actually has tags;
            "No tags yet" placeholder removed (idle redundancy). */}
        <div class="hero-tags" x-show="meetingTags.length > 0" x-cloak>
          <template x-for="tag in meetingTags" :key="tag">
            <span class="tag-chip" x-text="tag"></span>
          </template>
        </div>
      </div>

      <div class="hero-action">
        <div class="presence-card" :class="activityToneClass()" role="status" aria-live="polite">
          <div class="presence-main">
            <span class="presence-ring" :class="{ 'is-live': activityDotLive() }" aria-hidden="true"></span>
            <div class="presence-copy">
              <div class="presence-label" x-text="runtimeActivity.label"></div>
              <div class="presence-detail" x-text="activityDetailLine()"></div>
            </div>
          </div>
          <div class="presence-meta">
            <span x-text="activitySourceLabel()"></span>
            <span x-text="activityWindowLabel()"></span>
          </div>
        </div>

        <div class="action-stage" x-show="!meetingActive && !stopInProgress" x-cloak>
          <HoldMark size={72} ariaLabel="Hold to talk — runtime ready" />
          <p class="action-hint">
            Press start, then hold to talk. Audio, transcript, and intel
            stay on this machine.
          </p>
        </div>

        <button type="button" class="btn btn--primary btn--hero" x-show="!meetingActive" x-cloak :disabled="startInProgress" :class="{ 'is-loading': startInProgress }" @click="startMeeting()">
          <span class="btn-spinner" x-show="startInProgress" x-cloak></span>
          <span x-text="startInProgress ? 'Starting...' : 'Start meeting'"></span>
        </button>
        <button type="button" class="btn btn--danger btn--hero" x-show="meetingActive" x-cloak :disabled="stopInProgress" :class="{ 'is-loading': stopInProgress }" @click="stopMeeting()">
          <span class="btn-spinner" x-show="stopInProgress" x-cloak></span>
          <span x-text="stopInProgress ? 'Stopping...' : 'Stop meeting'"></span>
        </button>

        <div class="stats">
          <div class="stat">
            <span class="stat-label">Connection</span>
            <span class="stat-value">
              <span class="conn-dot" :class="[connectionTone(), connectionTone() === 'connecting' && 'is-live']"></span>
              <span x-text="connectionLabel()"></span>
            </span>
          </div>
          <div class="stat">
            <span class="stat-label">Duration</span>
            <span class="stat-value mono" x-text="duration"></span>
          </div>
          <div class="stat">
            <span class="stat-label">Segments</span>
            <span class="stat-value mono" x-text="segments.length"></span>
          </div>
          <div class="stat">
            <span class="stat-label">Open actions</span>
            <span class="stat-value mono" x-text="activeActionItems().filter(i => i.status !== 'done').length"></span>
          </div>
          {/* HS-69-01: meeting-intel egress posture as the canonical
              structured badge (the SAME chip /presence carries), not prose.
              The full sentence stays only in the title tooltip. */}
          <div class="stat" x-show="intelEgressBadge()" x-cloak>
            <span class="stat-label">Privacy</span>
            <span
              class="egress-badge"
              :class="`is-${intelEgressBadge()?.scope}`"
              :title="intelEgress?.egress"
              x-text="egressBadgeText()"
            ></span>
          </div>
        </div>
      </div>
    </section>

    {/* HS-44-01: idle "command center" home — warm daily-action cards (matching
        the Phase-43 wizard), shown only when no meeting is live so the active
        meeting view keeps the screen. */}
    <section class="home-actions" x-show="!meetingActive && !stopInProgress" x-cloak aria-label="Quick actions">
      <a class="home-card signal-card is-pressable" href="/dictation">
        <span class="home-card-glyph glyph-chip" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8"/></svg></span>
        <span class="home-card-t">Dictation cockpit</span>
        <span class="home-card-d">Tune the dictation pipeline — blocks, project context, runtime</span>
        <span class="home-card-go" aria-hidden="true">→</span>
      </a>
      <a class="home-card signal-card is-pressable" href="/history">
        <span class="home-card-glyph glyph-chip" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg></span>
        <span class="home-card-t">Meeting history</span>
        <span class="home-card-d">Past meetings, transcripts, artifacts &amp; exports</span>
        <span class="home-card-go" aria-hidden="true">→</span>
      </a>
      <a class="home-card signal-card is-pressable" href="/activity">
        <span class="home-card-glyph glyph-chip" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></span>
        <span class="home-card-t">Local activity</span>
        <span class="home-card-d">Your private work-context ledger &amp; connectors</span>
        <span class="home-card-go" aria-hidden="true">→</span>
      </a>
      <a class="home-card signal-card is-pressable" href="/settings">
        <span class="home-card-glyph glyph-chip" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
        <span class="home-card-t">Settings</span>
        <span class="home-card-d">Every global knob — sectioned &amp; searchable</span>
        <span class="home-card-go" aria-hidden="true">→</span>
      </a>
    </section>

    {/* HS-44-01: recent-meetings glance (idle only). */}
    <section class="home-recent" x-show="!meetingActive && !stopInProgress && recentMeetings.length" x-cloak aria-label="Recent meetings">
      <header class="home-recent-head">
        <h2>Recent meetings</h2>
        <a class="home-recent-all" href="/history">All history →</a>
      </header>
      <div class="recent-row">
        <template x-for="(m, i) in recentMeetings" :key="m.id">
          <a class="recent-card signal-card is-pressable hs-materialize" :href="`/history#meeting-${m.id}`" :style="`--i: ${i}`">
            <span class="recent-title" x-text="m.title || 'Untitled meeting'"></span>
            <span class="recent-date" x-text="formatDate(m.started_at)"></span>
            <span class="recent-meta">
              <span class="recent-stat" x-text="meetingDuration(m.duration_seconds)"></span>
              <span class="recent-dot">·</span>
              <span class="recent-stat" x-text="`${m.segment_count || 0} segs`"></span>
              <span class="recent-dot" x-show="(m.action_item_count || 0) > 0" x-cloak>·</span>
              <span class="recent-stat accent" x-show="(m.action_item_count || 0) > 0" x-cloak x-text="`${m.action_item_count} actions`"></span>
            </span>
          </a>
        </template>
      </div>
    </section>

    {/* HS-13-08: pre-meeting briefing surface. Renders the
        meeting_context pipeline's deterministic markdown when a
        briefing exists, and hides during active meetings so the
        live transcript can take the screen. */}
    <section class="panel panel--comfortable briefing" x-show="!meetingActive && briefingVisible()" x-cloak>
      <header class="panel-header">
        <div class="panel-title">Project briefing</div>
        <div class="panel-toolbar">
          <span class="pill" :class="briefingPillClass()" x-show="briefingState !== 'idle'" x-cloak>
            <span class="pill-dot"></span>
            <span x-text="briefingPillLabel()"></span>
          </span>
          <span class="briefing-meta mono" x-show="briefingLastRefreshed()" x-cloak x-text="briefingLastRefreshed()"></span>
          <button type="button" class="btn btn--secondary btn--sm" :disabled="briefingRefreshing" @click="refreshBriefing()">
            <span x-text="briefingRefreshing ? 'Refreshing…' : 'Refresh briefing'"></span>
          </button>
        </div>
      </header>
      <div class="panel-body">
        <template x-if="briefing">
          <div class="briefing-body" x-html="briefingHtml()"></div>
        </template>
        <template x-if="!briefing && !briefingRefreshing">
          <div class="briefing-empty">
            <p class="rail-title">No briefing yet.</p>
            <p class="rail-muted">
              Visit some PRs, tickets, or calendar events in the
              browser, enable the gh / jira connectors on
              <a href="/_built/activity">/activity</a>, then refresh.
            </p>
          </div>
        </template>
        <template x-if="briefingError">
          <p class="briefing-error" x-text="briefingError"></p>
        </template>
      </div>
    </section>

    <!-- Two-column board -->
    <div class="board">
      <!-- Transcript -->
      <section class="panel panel--comfortable">
        <header class="panel-header">
          <div class="panel-title">Transcript stream</div>
          <div class="panel-toolbar">
            <button type="button" class="btn btn--ghost btn--sm" @click="scrollTranscriptToBottom()">Jump to latest</button>
          </div>
        </header>
        <div class="panel-body">
          <div class="transcript-scroll" x-ref="transcriptScroll">
            <template x-if="entries.length === 0">
              <div class="transcript-empty">
                <HoldMark size={56} pulse={false} ariaLabel="Idle" />
                <h3 x-text="meetingActive ? 'Waiting for transcript' : 'Meeting idle'"></h3>
                <p x-text="meetingActive
                  ? 'Once audio arrives, segments stream in here with speaker chips, timestamps, and bookmark callouts.'
                  : 'Start a meeting to begin recording, transcription, and live intelligence updates.'"></p>
              </div>
            </template>

            <template x-for="entry in entries" :key="entry.id">
              <div class="entry">
                <template x-if="entry.kind === 'segment'">
                  <article class="segment" :class="`tone-${speakerTone(entry.speaker)}`" tabindex="0" @click="copySegment(entry)" @keydown.enter="copySegment(entry)">
                    <div class="segment-meta">
                      <span class="speaker-pill" :class="`tone-${speakerTone(entry.speaker)}`">
                        <span class="speaker-dot"></span>
                        <span x-text="speakerLabel(entry.speaker)"></span>
                      </span>
                      <span class="ts mono" x-text="entry.start ? `[${entry.start}${entry.end ? `-${entry.end}` : ''}]` : 'live'"></span>
                      <span class="copy-hint">Click to copy</span>
                    </div>
                    <p class="segment-text" x-text="entry.text"></p>
                  </article>
                </template>
                <template x-if="entry.kind === 'bookmark'">
                  <article class="bookmark">
                    <div class="bookmark-meta">
                      <span class="bookmark-flag">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M7 3h10v18l-5-3-5 3V3z"/></svg>
                        <span>Bookmark</span>
                      </span>
                      <span class="ts mono" x-text="entry.timestamp ? `at ${entry.timestamp}` : 'live'"></span>
                    </div>
                    <p class="bookmark-text" x-text="entry.label"></p>
                  </article>
                </template>
              </div>
            </template>
          </div>
        </div>
        <footer class="panel-footer">
          <div class="dock">
            <button type="button" class="btn btn--secondary btn--sm" :disabled="!meetingActive" @click="openBookmarkModal()">Bookmark</button>
            <button type="button" class="btn btn--secondary btn--sm" @click="copyAll()">Copy all</button>
            <div class="export-wrap">
              <button type="button" class="btn btn--primary btn--sm" @click="exportOpen = !exportOpen">Export</button>
              <div class="export-menu" x-show="exportOpen" x-cloak @click.outside="exportOpen = false">
                <button type="button" class="export-item" @click="exportAs('md')"><span>Meeting notes</span><span class="mono">.md</span></button>
                <button type="button" class="export-item" @click="exportAs('txt')"><span>Plain transcript</span><span class="mono">.txt</span></button>
                <button type="button" class="export-item" @click="exportAs('json')"><span>Structured data</span><span class="mono">.json</span></button>
              </div>
            </div>
          </div>
        </footer>
      </section>

      <!-- Side rail -->
      <aside class="rail">
        <div class="rail-group-label">Intelligence</div>
        <!-- Live intel -->
        <section class="panel panel--dense" x-show="intelStreaming" x-cloak>
          <header class="panel-header">
            <div class="panel-title">
              <span class="pill pill--info"><span class="pill-dot is-live"></span>analyzing</span>
            </div>
          </header>
          <div class="panel-body">
            <p class="streaming-text"><span x-text="intelBuffer"></span><span class="caret"></span></p>
          </div>
        </section>

        <!-- Intelligence -->
        <section class="panel panel--dense">
          <header class="panel-header"><div class="panel-title">Intelligence</div></header>
          <div class="panel-body">
            <p class="rail-title" x-text="intelStatusTitle()"></p>
            <p class="rail-muted" x-text="intelStatusCopy()"></p>
          </div>
        </section>

        <!-- HS-38-04: live actuator proposals — surfaced as the pipeline produces
             them, approve/reject on the spot. The broadcast carries no egress
             payload; approving only records a decision (nothing runs without it). -->
        <section class="panel panel--dense proposals-panel" x-show="pendingProposals.length" x-cloak>
          <header class="panel-header">
            <div class="panel-title">Pending actions</div>
            <div class="panel-toolbar">
              <span class="rail-faint" x-text="`${pendingProposals.length} awaiting`"></span>
            </div>
          </header>
          <div class="panel-body">
            <p class="rail-muted">An actuator proposed an external action. Review the preview, then approve or reject.</p>
            <ul class="proposal-list">
              <template x-for="p in pendingProposals" :key="p.id">
                <li class="proposal-item" :class="`accent-${proposalAccent(p)}`">
                  <div class="proposal-head">
                    <span class="proposal-icon" aria-hidden="true" x-text="proposalIcon(p)"></span>
                    <div class="proposal-headings">
                      <p class="proposal-title" x-text="`${p.action} → ${p.target}`"></p>
                      <div class="proposal-meta">
                        <span class="meta-chip status" :class="`proposal-${p.status}`" x-text="proposalStatusLabel(p.status)"></span>
                        <span class="meta-chip" x-text="p.reversible ? 'reversible' : 'irreversible'"></span>
                        <span class="meta-chip" x-show="p.decided_by" x-cloak x-text="`by ${p.decided_by}`"></span>
                      </div>
                    </div>
                  </div>
                  <p class="proposal-preview-line" x-show="p.preview" x-cloak x-text="p.preview"></p>
                  <div class="proposal-controls" x-show="p.status === 'proposed'" x-cloak>
                    <button type="button" class="btn btn--sm proposal-approve" @click="decideLiveProposal(p, 'approved')">Approve</button>
                    <button type="button" class="btn btn--secondary btn--sm" @click="decideLiveProposal(p, 'rejected')">Reject</button>
                  </div>
                  <p class="proposal-guard rail-faint" x-show="p.status === 'proposed'" x-cloak
                     x-text="p.target === 'slack'
                       ? 'Approving sends this message to Slack.'
                       : 'Approving records the decision; execution is a separate step.'"></p>
                  <p class="proposal-decided rail-faint" x-show="p.status !== 'proposed'" x-cloak
                     x-text="proposalStatusLabel(p.status) + (p.decided_by ? ` · ${p.decided_by}` : '')"></p>
                </li>
              </template>
            </ul>
          </div>
        </section>

        <!-- Devices -->
        <section class="panel panel--dense" x-show="devices.length > 0" x-cloak>
          <header class="panel-header"><div class="panel-title">Devices</div></header>
          <div class="panel-body">
            <ul class="device-list">
              <template x-for="device in devices" :key="device.id">
                <li class="device-item">
                  <div class="device-main">
                    <span class="device-label" x-text="device.label || device.id"></span>
                    <span class="device-id mono" x-text="device.id"></span>
                  </div>
                  <div class="device-health" x-show="hasDeviceHealth(device)" x-cloak :class="{ 'is-stale': deviceHealthStale(device) }">
                    <span class="meta-chip mono" x-show="deviceBatteryLabel(device)" x-cloak x-text="deviceBatteryLabel(device)"></span>
                    <span class="meta-chip mono" x-show="deviceRssiLabel(device)" x-cloak x-text="deviceRssiLabel(device)"></span>
                    <span class="rail-faint" x-show="deviceHealthStale(device)" x-cloak>stale</span>
                  </div>
                </li>
              </template>
            </ul>
          </div>
        </section>

        <!-- Topics -->
        <section class="panel panel--dense">
          <header class="panel-header"><div class="panel-title">Topics</div></header>
          <div class="panel-body">
            <template x-if="intel.topics.length === 0">
              <p class="rail-muted">Topics will appear once enough transcript has accumulated.</p>
            </template>
            <div class="topics" x-show="intel.topics.length > 0" x-cloak>
              <template x-for="topic in intel.topics" :key="topic">
                <span class="topic-pill" x-text="topic"></span>
              </template>
            </div>
          </div>
        </section>

        <!-- Summary -->
        <section class="panel panel--dense">
          <header class="panel-header"><div class="panel-title">Summary</div></header>
          <div class="panel-body">
            <template x-if="!intel.summary">
              <p class="rail-muted">No summary yet.</p>
            </template>
            <p class="summary-text" x-show="intel.summary" x-cloak x-text="intel.summary"></p>
          </div>
        </section>

        <div class="rail-group-label">Work</div>
        <!-- Action items -->
        <section class="panel panel--dense">
          <header class="panel-header">
            <div class="panel-title">Action items</div>
            <div class="panel-toolbar">
              <span class="rail-faint" x-text="meetingActive ? 'Live' : 'Read-only while idle'"></span>
            </div>
          </header>
          <div class="panel-body">
            <template x-if="activeActionItems().length === 0">
              <p class="rail-muted" x-text="meetingActive ? 'No action items yet.' : 'No active action items loaded for this session yet.'"></p>
            </template>
            <ul class="action-list" x-show="activeActionItems().length > 0" x-cloak>
              <template x-for="(item, idx) in activeActionItems()" :key="item.id || `${idx}-${item.task}`">
                <li class="action-item" :class="{ 'is-done': item.status === 'done' }">
                  <button type="button" class="check" :disabled="!meetingActive" @click="toggleActionItemStatus(item)" :title="item.status === 'done' ? 'Mark pending' : 'Mark done'">
                    <svg x-show="item.status === 'done'" x-cloak viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    <span class="sr-only">Toggle status</span>
                  </button>
                  <div class="action-body">
                    <p class="action-task" x-text="item.task || 'Action item'"></p>
                    <div class="action-meta">
                      <span class="meta-chip" x-show="item.owner" x-cloak x-text="`Owner ${item.owner}`"></span>
                      <span class="meta-chip" x-show="item.due" x-cloak x-text="`Due ${item.due}`"></span>
                      <span class="meta-chip status" :class="statusClass(item.status)" x-text="statusLabel(item.status)"></span>
                      <span class="meta-chip status" :class="reviewStatusClass(item.review_state)" x-text="reviewStatusLabel(item.review_state)"></span>
                    </div>
                    <div class="action-controls">
                      <button type="button" class="btn btn--ghost btn--sm" :disabled="!meetingActive || item.review_state === 'accepted'" @click="acceptActionItem(item)">Accept</button>
                      <button type="button" class="btn btn--secondary btn--sm" :disabled="!meetingActive" @click="editActionItem(item)">Edit</button>
                    </div>
                  </div>
                  <button type="button" class="dismiss" :disabled="!meetingActive" @click="dismissActionItem(item)" title="Dismiss">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18"/></svg>
                    <span class="sr-only">Dismiss</span>
                  </button>
                </li>
              </template>
            </ul>
            <p class="rail-faint" x-show="dismissedCount() > 0" x-cloak x-text="`${dismissedCount()} dismissed item${dismissedCount() === 1 ? '' : 's'}`"></p>
          </div>
        </section>

        <div class="rail-group-label">Operations</div>
        <!-- Plugin jobs -->
        <section class="panel panel--dense">
          <header class="panel-header"><div class="panel-title">Deferred plugin jobs</div></header>
          <div class="panel-body">
            <div class="topics">
              <span class="topic-pill" x-text="`Total ${pluginJobSummary?.total_jobs ?? 0}`"></span>
              <span class="topic-pill" x-text="`Queued ${pluginJobSummary?.queued_jobs ?? 0}`"></span>
              <span class="topic-pill" x-text="`Running ${pluginJobSummary?.running_jobs ?? 0}`"></span>
              <span class="topic-pill" x-text="`Failed ${pluginJobSummary?.failed_jobs ?? 0}`"></span>
              <span class="topic-pill" x-text="`Failure ${pluginQueueFailureRateLabel()}`"></span>
            </div>
            <p class="rail-muted" x-text="pluginQueueNextRetryLabel()"></p>
            <div class="jobs-controls">
              <select class="rail-input" x-model="pluginJobStatusFilter" @change="loadPluginJobs()">
                <option value="all">All jobs</option>
                <option value="queued">Queued</option>
                <option value="running">Running</option>
                <option value="failed">Failed</option>
              </select>
              <input class="rail-input rail-input--sm" type="number" min="1" x-model.number="pluginJobLimit" placeholder="Limit"/>
              <button type="button" class="btn btn--secondary btn--sm" :disabled="loadingPluginJobs" @click="loadPluginJobs()">Refresh</button>
              <button type="button" class="btn btn--primary btn--sm" :disabled="processingPluginJobs" @click="processPluginJobs('respect_backoff')">Process due</button>
              <button type="button" class="btn btn--ghost btn--sm" :disabled="processingPluginJobs" @click="processPluginJobs('retry_now')">Retry scheduled</button>
            </div>
            <template x-if="loadingPluginJobs">
              <p class="rail-muted">Loading deferred plugin jobs...</p>
            </template>
            <template x-if="!loadingPluginJobs && pluginJobs.length === 0">
              <p class="rail-muted">No deferred plugin jobs match this filter.</p>
            </template>
            <ul class="action-list" x-show="!loadingPluginJobs && pluginJobs.length > 0" x-cloak>
              <template x-for="job in pluginJobs" :key="job.id">
                <li class="action-item">
                  <span class="meta-chip status" :class="statusClass(job.status)" x-text="job.status"></span>
                  <div class="action-body">
                    <p class="action-task" x-text="job.plugin_id"></p>
                    <div class="action-meta">
                      <span class="meta-chip mono" x-text="job.meeting_id"></span>
                      <span class="meta-chip mono" x-text="job.window_id"></span>
                      <span class="meta-chip" x-text="`Attempts ${job.attempts}`"></span>
                      <span class="meta-chip" x-show="job.retry_scheduled" x-cloak x-text="pluginJobScheduleLabel(job)"></span>
                    </div>
                    <p class="rail-muted" x-show="job.last_error" x-cloak x-text="job.last_error"></p>
                    <div class="action-controls">
                      <button type="button" class="btn btn--primary btn--sm" :disabled="processingPluginJobs || job.status === 'running'" @click="retryPluginJob(job.id)">Retry now</button>
                      <button type="button" class="btn btn--ghost btn--sm" :disabled="processingPluginJobs || job.status === 'running'" @click="cancelPluginJob(job.id)">Cancel</button>
                    </div>
                  </div>
                </li>
              </template>
            </ul>
          </div>
        </section>

        <!-- Intent routing -->
        <section class="panel panel--dense" x-show="intentControls.enabled" x-cloak>
          <header class="panel-header"><div class="panel-title">Intent routing</div></header>
          <div class="panel-body">
            <p class="rail-muted">Profile and override controls for deterministic MIR preview routing.</p>
            <label class="rail-label" for="routing-profile">Profile</label>
            <select id="routing-profile" class="rail-input" x-model="intentProfile" :disabled="intentControlSaving">
              <template x-for="profile in intentControls.available_profiles" :key="profile">
                <option :value="profile" x-text="profile"></option>
              </template>
            </select>
            <label class="rail-label" for="routing-override">Override</label>
            <input id="routing-override" class="rail-input" type="text" x-model="intentOverrideInput" placeholder="architecture, delivery"/>
            <div class="jobs-controls">
              <button type="button" class="btn btn--secondary btn--sm" :disabled="intentControlSaving" @click="saveIntentProfile()">Save profile</button>
              <button type="button" class="btn btn--secondary btn--sm" :disabled="intentControlSaving" @click="saveIntentOverride()">Save override</button>
              <button type="button" class="btn btn--primary btn--sm" :disabled="routePreviewLoading" @click="previewIntentRoute()">
                <span x-text="routePreviewLoading ? 'Previewing...' : 'Preview route'"></span>
              </button>
            </div>
            <p class="rail-muted" x-show="routePreview && routePreview.active_intents" x-cloak>
              <strong>Active intents:</strong> <span x-text="(routePreview?.active_intents || []).join(', ') || 'none'"></span>
            </p>
            <p class="rail-muted" x-show="routePreview && routePreview.plugin_chain" x-cloak>
              <strong>Plugin chain:</strong> <span x-text="(routePreview?.plugin_chain || []).join(' -> ') || 'none'"></span>
            </p>
          </div>
        </section>
      </aside>
    </div>

    <!-- Toasts -->
    <div class="toast-stack" aria-live="polite">
      <template x-for="note in notifications" :key="note.id">
        <div class="toast"><p x-text="note.message"></p></div>
      </template>
    </div>

    <!-- Bookmark modal -->
    <div class="modal" x-show="bookmarkModalOpen" x-cloak @keydown.escape.window="bookmarkModalOpen = false">
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="bm-title">
        <h3 id="bm-title">Add bookmark</h3>
        <p class="rail-muted">Leave the label blank for a generic marker, or add a short reason so the moment is easy to spot later.</p>
        <label class="rail-label" for="bookmark-label">Label</label>
        <input id="bookmark-label" x-ref="bookmarkInput" class="rail-input" type="text" x-model="bookmarkLabel" placeholder="Decision on rollout window" @keydown.enter.prevent="submitBookmark()"/>
        <div class="modal-actions">
          <button type="button" class="btn btn--ghost btn--sm" @click="bookmarkModalOpen = false">Cancel</button>
          <button type="button" class="btn btn--primary btn--sm" @click="submitBookmark()">Save bookmark</button>
        </div>
      </div>
    </div>

    <!-- Metadata modal -->
    <div class="modal" x-show="metadataModalOpen" x-cloak @keydown.escape.window="metadataModalOpen = false">
      <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="md-title">
        <h3 id="md-title">Edit meeting details</h3>
        <p class="rail-muted">Update the title and comma-separated tags while the meeting is in progress.</p>
        <label class="rail-label" for="meeting-title">Title</label>
        <input id="meeting-title" x-ref="titleInput" class="rail-input" type="text" x-model="editingTitle" placeholder="Engineering review"/>
        <label class="rail-label" for="meeting-tags">Tags</label>
        <input id="meeting-tags" class="rail-input" type="text" x-model="editingTags" placeholder="planning, roadmap, follow-up" @keydown.enter.prevent="saveMetadata()"/>
        <div class="modal-actions">
          <button type="button" class="btn btn--ghost btn--sm" @click="metadataModalOpen = false">Cancel</button>
          <button type="button" class="btn btn--primary btn--sm" @click="saveMetadata()">Save details</button>
        </div>
      </div>
    </div>
  </div>

  {/* HS-42-03 / HS-43-06: first-run guard. A brand-new user (never dictated) is
      sent to the /welcome WIZARD; a returning-but-hard-blocked runtime goes to
      the /setup status surface; a healthy returning user stays on the dashboard
      (no nag — a mere WARN does NOT redirect). Best-effort; never blocks the
      dashboard. */}
  <script is:inline>
    (async () => {
      try {
        const res = await fetch("/api/setup/status");
        if (!res.ok) return;
        const s = await res.json();
        if (s && s.first_run) {
          location.replace("/welcome");
        } else if (s && s.overall === "blocked") {
          location.replace("/setup");
        }
      } catch (_e) {
        /* never block the dashboard on the setup check */
      }
    })();
  </script>

  <script>
    import Alpine from "alpinejs";
    import factorySource from "../scripts/dashboard-app.js?raw";
    import briefingMdSource from "../scripts/briefing-markdown.js?raw";
    import egressBadgeSource from "../scripts/egress-badge.js?raw";

    // The factory is evaluated via `new Function`, so ES module
    // imports don't reach inside it. Concatenating the shared
    // briefing renderer (HS-13-08 + HS-13-09) + the HS-69-01 egress
    // badge helpers before the factory gives the factory those
    // definitions without turning it into an ES module.
    const stripExports = (src) =>
      src.replace(/^\s*export\s+(function|const|let|var)/gm, "$1");
    const sharedSource =
      stripExports(briefingMdSource) + "\n" + stripExports(egressBadgeSource);
    const fn = new Function(
      sharedSource + "\n" + factorySource + "; return HoldSpeakDashboard;"
    );
    window.HoldSpeakDashboard = fn();

    window.Alpine = Alpine;
    Alpine.start();
  </script>
</AppLayout>

<style>
  /* All values flow from tokens.css; no raw hex / radius / duration. */

  .runtime {
    max-width: 88rem;
    margin: 0 auto;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* HS-44-01: a subtle accent glow behind the home, matching the wizard. */
  .runtime::before {
    content: "";
    position: fixed;
    inset: 0 0 auto 0;
    height: 360px;
    pointer-events: none;
    z-index: -1;
    background: radial-gradient(60% 100% at 50% 0%, color-mix(in srgb, var(--accent) 9%, transparent), transparent 70%);
  }

  /* HS-44-01: idle "command center" home cards. */
  .home-actions {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-3);
  }
  /* HS-69-02: surface / radius / top-lit hairline / shadow now come from
     the shared `.signal-card` primitive (global.css). This rule keeps
     only layout + the hover lift. */
  .home-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-4) var(--space-5);
    text-decoration: none;
    overflow: hidden;
    transition: border-color var(--duration-short) var(--ease-standard),
      transform var(--duration-short) var(--ease-standard),
      box-shadow var(--duration-short) var(--ease-standard);
  }
  .home-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--elev-2), 0 12px 28px color-mix(in srgb, var(--accent) 16%, transparent);
  }
  .home-card:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }
  /* HS-69-02: the glyph now uses the shared `.glyph-chip` (gradient fill +
     soft shadow). Only the cockpit-specific 38px size + spacing remain. */
  .home-card-glyph {
    --chip-size: 38px;
    margin-bottom: var(--space-2);
  }
  .home-card-t { font-family: var(--font-display); font-weight: 600; color: var(--text); font-size: var(--font-size-md); }
  .home-card-d { color: var(--text-muted); font-size: var(--font-size-xs); line-height: var(--line-height-relaxed); }
  .home-card-go {
    position: absolute; top: var(--space-4); right: var(--space-4);
    color: var(--text-faint); font-size: var(--font-size-lg);
    transition: transform var(--duration-short) var(--ease-standard), color var(--duration-short) var(--ease-standard);
  }
  .home-card:hover .home-card-go { color: var(--accent); transform: translateX(3px); }
  @media (prefers-reduced-motion: reduce) {
    .home-card:hover { transform: none; }
    .home-card:hover .home-card-go { transform: none; }
  }
  @media (max-width: 900px) { .home-actions { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .home-actions { grid-template-columns: 1fr; } }

  /* HS-44-01: idle hero headline. */
  .hero-idle-h {
    font-family: var(--font-display);
    font-size: clamp(var(--font-size-2xl), 3.4vw, var(--font-size-3xl));
    font-weight: 700; letter-spacing: -0.02em; line-height: 1.05;
    color: var(--text); margin: var(--space-1) 0 var(--space-2);
  }

  /* HS-44-01: recent-meetings glance. */
  .home-recent { display: flex; flex-direction: column; gap: var(--space-3); }
  .home-recent-head { display: flex; align-items: baseline; justify-content: space-between; }
  .home-recent-head h2 { font-family: var(--font-display); font-size: var(--font-size-lg); font-weight: 600; color: var(--text); margin: 0; }
  .home-recent-all { color: var(--accent); font-size: var(--font-size-sm); text-decoration: none; }
  .home-recent-all:hover { text-decoration: underline; }
  .recent-row { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-3); }
  /* HS-69-02: surface / radius / hairline / shadow from `.signal-card`.
     The accent left-bar identity is kept as a scoped override; the
     primitive's ::before hairline layers over the other three edges. */
  .recent-card {
    display: flex; flex-direction: column; gap: var(--space-1);
    padding: var(--space-4);
    border-left: 3px solid var(--accent);
    text-decoration: none;
    transition: transform var(--duration-short) var(--ease-standard), box-shadow var(--duration-short) var(--ease-standard);
  }
  .recent-card:hover { transform: translateY(-2px); box-shadow: var(--elev-3); }
  .recent-card:focus-visible { outline: var(--focus-outline-width) solid var(--accent); outline-offset: var(--focus-outline-offset); }
  @media (prefers-reduced-motion: reduce) { .recent-card:hover { transform: none; } }
  .recent-title { font-weight: 600; color: var(--text); font-size: var(--font-size-sm); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .recent-date { color: var(--text-faint); font-size: var(--font-size-xs); font-family: var(--font-mono); }
  .recent-meta { display: flex; align-items: center; gap: var(--space-1); margin-top: var(--space-2); color: var(--text-muted); font-size: var(--font-size-xs); }
  .recent-stat.accent { color: var(--accent); }
  .recent-dot { color: var(--text-faint); }
  @media (max-width: 900px) { .recent-row { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .recent-row { grid-template-columns: 1fr; } }

  /* === Hero =============================================== */
  /* HS-12-02 hero: tighter density, Workbench window grammar
   * (black border, blue title strip would be redundant with
   * TopNav, so we keep the hero as a single white surface but
   * trim the cavernous padding that read as "lazy SaaS" in
   * phase 10). */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--surface-1);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--elev-1);
    transition:
      border-color var(--duration-medium) var(--ease-standard),
      box-shadow var(--duration-medium) var(--ease-standard);
  }
  .hero.state-active { border-color: var(--accent); box-shadow: var(--glow-accent); }
  .hero.state-stopping { border-color: var(--warn); }

  .hero-id { display: flex; flex-direction: column; gap: var(--space-2); min-width: 0; }
  .hero-pills { display: flex; flex-wrap: wrap; gap: var(--space-2); }

  .hero-title { display: flex; align-items: center; gap: var(--space-2); }
  .hero-title h1 {
    margin: 0;
    /* HS-12-02: meeting title is a Workbench display moment;
     * scaled down from 3xl to xl since the wordmark duplicated
     * the TopNav brand. Real meeting titles read as the page's
     * primary identity. */
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    letter-spacing: 0.02em;
    line-height: 1.1;
    word-break: break-word;
  }
  .title-edit {
    background: transparent; border: 1px solid transparent;
    color: var(--text-muted); padding: var(--space-1);
    border-radius: var(--radius-1); cursor: pointer;
  }
  .title-edit:hover { color: var(--text); border-color: var(--line); }
  .title-edit:disabled { opacity: 0.4; cursor: not-allowed; }
  .title-edit:focus-visible {
    outline: var(--focus-outline-width) solid var(--accent);
    outline-offset: var(--focus-outline-offset);
  }

  .hero-copy {
    margin: 0; color: var(--text-muted);
    line-height: var(--line-height-relaxed); max-width: 60ch;
  }

  .hero-tags { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .tag-chip, .tag-chip-faint {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-pill);
    font-size: var(--font-size-xs);
    font-family: var(--font-mono);
    border: 1px solid var(--line);
  }
  .tag-chip { background: var(--canvas); color: var(--text-muted); }
  .tag-chip-faint { color: var(--text-faint); border-style: dashed; }

  .hero-action { display: flex; flex-direction: column; gap: var(--space-3); }

  .presence-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-height: 92px;
    padding: var(--space-3);
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius-3);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.02);
  }
  .presence-main {
    display: grid;
    grid-template-columns: 32px minmax(0, 1fr);
    gap: var(--space-3);
    align-items: center;
    min-width: 0;
  }
  .presence-ring {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid currentColor;
    box-shadow: 0 0 0 6px color-mix(in srgb, currentColor 13%, transparent);
    color: var(--text-faint);
  }
  .presence-ring.is-live {
    animation: hs-pulse 1.6s var(--ease-standard) infinite;
  }
  .presence-copy { min-width: 0; }
  .presence-label {
    color: var(--text);
    font-weight: 700;
    font-size: var(--font-size-md);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .presence-detail {
    margin-top: var(--space-1);
    color: var(--text-muted);
    font-size: var(--font-size-sm);
