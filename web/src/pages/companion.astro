---
// HS-69-12: /companion is now the Agent Desk — the same desk surface as the iPad
// (HSM-15-08), not a plainer control panel. A living desk of your recipes +
// the live companion link (the coders awaiting you), fed by the existing HTTP
// API (/api/recipes, /api/coders/status). The pairing/credential facts stay,
// folded into a "How it connects" footer.
import AppLayout from "../layouts/AppLayout.astro";

const pairingSteps = [
  { n: "1", title: "Point at your hub", body: "Host, port, an optional token, and a scheme — over your own network." },
  { n: "2", title: "Probe, never assume", body: "The device probes /health, then reads /api/runtime/status for readiness." },
  { n: "3", title: "Drive both modes", body: "The dictation teleprompter and the meeting afterlife, from the iPad." },
  { n: "4", title: "States its own health", body: "Settings on the iPad reports its store's schema safety and your hub's doctor, section by section." },
];
---

<AppLayout title="HoldSpeak Companion" current="companion">
  <div class="agent-desk" x-data="companionDesk()" x-init="init()">
    <header class="ad-head">
      <div class="ad-head-lead">
        <p class="ad-eyebrow">Companion</p>
        <h1 class="ad-title">The Agent Desk</h1>
        <p class="ad-sub">Your recipes and the coders that need you — on the desk your iPad shares.</p>
      </div>
      <div class="ad-head-side">
        <span class="ad-link" :class="`is-${linkScope}`">
          <span class="ad-link-dot" :class="{ 'is-live': linkScope !== 'idle' }"></span>
          <span x-text="linkLabel">Checking link…</span>
        </span>
        <span class="egress-badge is-mixed">local + your LAN</span>
      </div>
    </header>

    {/* the coders awaiting you — the live CompanionBoard moment */}
    <section class="ad-zone" x-show="awaiting.length" x-cloak>
      <div class="ad-zone-head"><span class="ad-zone-spine is-needs"></span><h2>Needs you</h2></div>
      <div class="ad-grid">
        <template x-for="s in awaiting" {...{ ":key": "s.session_id || s.agent" }}>
          <article class="signal-card ad-card is-needs">
            <div class="ad-card-type"><span class="ad-dot is-needs"></span><span>coder · awaiting</span></div>
            <h3 class="ad-card-title" x-text="sessionLabel(s)">session</h3>
            <p class="ad-card-body" x-show="s.summary" x-cloak x-text="s.summary"></p>
          </article>
        </template>
      </div>
    </section>

    {/* the recipes — the persona desk */}
    <section class="ad-zone">
      <div class="ad-zone-head"><span class="ad-zone-spine"></span><h2>Recipes</h2>
        <span class="ad-count" x-text="recipes.length" x-cloak></span></div>

      <div class="ad-empty signal-card" x-show="!loading && !recipes.length" x-cloak>
        <p>No recipes yet. Create one on the <a href="/desk">Desk</a> and it appears here.</p>
      </div>

      <div class="ad-grid" x-show="recipes.length" x-cloak>
        <template x-for="a in recipes" {...{ ":key": "a.id" }}>
          <article class="signal-card ad-card is-pressable">
            <div class="ad-card-head">
              <span class="ad-avatar" x-text="a.avatar || '🤖'">🤖</span>
              <div>
                <div class="ad-card-type"><span class="ad-dot"></span><span>agent</span></div>
                <h3 class="ad-card-title" x-text="a.name">Agent</h3>
              </div>
            </div>
            <p class="ad-card-body" x-text="a.role" x-show="a.role" x-cloak></p>
            <div class="ad-card-foot">
              <template x-for="t in agentTools(a)" {...{ ":key": "t" }}>
                <span class="ad-tag mono" x-text="t"></span>
              </template>
              <span class="ad-tag" x-show="a.kb_id" x-cloak x-text="`kb · ${a.kb_id}`"></span>
              <a class="ad-card-link" :href="`/desk?agent=${a.id}`">Open on desk</a>
            </div>
          </article>
        </template>
      </div>
    </section>

    {/* how it connects — the pairing + credential facts, secondary */}
    <details class="ad-connects signal-card">
      <summary>How it connects</summary>
      <ol class="ad-pair">
        {pairingSteps.map((step) => (
          <li><span class="ad-pair-n">{step.n}</span><div><strong>{step.title}</strong><p>{step.body}</p></div></li>
        ))}
      </ol>
      <p class="ad-pair-note">The bearer token is a credential — joined to each request in memory, never in a payload, a log, or back on screen. No hosted relay; never autonomous.</p>
    </details>
  </div>
</AppLayout>

<script>
  import Alpine from "alpinejs";
  import factorySource from "../scripts/companion-desk.js?raw";
  const fn = new Function(factorySource + "; return companionDesk;");
  window.companionDesk = fn();
  window.Alpine = Alpine;
  Alpine.start();
</script>

<style>
  .agent-desk {
    max-width: 92rem;
    margin: 0 auto;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .ad-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .ad-eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow);
    color: var(--accent);
  }
  .ad-title { margin: var(--space-1) 0 0; font-size: var(--font-size-3xl); font-family: var(--font-display); }
  .ad-sub { margin: var(--space-1) 0 0; color: var(--text-muted); font-size: var(--font-size-sm); }
  .ad-head-side { display: flex; flex-direction: column; align-items: flex-end; gap: var(--space-2); }
  .ad-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.25rem var(--space-3);
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }
  .ad-link.is-ok { color: var(--ok); border-color: color-mix(in srgb, var(--ok) 40%, transparent); }
  .ad-link.is-needs { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 45%, transparent); }
  .ad-link-dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; opacity: 0.5; }
  .ad-link-dot.is-live { opacity: 1; animation: hs-pulse 1.6s var(--ease-standard) infinite; }

  .ad-zone { display: flex; flex-direction: column; gap: var(--space-3); }
  .ad-zone-head { display: flex; align-items: center; gap: var(--space-2); }
  .ad-zone-head h2 { margin: 0; font-size: var(--font-size-lg); font-family: var(--font-display); }
  .ad-zone-spine { width: 3px; height: 18px; border-radius: var(--radius-pill); background: var(--accent); }
  .ad-zone-spine.is-needs { background: var(--warn-signal); }
  .ad-count { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--text-faint); }

  .ad-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
    gap: var(--space-3);
  }
  .ad-card {
    --signal-card-surface: var(--surface-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
  }
  .ad-card.is-needs { --signal-card-surface: color-mix(in srgb, var(--warn-signal) 8%, var(--surface-2)); }
  .ad-card-head { display: flex; align-items: center; gap: var(--space-3); }
  .ad-avatar { font-size: 1.6rem; line-height: 1; }
  .ad-card-type {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-mono); font-size: 0.6875rem; text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow); color: var(--text-faint);
  }
  .ad-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
  .ad-dot.is-needs { background: var(--warn-signal); }
  .ad-card-title { margin: 0; font-family: var(--font-display); font-size: var(--font-size-md); font-weight: 600; }
  .ad-card-body {
    margin: 0; color: var(--text-muted); font-size: var(--font-size-sm); line-height: var(--line-height-normal);
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .ad-card-foot { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); margin-top: auto; padding-top: var(--space-2); }
  .ad-tag {
    font-size: var(--font-size-xs); color: var(--text-muted);
    background: var(--surface-1); border: 1px solid var(--border); border-radius: var(--radius-pill);
    padding: 0.05rem var(--space-2);
  }
  .ad-tag.mono { font-family: var(--font-mono); }
  .ad-card-link { color: var(--accent); font-size: var(--font-size-sm); text-decoration: none; margin-left: auto; }
  .ad-card-link:hover { text-decoration: underline; }

  .ad-empty { padding: var(--space-5); text-align: center; color: var(--text-muted); }
  .ad-empty a { color: var(--accent); }

  .ad-connects { padding: var(--space-3) var(--space-4); }
  .ad-connects summary { cursor: pointer; font-family: var(--font-display); font-weight: 600; }
  .ad-pair { list-style: none; margin: var(--space-3) 0 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-3); }
  .ad-pair li { display: flex; gap: var(--space-3); }
  .ad-pair-n {
    flex: none; display: grid; place-items: center; width: 24px; height: 24px;
    border-radius: 50%; background: var(--surface-2); color: var(--accent);
    font-family: var(--font-mono); font-size: var(--font-size-xs);
  }
  .ad-pair li strong { font-size: var(--font-size-sm); }
  .ad-pair li p { margin: var(--space-1) 0 0; color: var(--text-muted); font-size: var(--font-size-sm); }
  .ad-pair-note { margin: var(--space-3) 0 0; color: var(--text-faint); font-size: var(--font-size-xs); }
</style>
