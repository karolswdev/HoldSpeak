---
// Docs-in-product: /companion — the iPad is now a first-class CLIENT of both
// HoldSpeak modes, reaching your own desktop/homelab hub over your own network.
//
// Every claim on this page is grounded in a SHIPPED client method on
// `HTTPDesktopClient` (apple/Sources/Providers/Desktop/HTTPDesktopClient*.swift):
//
//   • Pairing            — `DesktopPeer{host,port,token,scheme}` → `Config(peer:)`,
//                          `handshake()` (GET /health, GET /api/runtime/status).
//   • Dictation mode     — `dictationDryRun(utterance:)`, `dictationReadiness()`
//                          (the teleprompter: preview the rewrite + destination).
//   • Meeting mode       — `listMeetings()`, `startMeeting`/`stopMeeting`,
//                          `aftercare(meetingId:)`, `searchMeetings`/`listFacets`
//                          (faceted archive), `meetingProposals`/`decideProposal`
//                          (propose → review → approve).
//   • Activity nudges    — `activityNudges(...)` (GET /api/activity/nudges).
//   • Schema-safe store  — Providers/Storage/SQLiteStorage.swift: refuse-newer
//                          (StorageError.tooNew) + backup-before-migrate.
//
// This is a STATIC explainer (no live data, no Alpine app, so no null-read class
// to guard). Honest egress is the structured `.egress-badge` chip, never prose.
// On-device authoring screens are still in progress, so they are not claimed here.

import AppLayout from "../layouts/AppLayout.astro";

// Egress chips, structured {scope, label} per POSITIONING (never a sentence).
const egressLocal = { scope: "local", label: "stays on this machine" };
const egressLan = { scope: "mixed", label: "local + your LAN" };

type Capability = {
  glyph: string;
  title: string;
  body: string;
  route: string; // the shipped client method(s) this maps to
  egress: { scope: string; label: string };
};

const dictation: Capability[] = [
  {
    glyph: "M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z M19 10v2a7 7 0 0 1-14 0v-2 M12 19v4 M8 23h8",
    title: "Preview before a keystroke leaves",
    body:
      "The teleprompter shows what WOULD be typed and where it lands — the routed, rewritten preview — before anything is delivered. Preview-not-inject by design.",
    route: "dictationDryRun(utterance:) → POST /api/dictation/dry-run",
    egress: egressLan,
  },
  {
    glyph: "M9 12l2 2 4-4 M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z",
    title: "Readiness at a glance",
    body:
      "A setup snapshot drives the dictate screen's status strip, so the iPad knows the hub is ready before you hold to talk.",
    route: "dictationReadiness() → GET /api/dictation/readiness",
    egress: egressLan,
  },
];

const meeting: Capability[] = [
  {
    glyph: "M3 3v18h18 M7 14l4-4 3 3 5-6",
    title: "The faceted archive",
    body:
      "Browse past meetings, then narrow the archive server-side by speaker or tag, or full-text search the transcripts — the same facets the web history row offers.",
    route: "listMeetings() · listFacets() · searchMeetings(query:speaker:type:)",
    egress: egressLan,
  },
  {
    glyph: "M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11",
    title: "Aftercare: close the loop",
    body:
      "The read-only aftercare digest — what's still open by owner, what was decided, the real diff vs the last meeting. Pure read; viewing it acts on nothing.",
    route: "aftercare(meetingId:) → GET /api/meetings/{id}/aftercare",
    egress: egressLan,
  },
  {
    glyph: "M22 11.08V12a10 10 0 1 1-5.93-9.14 M22 4L12 14.01l-3-3",
    title: "Propose → review → approve",
    body:
      "The iPad keeps proposing and approving apart, exactly as the desktop's actuator audit does. Reading the queue performs no side effect; the human gate is a separate, explicit decision.",
    route: "meetingProposals(meetingId:) · decideProposal(meetingId:proposalId:approved:)",
    egress: egressLan,
  },
];

const ambient: Capability[] = [
  {
    glyph: "M22 12h-4l-3 9L9 3l-3 9H2",
    title: "Source-cited activity nudges",
    body:
      "The desktop's pre-briefing nudges reach the iPad too — the top cited cards, with select-for-next-dictation and dismiss. Returns nothing when activity tracking is off on the hub.",
    route: "activityNudges(projectId:limit:) → GET /api/activity/nudges",
    egress: egressLan,
  },
  {
    glyph: "M4 7V4a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v3 M4 7h16v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7z M9 11h6 M9 15h6",
    title: "Schema-safe local storage",
    body:
      "What the iPad keeps locally is versioned the same safe way the desktop is: a newer database is refused rather than corrupted, and an older one is backed up before it migrates.",
    route: "SQLiteStorage: StorageError.tooNew · backup-before-migrate",
    egress: egressLocal,
  },
];

const sections: { eyebrow: string; title: string; lead: string; cards: Capability[] }[] = [
  {
    eyebrow: "Dictation mode",
    title: "The dictation teleprompter",
    lead:
      "Hold to talk on the iPad; the rewrite and its destination are previewed against your hub before a single character is delivered.",
    cards: dictation,
  },
  {
    eyebrow: "Meeting mode",
    title: "Aftercare, archive & proposals",
    lead:
      "The full meeting afterlife is a client of your hub: search the archive, read the aftercare digest, and run the propose → approve gate without collapsing the two.",
    cards: meeting,
  },
  {
    eyebrow: "Ambient",
    title: "Nudges & local memory",
    lead:
      "Source-cited activity nudges ride to the iPad, and whatever it keeps locally follows the same refuse-newer, backup-before-migrate discipline as the desktop.",
    cards: ambient,
  },
];

const pairingSteps = [
  {
    n: "01",
    title: "Point it at your hub",
    body:
      "Enter the host and port of the machine your hub runs on — over your own network (LAN or Tailscale). There is no hosted relay in between.",
    code: "host · port",
  },
  {
    n: "02",
    title: "Add a token if the hub wants one",
    body:
      "An optional bearer token authenticates the device. It is joined to each request at call time and is never logged or echoed back to the screen.",
    code: "token (optional)",
  },
  {
    n: "03",
    title: "Choose the scheme",
    body:
      "Plain http over a trusted LAN or Tailscale by default; https once the hub has TLS. A half-filled form simply stays offline rather than building a junk URL.",
    code: "scheme: http | https",
  },
  {
    n: "04",
    title: "Pair & probe",
    body:
      "The device probes /health, then reads /api/runtime/status for readiness. An unreachable hub is a rendered state, never a crash — the on-device runtime is never gated on it.",
    code: "handshake()",
  },
];
---

<AppLayout title="HoldSpeak Companion" current="companion">
  <div class="companion-doc">
    <header class="doc-hero">
      <p class="eyebrow">Companion</p>
      <h1>Your iPad is a first-class client of your hub.</h1>
      <p class="lead">
        Point an iPad at the same desktop or homelab hub a coding session runs
        against, over your own network, and drive both HoldSpeak modes from it —
        the dictation teleprompter and the full meeting afterlife. The device
        talks to the hub's existing HTTP API, the same endpoints this portal uses.
      </p>
      <div class="hero-badges">
        <span class={`egress-badge is-${egressLan.scope}`}>local + your LAN</span>
        <span class="meta-pill">No hosted relay</span>
        <span class="meta-pill">Never autonomous</span>
      </div>
    </header>

    {sections.map((section) => (
      <section class="cap-section">
        <div class="section-head">
          <p class="eyebrow">{section.eyebrow}</p>
          <h2>{section.title}</h2>
          <p class="section-lead">{section.lead}</p>
        </div>
        <div class="cap-grid">
          {section.cards.map((cap) => (
            <article class="signal-card cap-card">
              <span class="glyph-chip" aria-hidden="true">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  {cap.glyph.split(" M").map((seg, i) => (
                    <path d={i === 0 ? seg : `M${seg}`} />
                  ))}
                </svg>
              </span>
              <h3>{cap.title}</h3>
              <p class="cap-body">{cap.body}</p>
              <div class="cap-foot">
                <code class="cap-route">{cap.route}</code>
                <span class={`egress-badge is-${cap.egress.scope}`} title={cap.egress.label}>
                  {cap.egress.scope === "local" ? "local-only" : "local + LAN"}
                </span>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="pair-section">
      <div class="section-head">
        <p class="eyebrow">Pairing</p>
        <h2>How to pair the iPad</h2>
        <p class="section-lead">
          Pairing is host, port, an optional token, and a scheme — turned into the
          device's hub config. Reachability is probed, never assumed.
        </p>
      </div>
      <ol class="pair-grid">
        {pairingSteps.map((step) => (
          <li class="signal-card pair-card">
            <span class="pair-n" aria-hidden="true">{step.n}</span>
            <h3>{step.title}</h3>
            <p class="pair-body">{step.body}</p>
            <code class="pair-code">{step.code}</code>
          </li>
        ))}
      </ol>
      <p class="pair-note">
        The bearer token is a credential: it is joined to each request in memory
        and never appears in a payload, a log, or back on screen.
      </p>
    </section>

    <section class="status-note signal-card">
      <h2>Still in progress</h2>
      <p>
        The on-device authoring screens — capturing, editing, and synthesizing
        entirely on the iPad without a hub — are still landing. This page covers
        what already ships: the iPad as a client of your hub. The fully on-device
        story will be documented here once it is real on the device.
      </p>
    </section>
  </div>
</AppLayout>

<style>
  .companion-doc {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    color: var(--text);
  }

  h1, h2, h3, p { margin: 0; }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-loose);
    color: var(--accent);
    margin-bottom: var(--space-2);
  }

  /* === Hero ============================================== */
  .doc-hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5) 0 var(--space-2);
  }
  .doc-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(var(--font-size-2xl), 3.4vw, var(--font-size-3xl));
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.08;
    max-width: 22ch;
  }
  .lead {
    color: var(--text-muted);
    line-height: var(--line-height-relaxed);
    max-width: 64ch;
    font-size: var(--font-size-md);
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  .meta-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.12rem 0.55rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--text-muted);
    font-size: var(--font-size-xs);
    letter-spacing: 0.02em;
  }

  /* === Capability sections =============================== */
  .cap-section,
  .pair-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .section-head { display: flex; flex-direction: column; gap: var(--space-1); }
  .section-head h2 {
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .section-lead {
    color: var(--text-muted);
    line-height: var(--line-height-relaxed);
    max-width: 70ch;
    font-size: var(--font-size-sm);
  }

  .cap-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
  }
  .cap-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
  }
  .cap-card .glyph-chip { --chip-size: 40px; margin-bottom: var(--space-1); }
  .cap-card h3 {
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text);
  }
  .cap-body {
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    flex: 1;
  }
  .cap-foot {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-subtle);
  }
  .cap-route {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.5;
    color: var(--text-faint);
    overflow-wrap: anywhere;
  }

  /* === Pairing ========================================== */
  .pair-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-3);
  }
  .pair-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
  }
  .pair-n {
    font-family: var(--font-mono);
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.04em;
  }
  .pair-card h3 {
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text);
  }
  .pair-body {
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    flex: 1;
  }
  .pair-code {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text);
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    width: fit-content;
  }
  .pair-note {
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    border-left: 3px solid var(--accent);
    padding-left: var(--space-3);
    max-width: 70ch;
  }

  /* === In-progress note ================================= */
  .status-note {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .status-note h2 {
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: 600;
  }
  .status-note p {
    color: var(--text-muted);
    line-height: var(--line-height-relaxed);
    max-width: 72ch;
    font-size: var(--font-size-sm);
  }

  @media (max-width: 1000px) {
    .cap-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .pair-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 600px) {
    .companion-doc { padding: var(--space-3); gap: var(--space-5); }
    .cap-grid,
    .pair-grid { grid-template-columns: 1fr; }
  }
</style>
