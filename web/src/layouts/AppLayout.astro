---
// HS-10-04 app shell · HS-30-04 "Signal" rebuild.
//
// Composes TopNav + skip-to-content + page <slot/> + optional secondary
// toolbar, and owns the global Settings drawer (IA spec §2: Settings is
// lifted out of History into a shell-level drawer, opened from TopNav's
// ⚙). The drawer + the mobile nav toggle are wired with a small vanilla
// script — Alpine loads per-page (and not on every page), so the shell
// must not depend on it.
//
// `current` is forwarded to TopNav for the active-route state.

import "../styles/global.css";
import TopNav from "../components/TopNav.astro";
import TrustChip from "../components/TrustChip.astro";
import ConfirmDialog from "../components/ConfirmDialog.astro";
import QueueHud from "../components/QueueHud.astro";

type Route = "runtime" | "desk" | "activity" | "history" | "dictation" | "companion" | "commands";

interface Props {
  title: string;
  description?: string;
  current?: Route;
}

const { title, description, current } = Astro.props;
const hasSecondary = Astro.slots.has("secondary");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/_built/favicon.svg" />
    <link rel="apple-touch-icon" href="/_built/apple-touch-icon.png" />
  </head>
  <body>
    <TopNav current={current}>
      {Astro.slots.has("status") ? (
        <Fragment slot="status"><slot name="status" /></Fragment>
      ) : (
        <TrustChip slot="status" />
      )}
      {Astro.slots.has("topnav-overflow") && (
        <Fragment slot="overflow"><slot name="topnav-overflow" /></Fragment>
      )}
    </TopNav>

    {hasSecondary && (
      <div class="app-secondary" role="region" aria-label="Page actions">
        <slot name="secondary" />
      </div>
    )}

    <main id="main" tabindex="-1">
      <slot />
    </main>

    {/* HS-69-07: the app-wide Queue HUD (collapsed pill → ledger), fed from
        the shared runtime-bus. Rides every route from the shell; starts hidden
        and reveals only when there is a live job. */}
    <QueueHud />

    <ConfirmDialog />

    {/* HS-42-05: the ambient Trust & Privacy panel (opened by the shell
        TrustChip). Populated client-side from GET /api/setup/status. */}
    <div class="trust-overlay" data-trust-overlay hidden>
      <div class="trust-backdrop" data-trust-close></div>
      <aside id="trust-panel" class="trust-panel" role="dialog" aria-modal="true" aria-label="Privacy and trust" tabindex="-1">
        <header class="trust-head">
          <div>
            <span class="trust-eyebrow">Privacy &amp; Trust</span>
            <p class="trust-summary" data-trust-summary>Checking what can leave this machine…</p>
          </div>
          <button type="button" class="trust-close" data-trust-close aria-label="Close">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
          </button>
        </header>
        <div class="trust-rows" data-trust-rows></div>
        <footer class="trust-foot">
          <p>Change any of this in <a href="/settings">Settings</a>. The invariant: nothing leaves your machine without you configuring it.</p>
        </footer>
      </aside>
    </div>

    <script>
      // HS-42-05: the ambient trust chip + panel. Fetches the privacy posture
      // once and renders the shell chip + the panel rows. Best-effort: a status
      // failure leaves the honest "Local only" default in place.
      import { trustPosture, trustRows } from "../scripts/trust-view.js";

      (async () => {
        const chip = document.querySelector("[data-trust-open]");
        const labelEl = document.querySelector("[data-trust-label]");
        const overlay = document.querySelector("[data-trust-overlay]");
        const summaryEl = document.querySelector("[data-trust-summary]");
        const rowsEl = document.querySelector("[data-trust-rows]");
        if (!chip || !overlay) return;

        // ── open / close ──
        let lastFocus = null;
        const open = () => {
          lastFocus = document.activeElement;
          overlay.hidden = false;
          requestAnimationFrame(() => overlay.setAttribute("data-open", ""));
          document.getElementById("trust-panel")?.focus();
        };
        const close = () => {
          overlay.removeAttribute("data-open");
          setTimeout(() => { if (!overlay.hasAttribute("data-open")) overlay.hidden = true; }, 240);
          if (lastFocus && lastFocus.focus) lastFocus.focus();
        };
        chip.addEventListener("click", open);
        overlay.querySelectorAll("[data-trust-close]").forEach((b) => b.addEventListener("click", close));
        document.addEventListener("keydown", (e) => { if (e.key === "Escape" && !overlay.hidden) close(); });

        // ── populate from the setup-status trust block ──
        try {
          const res = await fetch("/api/setup/status");
          if (!res.ok) return;
          const status = await res.json();
          const posture = trustPosture(status.trust);
          chip.className = `trust-chip tone-${posture.tone}`;
          if (labelEl) labelEl.textContent = posture.label;
          chip.title = posture.detail;
          if (summaryEl) summaryEl.textContent = posture.detail;
          if (rowsEl) {
            rowsEl.textContent = "";
            const cell = (cls, text) => {
              const d = document.createElement("div");
              d.className = cls;
              d.textContent = String(text);  // config values are user data — never innerHTML
              return d;
            };
            for (const row of trustRows(status.trust, status.presence)) {
              const el = document.createElement("div");
              el.className = `trust-row tone-${row.tone}`;
              el.append(
                cell("trust-row-label", row.label),
                cell("trust-row-value", row.value),
                cell("trust-row-meta", row.meta),
              );
              rowsEl.appendChild(el);
            }
          }
        } catch (_e) {
          /* keep the honest default chip */
        }
      })();
    </script>

    <script>
      // HS-30-04 / HS-42-02: shell interactions (mobile nav), vanilla so they
      // work on every route regardless of whether Alpine is loaded. Global
      // settings now live at the real /settings route (HS-42-02 retired the
      // interim drawer); preserve the legacy `#settings` deep link by
      // redirecting it there.
      (() => {
        if (location.hash === "#settings") {
          location.replace("/settings");
          return;
        }

        // Mobile nav toggle.
        const topnav = document.querySelector(".topnav");
        const toggle = document.querySelector("[data-nav-toggle]");
        if (topnav && toggle) {
          toggle.addEventListener("click", () => {
            const open = topnav.toggleAttribute("data-open");
            toggle.setAttribute("aria-expanded", open ? "true" : "false");
          });
        }
      })();
    </script>
  </body>
</html>

<style>
  main {
    outline: none;
  }

  .app-secondary {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    background: var(--surface-1);
    border-bottom: 1px solid var(--border-subtle);
  }

  /* HS-42-05: Trust & Privacy panel */
  .trust-overlay { position: fixed; inset: 0; z-index: var(--z-dialog); }
  .trust-backdrop {
    position: absolute; inset: 0; background: var(--canvas-overlay);
    opacity: 0; transition: opacity var(--duration-medium) var(--ease-standard);
  }
  .trust-overlay[data-open] .trust-backdrop { opacity: 1; }
  .trust-panel {
    position: absolute; top: 0; right: 0; height: 100%;
    width: min(440px, 94vw); display: flex; flex-direction: column;
    background: var(--surface-2); border-left: 1px solid var(--border);
    box-shadow: var(--elev-3); outline: none;
    transform: translateX(100%);
    transition: transform var(--duration-long) var(--ease-emphasized);
  }
  .trust-overlay[data-open] .trust-panel { transform: translateX(0); }
  .trust-head {
    display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-3);
    padding: var(--space-5); border-bottom: 1px solid var(--border-subtle);
  }
  .trust-eyebrow {
    font-family: var(--font-mono); font-size: var(--font-size-xs); text-transform: uppercase;
    letter-spacing: var(--letter-spacing-eyebrow); color: var(--accent);
  }
  .trust-summary { margin: var(--space-2) 0 0; color: var(--text); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); }
  .trust-close {
    flex: none; display: inline-grid; place-items: center; width: 32px; height: 32px;
    color: var(--text-muted); background: transparent; border: 1px solid var(--border);
    border-radius: var(--radius-sm); cursor: pointer;
  }
  .trust-close:hover { color: var(--text); border-color: var(--border-strong); }
  .trust-rows { flex: 1; overflow-y: auto; padding: var(--space-4) var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); }
  .trust-row {
    padding: var(--space-4); border-radius: var(--radius-md);
    background: var(--surface-3); border: 1px solid var(--border-subtle);
    border-left: 3px solid var(--border);
  }
  .trust-row.tone-ok { border-left-color: var(--ok); }
  .trust-row.tone-warn { border-left-color: var(--warn); }
  .trust-row.tone-danger { border-left-color: var(--danger); }
  .trust-row.tone-neutral { border-left-color: var(--border-strong); }
  .trust-row-label { font-family: var(--font-mono); font-size: var(--font-size-xs); text-transform: uppercase; letter-spacing: var(--letter-spacing-eyebrow); color: var(--text-faint); }
  .trust-row-value { color: var(--text); font-weight: 600; font-size: var(--font-size-sm); margin-top: 2px; }
  .trust-row.tone-ok .trust-row-value { color: var(--ok); }
  .trust-row.tone-warn .trust-row-value { color: var(--warn-strong, var(--warn)); }
  .trust-row.tone-danger .trust-row-value { color: var(--danger); }
  .trust-row-meta { color: var(--text-muted); font-size: var(--font-size-xs); margin-top: var(--space-1); }
  .trust-foot { padding: var(--space-4) var(--space-5); border-top: 1px solid var(--border-subtle); }
  .trust-foot p { margin: 0; color: var(--text-muted); font-size: var(--font-size-xs); }
  .trust-foot a { color: var(--accent); }

  @media (max-width: 640px) {
    .app-secondary {
      padding: var(--space-3);
    }
  }
</style>
