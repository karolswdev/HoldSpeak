---
// HS-10-04: app shell.
//
// Composes TopNav + skip-to-content target + page <slot/> + optional
// secondary toolbar slot for per-page actions (e.g. "Export", "Refresh").
//
// `current` is forwarded to TopNav so the active route reads as
// aria-current=page and visually selected.

import "../styles/global.css";
import TopNav from "../components/TopNav.astro";
import LocalPill from "../components/LocalPill.astro";

type Route = "runtime" | "activity" | "history" | "dictation";

interface Props {
  title: string;
  description?: string;
  current?: Route;
}

const { title, description, current } = Astro.props;
const hasSecondary = Astro.slots.has("secondary");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/_built/favicon.svg" />
    <link rel="apple-touch-icon" href="/_built/apple-touch-icon.png" />
  </head>
  <body>
    <TopNav current={current}>
      {Astro.slots.has("status") ? (
        <Fragment slot="status"><slot name="status" /></Fragment>
      ) : (
        <LocalPill slot="status" />
      )}
      {Astro.slots.has("topnav-overflow") && (
        <Fragment slot="overflow"><slot name="topnav-overflow" /></Fragment>
      )}
    </TopNav>

    {hasSecondary && (
      <div class="app-secondary" role="region" aria-label="Page actions">
        <slot name="secondary" />
      </div>
    )}

    <main id="main" tabindex="-1">
      <slot />
    </main>
  </body>
</html>

<style>
  main {
    outline: none;
  }

  .app-secondary {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    background: var(--canvas);
    border-bottom: 1px solid var(--line);
  }

  @media (max-width: 640px) {
    .app-secondary {
      padding: var(--space-3);
    }
  }
</style>
