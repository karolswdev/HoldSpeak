---
// HS-10-04 app shell · HS-30-04 "Signal" rebuild.
//
// Composes TopNav + skip-to-content + page <slot/> + optional secondary
// toolbar, and owns the global Settings drawer (IA spec §2: Settings is
// lifted out of History into a shell-level drawer, opened from TopNav's
// ⚙). The drawer + the mobile nav toggle are wired with a small vanilla
// script — Alpine loads per-page (and not on every page), so the shell
// must not depend on it.
//
// `current` is forwarded to TopNav for the active-route state.

import "../styles/global.css";
import TopNav from "../components/TopNav.astro";
import LocalPill from "../components/LocalPill.astro";
import ConfirmDialog from "../components/ConfirmDialog.astro";

type Route = "runtime" | "activity" | "history" | "dictation" | "companion";

interface Props {
  title: string;
  description?: string;
  current?: Route;
}

const { title, description, current } = Astro.props;
const hasSecondary = Astro.slots.has("secondary");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/_built/favicon.svg" />
    <link rel="apple-touch-icon" href="/_built/apple-touch-icon.png" />
  </head>
  <body>
    <TopNav current={current}>
      {Astro.slots.has("status") ? (
        <Fragment slot="status"><slot name="status" /></Fragment>
      ) : (
        <LocalPill slot="status" />
      )}
      {Astro.slots.has("topnav-overflow") && (
        <Fragment slot="overflow"><slot name="topnav-overflow" /></Fragment>
      )}
    </TopNav>

    {hasSecondary && (
      <div class="app-secondary" role="region" aria-label="Page actions">
        <slot name="secondary" />
      </div>
    )}

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <ConfirmDialog />

    <script>
      // HS-30-04 / HS-42-02: shell interactions (mobile nav), vanilla so they
      // work on every route regardless of whether Alpine is loaded. Global
      // settings now live at the real /settings route (HS-42-02 retired the
      // interim drawer); preserve the legacy `#settings` deep link by
      // redirecting it there.
      (() => {
        if (location.hash === "#settings") {
          location.replace("/settings");
          return;
        }

        // Mobile nav toggle.
        const topnav = document.querySelector(".topnav");
        const toggle = document.querySelector("[data-nav-toggle]");
        if (topnav && toggle) {
          toggle.addEventListener("click", () => {
            const open = topnav.toggleAttribute("data-open");
            toggle.setAttribute("aria-expanded", open ? "true" : "false");
          });
        }
      })();
    </script>
  </body>
</html>

<style>
  main {
    outline: none;
  }

  .app-secondary {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    background: var(--surface-1);
    border-bottom: 1px solid var(--border-subtle);
  }

  @media (max-width: 640px) {
    .app-secondary {
      padding: var(--space-3);
    }
  }
</style>
