{
  "name": "holdspeak-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "HoldSpeak Web — one typed Vite/React DeskOS surface.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "shots": "vite build && node scripts/shoot.mjs",
    "test:desk": "vitest run src/desk --maxWorkers=2",
    "typecheck": "tsc --noEmit",
    "test:web": "vitest run --maxWorkers=2",
    "guard:architecture": "node scripts/guard-architecture.mjs",
    "tokens": "node scripts/generate-tokens.cjs",
    "tokens:check": "node scripts/generate-tokens.cjs --check",
    "tokens:gate": "node scripts/validate-tokens.cjs",
    "check": "npm run tokens:check && npm run tokens:gate && npm run guard:architecture && npm run typecheck && npm run test:web && npm run build"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "axe-core": "^4.12.1",
    "jsdom": "^26.1.0",
    "open-props": "^1.7.13",
    "prettier": "^3.9.5",
    "puppeteer": "^25.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@use-gesture/react": "^10.3.1",
    "motion": "^12.42.2",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  }
}
